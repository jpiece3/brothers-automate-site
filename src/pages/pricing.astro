---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HowWeWork from '../components/HowWeWork.astro';
import CTA from '../components/CTA.astro';
import TopUtilityStrip from '../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../components/operator/EyebrowTag.astro';
import CalloutBox from '../components/operator/CalloutBox.astro';

const SITE_URL = 'https://brothersautomate.com';

const includes = [
  { title: 'Custom-built', description: 'No templates, no plugins. Built from scratch for your business.' },
  { title: 'Deployed on your accounts', description: 'Runs under your logins with full access. You own everything.' },
  { title: 'Staff training included', description: 'We teach your team how to use and maintain what we build.' },
  { title: 'Plain-English documentation', description: 'So you or your team understand how everything works.' },
  { title: 'Walkthrough call', description: 'We walk you through everything before handoff.' },
  { title: '30-day guarantee', description: "If it doesn't do what we scoped, we fix it free." },
];

const comparison = [
  { label: 'Cost', agency: '$8K–50K+/mo', freelancer: '$2K–8K', diy: '"Free" + your time', brothers: '$3,500/mo or scoped' },
  { label: 'Timeline', agency: '6–12 weeks', freelancer: '2–6 weeks', diy: 'Weeks of learning', brothers: 'Days to weeks' },
  { label: 'Staff training', agency: 'Rarely', freelancer: 'Almost never', diy: 'You figure it out', brothers: 'Built into every build' },
  { label: 'Custom to you', agency: 'Sometimes', freelancer: 'Usually', diy: 'Template-based', brothers: 'Always' },
  { label: 'Documentation', agency: 'Minimal', freelancer: 'Varies', diy: 'Platform docs only', brothers: 'Full plain-English docs' },
  { label: 'Who builds it', agency: 'Junior staff', freelancer: 'One person', diy: 'You', brothers: 'Two brothers, personally' },
];

const faqs = [
  {
    question: "What's included in the retainer?",
    answer: 'Each month we build, optimize, and maintain your automations. You get up to 2 new automations per month, unlimited maintenance on existing systems, a monthly strategy call to plan priorities, staff training baked into every build, and priority Slack/email support.',
  },
  {
    question: "What if I'm not sure which option is right?",
    answer: "Book a free call and we'll recommend the best path. Most clients start with a scoped project to see how we work, then move to the retainer for ongoing automation wins. No pressure either way.",
  },
  {
    question: 'Is there a long-term commitment?',
    answer: "The retainer runs in 90-day engagements. After that, it's month-to-month — cancel anytime with 30 days notice. No long-term lock-in. We keep clients by delivering results, not contracts.",
  },
  {
    question: 'What if I need more than the retainer covers?',
    answer: "We'll talk about it first. If a month runs heavier than usual, we scope the extra work transparently. No surprise invoices. Retainer clients get priority and preferred rates on additional builds.",
  },
  {
    question: 'What happens after a scoped project is delivered?',
    answer: 'You own everything we build. You get full documentation, a walkthrough call, and 30 days of support. Want ongoing improvements? Move to the retainer.',
  },
  {
    question: 'How is this different from hiring an agency?',
    answer: "Agencies charge $8K–50K/month and assign you a junior. We're two brothers who build every automation ourselves. Senior-level work, direct communication, at a fraction of the cost.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Pricing", "item": `${SITE_URL}/pricing` },
  ],
};
---

<Layout
  title="Pricing | Two Ways to Work With Us | Brothers Automate"
  description="Ongoing automation partner or one-time scoped build. $3,500/month retainer with staff training included, or a custom-quoted project delivered in weeks. No surprises."
>
  <Header />
  <main>
    {/* Hero */}
    <section class="op-pricing-hero op-grid-bg">
      <div class="op-pricing-hero-frame">
        <div class="op-pricing-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / PRICING · 02 PATHS"
            right="● TRANSPARENT · NO HIDDEN FEES"
            bordered
          />
        </div>
        <EyebrowTag label="PRICING · TWO PATHS" />
        <h1 class="op-pricing-h1" data-animate="fade-up">
          Two ways to<br />
          <span class="op-pricing-h1-orange">work with us.</span>
        </h1>
        <p class="op-pricing-sub" data-animate="fade-up">
          Whether you need an ongoing automation partner or a single system built and handed off — we keep it simple. Pick the path that fits.
        </p>
      </div>
    </section>

    {/* Reuse HowWeWork — has both engagement modes + process strip */}
    <HowWeWork />

    {/* Includes panel */}
    <section class="op-pricing-includes op-grid-bg">
      <div class="op-pricing-includes-frame">
        <div class="op-pricing-includes-header" data-animate="fade-up">
          <span class="op-mono op-pricing-section-label"><span class="op-pricing-section-num">03</span> INCLUDED IN EVERY ENGAGEMENT</span>
          <h2 class="op-pricing-h2">No matter which path you pick, this comes with it.</h2>
        </div>
        <div class="op-pricing-includes-grid" data-animate-stagger>
          {includes.map((item, i) => (
            <div class="op-pricing-include">
              <span class="op-mono op-pricing-include-num">I.{String(i + 1).padStart(2, '0')}</span>
              <h3 class="op-pricing-include-title">{item.title}</h3>
              <p class="op-pricing-include-body">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Comparison table */}
    <section class="op-pricing-compare">
      <div class="op-pricing-compare-frame">
        <div class="op-pricing-compare-header" data-animate="fade-up">
          <span class="op-mono op-pricing-section-label"><span class="op-pricing-section-num">04</span> HOW WE COMPARE</span>
          <h2 class="op-pricing-h2">Same outcome, very different costs.</h2>
        </div>
        <div class="op-pricing-table-wrap">
          <table class="op-pricing-table">
            <thead>
              <tr>
                <th class="op-mono">SPEC</th>
                <th class="op-mono">AGENCY</th>
                <th class="op-mono">FREELANCER</th>
                <th class="op-mono">DIY</th>
                <th class="op-mono op-pricing-table-mine">BROTHERS AUTOMATE</th>
              </tr>
            </thead>
            <tbody>
              {comparison.map((row) => (
                <tr>
                  <td class="op-mono op-pricing-table-label">{row.label}</td>
                  <td>{row.agency}</td>
                  <td>{row.freelancer}</td>
                  <td>{row.diy}</td>
                  <td class="op-pricing-table-mine">{row.brothers}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* Promise callout */}
    <section class="op-pricing-promise op-grid-bg">
      <div class="op-pricing-promise-frame">
        <CalloutBox header="THE PROMISE">
          <p>30-day guarantee on every build. If a system doesn't do what we scoped, we fix it free. We define deliverables before writing code so we're both clear on what "done" looks like.</p>
        </CalloutBox>
      </div>
    </section>

    {/* FAQ */}
    <section class="op-pricing-faq">
      <div class="op-pricing-faq-frame">
        <div class="op-pricing-faq-header" data-animate="fade-up">
          <span class="op-mono op-pricing-section-label"><span class="op-pricing-section-num">05</span> PRICING FAQ</span>
          <h2 class="op-pricing-h2">Questions before you book.</h2>
        </div>
        <div class="op-pricing-faq-list" data-animate-stagger>
          {faqs.map((faq, i) => (
            <details class="op-pricing-faq-item">
              <summary class="op-pricing-faq-q">
                <span class="op-mono op-pricing-faq-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="op-pricing-faq-q-text">{faq.question}</span>
                <span class="op-pricing-faq-q-icon" aria-hidden="true">+</span>
              </summary>
              <div class="op-pricing-faq-a">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-pricing-hero {
    padding: 120px var(--op-section-px) 64px;
    color: var(--op-ink);
  }
  .op-pricing-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-pricing-util { margin-bottom: 32px; }
  .op-pricing-hero :global(.op-eyebrow) { margin-bottom: 24px; }

  .op-pricing-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 24px;
    max-width: 900px;
    text-wrap: balance;
  }
  .op-pricing-h1-orange { color: var(--op-orange); }

  .op-pricing-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 660px;
    text-wrap: pretty;
  }

  /* Section label pattern */
  .op-pricing-section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-pricing-section-num { color: var(--op-orange); font-size: 9px; }

  .op-pricing-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 3.6vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }

  /* Includes */
  .op-pricing-includes {
    padding: 72px var(--op-section-px);
    border-top: 1px solid var(--op-rule);
  }
  .op-pricing-includes-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-pricing-includes-header { max-width: 720px; margin-bottom: 36px; }
  .op-pricing-includes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 700px) { .op-pricing-includes-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-pricing-includes-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-pricing-include {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    padding: 22px 24px;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .op-pricing-include-num { font-size: 9px; color: var(--op-orange); }
  .op-pricing-include-title {
    font-family: var(--op-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-pricing-include-body {
    font-family: var(--op-font-body);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
  }

  /* Comparison */
  .op-pricing-compare {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-pricing-compare-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-pricing-compare-header { max-width: 720px; margin-bottom: 36px; }

  .op-pricing-table-wrap {
    overflow-x: auto;
    border: var(--op-border);
    border-radius: var(--op-radius);
    box-shadow: var(--op-shadow);
    background: var(--op-cream);
  }
  .op-pricing-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--op-font-body);
    font-size: 14px;
    color: var(--op-ink);
  }
  .op-pricing-table th,
  .op-pricing-table td {
    padding: 14px 18px;
    text-align: left;
    border-right: 1px solid var(--op-rule);
    border-bottom: 1px solid var(--op-rule);
    white-space: nowrap;
  }
  .op-pricing-table th {
    background: var(--op-navy);
    color: var(--op-cream);
    font-size: 10px;
    border-right-color: rgba(255, 255, 255, 0.1);
    border-bottom: var(--op-border);
  }
  .op-pricing-table tr:last-child td { border-bottom: none; }
  .op-pricing-table th:last-child,
  .op-pricing-table td:last-child { border-right: none; }
  .op-pricing-table-label {
    background: var(--op-paper);
    color: var(--op-ink);
    font-size: 10px;
    width: 140px;
  }
  .op-pricing-table-mine {
    background: rgba(224, 112, 60, 0.08);
    color: var(--op-ink);
    font-weight: 700;
  }
  .op-pricing-table th.op-pricing-table-mine {
    background: var(--op-orange);
    color: var(--op-paper);
  }

  /* Promise */
  .op-pricing-promise {
    padding: 64px var(--op-section-px);
  }
  .op-pricing-promise-frame {
    max-width: 720px;
    margin: 0 auto;
  }

  /* FAQ */
  .op-pricing-faq {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-pricing-faq-frame { max-width: 1000px; margin: 0 auto; }
  .op-pricing-faq-header { margin-bottom: 36px; max-width: 720px; }
  .op-pricing-faq-list {
    display: flex;
    flex-direction: column;
  }
  .op-pricing-faq-item {
    border-bottom: 1px solid var(--op-rule);
  }
  .op-pricing-faq-item[open] { background: var(--op-cream); }
  .op-pricing-faq-q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 4px;
    font-family: var(--op-font-body);
    font-size: 16px;
    font-weight: 600;
    color: var(--op-ink);
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-pricing-faq-q::-webkit-details-marker { display: none; }
  .op-pricing-faq-num {
    width: 28px;
    flex-shrink: 0;
    font-size: 9px;
    color: var(--op-navy-soft);
  }
  .op-pricing-faq-q-text { flex: 1; text-wrap: balance; }
  .op-pricing-faq-q-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--op-font-display);
    font-size: 16px;
    font-weight: 800;
    color: var(--op-ink);
    line-height: 1;
    transition: transform var(--op-dur-hover) var(--op-ease), background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-pricing-faq-item[open] .op-pricing-faq-q-icon {
    transform: rotate(45deg);
    background: var(--op-orange);
    color: var(--op-paper);
  }
  .op-pricing-faq-q:hover { color: var(--op-orange); }

  .op-pricing-faq-a {
    padding: 4px 4px 22px 50px;
    font-family: var(--op-font-body);
    font-size: 15px;
    line-height: 1.6;
    font-weight: 500;
    color: var(--op-navy-soft);
    text-wrap: pretty;
    max-width: 800px;
  }

  @media (max-width: 700px) {
    .op-pricing-hero,
    .op-pricing-includes,
    .op-pricing-compare,
    .op-pricing-promise,
    .op-pricing-faq { padding-left: 22px; padding-right: 22px; }
    .op-pricing-table { font-size: 13px; }
    .op-pricing-table th,
    .op-pricing-table td { padding: 10px 14px; }
  }
</style>
