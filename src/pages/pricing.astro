---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Pricing", "item": `${SITE_URL}/pricing` }
  ]
};

const includes = [
  { title: "Custom-built", description: "No templates, no plugins. Built from scratch for your business." },
  { title: "Deployed on your accounts", description: "Runs under your logins with full access. You own everything." },
  { title: "Staff training included", description: "We teach your team how to use and maintain what we build." },
  { title: "Plain-English documentation", description: "So you or your team understand how everything works." },
  { title: "Walkthrough call", description: "We walk you through everything before handoff." },
  { title: "30-day guarantee", description: "If it doesn't do what we scoped, we fix it free." }
];

const comparison = [
  { label: "Cost", agency: "$8K-50K+/mo", freelancer: "$2K-8K", diy: '"Free" + your time', brothers: "$3,500/mo or custom quote" },
  { label: "Timeline", agency: "6-12 weeks", freelancer: "2-6 weeks", diy: "Weeks of learning", brothers: "Days to weeks" },
  { label: "Staff training", agency: "Rarely", freelancer: "Almost never", diy: "You figure it out", brothers: "Built into every engagement" },
  { label: "Custom to you", agency: "Sometimes", freelancer: "Usually", diy: "Template-based", brothers: "Always" },
  { label: "Documentation", agency: "Minimal", freelancer: "Varies", diy: "Platform docs only", brothers: "Full plain-English docs" },
  { label: "Who builds it", agency: "Junior staff", freelancer: "One person", diy: "You", brothers: "Two brothers, personally" }
];

const faqs = [
  {
    question: "What's included in the retainer?",
    answer: "Each month we build, optimize, and maintain your automations. You get up to 2 new automations per month, unlimited maintenance on existing systems, a monthly strategy call to plan priorities, staff training baked into every build, and priority Slack/email support."
  },
  {
    question: "What if I'm not sure which option is right?",
    answer: "Book a free call and we'll recommend the best path. Most clients start with a scoped project to see how we work, then move to the retainer for ongoing automation wins. No pressure either way."
  },
  {
    question: "Is there a long-term commitment?",
    answer: "The retainer runs in 90-day engagements. After that, it's month-to-month — cancel anytime with 30 days notice. No long-term lock-in. We keep clients by delivering results, not contracts."
  },
  {
    question: "What if I need more than the retainer covers in a given month?",
    answer: "We'll talk about it first. If a month runs heavier than usual, we scope the extra work transparently. No surprise invoices. Retainer clients get priority and preferred rates on additional builds."
  },
  {
    question: "What happens after a scoped project is delivered?",
    answer: "You own everything we build. You get full documentation, a walkthrough call, and 30 days of support. Want ongoing improvements? Move to the retainer. If you're set, no hard feelings."
  },
  {
    question: "How long does a scoped project take?",
    answer: "Most projects are delivered in 1-3 weeks depending on complexity. We scope everything upfront so you know the timeline and cost before we start."
  },
  {
    question: "Do you work with my industry / my tools?",
    answer: "We work with service businesses across industries — coaches, contractors, agencies, restaurants, real estate, e-commerce. We integrate with whatever tools you already use (CRM, email, scheduling, etc.)."
  },
  {
    question: "How is this different from hiring an agency?",
    answer: "Agencies charge $8K-50K/month and assign you a junior. We're two brothers who build every automation ourselves. Senior-level work, direct communication, at a fraction of the cost."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<Layout
  title="Pricing | Two Ways to Work With Us | Brothers Automate"
  description="Ongoing automation partner or one-time scoped build. $3,500/month retainer with staff training included, or a custom-quoted project delivered in weeks. No surprises."
>
  <Header />
  <main>
    <!-- Hero -->
    <section class="pricing-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="pricing-hero-content" data-animate="fade-up">
          <span class="badge">Pricing</span>
          <h1>Two Ways to<br /><span class="gradient-text">Work With Us.</span></h1>
          <p class="pricing-hero-sub">Whether you need an ongoing automation partner or a single system built and handed off — we keep it simple. Pick the path that fits.</p>
        </div>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="pricing-tiers">
      <div class="container">
        <div class="pricing-grid" data-animate-stagger>
          <!-- Retainer Card -->
          <div class="pricing-card card pricing-card-featured">
            <span class="featured-badge">Recommended</span>
            <div class="pricing-header">
              <h3>Automation Partner</h3>
              <span class="pricing-price">$3,500<span class="pricing-per">/month</span></span>
              <span class="pricing-timeline">90-day engagement</span>
            </div>
            <p class="pricing-description">Ongoing automation builds, maintenance, and staff training — so your team gets smarter every month, not just more dependent on us.</p>
            <h4 class="pricing-section-label">What you get:</h4>
            <ul class="pricing-features">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Up to 2 new automations per month
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Unlimited maintenance on existing systems
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Staff training baked into every build
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Monthly strategy call to plan priorities
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Priority Slack/email support
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Month-to-month after initial 90 days
              </li>
            </ul>
            <p class="pricing-best-for"><strong>Best for:</strong> Businesses with multiple processes to automate over time. Teams that want to understand their systems, not just use them.</p>
            <a
              href="#"
              class="btn btn-primary pricing-cta-btn"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Book Your Strategy Call</a>
          </div>

          <!-- Scoped Project Card -->
          <div class="pricing-card card">
            <div class="pricing-header">
              <h3>Scoped Build</h3>
              <span class="pricing-price">Custom Quote</span>
              <span class="pricing-timeline">1-3 weeks</span>
            </div>
            <p class="pricing-description">One system, built to spec, handed off clean. You tell us the problem, we scope it, build it, and walk you through everything.</p>
            <h4 class="pricing-section-label">What you get:</h4>
            <ul class="pricing-features">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                End-to-end custom automation
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Full documentation + walkthrough call
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                30-day support window after delivery
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Staff training on the delivered system
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Deployed on your accounts with full access
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                Clear scope and price before we start
              </li>
            </ul>
            <p class="pricing-best-for"><strong>Best for:</strong> A specific bottleneck you already know needs fixing. Businesses that want a one-time investment, not a monthly bill.</p>
            <a
              href="#"
              class="btn btn-secondary pricing-cta-btn"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Scope Your Project</a>
          </div>
        </div>

        <!-- Quick Fix Expander -->
        <div class="quick-fix-wrap" data-animate="fade-up">
          <details class="quick-fix">
            <summary class="quick-fix-trigger">
              <span class="quick-fix-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg>
              </span>
              <span>Just need a quick automation or fix?</span>
              <span class="quick-fix-chevron">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </span>
            </summary>
            <div class="quick-fix-content">
              <div class="quick-fix-body">
                <div class="quick-fix-details">
                  <h4>Quick Fix</h4>
                  <span class="quick-fix-price">$697</span>
                  <span class="quick-fix-timeline">3-5 days</span>
                  <p>One targeted automation that saves you hours every week. Perfect when you know exactly what needs fixing and just need someone to build it.</p>
                </div>
                <div class="quick-fix-includes">
                  <ul>
                    <li>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      Single workflow automation
                    </li>
                    <li>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      Connect 2-3 existing tools
                    </li>
                    <li>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      Setup + documentation
                    </li>
                    <li>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      14-day support window
                    </li>
                  </ul>
                  <div class="quick-fix-examples">
                    <span class="quick-fix-examples-label">Examples:</span>
                    Email sequences, inventory sync, appointment reminders, form-to-CRM, report generation
                  </div>
                </div>
                <a
                  href="#"
                  class="btn btn-secondary quick-fix-cta"
                  data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
                  data-cal-namespace="free-quiz-audit-automation-brothers"
                  data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
                >Talk to the Brothers</a>
              </div>
            </div>
          </details>
        </div>
      </div>
    </section>

    <!-- Decision Helper -->
    <section class="decision-helper">
      <div class="container">
        <div class="decision-card" data-animate="fade-up">
          <h3>Not sure which is right?</h3>
          <p>Most clients start with a scoped project, see the results, then move to the retainer when they're ready for ongoing automation wins. Either way, we'll figure out the best path on a call.</p>
          <a
            href="#"
            class="btn btn-primary"
            data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
            data-cal-namespace="free-quiz-audit-automation-brothers"
            data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
          >Book a Free Call</a>
          <span class="decision-sub">15 minutes. No pitch deck. Just figuring out what makes sense.</span>
        </div>
      </div>
    </section>

    <!-- What Every Engagement Includes -->
    <section class="pricing-includes bg-surface-alt">
      <div class="container">
        <div class="section-header" data-animate="fade-up">
          <h2>What Every Engagement Includes</h2>
        </div>
        <div class="includes-grid" data-animate-stagger>
          {includes.map((item) => (
            <div class="include-card">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <div>
                <strong>{item.title}</strong>
                <span>{item.description}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How We Compare -->
    <section class="pricing-compare bg-surface">
      <div class="container">
        <div class="section-header" data-animate="fade-up">
          <h2>How We Compare</h2>
        </div>
        <div class="compare-table-wrap" data-animate="fade-up">
          <table class="compare-table">
            <thead>
              <tr>
                <th></th>
                <th>Agency</th>
                <th>Freelancer</th>
                <th>DIY / No-Code</th>
                <th class="highlight-col">Brothers Automate</th>
              </tr>
            </thead>
            <tbody>
              {comparison.map((row) => (
                <tr>
                  <td class="row-label">{row.label}</td>
                  <td>{row.agency}</td>
                  <td>{row.freelancer}</td>
                  <td>{row.diy}</td>
                  <td class="highlight-col">{row.brothers}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="pricing-faq bg-surface-alt" id="faq">
      <div class="container">
        <div class="section-header" data-animate="fade-up">
          <h2>Common Questions</h2>
        </div>
        <div class="faq-list" data-animate="fade-up">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-question">{faq.question}</summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="pricing-final-cta">
      <div class="container">
        <div class="final-cta-content" data-animate="fade-up">
          <h2>Ready to stop doing the busywork?</h2>
          <p>Book a free call. We'll ask about your biggest time-suck, show you what's possible, and give you a clear recommendation.</p>
          <a
            href="#"
            class="btn btn-primary"
            data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
            data-cal-namespace="free-quiz-audit-automation-brothers"
            data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
          >Talk to the Brothers</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
  /* Hero */
  .pricing-hero {
    position: relative;
    padding-top: 160px;
    padding-bottom: var(--space-3xl);
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-surface-alt) 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .pricing-hero-content {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: rgba(237, 137, 54, 0.1);
    border: 1px solid rgba(237, 137, 54, 0.3);
    color: var(--orange);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .pricing-hero h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pricing-hero-sub {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Pricing Tiers */
  .pricing-tiers {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .pricing-grid {
    display: grid;
    gap: var(--space-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
      align-items: start;
    }
  }

  .pricing-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    position: relative;
    height: 100%;
  }

  .pricing-card-featured {
    border: 2px solid var(--orange);
    box-shadow: var(--shadow-lg);
  }

  .featured-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--orange);
    color: white;
    padding: var(--space-xs) var(--space-md);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .pricing-header h3 {
    font-size: 1.25rem;
    color: var(--navy);
    margin: 0 0 var(--space-sm);
  }

  .pricing-price {
    display: block;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: var(--space-xs);
  }

  .pricing-per {
    font-size: 0.5em;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .pricing-timeline {
    font-size: 0.8125rem;
    color: var(--orange);
    font-weight: 600;
    background: rgba(237, 137, 54, 0.1);
    padding: var(--space-xs) var(--space-sm);
    border-radius: 100px;
  }

  .pricing-description {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }

  .pricing-section-label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--navy);
    margin: 0 0 var(--space-sm);
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .pricing-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  .pricing-features svg {
    flex-shrink: 0;
    color: var(--blue);
    margin-top: 2px;
  }

  .pricing-best-for {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
    padding: var(--space-sm) var(--space-md);
    background: var(--bg-surface-alt);
    border-radius: var(--radius);
  }

  .pricing-best-for strong {
    color: var(--navy);
  }

  .pricing-cta-btn {
    width: 100%;
    justify-content: center;
    text-align: center;
    margin-top: auto;
  }

  /* Quick Fix Expander */
  .quick-fix-wrap {
    max-width: 900px;
    margin: var(--space-lg) auto 0;
  }

  .quick-fix {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    overflow: hidden;
    transition: box-shadow var(--transition);
  }

  .quick-fix[open] {
    box-shadow: var(--shadow);
  }

  .quick-fix-trigger {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--navy);
    list-style: none;
    transition: color var(--transition);
  }

  .quick-fix-trigger::-webkit-details-marker {
    display: none;
  }

  .quick-fix-trigger:hover {
    color: var(--orange);
  }

  .quick-fix-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius);
    background: rgba(237, 137, 54, 0.1);
    color: var(--orange);
    flex-shrink: 0;
  }

  .quick-fix-chevron {
    margin-left: auto;
    color: var(--text-muted);
    transition: transform var(--transition);
    flex-shrink: 0;
  }

  .quick-fix[open] .quick-fix-chevron {
    transform: rotate(180deg);
  }

  .quick-fix-content {
    border-top: 1px solid var(--border);
  }

  .quick-fix-body {
    padding: var(--space-lg);
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .quick-fix-body {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .quick-fix-cta {
      grid-column: 1 / -1;
    }
  }

  .quick-fix-details h4 {
    font-size: 1.125rem;
    color: var(--navy);
    margin: 0 0 var(--space-xs);
  }

  .quick-fix-price {
    display: inline-block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--navy);
