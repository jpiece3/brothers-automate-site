<script>
  function showWorkflow(index) {
    document.querySelectorAll('.pb-workflow-card').forEach((c, i) => {
      c.classList.toggle('active', i === index);
    });
    document.querySelectorAll('.pb-wf-tab').forEach((t, i) => {
      t.classList.toggle('active', i === index);
    });
    // Close any open agent detail boxes when switching workflows
    document.querySelectorAll('.pb-agent-detail-box').forEach(b => b.classList.remove('visible'));
  }

  function toggleAgent(id) {
    const box = document.getElementById(id);
    if (!box) return;
    const isVisible = box.classList.contains('visible');

    // Close all boxes in this workflow card
    const parentCard = box.closest('.pb-workflow-card');
    parentCard.querySelectorAll('.pb-agent-detail-box').forEach(b => b.classList.remove('visible'));
    parentCard.querySelectorAll('.pb-flow-node').forEach(n => n.classList.remove('selected'));

    // Toggle clicked one
    if (!isVisible) {
      box.classList.add('visible');
      // Highlight the node
      const nodes = parentCard.querySelectorAll('.pb-flow-node');
      nodes.forEach(n => {
        if (n.dataset.agentTarget === id) {
          n.classList.add('selected');
        }
      });
      // Scroll into view
      setTimeout(() => box.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
    }
  }

  // Attach event listeners for workflow tabs
  document.querySelectorAll('.pb-wf-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const index = parseInt(tab.dataset.wfIndex, 10);
      showWorkflow(index);
    });
  });

  // Attach event listeners for flow nodes
  document.querySelectorAll('.pb-flow-node[data-agent-target]').forEach(node => {
    node.addEventListener('click', () => {
      toggleAgent(node.dataset.agentTarget);
    });
  });
</script>

