<script>
  function showWorkflow(index) {
    document.querySelectorAll('.op-pb-wf-card').forEach((c, i) => {
      c.classList.toggle('active', i === index);
    });
    document.querySelectorAll('.op-pb-tab').forEach((t, i) => {
      t.classList.toggle('active', i === index);
    });
    document.querySelectorAll('.op-pb-detail').forEach(b => b.classList.remove('visible'));
  }

  function toggleAgent(id) {
    const box = document.getElementById(id);
    if (!box) return;
    const isVisible = box.classList.contains('visible');

    const parentCard = box.closest('.op-pb-wf-card');
    parentCard.querySelectorAll('.op-pb-detail').forEach(b => b.classList.remove('visible'));
    parentCard.querySelectorAll('.op-pb-node').forEach(n => n.classList.remove('selected'));

    if (!isVisible) {
      box.classList.add('visible');
      const nodes = parentCard.querySelectorAll('.op-pb-node');
      nodes.forEach(n => {
        if (n.dataset.agentTarget === id) {
          n.classList.add('selected');
        }
      });
      setTimeout(() => box.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
    }
  }

  document.querySelectorAll('.op-pb-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const index = parseInt(tab.dataset.wfIndex, 10);
      showWorkflow(index);
    });
  });

  document.querySelectorAll('.op-pb-node[data-agent-target]').forEach(node => {
    node.addEventListener('click', () => {
      toggleAgent(node.dataset.agentTarget);
    });
  });
</script>

