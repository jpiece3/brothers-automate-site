---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
---

<Layout title="AI Operations Stack — Brothers Automate" description="Every ops category scored by disruption level and consequence of failure. An interactive reference framework for service businesses planning their AI operations roadmap.">
  <Header />
  <main class="ops-stack-page">

    <!-- HERO -->
    <section class="op-respage-hero op-grid-bg">
      <div class="op-respage-hero-frame">
        <div class="op-respage-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / RESOURCES · AI OPS STACK"
            right="● INTERACTIVE FRAMEWORK"
            bordered
          />
        </div>
        <EyebrowTag label="INTERACTIVE REFERENCE FRAMEWORK" />
        <h1 class="op-respage-h1">
          The Full <span class="op-respage-h1-orange">AI Operations</span> Stack.
        </h1>
        <p class="op-respage-sub">Every ops category scored by disruption level — plus a second axis: what breaks if you get it wrong.</p>
        <div class="op-ops-hero-note" data-animate="fade-up">
          <span class="op-pulse-dot"></span>
          <span><strong>Two axes, not one.</strong> Disruption level tells you how much AI is changing the category. Consequence of failure tells you how carefully to move.</span>
        </div>
        <div class="op-ops-legend" data-animate="fade-up">
          <button class="op-ops-legend-item active" data-filter="all">ALL</button>
          <button class="op-ops-legend-item" data-filter="low"><span class="op-ops-dot dot-low"></span>LOW</button>
          <button class="op-ops-legend-item" data-filter="medium"><span class="op-ops-dot dot-medium"></span>MEDIUM</button>
          <button class="op-ops-legend-item" data-filter="high"><span class="op-ops-dot dot-high"></span>HIGH</button>
          <button class="op-ops-legend-item" data-filter="transformative"><span class="op-ops-dot dot-transformative"></span>TRANSFORMATIVE</button>
          <button class="op-ops-legend-item" data-filter="new"><span class="op-ops-dot dot-new"></span>NEW</button>
        </div>
      </div>
    </section>

    <!-- MAIN CONTENT -->
    <section class="op-ops-section-wrap">
      <div class="op-ops-frame ops-main">

        <!-- RISK AXIS EXPLAINER -->
        <div class="op-ops-risk-explainer" data-animate="fade-up" data-animate-stagger>
          <div class="op-ops-risk-col" data-animate="fade-up">
            <div class="op-ops-risk-head">
              <span class="op-pulse-dot"></span>
              <span class="op-mono op-ops-risk-code">RISK_01</span>
              <span class="op-mono op-ops-risk-axis">CONSEQUENCE OF FAILURE</span>
            </div>
            <div class="op-ops-risk-body">
              <p class="op-ops-risk-title">Reversible</p>
              <p class="op-ops-risk-desc">Errors are catchable and fixable without lasting damage. Low cost of mistakes — good place to move fast and experiment.</p>
            </div>
          </div>
          <div class="op-ops-risk-col" data-animate="fade-up">
            <div class="op-ops-risk-head">
              <span class="op-pulse-dot"></span>
              <span class="op-mono op-ops-risk-code">RISK_02</span>
              <span class="op-mono op-ops-risk-axis">CONSEQUENCE OF FAILURE</span>
            </div>
            <div class="op-ops-risk-body">
              <p class="op-ops-risk-title">Moderate</p>
              <p class="op-ops-risk-desc">Errors create friction, rework, or reputational exposure. Meaningful cost, but recoverable. Needs oversight, not paralysis.</p>
            </div>
          </div>
          <div class="op-ops-risk-col" data-animate="fade-up">
            <div class="op-ops-risk-head">
              <span class="op-pulse-dot"></span>
              <span class="op-mono op-ops-risk-code">RISK_03</span>
              <span class="op-mono op-ops-risk-axis">CONSEQUENCE OF FAILURE</span>
            </div>
            <div class="op-ops-risk-body">
              <p class="op-ops-risk-title">Critical</p>
              <p class="op-ops-risk-desc">Errors break compliance, payroll, contracts, or data integrity. Human sign-off is non-negotiable regardless of AI capability.</p>
            </div>
          </div>
        </div>

        <!-- FILTER BAR -->
        <div class="op-ops-filter-bar" data-animate="fade-up">
          <span class="op-mono op-ops-filter-label">FILTER /</span>
          <button class="op-ops-filter-btn active" data-filter="all">ALL</button>
          <button class="op-ops-filter-btn" data-filter="low">LOW</button>
          <button class="op-ops-filter-btn" data-filter="medium">MEDIUM</button>
          <button class="op-ops-filter-btn" data-filter="high">HIGH</button>
          <button class="op-ops-filter-btn" data-filter="transformative">TRANSFORMATIVE</button>
          <button class="op-ops-filter-btn" data-filter="new">NEW</button>
        </div>

        <!-- DYNAMIC SECTIONS -->
        <div id="ops-sections-container"></div>

        <!-- PRINCIPLES -->
        <div class="op-ops-principles" data-animate="fade-up">
          <div class="op-ops-section-header">
            <span class="op-mono op-ops-section-num">CROSS_CUTTING</span>
            <h2 class="op-ops-section-title">Implementation Principles</h2>
          </div>
          <div id="ops-principles-grid" class="op-ops-principles-grid" data-animate-stagger></div>
        </div>

        <!-- RISK MATRIX -->
        <div class="op-ops-matrix" data-animate="fade-up">
          <div class="op-ops-section-header">
            <span class="op-mono op-ops-section-num">FRAMEWORK</span>
            <h2 class="op-ops-section-title">How to Prioritise Your AI Ops Roadmap</h2>
          </div>
          <div class="op-ops-matrix-grid" data-animate-stagger>
            <div class="op-ops-matrix-cell" data-animate="fade-up">
              <header class="op-ops-matrix-head">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-ops-matrix-code">CAT_01</span>
                <span class="op-mono op-ops-matrix-tag">MOVE FAST</span>
              </header>
              <div class="op-ops-matrix-body">
                <p class="op-ops-matrix-label">Move Fast</p>
                <p class="op-ops-matrix-sublabel">High disruption + Reversible risk. Automate now. Learn fast.</p>
              </div>
            </div>
            <div class="op-ops-matrix-cell" data-animate="fade-up">
              <header class="op-ops-matrix-head">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-ops-matrix-code">CAT_02</span>
                <span class="op-mono op-ops-matrix-tag">BUILD CAREFULLY</span>
              </header>
              <div class="op-ops-matrix-body">
                <p class="op-ops-matrix-label">Build Carefully</p>
                <p class="op-ops-matrix-sublabel">High disruption + Moderate risk. Pilot with oversight before scaling.</p>
              </div>
            </div>
            <div class="op-ops-matrix-cell" data-animate="fade-up">
              <header class="op-ops-matrix-head">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-ops-matrix-code">CAT_03</span>
                <span class="op-mono op-ops-matrix-tag">HUMAN IN LOOP</span>
              </header>
              <div class="op-ops-matrix-body">
                <p class="op-ops-matrix-label">Human in Loop</p>
                <p class="op-ops-matrix-sublabel">Any disruption + Critical risk. AI assists, humans decide. Always.</p>
              </div>
            </div>
            <div class="op-ops-matrix-cell" data-animate="fade-up">
              <header class="op-ops-matrix-head">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-ops-matrix-code">CAT_04</span>
                <span class="op-mono op-ops-matrix-tag">WATCH &amp; WAIT</span>
              </header>
              <div class="op-ops-matrix-body">
                <p class="op-ops-matrix-label">Watch &amp; Wait</p>
                <p class="op-ops-matrix-sublabel">Low disruption + any risk. Monitor the space, don't overinvest yet.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>

<!-- MODAL (outside main for z-index stacking) -->
<div class="op-ops-modal-overlay" id="ops-modal-overlay">
  <div class="op-ops-modal">
    <div class="op-ops-modal-header">
      <button class="op-ops-modal-close" id="ops-modal-close" aria-label="Close modal">&times;</button>
      <div class="op-ops-modal-strip">
        <span class="op-pulse-dot"></span>
        <span class="op-mono op-ops-modal-code">OP_DETAIL</span>
        <span class="op-mono op-ops-modal-section-label" id="ops-modal-section-label"></span>
      </div>
      <h3 class="op-ops-modal-title" id="ops-modal-title"></h3>
      <div class="op-ops-modal-rule"></div>
      <div class="op-ops-modal-badges">
        <span class="op-ops-level-pill" id="ops-modal-level-badge"></span>
        <span class="op-ops-risk-pill" id="ops-modal-risk-badge"></span>
        <span id="ops-modal-new-tag"></span>
      </div>
    </div>
    <div class="op-ops-modal-body">
      <p class="op-ops-modal-short" id="ops-modal-short"></p>
      <div class="op-ops-modal-section">
        <span class="op-mono op-ops-modal-label">FULL BREAKDOWN</span>
        <div class="op-ops-modal-detail" id="ops-modal-detail"></div>
      </div>
      <div class="op-ops-modal-section">
        <span class="op-mono op-ops-modal-label">CONSEQUENCE OF FAILURE</span>
        <p class="op-ops-modal-risk-text" id="ops-modal-risk-text"></p>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ================================================================
     AI OPS STACK — OPERATOR DESIGN SYSTEM
     ================================================================ */

  .ops-stack-page {
    background: var(--op-cream);
  }

  /* ── HERO UTILITIES (note + legend chips inside hero) ── */
  .op-ops-hero-note {
    display: inline-flex;
    align-items: flex-start;
    gap: 10px;
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    padding: 12px 16px;
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    text-wrap: pretty;
    margin-top: 24px;
    box-shadow: var(--op-shadow);
    max-width: 640px;
  }
  .op-ops-hero-note strong { color: var(--op-orange); font-weight: 700; }
  .op-ops-hero-note .op-pulse-dot { margin-top: 6px; flex-shrink: 0; }

  .op-ops-legend {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 18px;
  }
  .op-ops-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--op-font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--op-navy);
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-sm);
    padding: 6px 10px;
    cursor: pointer;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease), transform var(--op-dur-hover) var(--op-ease);
  }
  .op-ops-legend-item:hover { transform: translate(-1px, -1px); }
  .op-ops-legend-item.active {
    background: var(--op-navy);
    color: var(--op-cream);
  }
  .op-ops-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; display: inline-block; }
  .dot-low { background: var(--op-navy-soft); }
  .dot-medium { background: #B79454; }
  .dot-high { background: var(--op-orange); }
  .dot-transformative { background: var(--op-orange-deep); }
  .dot-new { background: var(--op-navy); border: 1.5px solid var(--op-orange); }

  /* ── MAIN SECTION WRAP ── */
  .op-ops-section-wrap {
    padding: 64px var(--op-section-px) 96px;
    background: var(--op-cream);
    border-top: var(--op-border);
  }
  .op-ops-frame {
    max-width: var(--op-max-content);
    margin: 0 auto;
  }

  /* ── RISK AXIS EXPLAINER (3 panels) ── */
  .op-ops-risk-explainer {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 40px;
  }
  @media (min-width: 768px) {
    .op-ops-risk-explainer { grid-template-columns: 1fr 1fr 1fr; }
  }
  .op-ops-risk-col {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-ops-risk-col:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
  }
  .op-ops-risk-head {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-ops-risk-code {
    font-size: 9px;
    color: var(--op-orange);
    letter-spacing: 0.22em;
  }
  .op-ops-risk-axis {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.6;
    letter-spacing: 0.22em;
  }
  .op-ops-risk-body {
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .op-ops-risk-title {
    font-family: var(--op-font-display);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-navy);
    margin: 0;
    text-wrap: balance;
  }
  .op-ops-risk-desc {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--op-navy-soft);
    margin: 0;
    text-wrap: pretty;
  }

  /* ── FILTER BAR ── */
  .op-ops-filter-bar {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 56px;
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    padding: 10px 14px;
    align-items: center;
    box-shadow: var(--op-shadow);
  }
  .op-ops-filter-label {
    font-size: 10px;
    color: var(--op-orange);
    letter-spacing: 0.22em;
    margin-right: 4px;
  }
  .op-ops-filter-btn {
    font-family: var(--op-font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 6px 12px;
    border-radius: var(--op-radius-sm);
    border: 1.5px solid var(--op-ink);
    background: var(--op-cream);
    color: var(--op-navy);
    cursor: pointer;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease), transform var(--op-dur-hover) var(--op-ease);
  }
  .op-ops-filter-btn:hover { transform: translate(-1px, -1px); background: var(--op-paper); }
  .op-ops-filter-btn.active {
    background: var(--op-navy);
    color: var(--op-cream);
  }

  /* ── SECTIONS (JS-rendered category sections) ── */
  .op-ops-section { margin-bottom: 56px; }
  .op-ops-section-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
    padding-bottom: 14px;
    border-bottom: 1.5px solid var(--op-rule);
  }
  .op-ops-section-num {
    font-size: 10px;
    color: var(--op-orange);
    letter-spacing: 0.22em;
    flex-shrink: 0;
    background: var(--op-navy);
    padding: 6px 10px;
    border-radius: var(--op-radius-sm);
  }
  .op-ops-section-title {
    font-family: var(--op-font-display);
    font-size: clamp(20px, 2.4vw, 26px);
    font-weight: 800;
    color: var(--op-navy);
    letter-spacing: -0.02em;
    margin: 0;
    text-wrap: balance;
  }

  /* ── CARDS GRID ── */
  .op-ops-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 640px) {
    .op-ops-cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .op-ops-cards-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── OPS CARD ── */
  .op-ops-card {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
    position: relative;
  }
  .op-ops-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
  }
  .op-ops-card.hidden { display: none; }

  .op-ops-card-head {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-ops-card-code {
    font-size: 9px;
    color: var(--op-orange);
    letter-spacing: 0.22em;
  }
  .op-ops-card-tag {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.6;
    letter-spacing: 0.22em;
  }

  .op-ops-card-body {
    padding: 20px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .op-ops-card-name {
    font-family: var(--op-font-display);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-navy);
    line-height: 1.25;
    margin: 0;
    text-wrap: balance;
  }
  .op-ops-card-rule {
    width: 28px;
    height: 3px;
    background: var(--op-orange);
    margin: -2px 0 0;
  }
  .op-ops-card-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .op-ops-card-summary {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--op-navy-soft);
    margin: 0;
    text-wrap: pretty;
  }
  .op-ops-card-expand {
    font-family: var(--op-font-mono);
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--op-orange);
    margin: 6px 0 0;
    text-transform: uppercase;
  }

  /* ── LEVEL + RISK PILLS (rectangular chips) ── */
  .op-ops-level-pill,
  .op-ops-risk-pill,
  .op-ops-new-pill {
    font-family: var(--op-font-mono);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: var(--op-radius-sm);
    display: inline-block;
    line-height: 1.2;
  }

  .op-ops-level-pill.level-low { background: var(--op-navy); color: var(--op-cream); }
  .op-ops-level-pill.level-medium { background: var(--op-navy-soft); color: var(--op-cream); }
  .op-ops-level-pill.level-high { background: var(--op-orange); color: var(--op-cream); }
  .op-ops-level-pill.level-transformative { background: var(--op-orange-deep); color: var(--op-cream); }

  .op-ops-risk-pill.risk-reversible { background: var(--op-paper); color: var(--op-navy); border: 1.5px solid var(--op-ink); }
  .op-ops-risk-pill.risk-moderate { background: var(--op-navy-soft); color: var(--op-cream); }
  .op-ops-risk-pill.risk-critical { background: var(--op-orange-deep); color: var(--op-cream); }

  .op-ops-new-pill {
    background: var(--op-cream);
    color: var(--op-orange);
    border: 1.5px solid var(--op-orange);
  }

  /* ── PRINCIPLES ── */
  .op-ops-principles {
    margin-top: 80px;
    margin-bottom: 64px;
  }
  .op-ops-principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 640px) {
    .op-ops-principles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .op-ops-principles-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .op-ops-principle-card {
    background: var(--op-navy-deep);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-ops-principle-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
  }
  .op-ops-principle-head {
    background: var(--op-navy);
    color: var(--op-cream);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-ops-principle-num {
    font-size: 9px;
    color: var(--op-orange);
    letter-spacing: 0.22em;
  }
  .op-ops-principle-tag {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.6;
    letter-spacing: 0.22em;
  }
  .op-ops-principle-body {
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .op-ops-principle-title {
    font-family: var(--op-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-cream);
    line-height: 1.25;
    margin: 0;
    text-wrap: balance;
  }
  .op-ops-principle-title em { color: var(--op-orange); font-style: normal; }
  .op-ops-principle-rule {
    width: 28px;
    height: 3px;
    background: var(--op-orange);
    margin: -2px 0 2px;
