---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": `${SITE_URL}/resources` },
  ],
};

const resources = [
  {
    code: 'RES_01',
    tag: 'Interactive Framework',
    title: 'The Full AI Operations Stack',
    description: 'Every ops category scored by disruption level and consequence of failure. An interactive reference for service businesses planning their AI roadmap.',
    href: '/resources/ai-ops-stack',
    icon: 'M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z',
  },
  {
    code: 'RES_02',
    tag: 'Build Guide',
    title: '6 Agent Design Principles',
    description: 'The rules we follow when building AI agents that actually work in production. Error handling, human checkpoints, and why most agents fail.',
    href: '/resources/agent-principles',
    icon: 'M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 0 0 2.25-2.25V6.75a2.25 2.25 0 0 0-2.25-2.25H6.75A2.25 2.25 0 0 0 4.5 6.75v10.5a2.25 2.25 0 0 0 2.25 2.25Zm.75-12h9v9h-9v-9Z',
  },
  {
    code: 'RES_03',
    tag: 'Framework',
    title: 'Process Intake Framework',
    description: 'Ten sections to spec any automation from scratch. Workflow maps, agent specs, skill structures, human gates, and a QA checklist before you build.',
    href: '/resources/process-intake-framework',
    icon: 'M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75',
  },
  {
    code: 'RES_04',
    tag: 'Playbook',
    title: 'The Mid-Market Automation Playbook',
    description: 'Eight real workflow deep-dives for service businesses doing $10-50M. Quote generation, lead routing, invoice processing, and more, with full agent specs.',
    href: '/resources/automation-playbook',
    icon: 'M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25',
  },
  {
    code: 'RES_06',
    tag: 'Buyer\'s Guide',
    title: 'How Much Does AI Automation Cost?',
    description: 'Real pricing for AI automation in 2026: scoped projects ($1.5K–$15K), retainers ($2.5K–$8K/mo), DIY vs agency vs hire, and the hidden running costs nobody warns you about.',
    href: '/how-much-does-ai-automation-cost',
    icon: 'M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4',
  },
  {
    code: 'RES_07',
    tag: 'Buyer\'s Guide',
    title: 'AI Lead Follow-Up Automation',
    description: 'How a 60-second AI follow-up system recovers the 30–50% of leads service businesses lose to slow response. Cost, build timeline, integrations, and a real HVAC case study.',
    href: '/ai-lead-follow-up-automation',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  },
  {
    code: 'RES_08',
    tag: 'Buyer\'s Guide',
    title: 'How to Choose an AI Automation Partner',
    description: 'A 9-step buyer\'s checklist: outcome definition, operator background, fixed-scope quotes, proof of real work, handoff quality, fix guarantees, and the red flags that signal a bad fit.',
    href: '/how-to-choose-an-ai-automation-partner',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    code: 'RES_09',
    tag: 'Buyer\'s Guide',
    title: 'Agency vs In-House AI Hire',
    description: 'When a $3.5K/mo agency retainer beats a $200K full-time hire, and when it doesn\'t. Decision framework by revenue band, with cumulative-cost math over 3 years.',
    href: '/ai-automation-agency-vs-in-house-hire',
    icon: 'M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z',
  },
  {
    code: 'RES_10',
    tag: 'Buyer\'s Guide',
    title: 'Best AI Automation Services (2026)',
    description: 'Nine categories, nine vendors. Not a ranked list. Picked by use case: enterprise, no-code, SaaS, e-commerce, home services, marketing agencies, DIY, and operator-led service businesses.',
    href: '/best-ai-automation-services-for-service-businesses',
    icon: 'M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605',
  },
];

// Featured resource — pinned next to the hero, NOT in the grid below.
const featured = {
  code: 'RES_05',
  tag: 'Operator’s Catalog · Email Unlock',
  title: 'The Skill Packs Catalog',
  description: '36 chained skill packs across 7 themes — every workflow we use to deliver content engines, lead funnels, conversion pages, research dossiers, and paid acquisition. Email-gated.',
  href: '/resources/skill-packs',
  icon: 'M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h12M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6',
};

const totalResourceCount = resources.length + 1;
---

<Layout
  title="Resources | Guides & Frameworks | Brothers Automate"
  description="Free guides, interactive frameworks, and build principles from Brothers Automate. Learn how we think about AI automation for service businesses."
>
  <Header />
  <main>
    <section class="op-resources-hero op-grid-bg">
      <div class="op-resources-hero-frame">
        <div class="op-resources-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / RESOURCES · LIBRARY"
            right={`${totalResourceCount} GUIDES · MOST FREE · NO SPAM`}
            bordered
          />
        </div>

        <div class="op-resources-hero-grid">
          <div class="op-resources-hero-text">
            <EyebrowTag label="RESOURCES · GUIDES & FRAMEWORKS" />
            <h1 class="op-resources-h1" data-animate="fade-up">
              Guides &<br />
              <span class="op-resources-h1-orange">Frameworks.</span>
            </h1>
            <p class="op-resources-sub" data-animate="fade-up">
              How we think about AI automation, and the tools we use to plan it. Most are free with no gate. The Operator&rsquo;s Catalog requires an email — it&rsquo;s the only one.
            </p>
          </div>

          <a href={featured.href} class="op-resource-card op-resource-card--featured" data-animate="fade-up">
            <div class="op-resource-header">
              <span class="op-pulse-dot"></span>
              <span class="op-mono op-resource-code">FEATURED</span>
              <span class="op-mono op-resource-tag">{featured.tag.toUpperCase()}</span>
            </div>
            <div class="op-resource-body">
              <div class="op-resource-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d={featured.icon}></path>
                </svg>
              </div>
              <h3 class="op-resource-title">{featured.title}</h3>
              <p class="op-resource-desc">{featured.description}</p>
            </div>
            <div class="op-resource-foot op-mono">
              UNLOCK THE CATALOG <span class="op-resource-arrow" aria-hidden="true">→</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <section class="op-resources-list">
      <div class="op-resources-list-frame">
        <div class="op-resources-grid" data-animate-stagger>
          {resources.map((r) => (
            <a href={r.href} class="op-resource-card">
              <div class="op-resource-header" data-animate="fade-up">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-resource-code">{r.code}</span>
                <span class="op-mono op-resource-tag">{r.tag.toUpperCase()}</span>
              </div>
              <div class="op-resource-body">
                <div class="op-resource-icon">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={r.icon}></path>
                  </svg>
                </div>
                <h3 class="op-resource-title">{r.title}</h3>
                <p class="op-resource-desc">{r.description}</p>
              </div>
              <div class="op-resource-foot op-mono">
                READ THE GUIDE <span class="op-resource-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-resources-hero {
    padding: 120px var(--op-section-px) 64px;
    color: var(--op-ink);
  }
  .op-resources-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-resources-util { margin-bottom: 32px; }
  .op-resources-hero :global(.op-eyebrow) { margin-bottom: 24px; }

  /* 2-column hero: text left, featured card right */
  .op-resources-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  @media (min-width: 960px) {
    .op-resources-hero-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);
      gap: 64px;
      align-items: center;
    }
  }
  .op-resources-hero-text { min-width: 0; }

  .op-resource-card--featured {
    width: 100%;
    max-width: 520px;
    box-shadow: var(--op-shadow-md);
  }
  @media (min-width: 960px) {
    .op-resource-card--featured { justify-self: end; }
  }
  .op-resource-card--featured .op-resource-header {
    background: var(--op-orange);
    color: var(--op-paper);
    border-bottom: var(--op-border);
  }
  .op-resource-card--featured .op-resource-code {
    color: var(--op-paper);
    letter-spacing: var(--op-tracking-mono);
  }
  .op-resource-card--featured .op-resource-tag {
    color: var(--op-paper);
    opacity: 0.78;
  }
  .op-resource-card--featured .op-resource-icon {
    background: var(--op-paper);
    color: var(--op-orange);
  }
  .op-resource-card--featured:hover .op-resource-icon {
    background: var(--op-navy);
    color: var(--op-paper);
  }
  .op-resource-card--featured:hover {
    box-shadow: var(--op-shadow-lg);
  }

  .op-resources-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 5.6vw, 76px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 640px;
    text-wrap: balance;
  }
  .op-resources-h1-orange { color: var(--op-orange); }

  .op-resources-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 660px;
    text-wrap: pretty;
  }

  .op-resources-list {
    padding: 56px var(--op-section-px) 96px;
    background: var(--op-paper);
    border-top: var(--op-border);
  }
  .op-resources-list-frame { max-width: var(--op-max-content); margin: 0 auto; }

  .op-resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 700px) { .op-resources-grid { grid-template-columns: 1fr 1fr; } }

  .op-resource-card {
    background: var(--op-cream);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    box-shadow: var(--op-shadow);
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-resource-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }
  .op-resource-card:hover .op-resource-arrow {
    transform: translateX(3px);
    color: var(--op-orange);
  }
  .op-resource-card:hover .op-resource-icon {
    background: var(--op-orange);
    color: var(--op-paper);
  }

  .op-resource-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-resource-code { font-size: 9px; color: var(--op-orange); }
  .op-resource-tag { margin-left: auto; font-size: 9px; color: var(--op-cream); opacity: 0.55; }

  .op-resource-body {
    padding: 26px 26px 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }
  .op-resource-icon {
    width: 48px;
    height: 48px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    background: var(--op-paper);
    color: var(--op-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-resource-title {
    font-family: var(--op-font-display);
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
    font-weight: 800;
    text-wrap: balance;
  }
  .op-resource-desc {
    font-family: var(--op-font-body);
    font-size: 14.5px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
    text-wrap: pretty;
  }

  .op-resource-foot {
    background: var(--op-paper);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: var(--op-border);
    font-size: 10px;
    color: var(--op-ink);
  }
  .op-resource-arrow {
    font-size: 14px;
    transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease);
  }

  @media (max-width: 700px) {
    .op-resources-hero,
    .op-resources-list { padding-left: 22px; padding-right: 22px; }
  }
</style>
