---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": `${SITE_URL}/resources` },
    { "@type": "ListItem", "position": 3, "name": "Agent Principles", "item": `${SITE_URL}/resources/agent-principles` }
  ]
};

const principles = [
  {
    num: "01",
    pill: "Most critical",
    title: '<span class="accent">Graceful</span> error handling',
    know: "We build for failure, not just the happy path. APIs fail, return empty, or time out. Without handling this, agents loop infinitely or silently die mid-workflow.",
    scenario: "Agent calls a CRM, gets null back, tries to access contact.email — and crashes the entire run.",
    code: `<span class="c-orange">if</span> (!contact || !contact.email) {
  <span class="c-orange">// log · notify · fallback
  // NEVER continue blindly</span>
  return fallback_action()
}`,
    variant: "dark"
  },
  {
    num: "02",
    pill: "Safety",
    title: 'Human-in-the-loop <span class="accent">checkpoints</span>',
    know: "We know which actions to automate and which to gate. Some are irreversible — sending emails, deleting records, charging payments. The wrong automation at the wrong moment is worse than none.",
    scenario: "Agent drafts and sends a refund email to 200 customers before anyone reviews. One line was wrong. You can't unsend it.",
    code: `<span class="c-orange">&#x26A0;&#xFE0F; NEVER execute without approval:</span>
- send_email
- delete_record
- submit_payment

Draft → show human → confirm → act.`,
    variant: "light"
  },
  {
    num: "03",
    pill: "Architecture",
    title: 'Lean prompt + <span class="accent">on-demand</span> skills',
    know: "We keep system prompts lean — identity, tone, guardrails only. Process logic lives in separate skills loaded on demand. Leaner prompts mean more predictable, more maintainable agents.",
    scenario: "A 3,000-word system prompt covering 12 workflows. The agent starts mixing up instructions between processes.",
    code: `<span class="c-orange">System prompt:</span> identity + rules only
  → under 300 words

<span class="c-orange">Skills (loaded on demand):</span>
  handle_refund.md
  qualify_lead.md
  draft_proposal.md`,
    variant: "dark"
  },
  {
    num: "04",
    pill: "Maintainability",
    title: 'Keep data <span class="accent">external</span> and editable',
    know: "We separate instructions from data. Pricing, FAQs, and templates live in external sources the agent reads live — so anyone on the team can update content without touching the agent.",
    scenario: "Pricing changes. Agent still quotes last month's rates because they're hardcoded in a prompt only a developer can edit.",
    code: `<span class="c-orange">"Before quoting pricing, fetch the
current rate card from Notion page
{pricing_page_id}."</span>

// Team updates Notion.
// Agent always reads fresh data.`,
    variant: "light"
  },
  {
    num: "05",
    pill: "Reliability",
    title: '<span class="accent">Idempotency</span> — design for retries',
    know: "We design every workflow to be safe to re-run. Triggers fire twice. Retries happen. An idempotent workflow produces the same result regardless of how many times it executes.",
    scenario: "A Zap fires twice after a timeout. Agent creates two CRM contacts, sends two welcome emails, charges the card twice.",
    code: `existing = search_crm(email)

<span class="c-orange">if</span> existing:
  update_record(existing.id)
<span class="c-orange">else:</span>
  create_record(new_data)

<span class="c-orange"># Never blindly CREATE — check first.</span>`,
    variant: "dark"
  },
  {
    num: "06",
    pill: "Observability",
    title: 'Log what the agent <span class="accent">did and why</span>',
    know: "We build observability in from the start. Every meaningful action — what the agent read, decided, and executed — is logged. That's how you debug, audit, and improve over time.",
    scenario: "Agent misroutes 40 support tickets to the wrong team. No log exists. You can't diagnose why or prove it happened.",
    code: `<span class="c-orange">After each action, log:</span>
  - input received
  - decision made
  - action taken
  - timestamp + run_id

Store in: {audit_log_table}`,
    variant: "light"
  }
];
---

<Layout
  title="Top 6 Agent Principles | Brothers Automate"
  description="The 6 principles we follow when building AI agents for service businesses. Error handling, human checkpoints, lean prompts, external data, idempotency, and observability."
>
  <Header />
  <main>
    <section class="op-respage-hero op-grid-bg">
      <div class="op-respage-hero-frame">
        <div class="op-respage-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / RESOURCES · AGENT PRINCIPLES"
            right="● BUILD GUIDE · 06 PRINCIPLES"
            bordered
          />
        </div>
        <EyebrowTag label="HOW WE BUILD · OPERATOR PLAYBOOK" />
        <h1 class="op-respage-h1">
          Top 6 <span class="op-respage-h1-orange">Agent Principles.</span>
        </h1>
        <p class="op-respage-sub">The rules we follow every time we build an AI agent or workflow for a service business. No exceptions.</p>
      </div>
    </section>

    <section class="op-pri-grid-section">
      <div class="op-pri-frame">
        <div class="op-pri-grid" data-animate-stagger>
          {principles.map((p) => (
            <article class={`op-pri-card ${p.variant === 'light' ? 'light' : 'dark'}`} data-animate="fade-up">
              <header class="op-pri-card-head">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-pri-num">PRINCIPLE_{p.num}</span>
                <span class="op-mono op-pri-pill">{p.pill.toUpperCase()}</span>
              </header>
              <div class="op-pri-card-body">
                <h3 class="op-pri-title" set:html={p.title} />
                <div class="op-pri-rule"></div>
                <div class="op-pri-section">
                  <span class="op-mono op-pri-label">WHAT WE KNOW</span>
                  <p class="op-pri-text">{p.know}</p>
                </div>
                <div class="op-pri-section">
                  <span class="op-mono op-pri-label">EXAMPLE SCENARIO</span>
                  <p class="op-pri-text">{p.scenario}</p>
                </div>
                <div class="op-pri-section">
                  <span class="op-mono op-pri-label">HOW TO IMPLEMENT</span>
                  <pre class="op-pri-code" set:html={p.code} />
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-pri-grid-section {
    padding: 64px var(--op-section-px) 96px;
    background: var(--op-paper);
    border-top: var(--op-border);
  }
  .op-pri-frame { max-width: var(--op-max-content); margin: 0 auto; }

  .op-pri-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }

  .op-pri-card {
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-pri-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
  }

  .op-pri-card.dark { background: var(--op-navy-deep); }
  .op-pri-card.light { background: var(--op-cream); }

  .op-pri-card-head {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-pri-card.light .op-pri-card-head {
    background: var(--op-navy-deep);
  }
  .op-pri-num {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-pri-pill {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.6;
  }

  .op-pri-card-body {
    padding: 26px 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    flex: 1;
  }

  .op-pri-title {
    font-family: var(--op-font-display);
    font-size: 22px;
    line-height: 1.18;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin: 0;
    text-wrap: balance;
  }
  .op-pri-card.dark .op-pri-title { color: var(--op-cream); }
  .op-pri-card.light .op-pri-title { color: var(--op-ink); }
  :global(.op-pri-title .accent) { color: var(--op-orange); }

  .op-pri-rule {
    width: 36px;
    height: 3px;
    background: var(--op-orange);
    margin: -4px 0 4px;
  }

  .op-pri-section {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .op-pri-label {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-pri-card.light .op-pri-label { color: var(--op-orange); }

  .op-pri-text {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.6;
    margin: 0;
    text-wrap: pretty;
  }
  .op-pri-card.dark .op-pri-text { color: rgba(244, 238, 226, 0.78); }
  .op-pri-card.light .op-pri-text { color: var(--op-navy-soft); }

  .op-pri-code {
    font-family: var(--op-font-mono);
    font-size: 11.5px;
    line-height: 1.75;
    padding: 12px 14px;
    border-left: 3px solid var(--op-orange);
    border-radius: 0 6px 6px 0;
    white-space: pre;
    overflow-x: auto;
    margin: 4px 0 0;
  }
  .op-pri-card.dark .op-pri-code {
    background: rgba(0, 0, 0, 0.28);
    color: rgba(244, 238, 226, 0.9);
  }
  .op-pri-card.light .op-pri-code {
    background: var(--op-paper);
    color: var(--op-navy);
    border: 1.5px solid var(--op-rule);
    border-left: 3px solid var(--op-orange);
  }
  :global(.op-pri-code .c-orange) {
    color: var(--op-orange);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .op-pri-grid { grid-template-columns: 1fr; }
    .op-pri-grid-section { padding-left: 22px; padding-right: 22px; }
  }
</style>
