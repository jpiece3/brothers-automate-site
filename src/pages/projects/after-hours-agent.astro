---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'after-hours-agent';

const study = projectToCaseStudy(slug, {
  badge: 'After-Hours Lead Capture',
  headline: 'After-Hours AI Receptionist.',
  headlineHighlight: 'Capture leads while you sleep.',
  meta: {
    client: 'Service Business',
    industry: 'Trades / Service',
    timeline: '1-2 weeks to production',
    techStack: ['OpenAI', 'Twilio', 'Google Calendar', 'Webhooks'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "After-Hours Agent", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="After Hours Agent | AI Lead Capture Chat | Brothers Automate" description="Stop losing after-hours leads. Our AI chat agent qualifies prospects, provides quotes, and books appointments while you sleep — embedded on your website in one line of code.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
