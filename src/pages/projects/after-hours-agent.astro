---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'after-hours-agent';

const study = projectToCaseStudy(slug, {
  badge: 'Afterhours AI Chat',
  headline: 'After-Hours AI Chat.',
  headlineHighlight: 'Capture leads while you sleep.',
  meta: {
    client: 'Service Business',
    industry: 'Trades / Service',
    timeline: '1-2 weeks to production',
    techStack: ['OpenAI', 'Twilio', 'Google Calendar', 'Webhooks'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "After Hours AI Chat", "item": `${SITE_URL}/projects/${slug}` },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "After Hours AI Chat",
  "serviceType": "Afterhours AI Chat Agent",
  "description": "After hours AI chat widget that qualifies leads, gives quotes from your real service menu, and books appointments against your calendar — 24/7, no missed inquiries.",
  "provider": {
    "@type": "Organization",
    "name": "Brothers Automate",
    "url": SITE_URL,
  },
  "areaServed": "United States",
  "url": `${SITE_URL}/projects/${slug}`,
};
---

<Layout
  title="After Hours AI Chat | Lead Capture While You Sleep | Brothers Automate"
  description="After hours AI chat that qualifies prospects, gives accurate quotes, and books appointments at 11pm so you stop losing leads to competitors who replied first. One line of code to install."
  extraSchemas={[serviceSchema]}
>
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
