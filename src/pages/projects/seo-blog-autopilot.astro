---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';
import { getCollection } from 'astro:content';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'seo-blog-autopilot';

const allPosts = await getCollection('blog');
const liveCount = allPosts.length;

const study = projectToCaseStudy(slug, {
  badge: 'Automated SEO Blog',
  headline: 'SEO Blog Autopilot.',
  headlineHighlight: `${liveCount}+ posts. Zero hours of writing.`,
  meta: {
    client: 'Internal Tool · Brothers Automate',
    industry: 'Marketing / Content',
    timeline: '4 weeks to production',
    techStack: ['Claude', 'DataForSEO', 'GitHub Actions', 'Vercel'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Automated SEO Blog", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="SEO Blog Autopilot | Automated Content Pipeline | Brothers Automate" description="A fully autonomous SEO content pipeline. Researches keywords, drafts posts, ships to production three times a week. The blog you're reading runs on this.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
