---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Automated SEO Blog", "item": `${SITE_URL}/projects/seo-blog-autopilot` }
  ]
};

// Pull recent blog posts for proof section
const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

// Dashboard data (from build.py output)
const runs = [
  { date: '2026-03-23', keyword: 'high conversion landing page', volume: 140, kd: 26, wordCount: 2700, status: 'success' },
  { date: '2026-03-20', keyword: 'top of funnel marketing', volume: 880, kd: 12, wordCount: 2700, status: 'success' },
  { date: '2026-03-16', keyword: 'landing page seo optimization', volume: 1300, kd: 20, wordCount: 2900, status: 'success' },
  { date: '2026-03-13', keyword: 'lead generation tools', volume: 1900, kd: 23, wordCount: 2850, status: 'success' },
  { date: '2026-03-11', keyword: 'b2b lead generation strategies', volume: 1900, kd: 26, wordCount: 2943, status: 'success' },
  { date: '2026-03-09', keyword: 'ai marketing automation tools', volume: 590, kd: 44, wordCount: 2100, status: 'success' },
  { date: '2026-03-06', keyword: 'email marketing for small business', volume: 0, kd: 0, wordCount: 0, status: 'empty' },
  { date: '2026-03-04', keyword: 'lead scoring model', volume: 720, kd: 25, wordCount: 2954, status: 'success' },
  { date: '2026-03-02', keyword: 'lead generation for it services', volume: 2900, kd: 1, wordCount: 3800, status: 'success' },
  { date: '2026-02-27', keyword: 'marketing funnel', volume: 14800, kd: 39, wordCount: 3000, status: 'success' },
  { date: '2026-02-25', keyword: 'conversion rate optimization tools', volume: 18100, kd: 21, wordCount: 3500, status: 'success' },
  { date: '2026-02-23', keyword: 'small business marketing automation', volume: 480, kd: 16, wordCount: 2740, status: 'success' },
];

const syndicated = [
  { slug: 'high-converting-landing-page-guide', date: '2026-03-23' },
  { slug: 'top-of-funnel-marketing', date: '2026-03-20' },
  { slug: 'landing-page-seo-optimization', date: '2026-03-16' },
  { slug: 'lead-generation-tools-small-business', date: '2026-03-13' },
  { slug: 'b2b-lead-generation-strategies', date: '2026-03-11' },
  { slug: 'ai-marketing-automation-tools', date: '2026-03-09' },
  { slug: 'email-marketing-for-small-business', date: '2026-03-06' },
  { slug: 'lead-scoring-model', date: '2026-03-04' },
  { slug: 'lead-generation-for-it-services', date: '2026-03-02' },
  { slug: 'how-to-build-a-marketing-funnel', date: '2026-02-27' },
  { slug: 'conversion-rate-optimization-tools', date: '2026-02-25' },
  { slug: 'small-business-marketing-automation', date: '2026-02-24' },
  { slug: 'email-drip-campaign-guide', date: '2026-02-20' },
];

function kdColor(kd: number): string {
  if (kd < 20) return 'var(--green, #16a34a)';
  if (kd < 40) return 'var(--orange, #ed8936)';
  return 'var(--red, #dc2626)';
}
---

<Layout
  title="Automated SEO Blog | AI Content That Ranks | Brothers Automate"
  description="An AI pipeline that finds keyword gaps, writes SEO-optimized posts in your brand voice, publishes to your site, and syndicates for backlinks — 3x a week on autopilot."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="seo-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="seo-hero-content" data-animate="fade-up">
          <span class="badge">AI-Powered Content on Autopilot</span>
          <h1>Automated SEO Blog.<br /><span class="gradient-text">35 Posts. Zero Writers.</span></h1>
          <p class="seo-hero-sub">Five Claude Code agents run on a cron schedule to find keyword gaps, write human-sounding blog posts in your brand voice, publish them to your site, and syndicate for backlinks. Runs 3x a week. Zero manual work.</p>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-number">3x/week</span>
              <span class="hero-stat-label">Publishing Schedule</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">35</span>
              <span class="hero-stat-label">Posts Published</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">42,990</span>
              <span class="hero-stat-label">Monthly Searches Targeted</span>
            </div>
          </div>

          <div class="hero-buttons">
            <a href="/blog" class="btn btn-primary btn-lg">See Our Blog (The Proof)</a>
            <a
              href="#"
              class="btn btn-secondary btn-lg"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Talk to the Brothers</a>
          </div>

          <!-- Terminal Box -->
          <div class="seo-terminal">
            <div class="seo-terminal-bar">
              <div class="seo-terminal-dot" style="background:#e8b4a0"></div>
              <div class="seo-terminal-dot" style="background:#ddd6c8"></div>
              <div class="seo-terminal-dot" style="background:#b8d4b0"></div>
              <span style="margin-left:8px;font-size:0.75rem;color:var(--text-secondary)">seo-blog-autopilot / cron</span>
            </div>
            <div class="seo-terminal-body" id="seoTerminal">
              <div class="seo-term-line">$ seo-blog-autopilot --run</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LIVE DASHBOARD -->
    <section class="seo-section" id="dashboard">
      <div class="container">
        <div class="seo-section-header" data-animate="fade-up">
          <span class="eyebrow">Live Data</span>
          <h2>See It Working</h2>
          <p>This dashboard shows real data from <a href="/blog">our blog</a>. Every post was researched, written, optimized, and published by our AI autopilot.</p>
        </div>

        <!-- Stats Cards -->
        <div class="dash-stats" data-animate="fade-up" data-animate-stagger>
          <div class="dash-stat-card">
            <div class="dash-stat-label">Posts Published</div>
            <div class="dash-stat-value">35</div>
            <div class="dash-stat-sub">And growing 3x/week</div>
          </div>
          <div class="dash-stat-card">
            <div class="dash-stat-label">Keyword Volume Targeted</div>
            <div class="dash-stat-value accent-blue">42,990</div>
            <div class="dash-stat-sub">Monthly searches</div>
          </div>
          <div class="dash-stat-card">
            <div class="dash-stat-label">Posts Syndicated</div>
            <div class="dash-stat-value accent-green">13</div>
            <div class="dash-stat-sub">Dev.to backlinks live</div>
          </div>
          <div class="dash-stat-card">
            <div class="dash-stat-label">Avg Keyword Difficulty</div>
            <div class="dash-stat-value accent-orange">22.8</div>
            <div class="dash-stat-sub">Out of 100 (lower = easier)</div>
          </div>
        </div>

        <!-- Pipeline Runs Table -->
        <div class="dash-table-wrap" data-animate="fade-up">
          <h3>Recent Pipeline Runs</h3>
          <div class="dash-table-scroll">
            <table class="dash-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Keyword Targeted</th>
                  <th>Volume</th>
                  <th>KD</th>
                  <th>Words</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                {runs.map(r => (
                  <tr>
                    <td>{r.date}</td>
                    <td><span class="kw-pill">{r.keyword}</span></td>
                    <td>{r.volume ? r.volume.toLocaleString() : '-'}</td>
                    <td>
                      {r.kd ? (
                        <span class="kd-wrap">
                          <span class="kd-bar"><span class="kd-fill" style={`width:${Math.min(r.kd, 100)}%;background:${kdColor(r.kd)}`}></span></span>
                          {r.kd}
                        </span>
                      ) : '-'}
                    </td>
                    <td>{r.wordCount ? r.wordCount.toLocaleString() : '-'}</td>
                    <td>
                      <span class={`status-badge ${r.status === 'success' ? 'status-success' : 'status-empty'}`}>
                        {r.status === 'success' ? 'Published' : 'Empty'}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Syndication -->
        <div class="dash-syndication" data-animate="fade-up">
          <h3>Backlink Syndication</h3>
          <p class="dash-syndication-sub">Every post is automatically cross-posted to Dev.to with a canonical URL pointing back to our site. Free backlinks, zero effort.</p>
          <div class="syndication-grid">
            {syndicated.slice(0, 6).map(s => (
              <div class="syndication-item">
                <span class="syndication-date">{s.date}</span>
                <span class="syndication-slug">{s.slug.replace(/-/g, ' ')}</span>
                <span class="status-badge status-success">Live</span>
              </div>
            ))}
          </div>
          <p class="syndication-total">{syndicated.length} posts syndicated total</p>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="seo-section bg-surface-alt">
      <div class="container">
        <div class="seo-section-header" data-animate="fade-up">
          <span class="eyebrow">The Pipeline</span>
          <h2>How It Works</h2>
          <p>Five Claude Code agents run in sequence, 3x a week, on a cron schedule. No human in the loop.</p>
        </div>

        <div class="pipeline-steps" data-animate-stagger>
          <div class="pipeline-step" data-animate="fade-up">
            <div class="step-number">01</div>
            <div class="step-content">
              <h3>Competitor Gap Analysis</h3>
              <p>A Claude Code agent scans your organic competitors via DataForSEO. Finds keywords they rank for that you don't. Filters out what you've already covered. Outputs a prioritized list of content gaps with volume, difficulty, and intent data.</p>
            </div>
          </div>
          <div class="pipeline-step" data-animate="fade-up">
            <div class="step-number">02</div>
            <div class="step-content">
              <h3>Content Strategy</h3>
              <p>A Claude Code agent picks the highest-opportunity keyword from the gap list. Analyzes the top 10 SERP results. Plans the outline, maps internal links to existing posts, and pulls real statistics and research to cite.</p>
            </div>
          </div>
          <div class="pipeline-step" data-animate="fade-up">
            <div class="step-number">03</div>
            <div class="step-content">
              <h3>SEO Writing</h3>
              <p>A Claude Code agent writes a 2,700-3,500 word article in your brand voice. Not generic AI slop — it follows your tone, injects real opinions, cites sources, and weaves in internal links. Passes humanization checks to avoid AI-sounding output.</p>
            </div>
          </div>
          <div class="pipeline-step" data-animate="fade-up">
            <div class="step-number">04</div>
            <div class="step-content">
              <h3>Auto-Publish</h3>
              <p>A Claude Code agent validates frontmatter, checks slug uniqueness, confirms word count and link targets. Commits to your git repo and pushes. Vercel (or Netlify) auto-deploys. Post goes live without anyone touching a keyboard.</p>
            </div>
          </div>
          <div class="pipeline-step" data-animate="fade-up">
            <div class="step-number">05</div>
            <div class="step-content">
              <h3>Backlink Syndication</h3>
              <p>A Claude Code agent cross-posts the article to Dev.to with a canonical URL pointing back to your site. Builds domain authority over time with every post. Tracks all syndicated content to prevent duplicates.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROOF SECTION -->
    <section class="seo-section">
      <div class="container">
        <div class="seo-section-header" data-animate="fade-up">
          <span class="eyebrow">The Proof</span>
          <h2>Don't Take Our Word for It. Read the Posts.</h2>
          <p>Every post on our blog was written by this system. Click any one — it reads like a human wrote it, because we spent weeks tuning the voice, not the volume.</p>
        </div>

        <div class="proof-grid" data-animate-stagger>
          {recentPosts.map(post => (
            <a href={`/blog/${post.slug}/`} class="proof-card" data-animate="fade-up">
              <span class="proof-category">{post.data.category}</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="proof-date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </a>
          ))}
        </div>

        <div style="text-align:center;margin-top:var(--space-xl);" data-animate="fade-up">
          <a href="/blog" class="btn btn-secondary btn-lg">Browse All 35 Posts</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="seo-cta">
      <div class="seo-cta-glow"></div>
      <div class="container">
        <div class="seo-cta-content" data-animate="fade-up">
          <h2>Get an Automated SEO Blog Running on Your Site</h2>
          <p class="seo-cta-sub">We'll set up the same autopilot that runs our blog — competitor analysis, AI writing, auto-publishing, and syndication — custom-built for your business.</p>
          <div class="seo-cta-buttons">
            <a
              href="#"
              class="btn btn-primary btn-lg"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Talk to the Brothers</a>
            <a href="/blog" class="btn btn-secondary btn-lg">See Our Blog</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <script>
    // Terminal animation
    const lines = [
      { text: '[1/5] Running competitor gap analysis...', delay: 600 },
      { text: '  > Found 25 keyword gaps (avg volume: 1,720/mo)', delay: 1200 },
      { text: '[2/5] Selecting highest-opportunity keyword...', delay: 800 },
      { text: '  > Target: "conversion rate optimization tools" (18,100/mo, KD 21)', delay: 1000 },
      { text: '[3/5] Writing SEO-optimized article...', delay: 1500 },
      { text: '  > 3,500 words | 5 internal links | brand voice validated', delay: 1200 },
      { text: '[4/5] Publishing to brothersautomate.com/blog...', delay: 800 },
      { text: '  > Commit 5afde99 pushed. Vercel deploying...', delay: 600 },
      { text: '[5/5] Syndicating to Dev.to...', delay: 800 },
      { text: '  > Canonical URL set. Backlink live.', delay: 600 },
      { text: '', delay: 300 },
      { text: 'Done. Post live at /blog/conversion-rate-optimization-tools/', delay: 0 },
    ];

    function runTerminal() {
      const terminal = document.getElementById('seoTerminal');
      if (!terminal) return;
      let totalDelay = 1000;
      lines.forEach((line) => {
        totalDelay += line.delay;
        setTimeout(() => {
          const el = document.createElement('div');
          el.className = 'seo-term-line' + (line.text.startsWith('  >') ? ' seo-term-result' : '') + (line.text.startsWith('Done') ? ' seo-term-done' : '');
          el.textContent = line.text;
          terminal.appendChild(el);
          terminal.scrollTop = terminal.scrollHeight;
        }, totalDelay);
      });
    }

    // Run on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', runTerminal);
    } else {
      runTerminal();
    }
  </script>
</Layout>

<style>
  /* HERO */
  .seo-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 140px;
    padding-bottom: var(--space-3xl);
    background: var(--bg-primary);
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .seo-hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(237, 137, 54, 0.1);
    border: 1px solid rgba(237, 137, 54, 0.3);
    color: var(--orange);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--navy);
    margin-bottom: var(--space-md);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .seo-hero-sub {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--space-xl);
  }

  .hero-stat { text-align: center; }

  .hero-stat-number {
    display: block;
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--navy);
  }

  .hero-stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
  }

  .hero-stat-divider {
    width: 1px;
    height: 40px;
    background: var(--border);
  }

  .hero-buttons {
    display: flex;
    gap: var(--space-sm);
    justify-content: center;
    margin-bottom: var(--space-xl);
  }

  /* Terminal */
  .seo-terminal {
    background: var(--navy);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-align: left;
    max-width: 600px;
    margin: 0 auto;
    box-shadow: var(--shadow-lg);
  }

  .seo-terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(0,0,0,0.2);
  }

  .seo-terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .seo-terminal-body {
    padding: 16px;
    font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.7);
    min-height: 200px;
    max-height: 300px;
    overflow-y: auto;
  }

  .seo-term-line { margin-bottom: 2px; }
  .seo-term-result { color: rgba(255,255,255,0.5); }
  .seo-term-done { color: var(--green, #38a169); font-weight: 600; }

  /* SECTIONS */
  .seo-section {
    padding: var(--space-3xl) 0;
  }

  .bg-surface-alt {
    background: var(--bg-surface-alt, #f8f7f4);
  }

  .seo-section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-2xl);
  }

  .seo-section-header h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: var(--navy);
    margin-bottom: var(--space-sm);
  }

  .seo-section-header p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .eyebrow {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--blue);
    margin-bottom: var(--space-sm);
  }

  /* DASHBOARD STATS */
  .dash-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .dash-stat-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
    box-shadow: var(--shadow-sm);
  }

  .dash-stat-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 4px;
  }

  .dash-stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--navy);
  }

  .dash-stat-value.accent-blue { color: var(--blue); }
  .dash-stat-value.accent-green { color: var(--green, #16a34a); }
  .dash-stat-value.accent-orange { color: var(--orange); }

  .dash-stat-sub {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 2px;
  }

  /* TABLE */
  .dash-table-wrap {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
    box-shadow: var(--shadow-sm);
  }

  .dash-table-wrap h3 {
    font-size: 1.125rem;
    color: var(--navy);
    margin-bottom: var(--space-md);
  }

  .dash-table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .dash-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .dash-table thead th {
    text-align: left;
    padding: 10px 14px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    border-bottom: 2px solid var(--border);
    font-weight: 600;
    white-space: nowrap;
  }

  .dash-table tbody td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--border-light, #f0eeea);
    color: var(--navy);
    vertical-align: middle;
  }

  .dash-table tbody tr:last-child td { border-bottom: none; }
