---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'daily-ads';

const study = projectToCaseStudy(slug, {
  badge: 'AI Ad Creative on Autopilot',
  headline: 'Daily Ad Creator.',
  headlineHighlight: 'Fresh creative every day.',
  meta: {
    client: 'E-commerce Brand',
    industry: 'E-commerce / DTC',
    timeline: '2-3 weeks to production',
    techStack: ['OpenAI', 'Replicate', 'Meta Ads API', 'Airtable'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Daily Ads", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Daily Ads | AI Ad Creative Generator | Brothers Automate" description="Get fresh, on-brand ad creative generated daily in 15+ formats. Stop paying designers $5K/month for static that goes stale in a week.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
