---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'route-simply';

const study = projectToCaseStudy(slug, {
  badge: 'AI Route Optimization',
  headline: 'Route Simply.',
  headlineHighlight: 'Stop driving in circles.',
  meta: {
    client: 'Field Service Co.',
    industry: 'Field Service / Logistics',
    timeline: '2-3 weeks to production',
    techStack: ['Google Maps API', 'OpenAI', 'Supabase', 'Twilio'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Route Simply", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Route Simply | AI Route Optimization | Brothers Automate" description="AI-driven route optimization for field service teams. Cut drive time, hit more stops per day, and stop manually rebuilding routes every morning.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
