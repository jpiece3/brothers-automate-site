---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'brand-research';

const study = projectToCaseStudy(slug, {
  badge: 'AI Brand Research',
  headline: 'AI Brand Researcher.',
  headlineHighlight: 'Research that takes weeks. Done in minutes.',
  meta: {
    client: 'Marketing Agency',
    industry: 'Marketing / Brand Strategy',
    timeline: '3-4 weeks to production',
    techStack: ['OpenAI', 'Apify', 'DataForSEO', 'Notion'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Brand Research", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Brand Research | AI-Powered Market Intelligence | Brothers Automate" description="Get deep audience insights, competitor analysis, and positioning strategy powered by AI. In minutes, not months.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
