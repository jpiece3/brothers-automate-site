---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'signal-engine';

const study = projectToCaseStudy(slug, {
  badge: 'AI Prospect Scoring',
  headline: 'Signal Engine.',
  headlineHighlight: 'Score every prospect before you call.',
  meta: {
    client: 'B2B Sales Team',
    industry: 'B2B Sales / SDR',
    timeline: '3 weeks to production',
    techStack: ['DataForSEO', 'Apify', 'OpenAI', 'HubSpot'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Signal Engine", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Signal Engine | AI Prospect Scoring | Brothers Automate" description="AI-driven prospect scoring that pulls signals from across the web — hiring, funding, tech stack, news — to tell you which leads are ready to buy.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
