  .ha-pipe-desc { font-size: 10px; color: var(--ha-muted); line-height: 1.5; font-family: var(--ha-mono); }

  .ha-quote-block {
    margin-top: 40px; border-left: 4px solid var(--ha-accent);
    padding: 24px 28px; background: var(--bg-surface); border-radius: 0 16px 16px 0;
  }
  .ha-quote-text {
    font-size: clamp(14px, 2vw, 19px); font-weight: 700; line-height: 1.55;
    color: var(--ha-navy); margin-bottom: 10px;
  }
  .ha-quote-attr { font-size: 10px; color: var(--ha-muted); letter-spacing: 0.12em; text-transform: uppercase; font-family: var(--ha-mono); }

  /* ===== IMPACT GRID (Section 05) ===== */
  .ha-impact-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 48px;
  }
  .ha-impact-card {
    background: var(--bg-surface); border: 1.5px solid var(--border); border-radius: 16px;
    padding: 28px 24px; text-align: center; transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(30,53,87,0.05);
  }
  .ha-impact-card:hover { border-color: var(--ha-accent); box-shadow: 0 4px 20px rgba(224,123,57,0.1); }
  .ha-impact-num {
    font-size: 40px; font-weight: 900; color: var(--ha-accent);
    line-height: 1; margin-bottom: 10px; letter-spacing: -0.03em;
  }
  .ha-impact-label { font-size: 13px; font-weight: 700; color: var(--ha-navy); margin-bottom: 8px; line-height: 1.35; }
  .ha-impact-detail { font-size: 11px; color: var(--ha-blue-gray); line-height: 1.6; font-family: var(--ha-mono); }

  /* ===== HIPAA (Section 06) ===== */
  .ha-hipaa-section { padding-bottom: 40px; }
  .ha-hipaa-card {
    display: flex; align-items: flex-start; gap: 20px;
    background: var(--bg-surface); border: 1.5px solid var(--border); border-radius: 16px;
    padding: 28px; margin-top: 24px;
    box-shadow: 0 2px 8px rgba(30,53,87,0.05);
  }
  .ha-hipaa-icon { font-size: 32px; flex-shrink: 0; margin-top: 2px; }
  .ha-hipaa-title { font-weight: 800; font-size: 16px; color: var(--ha-navy); margin-bottom: 8px; }
  .ha-hipaa-text { font-size: 13px; color: var(--ha-blue-gray); line-height: 1.7; }

  /* ===== CTA ===== */
  .ha-cta-section {
    max-width: 980px; margin: 0 auto; padding: 80px 32px 120px;
    border-top: 1px solid var(--border); text-align: center;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .ha-cta-section.visible { opacity: 1; transform: none; }
  .ha-cta-title {
    font-size: clamp(36px, 6vw, 72px); font-weight: 900;
    line-height: 1.02; margin-bottom: 18px; color: var(--ha-navy); letter-spacing: -0.03em;
  }
  .ha-cta-sub {
    font-size: 16px; color: var(--ha-blue-gray); max-width: 420px;
    margin: 0 auto 40px; line-height: 1.7;
  }
  .ha-cta-btn-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .ha-btn-p {
    display: inline-block; background: var(--ha-accent); color: #fff; border: none;
    padding: 16px 34px; font-family: var(--ha-sans); font-weight: 700; font-size: 14px;
    cursor: pointer; border-radius: 999px; transition: background 0.15s;
    box-shadow: 0 4px 16px rgba(224,123,57,0.3); text-decoration: none;
  }
  .ha-btn-p:hover { background: var(--ha-accent2); }
  .ha-btn-s {
    display: inline-block; background: transparent; color: var(--ha-navy);
    border: 2px solid var(--ha-navy); padding: 16px 34px;
    font-family: var(--ha-sans); font-weight: 700; font-size: 14px;
    cursor: pointer; border-radius: 999px; transition: all 0.15s; text-decoration: none;
  }
  .ha-btn-s:hover { background: var(--ha-navy); color: #fff; }

  /* ===== ANIMATIONS ===== */
  @keyframes haFadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }

  /* ===== MOBILE ===== */
  @media (max-width: 767px) {
    .project-hero { padding-top: 120px; padding-bottom: var(--space-2xl); }
    .hero-stats { flex-direction: column; gap: var(--space-md); padding: var(--space-md); }
    .hero-stat-divider { width: 60px; height: 1px; }
    .hero-buttons .btn { width: 100%; justify-content: center; }
  }

  @media (max-width: 640px) {
    .ha-gap-grid { grid-template-columns: 1fr; }
    .ha-pipeline { grid-template-columns: 1fr; }
    .ha-impact-grid { grid-template-columns: 1fr; }
    .ha-section { padding: 60px 20px; }
    .ha-cta-section { padding: 60px 20px 80px; }
    .ha-hipaa-card { flex-direction: column; gap: 12px; }
  }

  @media (min-width: 641px) and (max-width: 900px) {
    .ha-gap-grid { grid-template-columns: repeat(2, 1fr); }
    .ha-pipeline { grid-template-columns: repeat(2, 1fr); }
    .ha-impact-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<!-- DM Mono font -->
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" />

<script>
  // Terminal demo
  const haLines = [
    ['ha-log-working', '\u27F6 New lead received \u00B7 Mary Johnson \u00B7 Bethesda MD'],
    ['ha-log-ok', '\u2713 AI classification \u00B7 concern: hearing_loss \u00B7 urgency: 8/10'],
    ['ha-log-ok', '\u2713 Location matched \u00B7 Bethesda Office \u00B7 zip 20814'],
    ['ha-log-working', '\u27F6 Routing to HIGH urgency path...'],
    ['ha-log-ok', '\u2713 Personalized email sent \u00B7 mary.johnson@email.com'],
    ['ha-log-ok', '\u2713 Slack alert \u00B7 #high-priority-leads \u00B7 Bethesda manager notified'],
    ['ha-log-ok', '\u2713 Lead Pipeline updated \u00B7 row 847 \u00B7 status: New'],
    ['ha-log-qual', '\u2192 Lead qualified \u00B7 HIGH priority \u00B7 hearing_loss \u00B7 ~3 credits used'],
    ['ha-log-ok', '\u26A1 Intake complete \u00B7 total time: 4 seconds'],
  ];

  function haRunDemo() {
    const log = document.getElementById('haLog');
    if (!log) return;
    log.innerHTML = '';
    log.classList.add('visible');
    let i = 0;
    const iv = setInterval(() => {
      if (i >= haLines.length) { clearInterval(iv); return; }
      const [cls, msg] = haLines[i];
      const div = document.createElement('div');
      div.className = cls;
      div.textContent = msg;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      i++;
    }, 380);
  }

  const haInput = document.getElementById('haInput');
  if (haInput) {
    haInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') haRunDemo();
    });
  }

  // Workflow card toggle
  function haToggleWf(el) {
    const wasActive = el.classList.contains('active');
    document.querySelectorAll('.ha-wf-card').forEach(c => c.classList.remove('active'));
    if (!wasActive) el.classList.add('active');
  }

  // Phase filter
  function haFilterPhase(phase) {
    document.querySelectorAll('.ha-phase-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    document.querySelectorAll('.ha-wf-card').forEach(card => {
      if (phase === 'all' || card.dataset.phase === phase) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
  }

  // Roadmap toggle
  function haToggleRoadmap(el) {
    const wasActive = el.classList.contains('active');
    document.querySelectorAll('.ha-rm-phase').forEach(p => p.classList.remove('active'));
    if (!wasActive) el.classList.add('active');
  }

  // Pipeline toggle
  function haTogglePipe(el) {
    document.querySelectorAll('.ha-pipe-stage').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
  }

  // Section scroll animations
  const haObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.ha-section, .ha-cta-section').forEach(el => haObs.observe(el));

  // Make functions globally available for inline onclick handlers
  window.haRunDemo = haRunDemo;
  window.haToggleWf = haToggleWf;
  window.haFilterPhase = haFilterPhase;
  window.haToggleRoadmap = haToggleRoadmap;
  window.haTogglePipe = haTogglePipe;
</script>

