<script>
  // Plain-English terminal demo
  const haLines = [
    ['ha-log-working', '\u27F6 New inquiry from Mary Johnson in Bethesda, MD'],
    ['ha-log-ok', '\u2713 Identified as hearing concern \u00B7 sounds urgent'],
    ['ha-log-ok', '\u2713 Matched to your Bethesda office'],
    ['ha-log-working', '\u27F6 Sending personalized welcome email...'],
    ['ha-log-ok', '\u2713 Mary got a response within seconds'],
    ['ha-log-ok', '\u2713 Bethesda office manager notified'],
    ['ha-log-ok', '\u2713 Contact saved to your records'],
    ['ha-log-qual', '\u2192 Done \u00B7 Mary is taken care of \u00B7 your team can follow up when ready'],
    ['ha-log-ok', '\u26A1 Total time: 4 seconds \u00B7 zero manual steps'],
  ];

  function haRunDemo() {
    const log = document.getElementById('haLog');
    if (!log) return;
    log.innerHTML = '';
    log.classList.add('visible');
    let i = 0;
    const iv = setInterval(() => {
      if (i >= haLines.length) { clearInterval(iv); return; }
      const [cls, msg] = haLines[i];
      const div = document.createElement('div');
      div.className = cls;
      div.textContent = msg;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      i++;
    }, 380);
  }

  const haInput = document.getElementById('haInput');
  if (haInput) {
    haInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') haRunDemo();
    });
  }

  // Idea card toggle
  function haToggleWf(el) {
    const wasActive = el.classList.contains('active');
    document.querySelectorAll('.ha-wf-card').forEach(c => c.classList.remove('active'));
    if (!wasActive) el.classList.add('active');
  }

  // Pipeline toggle
  function haTogglePipe(el) {
    document.querySelectorAll('.ha-pipe-stage').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
  }

  // Section scroll animations
  const haObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.15 });
  document.querySelectorAll('.ha-section, .ha-cta-section').forEach(el => haObs.observe(el));

  // Global functions for onclick handlers
  window.haRunDemo = haRunDemo;
  window.haToggleWf = haToggleWf;
  window.haTogglePipe = haTogglePipe;
</script>

