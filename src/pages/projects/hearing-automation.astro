---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Hearing Practice Automation", "item": `${SITE_URL}/projects/hearing-automation` }
  ]
};
---

<Layout
  title="Hearing Practice Automation | 10 Workflows for Audiology Practices | Brothers Automate"
  description="Automated workflows for multi-location audiology practices. Lead qualification, appointment reminders, review collection, physician referral tracking, and more."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="project-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="project-hero-content" data-animate="fade-up">
          <span class="badge">Automated Workflows for Audiology Practices</span>
          <h1>27 Locations.<br /><span class="gradient-text">0 Leads Lost.</span></h1>
          <p class="project-hero-sub">Lead qualification, appointment reminders, review collection, physician nurture, and patient reactivation. All automated. All connected.</p>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-number">10</span>
              <span class="hero-stat-label">Workflows</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">$150K+</span>
              <span class="hero-stat-label">Revenue Recovered / yr</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">25 hrs</span>
              <span class="hero-stat-label">Saved Per Week</span>
            </div>
          </div>

          <div class="hero-buttons">
            <a href="#ha-workflows" class="btn btn-primary btn-lg">See the Workflows</a>
            <a
              href="#"
              class="btn btn-secondary btn-lg"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Talk to the Brothers</a>
          </div>

          <!-- Command Terminal -->
          <div class="ha-scan-box">
            <div class="ha-scan-bar">
              <div class="ha-scan-dot" style="background:#e8b4a0"></div>
              <div class="ha-scan-dot" style="background:#ddd6c8"></div>
              <div class="ha-scan-dot" style="background:#b8d4b0"></div>
              <span style="margin-left:6px">hearing-automation / workflow dashboard</span>
            </div>
            <div class="ha-scan-input-row">
              <input class="ha-scan-input" id="haInput" placeholder="new-lead &middot; Mary Johnson &middot; Bethesda MD" />
              <button class="ha-scan-btn" onclick="haRunDemo()">&#9654; RUN INTAKE</button>
            </div>
            <div class="ha-scan-log" id="haLog"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- TICKER -->
    <div class="ha-ticker">
      <div class="ha-ticker-inner">
        NEW LEAD &rarr; QUALIFY &nbsp;&middot;&nbsp; ROUTE TO OFFICE &nbsp;&middot;&nbsp; CONFIRM APPOINTMENT &nbsp;&middot;&nbsp; SEND REMINDERS &nbsp;&middot;&nbsp; COLLECT REVIEW &nbsp;&middot;&nbsp; NURTURE PHYSICIAN &nbsp;&middot;&nbsp; REACTIVATE PATIENT &nbsp;&middot;&nbsp;
        NEW LEAD &rarr; QUALIFY &nbsp;&middot;&nbsp; ROUTE TO OFFICE &nbsp;&middot;&nbsp; CONFIRM APPOINTMENT &nbsp;&middot;&nbsp; SEND REMINDERS &nbsp;&middot;&nbsp; COLLECT REVIEW &nbsp;&middot;&nbsp; NURTURE PHYSICIAN &nbsp;&middot;&nbsp; REACTIVATE PATIENT &nbsp;&middot;&nbsp;
      </div>
    </div>

    <!-- 01 - THE PROBLEM -->
    <section class="ha-section" id="ha-section-1">
      <div class="ha-section-label">01 &mdash; The Problem</div>
      <h2 class="ha-section-title">27 locations.<br><span class="ha-accent">Zero automation.</span></h2>
      <p class="ha-section-sub">Every lead, every appointment, every review request, every physician follow-up is done manually. Here's what's falling through the cracks.</p>

      <div class="ha-gap-grid">
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#128222;</div>
          <div class="ha-gap-title">Phone-Only Leads</div>
          <div class="ha-gap-desc">Website visitors who aren't ready to call have no way to engage. They leave and never come back.</div>
          <div class="ha-gap-stat">~0% digital capture rate</div>
        </div>
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#128197;</div>
          <div class="ha-gap-title">No-Show Revenue Loss</div>
          <div class="ha-gap-desc">No automated reminders means 15-20% no-show rates across all locations. No recovery emails sent.</div>
          <div class="ha-gap-stat">$50K-$150K lost / year</div>
        </div>
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#11088;</div>
          <div class="ha-gap-title">Manual Review Collection</div>
          <div class="ha-gap-desc">10,000+ reviews collected by hand. No automated routing for unhappy patients before they post publicly.</div>
          <div class="ha-gap-stat">2-3x more reviews possible</div>
        </div>
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#129657;</div>
          <div class="ha-gap-title">Physician Referrals Blind</div>
          <div class="ha-gap-desc">1,500+ referring physicians with no tracking, no nurture emails, no visibility into declining referral volume.</div>
          <div class="ha-gap-stat">0 referral analytics</div>
        </div>
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#128164;</div>
          <div class="ha-gap-title">Lapsed Patients</div>
          <div class="ha-gap-desc">Patients who haven't returned in 12+ months get no outreach. Hearing aids need replacement every 5-7 years.</div>
          <div class="ha-gap-stat">$100K+ in dormant revenue</div>
        </div>
        <div class="ha-gap-card">
          <div class="ha-gap-icon">&#9201;</div>
          <div class="ha-gap-title">Staff Time Drain</div>
          <div class="ha-gap-desc">Admin, marketing, and care teams spend 25+ hours per week on tasks that should be automated.</div>
          <div class="ha-gap-stat">25 hrs / week wasted</div>
        </div>
      </div>
    </section>

    <!-- 02 - 10 WORKFLOWS -->
    <section class="ha-section" id="ha-workflows">
      <div class="ha-section-label">02 &mdash; 10 Automated Workflows</div>
      <h2 class="ha-section-title">The complete<br><span class="ha-accent">automation system.</span></h2>
      <p class="ha-section-sub">10 workflows across 4 phases. Click any workflow to see what it does under the hood.</p>

      <!-- Phase badges -->
      <div class="ha-phase-row">
        <button class="ha-phase-btn active" onclick="haFilterPhase('all')">All Workflows</button>
        <button class="ha-phase-btn" onclick="haFilterPhase('1')">Phase 1</button>
        <button class="ha-phase-btn" onclick="haFilterPhase('2')">Phase 2</button>
        <button class="ha-phase-btn" onclick="haFilterPhase('3')">Phase 3</button>
        <button class="ha-phase-btn" onclick="haFilterPhase('4')">Phase 4</button>
      </div>

      <div class="ha-wf-grid" id="haWfGrid">
        <!-- Workflow 1 -->
        <div class="ha-wf-card" data-phase="1" data-impact="high" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">01</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-high">HIGH IMPACT</span>
              <span class="ha-badge-phase">PHASE 1</span>
            </div>
          </div>
          <div class="ha-wf-title">Lead Intake & Qualification</div>
          <div class="ha-wf-summary">AI classifies every form submission by concern type and urgency. Routes to nearest office with personalized response.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Trigger</span> Webflow form webhook</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Extract name, zip, concern type, urgency 1-10</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Match</span> Zip code &rarr; nearest of 27 locations</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Route</span> HIGH / MEDIUM / LOW urgency paths</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Email</span> Personalized response per urgency level</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Slack</span> Office manager notified instantly</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Log</span> Lead Pipeline Google Sheet updated</div>
            </div>
            <div class="ha-wf-cost">Webhook trigger &middot; runs per form submission</div>
          </div>
        </div>

        <!-- Workflow 2 -->
        <div class="ha-wf-card" data-phase="1" data-impact="high" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">02</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-high">HIGH IMPACT</span>
              <span class="ha-badge-phase">PHASE 1</span>
            </div>
          </div>
          <div class="ha-wf-title">Appointment Reminders & No-Show Recovery</div>
          <div class="ha-wf-summary">Confirmation email on booking. 48-hour email reminder. Same-day SMS. Empathetic recovery email for no-shows.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">2A</span> New appointment &rarr; confirmation email</div>
              <div class="ha-flow-step"><span class="ha-flow-label">2B</span> Daily 8am &rarr; 48hr email + same-day SMS</div>
              <div class="ha-flow-step"><span class="ha-flow-label">2C</span> Daily 6pm &rarr; identify no-shows</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Generate empathetic recovery email</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Slack</span> #no-shows channel alerted</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Track</span> All statuses logged in Sheet</div>
            </div>
            <div class="ha-wf-cost">3 sub-workflows &middot; daily automated runs</div>
          </div>
        </div>

        <!-- Workflow 3 -->
        <div class="ha-wf-card" data-phase="1" data-impact="high" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">03</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-high">HIGH IMPACT</span>
              <span class="ha-badge-phase">PHASE 1</span>
            </div>
          </div>
          <div class="ha-wf-title">Review Collection & Satisfaction Router</div>
          <div class="ha-wf-summary">Post-visit satisfaction check. Happy patients get review link. Unhappy patients get internal recovery before going public.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">3A</span> Daily 5pm &rarr; satisfaction email to today's patients</div>
              <div class="ha-flow-step"><span class="ha-flow-label">3B</span> Response router &rarr; 3 paths</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Happy</span> Google Review link + thank you</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Neutral</span> Care tips email + internal note</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Unhappy</span> Slack alert + CEO-signed apology</div>
              <div class="ha-flow-step"><span class="ha-flow-label">3C</span> Day 7 care tips + Day 30 check-in nurture</div>
            </div>
            <div class="ha-wf-cost">3 sub-workflows &middot; daily automated runs</div>
          </div>
        </div>

        <!-- Workflow 4 -->
        <div class="ha-wf-card" data-phase="3" data-impact="high" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">04</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-high">HIGH IMPACT</span>
              <span class="ha-badge-phase">PHASE 3</span>
            </div>
          </div>
          <div class="ha-wf-title">Physician Referral Intelligence</div>
          <div class="ha-wf-summary">Track referral volume from 1,500+ physicians. Monthly AI reports on top, declining, and new referrers.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Track</span> Log each referral to Referral Tracker sheet</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Alert</span> New physician &rarr; CMO notified via Slack</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Report</span> Monthly AI trend analysis</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Nurture</span> Monthly email by specialty (ENT / PCP / geriatric)</div>
            </div>
            <div class="ha-wf-cost">Monthly scheduled &middot; personalized per specialty</div>
          </div>
        </div>

        <!-- Workflow 5 -->
        <div class="ha-wf-card" data-phase="2" data-impact="high" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">05</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-high">HIGH IMPACT</span>
              <span class="ha-badge-phase">PHASE 2</span>
            </div>
          </div>
          <div class="ha-wf-title">Hearing Screening Quiz Backend</div>
          <div class="ha-wf-summary">Online self-assessment captures email, AI scores severity, sends personalized results, and routes high-severity to nearest office.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Trigger</span> Quiz submission webhook</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Score severity &rarr; mild / moderate / severe</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Email</span> Personalized results + education + CTA</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Drip</span> Day 1 results, Day 3 education, Day 7 proof, Day 14 offer</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Alert</span> Severe leads &rarr; Slack to nearest office</div>
            </div>
            <div class="ha-wf-cost">Captures 20-40% of website visitors vs ~0% today</div>
          </div>
        </div>

        <!-- Workflow 6 -->
        <div class="ha-wf-card" data-phase="2" data-impact="medium" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">06</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-med">MEDIUM</span>
              <span class="ha-badge-phase">PHASE 2</span>
            </div>
          </div>
          <div class="ha-wf-title">Review Monitoring Agent</div>
          <div class="ha-wf-summary">Daily scrape of Google Maps reviews across all 27 locations. AI drafts responses. Slack approval queue.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Scrape</span> Apify scans Google Maps daily</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Sentiment classification + theme extraction</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Positive</span> Draft thank-you &rarr; Slack for approval</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Negative</span> Immediate alert + draft empathetic response</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Weekly</span> Digest with trends by location</div>
            </div>
            <div class="ha-wf-cost">Daily scheduled &middot; covers 27 locations</div>
          </div>
        </div>

        <!-- Workflow 7 -->
        <div class="ha-wf-card" data-phase="3" data-impact="medium" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">07</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-med">MEDIUM</span>
              <span class="ha-badge-phase">PHASE 3</span>
            </div>
          </div>
          <div class="ha-wf-title">Content Repurposing Pipeline</div>
          <div class="ha-wf-summary">New blog post triggers AI to generate 3 social posts, 5 education tips, and a newsletter snippet automatically.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Trigger</span> Webflow blog publish webhook</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Read article &rarr; generate platform content</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Output</span> 3 social posts + 5 tips + newsletter snippet</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Sheet</span> Content Calendar with suggested dates</div>
            </div>
            <div class="ha-wf-cost">Triggered per blog post &middot; multiplies content 9x</div>
          </div>
        </div>

        <!-- Workflow 8 -->
        <div class="ha-wf-card" data-phase="4" data-impact="medium" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">08</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-med">MEDIUM</span>
              <span class="ha-badge-phase">PHASE 4</span>
            </div>
          </div>
          <div class="ha-wf-title">Insurance Verification Pre-Check</div>
          <div class="ha-wf-summary">AI pre-fills verification forms by insurance provider. Flags cases needing manual review to the insurance manager.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Trigger</span> New appointment with insurance info</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Pre-fill form template by provider</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Check</span> Common providers: auto-verify online</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Flag</span> Manual cases &rarr; Slack to Insurance Manager</div>
            </div>
            <div class="ha-wf-cost">Saves hours of phone calls daily</div>
          </div>
        </div>

        <!-- Workflow 9 -->
        <div class="ha-wf-card" data-phase="2" data-impact="medium" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">09</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-med">MEDIUM</span>
              <span class="ha-badge-phase">PHASE 2</span>
            </div>
          </div>
          <div class="ha-wf-title">Patient Reactivation Campaign</div>
          <div class="ha-wf-summary">Monthly scan for patients inactive 12+ months. AI generates personalized win-back emails by service type and hearing aid age.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Scan</span> Monthly &rarr; find patients with last visit 12+ months</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Segment</span> By service type, hearing aid age, location</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Personalized reactivation email</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Drip</span> Day 0 check-in, Day 7 new tech, Day 14 offer</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Hot</span> Responders &rarr; Slack for phone follow-up</div>
            </div>
            <div class="ha-wf-cost">Reactivates dormant patient relationships</div>
          </div>
        </div>

        <!-- Workflow 10 -->
        <div class="ha-wf-card" data-phase="4" data-impact="low" onclick="haToggleWf(this)">
          <div class="ha-wf-header">
            <div class="ha-wf-num">10</div>
            <div class="ha-wf-badges">
              <span class="ha-badge-impact ha-impact-low">STRATEGIC</span>
              <span class="ha-badge-phase">PHASE 4</span>
            </div>
          </div>
          <div class="ha-wf-title">Competitor & Market Intel Monitor</div>
          <div class="ha-wf-summary">Weekly scan of OTC hearing aid news, competitor moves, and FDA announcements. AI-summarized brief to leadership.</div>
          <div class="ha-wf-detail">
            <div class="ha-wf-flow">
              <div class="ha-flow-step"><span class="ha-flow-label">Scrape</span> Weekly Apify scan of competitors + news</div>
              <div class="ha-flow-step"><span class="ha-flow-label">AI</span> Summarize + categorize by threat level</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Email</span> Market Intel Brief to leadership team</div>
              <div class="ha-flow-step"><span class="ha-flow-label">Slack</span> High-priority flags to CMO</div>
            </div>
            <div class="ha-wf-cost">Weekly scheduled &middot; OTC disruption monitoring</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 03 - IMPLEMENTATION ROADMAP -->
    <section class="ha-section" id="ha-section-3">
      <div class="ha-section-label">03 &mdash; Implementation Roadmap</div>
      <h2 class="ha-section-title">4 phases.<br><span class="ha-accent">8 weeks to full automation.</span></h2>
      <p class="ha-section-sub">Start with the highest-impact, lowest-complexity workflows and expand from there.</p>

      <div class="ha-roadmap">
        <div class="ha-rm-phase active" onclick="haToggleRoadmap(this)">
          <div class="ha-rm-header">
            <div class="ha-rm-badge">PHASE 1</div>
            <div class="ha-rm-timeline">Week 1-2</div>
          </div>
          <div class="ha-rm-title">Quick Wins</div>
          <div class="ha-rm-workflows">Lead Intake &middot; Appointment Reminders &middot; Review Engine</div>
          <div class="ha-rm-detail">
            <div class="ha-rm-items">
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Set up Google Sheets (Lead Pipeline, Appointment Tracker, Follow-Up Tracker)</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Connect Gmail, Slack channels, Webflow webhook</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Build 7 Gumloop workflows (3 systems x sub-workflows)</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Create location directory with zip code mapping</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Set up Google Form for satisfaction routing</span>
              </div>
            </div>
            <div class="ha-rm-cost">Google Sheets &middot; Gmail &middot; Slack &middot; Webflow</div>
          </div>
        </div>

        <div class="ha-rm-phase" onclick="haToggleRoadmap(this)">
          <div class="ha-rm-header">
            <div class="ha-rm-badge">PHASE 2</div>
            <div class="ha-rm-timeline">Week 3-4</div>
          </div>
          <div class="ha-rm-title">Lead Engine</div>
          <div class="ha-rm-workflows">Quiz Backend &middot; Review Monitor &middot; Patient Reactivation</div>
          <div class="ha-rm-detail">
            <div class="ha-rm-items">
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Build hearing screening quiz (Typeform or Webflow)</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Connect Apify for Google Maps review scraping</span>
              </div>
              <div class="ha-rm-item">
                <span class="ha-rm-check">&#10003;</span>
                <span>Import patient database for reactivation scanning</span>
              </div>
