---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Quiz Funnels", "item": `${SITE_URL}/projects/quiz-funnels` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What do I actually get?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A fully custom quiz funnel deployed on your domain: interactive quiz with 6-12 questions, smart lead scoring, 26 automated follow-up emails across 5 sequences, a real-time analytics dashboard, and complete documentation."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "7-10 business days from kickoff call to live deployment."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Quiz funnel projects fall in our Custom Build tier: $3,497 - $4,997 depending on complexity. One flat fee. No monthly retainer."
      }
    }
  ]
};

const study = {
  badge: 'Automated Lead Qualification & Follow-Up',
  headline: '2-3x more qualified leads.',
  headlineHighlight: 'Running 24/7, on autopilot.',
  subtitle: 'An interactive quiz that makes prospects self-identify their problem and readiness to buy. The system scores them, routes them to the right follow-up, and nurtures them automatically with 26 emails across 5 sequences.',
  meta: {
    client: 'Service Businesses',
    industry: 'Home Services / Professional Services',
    timeline: '7-10 days to deploy',
    techStack: ['Custom Quiz Engine', 'Lead Scoring', 'Email Automation', 'Analytics Dashboard']
  },
  metrics: [
    { number: '2-3x', label: 'More Qualified Leads' },
    { number: '26', label: 'Automated Emails' },
    { number: '5', label: 'Nurture Sequences' },
    { number: '24/7', label: 'Always Running' }
  ],
  problemHeadline: 'Your leads are slipping through the cracks',
  problemDescription: 'You\'re getting leads, but half of them aren\'t qualified and the other half never hear from you fast enough. A PDF download or contact form doesn\'t tell you who\'s ready to buy. Manual follow-up doesn\'t scale.',
  painPoints: [
    'Leads come in but nobody follows up within the first 2 minutes, by then they\'ve moved on',
    'You can\'t tell who\'s ready to buy vs. who\'s just browsing, so you waste time on tire-kickers',
    'Follow-up emails get written once and forgotten, leads go cold in your CRM',
    'Your calendar fills up with unqualified calls that go nowhere'
  ],
  solutionHeadline: 'A quiz that qualifies leads while you serve clients',
  solutionDescription: 'We build an interactive quiz that guides prospects through questions designed to surface their problem, urgency, and budget. The system scores each lead as hot, warm, or cold and triggers the right follow-up sequence automatically.',
  pipeline: [
    { step: 'Quiz', description: 'Prospect answers 6-12 tailored questions' },
    { step: 'Score', description: 'AI classifies as hot, warm, or cold' },
    { step: 'Route', description: 'Hot leads get instant calendar link' },
    { step: 'Nurture', description: '26 emails across 5 sequences' },
    { step: 'Convert', description: 'Warm leads book when ready' }
  ],
  features: [
    { title: 'Smart Lead Scoring', description: 'Hot, warm, and cold classification based on quiz responses. Your sales team only talks to people who are actually ready.' },
    { title: '26 Automated Emails', description: 'Five nurture sequences that follow up based on lead temperature. Every lead gets the right message at the right time.' },
    { title: 'Real-Time Analytics', description: 'Dashboard showing funnel metrics, lead scores, drop-off points, and conversion rates. You know what\'s working and what needs tuning.' },
    { title: 'Custom Deployment', description: 'Hosted on your domain, branded to your business. Looks like you built it, because we built it for you.' }
  ],
  beforeAfter: [
    { label: 'Lead Qualification', before: 'Manual, gut feel on calls', after: 'Automated scoring before you talk' },
    { label: 'Follow-Up Speed', before: 'Hours or days', after: 'Instant, within seconds' },
    { label: 'Email Sequences', before: '0 (or 1 forgotten drip)', after: '26 emails across 5 sequences' },
    { label: 'Calendar Bookings', before: 'Mixed, unqualified calls', after: 'Only hot leads on calendar' },
    { label: 'Lead Insight', before: 'Name and email', after: 'Problem, budget, urgency, fit score' }
  ],
  resultsHeadline: 'Results that speak for themselves',
  resultsStats: [
    { number: '2-3x', label: 'More Qualified Leads', context: 'vs. PDF lead magnets' },
    { number: '26', label: 'Automated Emails', context: 'Across 5 sequences' },
    { number: '24/7', label: 'Always Running', context: 'No manual follow-up needed' }
  ],
  ctaHeadline: 'Stop losing leads to slow follow-up',
  ctaDescription: 'Let\'s build a quiz funnel that qualifies and nurtures your leads automatically. 7-10 days from kickoff to live.',
  productUrl: 'https://quiz.brothersautomate.com',
  videoUrl: 'https://www.youtube.com/embed/FRZjVr_BrrA'
};
---

<Layout
  title="Quiz Funnels Case Study | Automated Lead Qualification | Brothers Automate"
  description="How we help service businesses get 2-3x more qualified leads with automated quiz funnels, smart scoring, and 26-email nurture sequences running 24/7."
>
  <Header />
  <main>
    <CaseStudyPage study={study} />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
