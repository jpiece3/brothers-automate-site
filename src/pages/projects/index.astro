---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
import SpecStrip from '../../components/operator/SpecStrip.astro';
import MonoCTA from '../../components/operator/MonoCTA.astro';
import { getAllProjects, type Project } from '../../data/projects';

const SITE_URL = 'https://brothersautomate.com';
const allProjects = getAllProjects();

function getProjectsBySlug(slugs: string[]): Project[] {
  return slugs
    .map((slug) => allProjects.find((p) => p.slug === slug))
    .filter((p): p is Project => p !== undefined);
}

// The featured 6, same lineup as homepage
const featured = getProjectsBySlug([
  'quiz-funnels',
  'cpq-agent',
  'client-scan',
  'onboarding-workflow',
  'screenfast',
  'inbound-ai-sdr',
]);

// Case studies (carry-over)
const caseStudies = getProjectsBySlug(['quiz-funnels', 'client-scan', 'cpq-agent']);

// Outcome groupings (the existing 3-category spine)
const categories = [
  {
    code: 'GROUP_01',
    heading: 'Get more and better leads.',
    description: 'Systems that capture, qualify, and follow up with leads, automatically, around the clock.',
    projects: getProjectsBySlug(['after-hours-agent', 'cpq-agent', 'signal-engine', 'daily-ads', 'seo-blog-autopilot']),
  },
  {
    code: 'GROUP_02',
    heading: 'Eliminate repetitive admin.',
    description: 'The onboarding, tracking, and scheduling work that eats your week, handled by systems that run themselves.',
    projects: getProjectsBySlug(['onboarding-workflow', 'automated-inventory', 'route-simply']),
  },
  {
    code: 'GROUP_03',
    heading: 'Speed up decisions and research.',
    description: 'Research and analysis that used to take weeks, done in minutes. Better data, faster decisions.',
    projects: getProjectsBySlug(['brand-research', 'screenfast', 'equipment-identifier', 'app-validator', 'client-scan']),
  },
];

// Custom one-offs strip (the relegated set)
const customBuilds = getProjectsBySlug(['equipment-identifier', 'app-validator', 'crisply']);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
  ],
};
---

<Layout
  title="AI Systems for Service Businesses | Projects | Brothers Automate"
  description="See the AI systems we build for service businesses: lead generation, admin automation, and decision tools. Custom-built, running 24/7, and saving hours every week."
>
  <Header />
  <main>
    {/* Hero */}
    <section class="op-projhero op-grid-bg">
      <div class="op-projhero-frame">
        <div class="op-projhero-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / PROJECTS · ALL BUILDS"
            right="06 FLAGSHIP · 10+ TOTAL · ALL LIVE"
            bordered
          />
        </div>

        <div data-animate="fade-up"><EyebrowTag label="THE WORK · CUSTOM PER CLIENT" /></div>

        <h1 class="op-projhero-h1" data-animate="fade-up">
          Everyone's talking about AI.<br />
          <span class="op-projhero-h1-orange">Here's what it actually does.</span>
        </h1>

        <p class="op-projhero-sub" data-animate="fade-up">
          Done-for-you automation for small service teams. We build the systems that handle your follow-up, scheduling, admin, and reporting, so you can take on more clients without hiring more people.
        </p>

        <div class="op-projhero-ctas" data-animate="fade-up">
          <MonoCTA
            label="Talk to the Brothers"
            variant="orange"
            size="lg"
            calLink="james-pinder/simple-automation-discovery"
            trackLocation="projects-hero"
            trackLabel="Talk to the Brothers"
          />
          <a href="#flagship" class="op-projhero-link op-mono">SEE THE BUILDS →</a>
        </div>

        <div class="op-projhero-specs">
          <SpecStrip cells={[
            { value: '10+', label: 'Systems deployed' },
            { value: '85%', label: 'Less busywork' },
            { value: '24/7', label: 'While you sleep' },
          ]} />
        </div>
      </div>
    </section>

    {/* Flagship 6, same as homepage */}
    <section class="op-flagship op-grid-bg" id="flagship">
      <div class="op-flagship-frame">
        <div class="op-flagship-header" data-animate="fade-up">
          <EyebrowTag label="FLAGSHIP BUILDS · 06 SYSTEMS" />
          <h2 class="op-flagship-h2">The six builds clients ask for most.</h2>
          <p class="op-flagship-sub">Custom-built around your business. Each one shipped in 1–3 weeks. No template, no agency retainer.</p>
        </div>

        <div class="op-flagship-grid" data-animate-stagger>
          {featured.map((p, i) => (
            <a href={`/projects/${p.slug}`} class="op-flagship-card">
              <div class="op-flagship-card-header">
                <span class="op-pulse-dot"></span>
                <span class="op-mono">BUILD_{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="op-flagship-card-body">
                <h3>{p.name}</h3>
                <p class="op-flagship-card-tag">{p.tagline}</p>
                <div class="op-flagship-card-stats">
                  {p.results.stats.slice(0, 2).map((s) => (
                    <div>
                      <div class="op-flagship-card-stat-num">{s.number}</div>
                      <div class="op-mono op-flagship-card-stat-label">{s.label}</div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="op-flagship-card-foot op-mono">
                SEE THE BUILD <span class="op-flagship-card-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* Case Studies */}
    <section class="op-cases op-grid-bg">
      <div class="op-cases-frame">
        <div class="op-cases-header" data-animate="fade-up">
          <EyebrowTag label="CASE STUDIES · PROVEN RESULTS" />
          <h2 class="op-cases-h2">Real systems. Real businesses. Real results.</h2>
        </div>

        <div class="op-cases-grid" data-animate-stagger>
          {caseStudies.map((p, i) => (
            <a href={`/projects/${p.slug}`} class="op-case-card">
              <div class="op-case-card-header">
                <span class="op-pulse-dot"></span>
                <span class="op-mono">CASE_{String(i + 1).padStart(2, '0')} · {p.name.toUpperCase().replace(/[^A-Z0-9]+/g, '_')}</span>
              </div>
              <div class="op-case-card-body">
                <h3>{p.name}</h3>
                <p class="op-case-card-tag">{p.tagline}</p>
                <p class="op-case-card-desc">{p.description}</p>
                <div class="op-case-card-stats">
                  {p.results.stats.slice(0, 2).map((s) => (
                    <div>
                      <div class="op-case-card-stat-num">{s.number}</div>
                      <div class="op-mono op-case-card-stat-label">{s.label}</div>
                    </div>
                  ))}
                </div>
              </div>
              <div class="op-case-card-foot op-mono">
                READ THE CASE STUDY <span class="op-flagship-card-arrow">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* Outcome-grouped library */}
    <section class="op-outcomes op-grid-bg" id="library">
      <div class="op-outcomes-frame">
        <div class="op-outcomes-intro" data-animate="fade-up">
          <EyebrowTag label="THE LIBRARY · BY OUTCOME" />
          <h2 class="op-outcomes-h2">More builds, sorted by what they do for you.</h2>
        </div>

        {categories.map((cat) => (
          <div class="op-outcome-group">
            <div class="op-outcome-header" data-animate="fade-up">
              <span class="op-mono op-outcome-code">{cat.code}</span>
              <h3 class="op-outcome-heading">{cat.heading}</h3>
              <p class="op-outcome-desc">{cat.description}</p>
            </div>
            <div class="op-outcome-grid" data-animate-stagger>
              {cat.projects.map((p) => (
                <a href={`/projects/${p.slug}`} class="op-outcome-card">
                  <div class="op-outcome-card-icon">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d={p.icon}></path>
                    </svg>
                  </div>
                  <h4 class="op-outcome-card-name">{p.name}</h4>
                  <p class="op-outcome-card-problem">{p.problem.headline}</p>
                  <div class="op-outcome-card-stats">
                    {p.results.stats.slice(0, 2).map((s) => (
                      <div>
                        <div class="op-outcome-card-stat-num">{s.number}</div>
                        <div class="op-mono op-outcome-card-stat-label">{s.label}</div>
                      </div>
                    ))}
                  </div>
                  <span class="op-mono op-outcome-card-cta">SEE HOW IT WORKS →</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Custom builds strip, minimized at bottom */}
    <section class="op-custom op-grid-bg">
      <div class="op-custom-frame">
        <div class="op-custom-header" data-animate="fade-up">
          <span class="op-mono op-custom-code">SECONDARY · ALSO BUILT</span>
          <h2 class="op-custom-h2">Custom AI for unusual problems.</h2>
          <p class="op-custom-sub">One-offs we built for specific clients. If your problem doesn't fit our flagship lineup, this is the kind of work we'd do for you.</p>
        </div>
        <div class="op-custom-grid" data-animate-stagger>
          {customBuilds.map((p) => (
            <a href={`/projects/${p.slug}`} class="op-custom-card">
              <span class="op-mono op-custom-card-id">{p.name.toUpperCase().replace(/[^A-Z0-9]+/g, '_')}</span>
              <span class="op-custom-card-name">{p.name}</span>
              <span class="op-custom-card-tag">{p.tagline}</span>
              <span class="op-custom-card-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  /* === Hero === */
  .op-projhero {
    padding: 120px var(--op-section-px) 80px;
    color: var(--op-ink);
  }
  .op-projhero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-projhero-util { margin-bottom: 32px; }
  .op-projhero :global(.op-eyebrow) { margin-bottom: 24px; }

  .op-projhero-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.5vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 24px;
    max-width: 900px;
    text-wrap: balance;
  }
  .op-projhero-h1-orange { color: var(--op-orange); }

  .op-projhero-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 32px;
    max-width: 660px;
    text-wrap: pretty;
  }

  .op-projhero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .op-projhero-link {
    font-size: 11px;
    color: var(--op-ink);
    text-decoration: none;
    border-bottom: 2px solid var(--op-ink);
    padding-bottom: 4px;
    transition: color var(--op-dur-hover) var(--op-ease), border-color var(--op-dur-hover) var(--op-ease);
  }
  .op-projhero-link:hover {
    color: var(--op-orange);
    border-color: var(--op-orange);
  }

  /* === Flagship === */
  .op-flagship {
    padding: 64px var(--op-section-px) 80px;
    border-top: 1px solid var(--op-rule);
  }
  .op-flagship-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-flagship-header { max-width: 720px; margin-bottom: 40px; }
  .op-flagship-header :global(.op-eyebrow) { margin-bottom: 18px; }
  .op-flagship-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .op-flagship-sub {
    font-family: var(--op-font-body);
    font-size: 15.5px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    text-wrap: pretty;
  }

  .op-flagship-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 700px) { .op-flagship-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-flagship-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-flagship-card,
  .op-case-card {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-flagship-card:hover,
  .op-case-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }

  .op-flagship-card-header,
  .op-case-card-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
    font-size: 9px;
  }
  .op-flagship-card-header .op-mono,
  .op-case-card-header .op-mono { color: var(--op-orange); font-size: 10px; }

  .op-flagship-card-body { padding: 20px 22px; flex: 1; }
  .op-flagship-card-body h3,
  .op-case-card-body h3 {
    font-family: var(--op-font-display);
    font-size: 20px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0 0 6px;
    font-weight: 800;
    text-wrap: balance;
  }
  .op-flagship-card-tag,
  .op-case-card-tag {
    font-family: var(--op-font-body);
    font-size: 13px;
    line-height: 1.45;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 16px;
  }
  .op-flagship-card-stats,
  .op-case-card-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding-top: 14px;
    border-top: 1px solid var(--op-rule-soft);
  }
  .op-flagship-card-stat-num,
  .op-case-card-stat-num {
    font-family: var(--op-font-display);
    font-size: 20px;
    font-weight: 800;
    color: var(--op-ink);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 4px;
  }
  .op-flagship-card-stat-label,
  .op-case-card-stat-label {
    font-size: 8px;
    color: var(--op-navy-soft);
    letter-spacing: 0.18em;
  }

  .op-flagship-card-foot,
  .op-case-card-foot {
    padding: 12px 16px;
    background: var(--op-paper);
    border-top: var(--op-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    color: var(--op-ink);
  }
  .op-flagship-card-arrow {
    transition: transform var(--op-dur-fast) var(--op-ease);
  }
  .op-flagship-card:hover .op-flagship-card-arrow,
  .op-case-card:hover .op-flagship-card-arrow {
    transform: translateX(3px);
    color: var(--op-orange);
  }

  /* === Cases === */
  .op-cases {
    padding: 64px var(--op-section-px) 80px;
    border-top: 1px solid var(--op-rule);
  }
  .op-cases-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cases-header { max-width: 720px; margin-bottom: 36px; }
  .op-cases-header :global(.op-eyebrow) { margin-bottom: 18px; }
  .op-cases-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }

  .op-cases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 900px) { .op-cases-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-case-card-body { padding: 20px 22px; flex: 1; }
  .op-case-card-desc {
    font-family: var(--op-font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--op-navy-soft);
    margin: 0 0 16px;
  }

  /* === Outcomes === */
  .op-outcomes {
    padding: 64px var(--op-section-px) 80px;
    border-top: 1px solid var(--op-rule);
  }
  .op-outcomes-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-outcomes-intro { max-width: 720px; margin-bottom: 48px; }
  .op-outcomes-intro :global(.op-eyebrow) { margin-bottom: 18px; }
  .op-outcomes-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }

  .op-outcome-group {
    margin-bottom: 56px;
  }
  .op-outcome-group:last-child { margin-bottom: 0; }

  .op-outcome-header {
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1.5px solid var(--op-ink);
    display: grid;
    gap: 8px;
  }
  .op-outcome-code {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-outcome-heading {
    font-family: var(--op-font-display);
    font-size: 26px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }
  .op-outcome-desc {
    font-family: var(--op-font-body);
    font-size: 14.5px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 720px;
  }

  .op-outcome-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 700px) { .op-outcome-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-outcome-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-outcome-card {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    padding: 18px 20px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
    box-shadow: var(--op-shadow);
  }
  .op-outcome-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }

  .op-outcome-card-icon {
    width: 36px;
    height: 36px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--op-navy);
  }
  .op-outcome-card-name {
    font-family: var(--op-font-display);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-outcome-card-problem {
    font-family: var(--op-font-body);
    font-size: 13px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
  }
  .op-outcome-card-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    padding-top: 12px;
    border-top: 1px solid var(--op-rule-soft);
  }
  .op-outcome-card-stat-num {
    font-family: var(--op-font-display);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--op-ink);
    margin-bottom: 3px;
  }
  .op-outcome-card-stat-label {
    font-size: 7.5px;
    color: var(--op-navy-soft);
    letter-spacing: 0.18em;
  }
  .op-outcome-card-cta {
    font-size: 9px;
    color: var(--op-orange);
    margin-top: 4px;
  }

  /* === Custom builds (minimized strip) === */
  .op-custom {
    padding: 56px var(--op-section-px) 72px;
    border-top: 1px solid var(--op-rule);
  }
  .op-custom-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-custom-header { max-width: 720px; margin-bottom: 24px; }
  .op-custom-code {
    font-size: 9px;
    color: var(--op-orange);
    margin-bottom: 12px;
    display: inline-block;
  }
  .op-custom-h2 {
    font-family: var(--op-font-display);
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0 0 8px;
  }
  .op-custom-sub {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    color: var(--op-navy-soft);
    margin: 0;
    line-height: 1.55;
  }

  .op-custom-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
