---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="After-Hours Quote Automation | CPQ Agent | Brothers Automate"
  description="An AI agent that qualifies leads, looks up real pricing, books sales calls, and pushes deals to your CRM — while your team sleeps. Built for B2B manufacturing."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="project-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="project-hero-content" data-animate="fade-up">
          <span class="badge">After-Hours Quote Automation</span>
          <h1>Your sales team goes home at 5.<br /><span class="gradient-text">Your website doesn't have to.</span></h1>
          <p class="project-hero-sub">35-45% of B2B inquiries arrive outside business hours. Those leads hit a contact form and sit until morning. By then, the prospect has already talked to a competitor.</p>
          <p class="project-hero-sub" style="margin-top: 0;"><strong>The solution:</strong> An AI agent that sits on your client's website 24/7 and does what a sales rep does &mdash; collects requirements, checks pricing, qualifies the lead, sends an email with a quote and link to book a call, and pushes a fully populated deal to HubSpot. All before the rep wakes up.</p>
        </div>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="cpq-section bg-surface-alt" id="cpq-how">
      <div class="container">
        <div class="cpq-section-header" data-animate="fade-up">
          <h2>How It <span class="gradient-text">Works</span></h2>
        </div>

        <div class="cpq-table-wrap" data-animate="fade-up">
          <table class="cpq-table">
            <thead>
              <tr>
                <th>Step</th>
                <th>What Happens</th>
                <th>What the Rep Gets</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Chat</strong></td>
                <td>Prospect describes what they need. Agent collects product, quantity, specs, material, timeline.</td>
                <td>Full requirements documented</td>
              </tr>
              <tr>
                <td><strong>Qualify + Price</strong></td>
                <td>Checks against the client's business rules. Looks up real pricing from their ERP.</td>
                <td>Bad fits filtered. Ballpark range attached.</td>
              </tr>
              <tr>
                <td><strong>Book Call</strong></td>
                <td>Shows the sales team's availability. Books directly.</td>
                <td>Call on the calendar</td>
              </tr>
              <tr>
                <td><strong>Push to CRM</strong></td>
                <td>Contact, deal, specs, pricing, call date, conversation summary &mdash; all in HubSpot.</td>
                <td>Pre-built deal. Zero data entry.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- WHAT I BUILT THIS WEEK -->
    <section class="cpq-section" id="cpq-built">
      <div class="container">
        <div class="cpq-section-header" data-animate="fade-up">
          <h2>What I Built <span class="gradient-text">This Week</span></h2>
          <p class="cpq-sub">Working prototype for a sample manufacturing company:</p>
        </div>

        <div class="cpq-built-grid" data-animate-stagger>
          <div class="cpq-built-item">
            <strong>Chat widget</strong>
            <p>Live on a test page, handles natural conversation (not a form)</p>
          </div>
          <div class="cpq-built-item">
            <strong>Qualification engine</strong>
            <p>37 configurable rules (geography, materials, scope, certifications, timelines)</p>
          </div>
          <div class="cpq-built-item">
            <strong>ERP pricing lookup</strong>
            <p>Hitting a Supabase database simulating real ERP data (78 products, 250 pricing tiers)</p>
          </div>
          <div class="cpq-built-item">
            <strong>HubSpot integration</strong>
            <p>Creates real contacts, deals, and notes with 13 custom properties</p>
          </div>
          <div class="cpq-built-item">
            <strong>Slack alerts</strong>
            <p>Team notified on every run with outcome and next action</p>
          </div>
          <div class="cpq-built-item">
            <strong>Error handling</strong>
            <p>Dead letter queue, structured error logging, no data loss</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ERP FLEXIBILITY -->
    <section class="cpq-section bg-surface-alt" id="cpq-erp">
      <div class="container">
        <div class="cpq-section-header" data-animate="fade-up">
          <h2>ERP <span class="gradient-text">Flexibility</span></h2>
          <p class="cpq-sub">The pipeline is modular. The ERP connector swaps via config &mdash; no code rewrite needed.</p>
        </div>

        <div class="cpq-erp-grid" data-animate-stagger>
          <div class="cpq-erp-badge">
            <strong>NetSuite</strong>
            <div class="erp-status cpq-green">Connector ready</div>
          </div>
          <div class="cpq-erp-badge">
            <strong>Sage</strong>
            <div class="erp-status">Same pattern</div>
          </div>
          <div class="cpq-erp-badge">
            <strong>QuickBooks</strong>
            <div class="erp-status">Same pattern</div>
          </div>
          <div class="cpq-erp-badge">
            <strong>Microsoft F&amp;O</strong>
            <div class="erp-status">Same pattern</div>
          </div>
        </div>

        <div class="cpq-api-flow" data-animate="fade-up">
          <div class="cpq-api-step">
            <div class="cpq-api-method post">POST</div>
            <div>
              <div class="cpq-api-path">/quote</div>
              <div class="cpq-api-desc">Send product, quantity, material, and specs. ERP creates a quote.</div>
            </div>
          </div>
          <div class="cpq-api-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>
          <div class="cpq-api-step">
            <div class="cpq-api-method get">GET</div>
            <div>
              <div class="cpq-api-path">/quote/{'{'}id{'}'}</div>
              <div class="cpq-api-desc">Retrieve the ballpark price range and lead time. That's it.</div>
            </div>
          </div>
        </div>

        <p class="cpq-config-note" data-animate="fade-in">Two REST calls. The prototype uses Supabase (Postgres) to simulate ERP data. Production swap is config + credentials.</p>
      </div>
    </section>

    <!-- BUILT FOR -->
    <section class="cpq-section" id="cpq-for">
      <div class="container">
        <div class="cpq-section-header" data-animate="fade-up">
          <h2>Built <span class="gradient-text">For</span></h2>
        </div>

        <div class="cpq-built-for" data-animate="fade-up">
          <p>B2B services, manufacturing, and technology companies where pricing depends on specs, quantity, or configuration &mdash; and the buyer needs a conversation before they buy.</p>
          <p>Each client gets their own config: products, pricing rules, disqualification rules, HubSpot pipeline, branding. The core pipeline stays the same. Onboarding a new client is data setup, not engineering.</p>
        </div>
      </div>
    </section>

    <!-- WHAT'S NEXT -->
    <section class="cpq-section bg-surface-alt" id="cpq-next">
      <div class="container">
        <div class="cpq-section-header" data-animate="fade-up">
          <h2>What's <span class="gradient-text">Next</span></h2>
        </div>

        <div class="cpq-steps" data-animate-stagger>
          <div class="cpq-step-item">
            <div class="cpq-step-number">1</div>
            <div>
              <h3>Connect Real ERP</h3>
              <p>NetSuite, Sage, or other ERP via API</p>
            </div>
          </div>
          <div class="cpq-step-item">
            <div class="cpq-step-number">2</div>
            <div>
              <h3>Load Product Catalog</h3>
              <p>Client's products, pricing, and rules</p>
            </div>
          </div>
          <div class="cpq-step-item">
            <div class="cpq-step-number">3</div>
            <div>
              <h3>Configure HubSpot</h3>
              <p>Pipeline and custom properties</p>
            </div>
          </div>
          <div class="cpq-step-item">
            <div class="cpq-step-number">4</div>
            <div>
              <h3>Go Live</h3>
              <p>Agent starts capturing leads 24/7</p>
            </div>
          </div>
        </div>

        <div class="cpq-timeline-card" data-animate="fade-up">
          <div class="cpq-timeline-heading">3&ndash;5 weeks to production</div>
          <p>Depends on ERP integration complexity and product catalog size.</p>
        </div>

        <div class="cpq-contact" data-animate="fade-up">
          <p class="cpq-contact-name">James Pinder</p>
          <p class="text-orange" style="font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem;">Brothers Automate</p>
          <p style="font-size: 0.9rem; color: var(--text-muted);">james@brothersautomate.com</p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* ===== HERO ===== */
  .project-hero {
    position: relative;
    padding-top: 160px;
    padding-bottom: var(--space-3xl);
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-surface-alt) 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .project-hero-content {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: rgba(237, 137, 54, 0.1);
    border: 1px solid rgba(237, 137, 54, 0.3);
    color: var(--orange);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .project-hero h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .project-hero-sub {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 650px;
    margin: 0 auto var(--space-md);
  }

  /* ===== SECTIONS ===== */
  .cpq-section {
    padding: var(--space-4xl) 0;
  }

  .cpq-section-header {
    max-width: 750px;
    margin: 0 auto var(--space-xl);
    text-align: center;
  }

  .cpq-section-header h2 {
    margin-bottom: var(--space-md);
  }

  .cpq-sub {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ===== TABLE ===== */
  .cpq-table-wrap {
    max-width: 900px;
    margin: 0 auto;
    overflow-x: auto;
  }

  .cpq-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--bg-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .cpq-table thead {
    background: var(--navy);
    color: white;
  }

  .cpq-table th {
    padding: var(--space-sm) var(--space-md);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-align: left;
  }

  .cpq-table td {
    padding: var(--space-sm) var(--space-md);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }

  .cpq-table td strong {
    color: var(--navy);
  }

  .cpq-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* ===== BUILT GRID ===== */
  .cpq-built-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .cpq-built-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 1024px) {
    .cpq-built-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .cpq-built-item {
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .cpq-built-item strong {
    display: block;
    color: var(--navy);
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .cpq-built-item p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* ===== ERP GRID ===== */
  .cpq-erp-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
    justify-content: center;
  }

  .cpq-erp-badge {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    text-align: center;
    min-width: 150px;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition);
  }

  .cpq-erp-badge:hover {
    border-color: var(--orange);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .cpq-erp-badge strong {
    display: block;
    font-size: 1rem;
    color: var(--navy);
    margin-bottom: 0.35rem;
  }

  .erp-status {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  .cpq-green { color: var(--green); font-weight: 700; }

  /* ===== API FLOW ===== */
  .cpq-api-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin: 0 auto var(--space-lg);
    max-width: 700px;
  }

  .cpq-api-step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    flex: 1;
  }

  .cpq-api-method {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cpq-api-method.post {
    background: rgba(237, 137, 54, 0.15);
    color: var(--orange);
  }

  .cpq-api-method.get {
    background: rgba(22, 163, 74, 0.15);
    color: var(--green);
  }

  .cpq-api-path {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 0.2rem;
  }

  .cpq-api-desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .cpq-api-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .cpq-config-note {
    font-size: 0.9rem;
    color: var(--text-muted);
    text-align: center;
  }

  /* ===== BUILT FOR ===== */
  .cpq-built-for {
    max-width: 750px;
    margin: 0 auto;
    text-align: center;
  }

  .cpq-built-for p {
    font-size: 1.0625rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-md);
  }

  .cpq-built-for p:last-child {
    margin-bottom: 0;
  }

  /* ===== STEPS ===== */
  .cpq-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    max-width: 900px;
    margin: 0 auto var(--space-xl);
  }

  @media (min-width: 768px) {
    .cpq-steps {
      grid-template-columns: 1fr 1fr;
    }
  }

  .cpq-step-item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
    padding: var(--space-md);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .cpq-step-number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--orange);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .cpq-step-item h3 {
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }

  .cpq-step-item p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ===== TIMELINE CARD ===== */
  .cpq-timeline-card {
    background: var(--bg-surface);
    border: 2px solid rgba(237, 137, 54, 0.3);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-align: center;
    box-shadow: var(--shadow);
    max-width: 600px;
    margin: 0 auto var(--space-xl);
  }

  .cpq-timeline-heading {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: var(--space-xs);
  }

  .cpq-timeline-card p {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0;
  }

  /* ===== CONTACT ===== */
  .cpq-contact {
    text-align: center;
  }

  .cpq-contact-name {
    font-size: 1.1rem;
    color: var(--navy);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 767px) {
    .project-hero {
      padding-top: 120px;
      padding-bottom: var(--space-2xl);
    }

    .cpq-api-flow {
      flex-direction: column;
    }

    .cpq-erp-grid {
      gap: var(--space-xs);
    }

    .cpq-erp-badge {
      min-width: 130px;
      padding: var(--space-sm) var(--space-md);
    }
  }
</style>
