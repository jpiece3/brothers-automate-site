---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'automated-inventory';

const study = projectToCaseStudy(slug, {
  badge: 'Automated Inventory Tracking',
  headline: 'AI Inventory Tracker.',
  headlineHighlight: 'Stop counting things by hand.',
  meta: {
    client: 'Field Service / E-commerce',
    industry: 'Operations / Logistics',
    timeline: '2-3 weeks to production',
    techStack: ['OpenAI Vision', 'Airtable', 'Webhooks', 'Slack'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "AI Inventory Tracker", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Automated Inventory | AI Inventory Tracking | Brothers Automate" description="AI-powered inventory tracking that runs from photos and receipts. No more manual counts, no more missed reorders.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
