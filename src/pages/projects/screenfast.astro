---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "ScreenFast", "item": `${SITE_URL}/projects/screenfast` }
  ]
};

const study = {
  badge: 'AI-Powered Resume Screening',
  headline: '85% less time screening resumes.',
  headlineHighlight: 'Better hires, faster.',
  subtitle: 'Built for the YMCA to handle seasonal hiring surges. ScreenFast reads every resume against your criteria, scores candidates, and delivers a ranked shortlist so you skip straight to interviewing the best fits.',
  meta: {
    client: 'YMCA',
    industry: 'Nonprofit / Recreation',
    timeline: '2 weeks to deploy',
    techStack: ['Claude AI', 'PDF Parsing', 'Scoring Engine', 'Dashboard']
  },
  metrics: [
    { number: '85%', label: 'Less Screening Time' },
    { number: '<10s', label: 'Per Resume' },
    { number: '100s', label: 'Resumes Per Cycle' },
    { number: '0', label: 'Qualified Candidates Missed' }
  ],
  problemHeadline: 'Seasonal hiring was eating the team alive',
  problemDescription: 'Every open position brought hundreds of applications. The YMCA team was spending full days reading through resumes for seasonal roles, and the best candidates were getting hired elsewhere while they were still sorting through the pile.',
  painPoints: [
    'Spending 3+ hours per position just reading resumes — multiply that by dozens of seasonal roles',
    'Great candidates slipping through because the team couldn\'t review fast enough',
    'Same painful screening process every few months with each seasonal hiring wave',
    'No consistent criteria — screening quality depended on who was reading that day'
  ],
  solutionHeadline: 'AI that screens resumes in seconds, not hours',
  solutionDescription: 'We built ScreenFast to read every resume against the YMCA\'s specific criteria, score candidates on fit, and deliver a ranked shortlist. The hiring team skips straight to interviewing the best people.',
  pipeline: [
    { step: 'Upload', description: 'Drag and drop resumes or bulk upload' },
    { step: 'Parse', description: 'AI reads and extracts key details' },
    { step: 'Score', description: 'Each resume scored against your criteria' },
    { step: 'Rank', description: 'Top candidates surfaced first' },
    { step: 'Review', description: 'Team sees shortlist with reasoning' }
  ],
  features: [
    { title: 'Custom Criteria', description: 'Define exactly what you\'re looking for — skills, experience, certifications, availability. The AI scores against your requirements, not generic ones.' },
    { title: 'Instant Scoring', description: 'Every resume scored and ranked within seconds of upload. No waiting. No batching. Results appear as fast as you can upload.' },
    { title: 'Ranked Shortlists', description: 'Top candidates surfaced first with clear reasoning for each score. Your team sees why someone ranked high, not just that they did.' },
    { title: 'Bias Reduction', description: 'Consistent, criteria-based evaluation for every applicant. Every resume gets the same treatment whether it\'s the first or the five-hundredth.' }
  ],
  beforeAfter: [
    { label: 'Time Per Resume', before: '5-10 minutes', after: 'Under 10 seconds' },
    { label: 'Time Per Position', before: '3+ hours', after: '~25 minutes' },
    { label: 'Screening Consistency', before: 'Depends on who reads it', after: 'Same criteria, every time' },
    { label: 'Candidate Response Time', before: 'Days', after: 'Same day' },
    { label: 'Top Candidates Missed', before: 'Regularly', after: 'Zero' }
  ],
  resultsHeadline: 'Built for the YMCA. Proven at scale.',
  resultsStats: [
    { number: '85%', label: 'Less Screening Time', context: 'From hours to minutes' },
    { number: '<10s', label: 'Per Resume', context: 'vs. 5-10 minutes manual' },
    { number: '100s', label: 'Resumes Processed', context: 'Per hiring cycle' }
  ],
  ctaHeadline: 'Stop spending hours reading resumes',
  ctaDescription: 'Let\'s build a screening system that surfaces your best candidates automatically. Same results the YMCA got — customized for your hiring process.',
  productUrl: 'https://screenfast.replit.app/'
};
---

<Layout
  title="ScreenFast Case Study | AI Resume Screening for YMCA | Brothers Automate"
  description="How we cut the YMCA's resume screening time by 85% with AI-powered candidate scoring. Hundreds of resumes processed per cycle, better hires, zero candidates missed."
>
  <Header />
  <main>
    <CaseStudyPage study={study} />
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
