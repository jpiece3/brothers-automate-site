---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'app-validator';

const study = projectToCaseStudy(slug, {
  badge: 'AI Idea Validation',
  headline: 'AI App Idea Validator.',
  headlineHighlight: 'Stop building things nobody wants.',
  meta: {
    client: 'Internal Tool / Indie Founders',
    industry: 'Product / Startup',
    timeline: '2 weeks to production',
    techStack: ['OpenAI', 'DataForSEO', 'Apify', 'Supabase'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "App Validator", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="App Validator | AI Idea Validation Engine | Brothers Automate" description="Validate any app idea against real market data in minutes. AI-powered competitor analysis, demand signals, and pricing benchmarks, built for indie founders and product teams.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
