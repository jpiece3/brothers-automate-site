---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';
const productUrl = 'https://validate.brothersautomate.com/';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "AI App Idea Validator", "item": `${SITE_URL}/projects/app-validator` }
  ]
};
---

<Layout
  title="AI App Idea Validator | Validate Before You Build | Brothers Automate"
  description="Stop guessing if your app idea will work. Live keyword data, competitor analysis, and an AI-generated GO or NO-GO verdict — in under 2 minutes."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="project-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="project-hero-content" data-animate="fade-up">
          <span class="badge">AI-Powered App Idea Validation</span>
          <h1>AI App Idea Validator.<br /><span class="gradient-text">GO or NO-GO in 2 Minutes.</span></h1>
          <p class="project-hero-sub">Describe your app idea in one sentence. Get back a full validation report with keyword demand, competitor analysis, and a data-backed verdict — before you write a single line of code.</p>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-number">&lt;2 min</span>
              <span class="hero-stat-label">Full Report</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">5</span>
              <span class="hero-stat-label">Scoring Dimensions</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">$0.60</span>
              <span class="hero-stat-label">Per Validation</span>
            </div>
          </div>

          <div class="hero-buttons">
            <a href={productUrl} class="btn btn-primary btn-lg" target="_blank" rel="noopener">Try It Free</a>
            <a
              href="#"
              class="btn btn-secondary btn-lg"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Talk to the Brothers</a>
          </div>

          <!-- Validation Terminal -->
          <div class="av-scan-box">
            <div class="av-scan-bar">
              <div class="av-scan-dot" style="background:#e8b4a0"></div>
              <div class="av-scan-dot" style="background:#ddd6c8"></div>
              <div class="av-scan-dot" style="background:#b8d4b0"></div>
              <span style="margin-left:6px">app-validator / validate</span>
            </div>
            <div class="av-scan-input-row">
              <input class="av-scan-input" id="scanInput" placeholder="An app that helps introverts practice phone calls with AI" />
              <button class="av-scan-btn" onclick="runScan()">&#9654; VALIDATE</button>
            </div>
            <div class="av-scan-log" id="scanLog"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- TICKER -->
    <div class="av-ticker">
      <div class="av-ticker-inner">
        IDEA &rarr; KEYWORDS &nbsp;&middot;&nbsp; DEMAND SIGNALS &nbsp;&middot;&nbsp; COMPETITOR SCAN &nbsp;&middot;&nbsp; APP STORE ANALYSIS &nbsp;&middot;&nbsp; 5-DIMENSION SCORE &nbsp;&middot;&nbsp; VERDICT &nbsp;&middot;&nbsp; LAUNCH PLAN &nbsp;&middot;&nbsp;
        IDEA &rarr; KEYWORDS &nbsp;&middot;&nbsp; DEMAND SIGNALS &nbsp;&middot;&nbsp; COMPETITOR SCAN &nbsp;&middot;&nbsp; APP STORE ANALYSIS &nbsp;&middot;&nbsp; 5-DIMENSION SCORE &nbsp;&middot;&nbsp; VERDICT &nbsp;&middot;&nbsp; LAUNCH PLAN &nbsp;&middot;&nbsp;
      </div>
    </div>

    <!-- 01 — HOW IT WORKS -->
    <section class="av-section" id="av-section-1">
      <div class="av-section-label">01 — How It Works</div>
      <h2 class="av-section-title">One sentence.<br><span class="av-accent">Full validation.</span></h2>
      <p class="av-section-sub">Type your app idea in plain English. Three AI pipelines run in parallel to pull live market data, analyze competition, and score your concept across 5 dimensions.</p>

      <div class="av-loop">
        <div class="av-loop-card active" onclick="toggleLoop(this)">
          <div class="av-loop-num">01</div>
          <div class="av-loop-title">Demand Analysis</div>
          <div class="av-loop-desc">Is anyone searching for this?</div>
          <div class="av-loop-detail">
            &rarr; AI extracts 10-15 target keywords from your idea<br>
            &rarr; Live DataForSEO search volume + difficulty scores<br>
            &rarr; Reddit &amp; forum community signal mining<br>
            &rarr; Google Trends momentum check<br>
            &rarr; Total addressable search demand calculated
          </div>
        </div>
        <div class="av-loop-card" onclick="toggleLoop(this)">
          <div class="av-loop-num">02</div>
          <div class="av-loop-title">Competitive Landscape</div>
          <div class="av-loop-desc">Who's already building this?</div>
          <div class="av-loop-detail">
            &rarr; App Store competitor discovery<br>
            &rarr; Pricing, ratings, and download estimates<br>
            &rarr; Funding and team size research<br>
            &rarr; Feature gap identification<br>
            &rarr; Market positioning opportunities
          </div>
        </div>
        <div class="av-loop-card" onclick="toggleLoop(this)">
          <div class="av-loop-num">03</div>
          <div class="av-loop-title">AI Scoring</div>
          <div class="av-loop-desc">GO, CONDITIONAL, or NO-GO</div>
          <div class="av-loop-detail">
            &rarr; 5-dimension scoring (1-10 each):<br>
            &rarr; Demand &middot; Competition &middot; Differentiation<br>
            &rarr; Monetization potential &middot; Timing<br>
            &rarr; Weighted composite score<br>
            &rarr; Clear verdict with rationale
          </div>
        </div>
        <div class="av-loop-card" onclick="toggleLoop(this)">
          <div class="av-loop-num">04</div>
          <div class="av-loop-title">Launch Playbook</div>
          <div class="av-loop-desc">How to go from idea to users</div>
          <div class="av-loop-detail">
            &rarr; Positioning angles that resonate<br>
            &rarr; ASO keyword strategy<br>
            &rarr; Channel recommendations<br>
            &rarr; Monetization model analysis<br>
            &rarr; 30-day launch plan
          </div>
        </div>
      </div>
    </section>

    <!-- 02 — SCORING DIMENSIONS -->
    <section class="av-section" id="av-section-2">
      <div class="av-section-label">02 — The Scoring System</div>
      <h2 class="av-section-title">Five dimensions.<br><span class="av-accent">Data-backed.</span></h2>
      <p class="av-section-sub">Every app idea gets scored across 5 dimensions. Each score is backed by real data — keyword volumes, competitor counts, market timing signals — not vibes.</p>

      <div class="av-signal-grid">
        <div class="av-signal-card">
          <div class="av-signal-top">
            <div class="av-signal-name">Demand</div>
            <div class="av-signal-weight">W: 0.25</div>
          </div>
          <div class="av-signal-desc">Total search volume for target keywords. Are people actively looking for a solution to this problem?</div>
          <div class="av-signal-bar-wrap"><div class="av-signal-bar av-bar-green" style="width:85%"></div></div>
          <div class="av-signal-meta"><span>Keyword volume</span><span>DataForSEO</span></div>
        </div>
        <div class="av-signal-card">
          <div class="av-signal-top">
            <div class="av-signal-name">Competition</div>
            <div class="av-signal-weight">W: 0.20</div>
          </div>
          <div class="av-signal-desc">Number of existing apps, their ratings, funding levels. Is the market crowded or wide open?</div>
          <div class="av-signal-bar-wrap"><div class="av-signal-bar" style="width:65%"></div></div>
          <div class="av-signal-meta"><span>App Store analysis</span><span>Tavily</span></div>
        </div>
        <div class="av-signal-card">
          <div class="av-signal-top">
            <div class="av-signal-name">Differentiation</div>
            <div class="av-signal-weight">W: 0.25</div>
          </div>
          <div class="av-signal-desc">Can your idea carve a unique position? AI assesses feature gaps and underserved niches in the current market.</div>
          <div class="av-signal-bar-wrap"><div class="av-signal-bar av-bar-green" style="width:78%"></div></div>
          <div class="av-signal-meta"><span>Gap analysis</span><span>Claude AI</span></div>
        </div>
        <div class="av-signal-card">
          <div class="av-signal-top">
            <div class="av-signal-name">Monetization</div>
            <div class="av-signal-weight">W: 0.15</div>
          </div>
          <div class="av-signal-desc">Revenue model viability. Subscription potential, willingness to pay, pricing benchmarks from competitors.</div>
          <div class="av-signal-bar-wrap"><div class="av-signal-bar" style="width:60%"></div></div>
          <div class="av-signal-meta"><span>Pricing analysis</span><span>Market data</span></div>
        </div>
        <div class="av-signal-card">
          <div class="av-signal-top">
            <div class="av-signal-name">Timing</div>
            <div class="av-signal-weight">W: 0.15</div>
          </div>
          <div class="av-signal-desc">Is the market growing, flat, or declining? Trend analysis and regulatory environment check.</div>
          <div class="av-signal-bar-wrap"><div class="av-signal-bar av-bar-green" style="width:72%"></div></div>
          <div class="av-signal-meta"><span>Google Trends</span><span>News analysis</span></div>
        </div>
      </div>
    </section>

    <!-- 03 — EXAMPLE VERDICT -->
    <section class="av-section" id="av-section-3">
      <div class="av-section-label">03 — Example Output</div>
      <h2 class="av-section-title">Real verdict.<br><span class="av-accent">Real data.</span></h2>
      <p class="av-section-sub">Here's what the validator returned for "an app that helps introverts practice phone calls with AI" — a real validation we ran.</p>

      <div class="av-score-demo">
        <div class="av-score-card">
          <div class="av-score-card-top">
            <div class="av-score-company">Phone Anxiety Practice App</div>
            <div class="av-score-badge av-status-go">CONDITIONAL GO</div>
          </div>
          <div class="av-score-num av-high">7.2</div>
          <div class="av-score-evidence">14,800 monthly searches &middot; 4 direct competitors &middot; none focused on phone anxiety specifically &middot; subscription model viable at $9.99/mo &middot; growing search trend</div>
          <div class="av-score-signals">
            <div class="av-sig-line"><span class="av-sig-check" style="color:var(--av-green)">&check;</span> Demand (8/10) <div class="av-sig-bar-mini"><div class="av-sig-fill" style="width:80%;background:var(--av-green)"></div></div></div>
            <div class="av-sig-line"><span class="av-sig-check" style="color:var(--av-green)">&check;</span> Differentiation (8/10) <div class="av-sig-bar-mini"><div class="av-sig-fill" style="width:80%;background:var(--av-green)"></div></div></div>
            <div class="av-sig-line"><span class="av-sig-check" style="color:var(--av-accent)">~</span> Competition (6/10) <div class="av-sig-bar-mini"><div class="av-sig-fill" style="width:60%;background:var(--av-accent)"></div></div></div>
            <div class="av-sig-line"><span class="av-sig-check" style="color:var(--av-green)">&check;</span> Monetization (7/10) <div class="av-sig-bar-mini"><div class="av-sig-fill" style="width:70%;background:var(--av-green)"></div></div></div>
            <div class="av-sig-line"><span class="av-sig-check" style="color:var(--av-green)">&check;</span> Timing (7/10) <div class="av-sig-bar-mini"><div class="av-sig-fill" style="width:70%;background:var(--av-green)"></div></div></div>
          </div>
        </div>
      </div>

      <div class="av-quote-block">
        <div class="av-quote-text">"Strong demand signal with minimal direct competition. The niche focus on phone anxiety (vs. general communication skills) creates a defensible position. Conditional on: validating willingness to pay via landing page test before building."</div>
        <div class="av-quote-attr">AI verdict rationale</div>
      </div>
    </section>

    <!-- 04 — PIPELINE -->
    <section class="av-section" id="av-section-4">
      <div class="av-section-label">04 — The Pipeline</div>
      <h2 class="av-section-title">Idea to verdict.<br><span class="av-accent">90 seconds.</span></h2>
      <p class="av-section-sub">Three parallel pipelines hit live APIs simultaneously. You don't wait for keyword research, then competitor analysis, then scoring — it all runs at once.</p>

      <div class="av-pipeline">
        <div class="av-pipe-stage active" onclick="togglePipe(this)">
          <div class="av-pipe-icon">&#128161;</div>
          <div class="av-pipe-name">Idea</div>
          <div class="av-pipe-count">One sentence</div>
        </div>
        <div class="av-pipe-stage" onclick="togglePipe(this)">
          <div class="av-pipe-icon">&#128270;</div>
          <div class="av-pipe-name">Research</div>
          <div class="av-pipe-count">3 parallel APIs</div>
        </div>
        <div class="av-pipe-stage" onclick="togglePipe(this)">
          <div class="av-pipe-icon">&#128202;</div>
          <div class="av-pipe-name">Score</div>
          <div class="av-pipe-count">5 dimensions</div>
        </div>
        <div class="av-pipe-stage av-won" onclick="togglePipe(this)">
          <div class="av-pipe-icon">&#9989;</div>
          <div class="av-pipe-name">Verdict</div>
          <div class="av-pipe-count">GO / NO-GO</div>
        </div>
        <div class="av-pipe-stage" onclick="togglePipe(this)">
          <div class="av-pipe-icon">&#128640;</div>
          <div class="av-pipe-name">Playbook</div>
          <div class="av-pipe-count">30-day plan</div>
        </div>
      </div>

      <div class="av-stat-row" style="margin-top:32px">
        <div class="av-stat">
          <div class="av-stat-num">3</div>
          <div class="av-stat-label">parallel API pipelines (demand, competition, scoring)</div>
        </div>
        <div class="av-stat">
          <div class="av-stat-num">$0.60</div>
          <div class="av-stat-label">total cost per validation report</div>
        </div>
        <div class="av-stat">
          <div class="av-stat-num">0</div>
          <div class="av-stat-label">weeks of manual market research</div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="av-cta-section" id="av-section-5">
      <div class="av-section-label" style="justify-content:center;margin-bottom:28px">05 — Get Started</div>
      <h2 class="av-cta-title">Idea in.<br>Verdict out.<br><span style="color:var(--av-accent)">2 minutes.</span></h2>
      <p class="av-cta-sub">First validation is free. Describe your app idea and get a data-backed GO or NO-GO.</p>
      <div class="av-cta-btn-row">
        <a href={productUrl} class="av-btn-p" target="_blank" rel="noopener">Validate Your Idea &rarr;</a>
        <a
          href="#"
          class="av-btn-s"
          data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
          data-cal-namespace="free-quiz-audit-automation-brothers"
          data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        >Talk to the Brothers</a>
      </div>
      <p style="font-size:11px;color:var(--av-muted);margin-top:28px;font-family:var(--av-mono)">App Validator &middot; AI-powered market validation &middot; built for founders</p>
    </section>

  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .project-hero { position: relative; padding-top: 160px; padding-bottom: var(--space-3xl); background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-surface-alt) 100%); text-align: center; overflow: hidden; }
  .hero-bg-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%); -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%); }
  .project-hero-content { position: relative; max-width: 750px; margin: 0 auto; }
  .badge { display: inline-block; padding: var(--space-xs) var(--space-md); background: rgba(237, 137, 54, 0.1); border: 1px solid rgba(237, 137, 54, 0.3); color: var(--orange); border-radius: 100px; font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: var(--space-md); }
  .project-hero h1 { margin-bottom: var(--space-md); font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.15; }
  .gradient-text { background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .project-hero-sub { font-size: clamp(1.0625rem, 2vw, 1.25rem); color: var(--text-secondary); line-height: 1.7; max-width: 600px; margin: 0 auto var(--space-lg); }
  .hero-stats { display: flex; align-items: center; justify-content: center; gap: var(--space-lg); margin-bottom: var(--space-xl); padding: var(--space-lg) var(--space-xl); background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow); }
  .hero-stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .hero-stat-number { font-size: 1.75rem; font-weight: 800; color: var(--navy); line-height: 1; }
  .hero-stat-label { font-size: 0.8125rem; color: var(--text-muted); font-weight: 500; }
  .hero-stat-divider { width: 1px; height: 40px; background: var(--border); }
  .hero-buttons { display: flex; flex-direction: column; gap: var(--space-sm); align-items: center; margin-bottom: var(--space-xl); }
  @media (min-width: 480px) { .hero-buttons { flex-direction: row; justify-content: center; } }

  :root {
    --av-accent: #e07b39; --av-accent2: #c4622a; --av-navy: #1e3557; --av-blue-gray: #7a95b0;
    --av-muted: #8a9ab0; --av-green: #3a9e6e; --av-green-bg: #e8f5ef; --av-surface: #faf7f2;
    --av-surface2: #eee8dc; --av-border: #ddd6c8; --av-mono: 'DM Mono', monospace;
  }

  .av-scan-box { max-width: 520px; width: 100%; margin: 0 auto; background: var(--bg-surface); border: 1.5px solid var(--border); border-radius: 18px; overflow: hidden; box-shadow: 0 4px 24px rgba(30,53,87,0.09); }
  .av-scan-bar { background: var(--bg-surface-alt); border-bottom: 1px solid var(--border); padding: 10px 16px; display: flex; align-items: center; gap: 6px; font-size: 10px; color: var(--text-muted); letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--av-mono); }
  .av-scan-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .av-scan-input-row { display: flex; align-items: center; padding: 12px 12px 12px 18px; }
  .av-scan-input { flex: 1; background: transparent; border: none; outline: none; font-family: var(--av-mono); font-size: 13px; color: var(--navy); }
  .av-scan-input::placeholder { color: var(--text-muted); }
  .av-scan-btn { background: var(--orange); color: #fff; border: none; padding: 11px 22px; border-radius: 12px; font-family: var(--font-sans); font-weight: 700; font-size: 12px; cursor: pointer; transition: background 0.15s; white-space: nowrap; animation: avPulse 2.5s ease-in-out infinite; }
  .av-scan-btn:hover { background: var(--orange-hover); animation: none; }
  @keyframes avPulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(224,123,57,0.5); } 50% { box-shadow: 0 0 0 8px rgba(224,123,57,0); } }
  .av-scan-log { padding: 0 18px 18px; font-family: var(--av-mono); font-size: 11px; line-height: 2.1; display: none; border-top: 1px solid var(--border); margin-top: 4px; }
  .av-scan-log.visible { display: block; animation: avFadeUp 0.3s ease; }

  .av-ticker { background: var(--av-navy); color: rgba(255,255,255,0.7); padding: 10px 0; overflow: hidden; white-space: nowrap; }
  .av-ticker-inner { display: inline-block; animation: avTicker 25s linear infinite; font-family: var(--av-mono); font-size: 11px; letter-spacing: 0.1em; }
  @keyframes avTicker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  .av-section { max-width: 980px; margin: 0 auto; padding: 80px 32px; border-top: 1px solid var(--av-border); opacity: 0; transform: translateY(28px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .av-section.visible { opacity: 1; transform: none; }
  .av-section-label { font-size: 10px; letter-spacing: 0.18em; color: var(--av-muted); text-transform: uppercase; margin-bottom: 36px; display: flex; align-items: center; gap: 14px; font-weight: 600; }
  .av-section-label::after { content: ''; flex: 1; height: 1px; background: var(--av-border); }
  .av-section-title { font-size: clamp(30px, 4.5vw, 52px); font-weight: 800; line-height: 1.08; margin-bottom: 14px; color: var(--av-navy); letter-spacing: -0.025em; }
  .av-accent { color: var(--av-accent); }
  .av-section-sub { font-size: 13px; color: var(--av-blue-gray); max-width: 560px; line-height: 1.75; }

  .av-loop { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 48px; }
  .av-loop-card { background: var(--av-surface); border: 1.5px solid var(--av-border); border-radius: 16px; padding: 24px 20px; cursor: pointer; transition: all 0.2s; box-shadow: 0 2px 8px rgba(30,53,87,0.05); position: relative; }
  .av-loop-card::after { content: '\2192'; position: absolute; right: -18px; top: 50%; transform: translateY(-50%); color: var(--av-accent); font-size: 16px; font-weight: 700; pointer-events: none; }
  .av-loop-card:last-child::after { display: none; }
  .av-loop-card:hover, .av-loop-card.active { border-color: var(--av-accent); box-shadow: 0 4px 20px rgba(224,123,57,0.14); background: #fff; }
  .av-loop-num { font-family: var(--av-mono); font-size: 10px; color: var(--av-muted); margin-bottom: 10px; }
  .av-loop-title { font-weight: 800; font-size: 16px; color: var(--av-navy); margin-bottom: 6px; }
  .av-loop-desc { font-size: 11px; color: var(--av-blue-gray); line-height: 1.7; }
  .av-loop-detail { max-height: 0; overflow: hidden; transition: max-height 0.4s ease, margin-top 0.3s ease; font-size: 11px; color: var(--av-blue-gray); line-height: 1.9; font-family: var(--av-mono); }
  .av-loop-card.active .av-loop-detail { max-height: 250px; margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--av-border); }

  .av-signal-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 48px; }
  .av-signal-card { background: var(--av-surface); border: 1.5px solid var(--av-border); border-radius: 14px; padding: 20px; transition: all 0.2s; }
  .av-signal-card:hover { border-color: var(--av-accent); box-shadow: 0 4px 16px rgba(224,123,57,0.1); }
  .av-signal-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
  .av-signal-name { font-weight: 700; font-size: 13px; color: var(--av-navy); }
  .av-signal-weight { font-family: var(--av-mono); font-size: 10px; color: var(--av-accent); background: rgba(224,123,57,0.1); padding: 3px 8px; border-radius: 6px; }
  .av-signal-desc { font-size: 11px; color: var(--av-blue-gray); line-height: 1.6; margin-bottom: 12px; }
  .av-signal-bar-wrap { height: 4px; background: var(--av-surface2); border-radius: 999px; overflow: hidden; }
  .av-signal-bar { height: 100%; border-radius: 999px; background: var(--av-accent); transition: width 0.6s ease; }
  .av-bar-green { background: var(--av-green); }
  .av-signal-meta { display: flex; justify-content: space-between; margin-top: 6px; font-size: 10px; color: var(--av-muted); font-family: var(--av-mono); }

  .av-score-demo { margin-top: 48px; max-width: 600px; }
  .av-score-card { background: var(--av-surface); border: 1.5px solid var(--av-border); border-radius: 16px; padding: 24px; }
  .av-score-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .av-score-company { font-weight: 800; font-size: 15px; color: var(--av-navy); }
  .av-score-badge { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 12px; border-radius: 999px; font-weight: 700; font-family: var(--av-mono); }
  .av-status-go { background: var(--av-green-bg); color: var(--av-green); }
  .av-score-num { font-size: 52px; font-weight: 900; line-height: 1; letter-spacing: -0.04em; margin-bottom: 12px; }
  .av-score-num.av-high { color: var(--av-green); }
  .av-score-evidence { font-size: 11px; color: var(--av-blue-gray); line-height: 1.7; font-family: var(--av-mono); }
  .av-score-signals { margin-top: 14px; display: flex; flex-direction: column; gap: 6px; }
  .av-sig-line { display: flex; align-items: center; gap: 10px; font-size: 11px; color: var(--av-muted); }
  .av-sig-check { font-size: 12px; }
  .av-sig-bar-mini { flex: 1; height: 3px; background: var(--av-surface2); border-radius: 999px; overflow: hidden; }
  .av-sig-fill { height: 100%; border-radius: 999px; }

  .av-quote-block { margin-top: 28px; border-left: 4px solid var(--av-accent); padding: 24px 28px; background: var(--av-surface); border-radius: 0 16px 16px 0; }
  .av-quote-text { font-size: clamp(14px, 2vw, 19px); font-weight: 700; line-height: 1.55; color: var(--av-navy); margin-bottom: 10px; }
  .av-quote-attr { font-size: 10px; color: var(--av-muted); letter-spacing: 0.12em; text-transform: uppercase; font-family: var(--av-mono); }

  .av-pipeline { display: flex; gap: 0; margin-top: 48px; overflow-x: auto; }
  .av-pipe-stage { flex: 1; min-width: 110px; background: var(--av-surface); border-top: 3px solid var(--av-border); border-right: 1px solid var(--av-border); border-bottom: 1.5px solid var(--av-border); padding: 20px 16px; text-align: center; cursor: pointer; transition: all 0.2s; }
  .av-pipe-stage:first-child { border-left: 1.5px solid var(--av-border); border-radius: 16px 0 0 16px; }
  .av-pipe-stage:last-child { border-right: 1.5px solid var(--av-border); border-radius: 0 16px 16px 0; }
  .av-pipe-stage:hover, .av-pipe-stage.active { border-top-color: var(--av-accent); background: #fff; }
  .av-pipe-stage.av-won { border-top-color: var(--av-green); }
  .av-pipe-icon { font-size: 20px; margin-bottom: 8px; }
  .av-pipe-name { font-weight: 700; font-size: 11px; color: var(--av-navy); }
  .av-pipe-count { font-size: 10px; color: var(--av-muted); margin-top: 4px; font-family: var(--av-mono); }

  .av-stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 40px; }
  .av-stat { background: var(--av-surface); border: 1.5px solid var(--av-border); border-radius: 16px; padding: 28px; text-align: center; }
  .av-stat-num { font-size: 44px; font-weight: 900; color: var(--av-accent); line-height: 1; margin-bottom: 8px; letter-spacing: -0.03em; }
  .av-stat-label { font-size: 12px; color: var(--av-blue-gray); line-height: 1.5; }

  .av-cta-section { max-width: 980px; margin: 0 auto; padding: 80px 32px 120px; border-top: 1px solid var(--av-border); text-align: center; opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .av-cta-section.visible { opacity: 1; transform: none; }
  .av-cta-title { font-size: clamp(36px, 6vw, 72px); font-weight: 900; line-height: 1.02; margin-bottom: 18px; color: var(--av-navy); letter-spacing: -0.03em; }
  .av-cta-sub { font-size: 16px; color: var(--av-blue-gray); max-width: 400px; margin: 0 auto 40px; line-height: 1.7; }
  .av-cta-btn-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .av-btn-p { display: inline-block; background: var(--av-accent); color: #fff; border: none; padding: 16px 34px; font-weight: 700; font-size: 14px; cursor: pointer; border-radius: 999px; transition: background 0.15s; box-shadow: 0 4px 16px rgba(224,123,57,0.3); text-decoration: none; }
  .av-btn-p:hover { background: var(--av-accent2); }
  .av-btn-s { display: inline-block; background: transparent; color: var(--av-navy); border: 2px solid var(--av-navy); padding: 16px 34px; font-weight: 700; font-size: 14px; cursor: pointer; border-radius: 999px; transition: all 0.15s; text-decoration: none; }
  .av-btn-s:hover { background: var(--av-navy); color: #fff; }

  @keyframes avFadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

  @media (max-width: 767px) { .project-hero { padding-top: 120px; padding-bottom: var(--space-2xl); } .hero-stats { flex-direction: column; gap: var(--space-md); padding: var(--space-md); } .hero-stat-divider { width: 60px; height: 1px; } .hero-buttons .btn { width: 100%; justify-content: center; } }
  @media (max-width: 640px) { .av-loop { grid-template-columns: 1fr 1fr; } .av-loop-card::after { display: none; } .av-signal-grid { grid-template-columns: 1fr 1fr; } .av-stat-row { grid-template-columns: 1fr; } }
</style>

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" />

<script>
  const scanLines = [
    ['av-log-working', '\u27F6 Parsing idea: "An app that helps introverts practice phone calls with AI"'],
    ['av-log-ok', '\u2713 12 target keywords extracted'],
    ['av-log-working', '\u27F6 Running 3 pipelines in parallel...'],
    ['av-log-ok', '\u2713 Demand: 14,800 monthly searches \u00B7 growing trend'],
    ['av-log-ok', '\u2713 Competition: 4 direct competitors found \u00B7 none phone-anxiety focused'],
    ['av-log-ok', '\u2713 Scoring: Demand 8/10 \u00B7 Differentiation 8/10 \u00B7 Competition 6/10'],
    ['av-log-working', '\u27F6 Generating verdict and launch playbook...'],
    ['av-log-qual', '\u2192 CONDITIONAL GO \u00B7 Score: 7.2/10'],
    ['av-log-ok', '\u2713 30-day launch plan generated'],
    ['av-log-ok', '\u26A1 Validation complete \u00B7 $0.58 \u00B7 87 seconds'],
  ];
  function runScan() {
    const log = document.getElementById('scanLog');
    if (!log) return;
    log.innerHTML = '';
    log.classList.add('visible');
    let i = 0;
    const iv = setInterval(() => {
      if (i >= scanLines.length) { clearInterval(iv); return; }
      const [cls, msg] = scanLines[i];
      const div = document.createElement('div');
      div.className = cls;
      div.textContent = msg;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      i++;
    }, 320);
  }
  const scanInput = document.getElementById('scanInput');
  if (scanInput) scanInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') runScan(); });
  function toggleLoop(el) { document.querySelectorAll('.av-loop-card').forEach(c => c.classList.remove('active')); el.classList.add('active'); }
  function togglePipe(el) { document.querySelectorAll('.av-pipe-stage').forEach(s => s.classList.remove('active')); el.classList.add('active'); }
  const avObs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }); }, { threshold: 0.2 });
  document.querySelectorAll('.av-section, .av-cta-section').forEach(el => avObs.observe(el));
  const sigObs = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) e.target.querySelectorAll('.av-signal-bar').forEach(b => { const w = b.style.width; b.style.width = '0'; requestAnimationFrame(() => { b.style.width = w; }); }); }); }, { threshold: 0.3 });
  document.querySelectorAll('.av-signal-grid').forEach(g => sigObs.observe(g));
  window.runScan = runScan; window.toggleLoop = toggleLoop; window.togglePipe = togglePipe;
</script>
<style is:global>
  .av-log-ok { color: #3a9e6e; }
  .av-log-working { color: #e07b39; }
  .av-log-qual { color: #1e3557; font-weight: 500; }
</style>
