---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import type { CaseStudyProps } from '../../components/CaseStudyPage.astro';

const SITE_URL = 'https://brothersautomate.com';

const study: CaseStudyProps = {
  badge: 'Client Onboarding Automation',
  headline: 'Onboard a client.',
  headlineHighlight: 'Without sending a single email.',
  subtitle: "Contract signs, questionnaire goes out, accounts get provisioned, kickoff lands on the calendar. Same experience every new client. You don't lift a finger. Built for a paving company, works for any service business.",
  meta: {
    client: 'Paving Company',
    industry: 'Service / Trades',
    timeline: '2–3 weeks to production',
    techStack: ['Make.com', 'HubSpot', 'DocuSign', 'Google Workspace'],
  },
  metrics: [
    { number: '0', label: 'Manual steps' },
    { number: '100%', label: 'Consistency' },
    { number: '10', label: 'Steps automated' },
    { number: '12 hrs', label: 'Saved per client' },
  ],
  problemHeadline: 'Every new client means the same manual onboarding.',
  problemDescription: 'New project comes in. You pull the client info. Send the welcome email. Schedule the walkthrough. Prep the docs. Set up the accounts. Same exact steps every time, different client, different address, different details. All done by hand. Steps get missed when things get busy. Clients notice.',
  painPoints: [
    'Every new client triggers the same 10-step onboarding sequence',
    'Client details get copied and pasted between systems manually',
    'Steps get missed when you get busy and clients feel it',
    'Welcome email tone varies depending on who sent it',
    'Account provisioning takes a day longer than it should',
    "You know it could run itself, nobody's built it yet",
  ],
  solutionHeadline: 'Your onboarding flow, fully automated end to end.',
  solutionDescription: "We build a system that pulls new client info from your database the moment a contract is signed, then runs the entire onboarding sequence automatically. Welcome email goes out, intake questionnaire fires off, account is provisioned, kickoff meeting lands on your calendar, same flow every time, every client. Built around your exact process, not a SaaS template.",
  pipeline: [
    { step: 'CONTRACT SIGNED', description: 'DocuSign webhook fires. The system pulls signed contract details into the onboarding queue.' },
    { step: 'INTAKE', description: 'Welcome email + branded intake questionnaire goes out within 5 minutes of signature.' },
    { step: 'PROVISION', description: 'Client gets logins, project workspace, and shared folders auto-created and shared.' },
    { step: 'SCHEDULE', description: 'Kickoff meeting lands on your calendar with prep notes pre-filled from intake answers.' },
    { step: 'BRIEF', description: 'Project brief auto-generated from the intake form and dropped in your team channel.' },
    { step: 'KICKOFF', description: 'You walk into the meeting prepared. The client feels like a $50K account. Same every time.' },
  ],
  features: [
    { title: 'Database-driven', description: 'Pulls client name, address, project details, and preferences automatically. No copy-paste between systems.' },
    { title: 'Automated comms', description: 'Welcome emails, scheduling confirmations, and follow-ups fire on time, every time. Tone stays on-brand because the templates do.' },
    { title: 'Document prep', description: 'Contracts, checklists, and project docs get generated with the right details filled in. Branded PDFs land in the client folder before the kickoff call.' },
    { title: 'Custom to your flow', description: "Built around the exact steps your business already runs. We don't make you change your process, we automate the one you already have." },
  ],
  beforeAfter: [
    { label: 'Time per onboarding', before: '12+ hours of manual work', after: '0 hours, runs itself' },
    { label: 'Steps that get missed', before: 'A few when things get busy', after: 'Zero, every step fires' },
    { label: 'Client experience', before: 'Varies depending on who handled it', after: 'Identical white-glove every time' },
    { label: 'Time to provisioned account', before: '1–2 days', after: '5 minutes after signature' },
    { label: 'Owner involvement', before: 'Pulled into every onboarding', after: 'Owner sees it on the calendar' },
  ],
  resultsHeadline: 'Built for a paving company. Works for any service business.',
  resultsStats: [
    { number: '0', label: 'Manual steps', context: 'Fully automated flow' },
    { number: '100%', label: 'Consistency', context: 'Every client, same experience' },
    { number: '12 hrs', label: 'Saved per client', context: 'That you can put back into delivery' },
  ],
  ctaHeadline: 'Want this for your service business?',
  ctaDescription: 'We map your current onboarding flow on the discovery call, scope it, then build it on your accounts. Most teams ship in 2–3 weeks. 30-day guarantee.',
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Client Onboarding Automation", "item": `${SITE_URL}/projects/onboarding-workflow` },
  ],
};
---

<Layout
  title="Onboarding Workflow | Automated Client Onboarding | Brothers Automate"
  description="Stop doing the same onboarding steps manually for every new client. We automate the entire flow, emails, scheduling, documents, pulled from your database."
>
  <Header />
  <main>
    <CaseStudyPage study={study} />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
