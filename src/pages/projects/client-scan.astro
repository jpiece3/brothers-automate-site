---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const SITE_URL = 'https://brothersautomate.com';
const productUrl = 'https://brothersautomate.com/clientintel/';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "SEO Audit Engine", "item": `${SITE_URL}/projects/client-scan` }
  ]
};
---

<Layout
  title="SEO Audit Engine | Automated Digital Presence Audits | Brothers Automate"
  description="Automated SEO audits in 10 minutes. Keyword rankings, competitor gaps, Google Maps visibility, Lighthouse scores, social presence, and company intel — delivered as shareable client-ready reports."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="project-hero">
      <div class="hero-bg-grid"></div>
      <div class="container">
        <div class="project-hero-content" data-animate="fade-up">
          <span class="badge">Automated SEO & Digital Presence Auditing</span>
          <h1>SEO Audit Engine.<br /><span class="gradient-text">10 Minutes. Full Audit.</span></h1>
          <p class="project-hero-sub">Stop spending 6 hours Googling a prospect. Four AI agents pull rankings, competitors, maps data, social presence, and company intel from 20+ sources — and deliver it as reports you can share.</p>

          <div class="hero-stats">
            <div class="hero-stat">
              <span class="hero-stat-number">10 min</span>
              <span class="hero-stat-label">Full Audit</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">50+</span>
              <span class="hero-stat-label">Data Points</span>
            </div>
            <div class="hero-stat-divider"></div>
            <div class="hero-stat">
              <span class="hero-stat-number">$1.50</span>
              <span class="hero-stat-label">Per Audit</span>
            </div>
          </div>

          <div class="hero-buttons">
            <a href={productUrl} class="btn btn-primary btn-lg" target="_blank" rel="noopener">See the Dashboard</a>
            <a
              href="#"
              class="btn btn-secondary btn-lg"
              data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
              data-cal-namespace="free-quiz-audit-automation-brothers"
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
            >Talk to the Brothers</a>
          </div>

          <!-- Scan Terminal Box -->
          <div class="sa-scan-box">
            <div class="sa-scan-bar">
              <div class="sa-scan-dot" style="background:#e8b4a0"></div>
              <div class="sa-scan-dot" style="background:#ddd6c8"></div>
              <div class="sa-scan-dot" style="background:#b8d4b0"></div>
              <span style="margin-left:6px">seo-audit-engine / scan</span>
            </div>
            <div class="sa-scan-input-row">
              <input class="sa-scan-input" id="scanInput" placeholder="handymanbocaratonfl.com · Boca Raton, FL" />
              <button class="sa-scan-btn" onclick="runScan()">&#9654; RUN AUDIT</button>
            </div>
            <div class="sa-scan-log" id="scanLog"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- TICKER -->
    <div class="sa-ticker">
      <div class="sa-ticker-inner">
        DOMAIN &rarr; 4 AGENTS &nbsp;&middot;&nbsp; SEO ANALYSIS &nbsp;&middot;&nbsp; COMPANY INTEL &nbsp;&middot;&nbsp; LOCAL & MAPS &nbsp;&middot;&nbsp; SOCIAL & REVIEWS &nbsp;&middot;&nbsp; 5 REPORTS &nbsp;&middot;&nbsp; PITCH STRATEGY &nbsp;&middot;&nbsp; DASHBOARD &nbsp;&middot;&nbsp;
        DOMAIN &rarr; 4 AGENTS &nbsp;&middot;&nbsp; SEO ANALYSIS &nbsp;&middot;&nbsp; COMPANY INTEL &nbsp;&middot;&nbsp; LOCAL & MAPS &nbsp;&middot;&nbsp; SOCIAL & REVIEWS &nbsp;&middot;&nbsp; 5 REPORTS &nbsp;&middot;&nbsp; PITCH STRATEGY &nbsp;&middot;&nbsp; DASHBOARD &nbsp;&middot;&nbsp;
      </div>
    </div>

    <!-- 01 — HOW IT WORKS -->
    <section class="sa-section" id="sa-section-1">
      <div class="sa-section-label">01 — How It Works</div>
      <h2 class="sa-section-title">One domain.<br><span class="sa-accent">Four agents. Full picture.</span></h2>
      <p class="sa-section-sub">Enter a domain and location. Four AI research agents run in parallel — each specializing in a different dimension of the prospect's digital presence. Click each agent to see what it pulls.</p>

      <div class="sa-loop">
        <div class="sa-loop-card active" onclick="toggleLoop(this)">
          <div class="sa-loop-num">01</div>
          <div class="sa-loop-title">SEO & Technical</div>
          <div class="sa-loop-desc">Rankings, keywords, site health</div>
          <div class="sa-loop-detail">
            &rarr; Domain rank &amp; total ranked keywords<br>
            &rarr; Keyword positions with search volume &amp; difficulty<br>
            &rarr; Competitor discovery &amp; keyword gap analysis<br>
            &rarr; Lighthouse scores (desktop + mobile)<br>
            &rarr; Full site crawl: 404s, missing meta, H1 tags<br>
            &rarr; Tech stack detection (CMS, analytics, plugins)
          </div>
        </div>
        <div class="sa-loop-card" onclick="toggleLoop(this)">
          <div class="sa-loop-num">02</div>
          <div class="sa-loop-title">Company Intel</div>
          <div class="sa-loop-desc">Leadership, revenue, hiring signals</div>
          <div class="sa-loop-detail">
            &rarr; Company name, tagline, founding year<br>
            &rarr; Leadership profiles + LinkedIn<br>
            &rarr; Revenue estimates &amp; employee count<br>
            &rarr; Job postings (growth signals)<br>
            &rarr; Brand mentions &amp; sentiment analysis<br>
            &rarr; Marketing capability assessment
          </div>
        </div>
        <div class="sa-loop-card" onclick="toggleLoop(this)">
          <div class="sa-loop-num">03</div>
          <div class="sa-loop-title">Local & Maps</div>
          <div class="sa-loop-desc">Google Maps, GBP, organic SERP</div>
          <div class="sa-loop-detail">
            &rarr; Google Maps pack rankings (3-5 queries)<br>
            &rarr; Google Business Profile data<br>
            &rarr; Organic SERP positions vs. competitors<br>
            &rarr; Google Trends (12-month keyword interest)<br>
            &rarr; Competitor reviews with full text<br>
            &rarr; Places data: photos, Q&amp;A, popular times
          </div>
        </div>
        <div class="sa-loop-card" onclick="toggleLoop(this)">
          <div class="sa-loop-num">04</div>
          <div class="sa-loop-title">Social & Reviews</div>
          <div class="sa-loop-desc">Instagram, Facebook, Yelp, BBB</div>
          <div class="sa-loop-detail">
            &rarr; Instagram: followers, posts, engagement rate<br>
            &rarr; Facebook: likes, followers, rating, ad activity<br>
            &rarr; Yelp, BBB, and review platform presence<br>
            &rarr; Competitor social benchmarking<br>
            &rarr; Contact info scraping (emails, phones)<br>
            &rarr; Social presence score (0-100)
          </div>
        </div>
      </div>
    </section>

    <!-- 02 — THE DATA SOURCES -->
    <section class="sa-section" id="sa-section-2">
      <div class="sa-section-label">02 — The Data Sources</div>
      <h2 class="sa-section-title">20+ APIs.<br><span class="sa-accent">One report.</span></h2>
      <p class="sa-section-sub">Every data point is pulled from a real API — not scraped from a cached database. Live data, every scan. Click a source to see what it provides.</p>

      <div class="sa-tier-table">
        <div class="sa-tier-header">
          <div>Source</div>
          <div>Data Provided</div>
          <div>Cost</div>
          <div>Agent</div>
        </div>
        <div class="sa-tier-row" onclick="highlightTier(this)">
          <div><div class="sa-tier-badge sa-t0">DFS</div></div>
          <div class="sa-tier-info">
            <div class="sa-tier-name">DataForSEO</div>
            <div class="sa-tier-source">15+ endpoints &middot; live Google data</div>
          </div>
          <div class="sa-tier-cost">~$0.20</div>
          <div class="sa-tier-filter">SEO, Local</div>
        </div>
        <div class="sa-tier-row" onclick="highlightTier(this)">
          <div><div class="sa-tier-badge sa-t1">LH</div></div>
          <div class="sa-tier-info">
            <div class="sa-tier-name">Google Lighthouse</div>
            <div class="sa-tier-source">Performance, accessibility, SEO scores</div>
          </div>
          <div class="sa-tier-cost">~$0.01</div>
          <div class="sa-tier-filter">SEO</div>
        </div>
        <div class="sa-tier-row" onclick="highlightTier(this)">
          <div><div class="sa-tier-badge sa-t2">API</div></div>
          <div class="sa-tier-info">
            <div class="sa-tier-name">Apify Scrapers</div>
            <div class="sa-tier-source">Instagram, Facebook, Google Places, Reviews</div>
          </div>
          <div class="sa-tier-cost">~$0.10</div>
          <div class="sa-tier-filter">Social, Local</div>
        </div>
        <div class="sa-tier-row" onclick="highlightTier(this)">
          <div><div class="sa-tier-badge sa-t3">AI</div></div>
          <div class="sa-tier-info">
            <div class="sa-tier-name">AI Analysis</div>
            <div class="sa-tier-source">Company intel, sentiment, gap assessment</div>
          </div>
          <div class="sa-tier-cost">~$1.00</div>
          <div class="sa-tier-filter">Intel</div>
        </div>
      </div>

      <div class="sa-stat-row">
        <div class="sa-stat">
          <div class="sa-stat-num">$1.50</div>
          <div class="sa-stat-label">total cost per full audit</div>
        </div>
        <div class="sa-stat">
          <div class="sa-stat-num">$0.04</div>
          <div class="sa-stat-label">per metric refresh (rankings + lighthouse)</div>
        </div>
        <div class="sa-stat">
          <div class="sa-stat-num">0</div>
          <div class="sa-stat-label">manual research hours</div>
        </div>
      </div>
    </section>

    <!-- 03 — AUDIT RESULTS -->
    <section class="sa-section" id="sa-section-3">
      <div class="sa-section-label">03 — What You Get</div>
      <h2 class="sa-section-title">Before &amp; after.<br><span class="sa-accent">Real example.</span></h2>
      <p class="sa-section-sub">Here's what the SEO Audit Engine found for a handyman business in Boca Raton — a company with a decent website but zero marketing infrastructure.</p>

      <div class="sa-score-demo">
        <div class="sa-score-card" onclick="this.classList.toggle('expanded')">
          <div class="sa-score-card-top">
            <div class="sa-score-company">1st Home Maintenance</div>
            <div class="sa-score-badge sa-status-low">Visibility: F</div>
          </div>
          <div class="sa-score-num sa-low">6%</div>
          <div class="sa-score-evidence">Domain rank: 7 &middot; 24 keywords (none on page 1) &middot; 26 monthly visits &middot; zero Google reviews &middot; no social media &middot; no Google Business Profile</div>
          <div class="sa-score-signals">
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:#c0392b">&cross;</span> Google Business Profile <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:0%;background:#c0392b"></div></div> Not found</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:#c0392b">&cross;</span> Google Reviews <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:0%;background:#c0392b"></div></div> 0 reviews</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:#c0392b">&cross;</span> Social Presence <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:0%;background:#c0392b"></div></div> 0/100</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:var(--sa-green)">&check;</span> Lighthouse Score <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:97%;background:var(--sa-green)"></div></div> 97/100</div>
          </div>
        </div>
        <div class="sa-score-card" onclick="this.classList.toggle('expanded')">
          <div class="sa-score-card-top">
            <div class="sa-score-company">Mr. Handyman (competitor)</div>
            <div class="sa-score-badge sa-status-high">Top Competitor</div>
          </div>
          <div class="sa-score-num sa-high">286</div>
          <div class="sa-score-evidence">Google reviews &middot; 4.9 star rating &middot; 59,210 keywords &middot; $932K traffic value &middot; Maps position #1 for all local queries</div>
          <div class="sa-score-signals">
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:var(--sa-green)">&check;</span> Google Reviews <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:100%;background:var(--sa-green)"></div></div> 286 reviews</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:var(--sa-green)">&check;</span> Maps Ranking <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:100%;background:var(--sa-green)"></div></div> #1 position</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:var(--sa-green)">&check;</span> Keywords <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:100%;background:var(--sa-green)"></div></div> 59,210</div>
            <div class="sa-sig-line"><span class="sa-sig-check" style="color:var(--sa-green)">&check;</span> Traffic Value <div class="sa-sig-bar-mini"><div class="sa-sig-fill" style="width:100%;background:var(--sa-green)"></div></div> $932K/mo</div>
          </div>
        </div>
      </div>

      <div class="sa-quote-block">
        <div class="sa-quote-text">"Their site scores 97 on Lighthouse — the foundation is solid. The problem isn't the website, it's that nobody can find it. Zero Maps presence, zero reviews, zero social. The gap isn't technical — it's visibility."</div>
        <div class="sa-quote-attr">From the audit report</div>
      </div>
    </section>

    <!-- 04 — THE REPORTS -->
    <section class="sa-section" id="sa-section-4">
      <div class="sa-section-label">04 — The Deliverables</div>
      <h2 class="sa-section-title">5 reports.<br><span class="sa-accent">Share-ready.</span></h2>
      <p class="sa-section-sub">Every audit produces five self-contained HTML reports plus three internal strategy documents. The client-facing reports use plain language — no API names, no jargon, no credentials exposed.</p>

      <div class="sa-signal-grid">
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">SEO Analysis</div>
            <div class="sa-signal-weight">Client-Facing</div>
          </div>
          <div class="sa-signal-desc">Keyword gaps, competitor comparison, ranking opportunities — presented as insights, not spreadsheets.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar sa-bar-green" style="width:100%"></div></div>
          <div class="sa-signal-meta"><span>Rankings + gaps</span><span>Shareable</span></div>
        </div>
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">Website Audit</div>
            <div class="sa-signal-weight">Client-Facing</div>
          </div>
          <div class="sa-signal-desc">Category scores for performance, content freshness, local visibility, social presence, and technical health.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar sa-bar-green" style="width:92%"></div></div>
          <div class="sa-signal-meta"><span>Health scores</span><span>Shareable</span></div>
        </div>
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">Action Plan</div>
            <div class="sa-signal-weight">Client-Facing</div>
          </div>
          <div class="sa-signal-desc">Tiered roadmap: quick wins (green), growth plays (blue), long-term investments (navy) — each with expected ROI.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar" style="width:88%"></div></div>
          <div class="sa-signal-meta"><span>Prioritized fixes</span><span>Shareable</span></div>
        </div>
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">Company Intel</div>
            <div class="sa-signal-weight" style="background:rgba(30,53,87,0.1);color:var(--sa-navy)">Internal</div>
          </div>
          <div class="sa-signal-desc">Leadership profiles, revenue estimates, hiring signals, gap-to-service mapping. Your eyes only.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar" style="width:75%;background:var(--sa-navy)"></div></div>
          <div class="sa-signal-meta"><span>Strategy intel</span><span>Internal only</span></div>
        </div>
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">Pitch Plan</div>
            <div class="sa-signal-weight" style="background:rgba(30,53,87,0.1);color:var(--sa-navy)">Internal</div>
          </div>
          <div class="sa-signal-desc">Meeting strategy, 3 big problems to lead with, objection handling, recommended close, and talking points.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar" style="width:82%;background:var(--sa-navy)"></div></div>
          <div class="sa-signal-meta"><span>Meeting prep</span><span>Internal only</span></div>
        </div>
        <div class="sa-signal-card">
          <div class="sa-signal-top">
            <div class="sa-signal-name">Live Dashboard</div>
            <div class="sa-signal-weight">Ongoing</div>
          </div>
          <div class="sa-signal-desc">All clients in one view. Keyword trends, position tracking, visibility scores, and one-click metric refresh.</div>
          <div class="sa-signal-bar-wrap"><div class="sa-signal-bar sa-bar-green" style="width:95%"></div></div>
          <div class="sa-signal-meta"><span>Real-time tracking</span><span>$0.04 refresh</span></div>
        </div>
      </div>
    </section>

    <!-- 05 — DASHBOARD PREVIEW -->
    <section class="sa-section" id="sa-section-5">
      <div class="sa-section-label">05 — The Dashboard</div>
      <h2 class="sa-section-title">All clients.<br><span class="sa-accent">One place.</span></h2>
      <p class="sa-section-sub">Every audit feeds into a centralized dashboard. Track visibility scores, keyword positions, competitor gaps, and Google reviews — with trend charts that show how things change between scans.</p>

      <div class="sa-pipeline">
        <div class="sa-pipe-stage active" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128269;</div>
          <div class="sa-pipe-name">Scan</div>
          <div class="sa-pipe-count">Run audit</div>
        </div>
        <div class="sa-pipe-stage" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128200;</div>
          <div class="sa-pipe-name">Track</div>
          <div class="sa-pipe-count">Dashboard</div>
        </div>
        <div class="sa-pipe-stage" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128196;</div>
          <div class="sa-pipe-name">Report</div>
          <div class="sa-pipe-count">5 deliverables</div>
        </div>
        <div class="sa-pipe-stage" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128640;</div>
          <div class="sa-pipe-name">Pitch</div>
          <div class="sa-pipe-count">Win the deal</div>
        </div>
        <div class="sa-pipe-stage" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128260;</div>
          <div class="sa-pipe-name">Refresh</div>
          <div class="sa-pipe-count">$0.04 / update</div>
        </div>
        <div class="sa-pipe-stage sa-won" onclick="togglePipe(this)">
          <div class="sa-pipe-icon">&#128202;</div>
          <div class="sa-pipe-name">Trend</div>
          <div class="sa-pipe-count">Track over time</div>
        </div>
      </div>

      <div class="sa-stat-row" style="margin-top:32px">
        <div class="sa-stat">
          <div class="sa-stat-num">7</div>
          <div class="sa-stat-label">tabs per client (overview, SEO, local, social, company, history, reports)</div>
        </div>
        <div class="sa-stat">
          <div class="sa-stat-num">A-F</div>
          <div class="sa-stat-label">visibility grade based on reviews, keywords, traffic, social</div>
        </div>
        <div class="sa-stat">
          <div class="sa-stat-num">&infin;</div>
          <div class="sa-stat-label">scans tracked — full history with trend charts</div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="sa-cta-section" id="sa-section-6">
      <div class="sa-section-label" style="justify-content:center;margin-bottom:28px">06 — Get Started</div>
      <h2 class="sa-cta-title">Domain in.<br>Audit out.<br><span style="color:var(--sa-accent)">10 minutes.</span></h2>
      <p class="sa-cta-sub">Stop spending all day on prospect research. Walk into every meeting with data, not guesses.</p>
      <div class="sa-cta-btn-row">
        <a href={productUrl} class="sa-btn-p" target="_blank" rel="noopener">See the Dashboard &rarr;</a>
        <a
          href="#"
          class="sa-btn-s"
          data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
          data-cal-namespace="free-quiz-audit-automation-brothers"
          data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        >Talk to the Brothers</a>
      </div>
      <p style="font-size:11px;color:var(--sa-muted);margin-top:28px;font-family:var(--sa-mono)">SEO Audit Engine &middot; automated prospect intelligence &middot; built for operators</p>
    </section>

  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  /* ===== HERO (from ProjectPage.astro) ===== */
  .project-hero {
    position: relative;
    padding-top: 160px;
    padding-bottom: var(--space-3xl);
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-surface-alt) 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .project-hero-content {
    position: relative;
    max-width: 750px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: rgba(237, 137, 54, 0.1);
    border: 1px solid rgba(237, 137, 54, 0.3);
    color: var(--orange);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .project-hero h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .project-hero-sub {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto var(--space-lg);
  }

  .hero-stats {
    display: flex;
    align-items: center;
