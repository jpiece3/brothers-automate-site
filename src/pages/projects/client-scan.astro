---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import type { CaseStudyProps } from '../../components/CaseStudyPage.astro';

const SITE_URL = 'https://brothersautomate.com';
const productUrl = 'https://brothersautomate.com/clientintel/';

const study: CaseStudyProps = {
  badge: 'SEO Audit Automation',
  headline: 'SEO Audit Engine.',
  headlineHighlight: '10 minutes. Full audit.',
  subtitle: 'Four AI agents run in parallel. They pull SEO rankings, company intel, local visibility, and review data from 20+ sources, then produce five client-ready reports. What used to take half a week now ships before lunch.',
  meta: {
    client: 'Marketing Agency',
    industry: 'Marketing / Agency',
    timeline: '3–4 weeks to production',
    techStack: ['DataForSEO', 'Google Lighthouse', 'Apify', 'Google Business Profile'],
  },
  metrics: [
    { number: '10 min', label: 'Time to audit' },
    { number: '20+', label: 'Data sources' },
    { number: '50+', label: 'Checks per scan' },
    { number: '$1.50', label: 'Cost per audit' },
  ],
  problemHeadline: 'SEO audits take all week and still miss half the picture.',
  problemDescription: "Every new prospect means the same routine: open Semrush, check rankings, manually look up Google reviews, screenshot Lighthouse scores, research competitors, hunt for social profiles. 4–6 hours of tab-switching per prospect, and you still walk into the meeting with a spreadsheet and guesswork.",
  painPoints: [
    'A single prospect audit takes 4–6 hours across a dozen different tools',
    "You're checking rankings in one tool, reviews in another, social in a third, nothing connects",
    'Competitor analysis means manually pulling data for each one and comparing in a spreadsheet',
    "The deliverable is a Loom and a Google Doc, not something that makes you look like a $10K/month agency",
    "By the time you've audited one prospect, three more filled out your contact form",
    'Junior team members miss critical data points that change the entire pitch strategy',
  ],
  solutionHeadline: 'Enter a domain. Get a full audit and 5 share-ready reports.',
  solutionDescription: 'Four AI research agents run simultaneously, one pulls SEO and keyword data, one gathers company intel and hiring signals, one checks Google Maps and local visibility, and one audits social and review platforms. They pull from 20+ sources including DataForSEO, Google Lighthouse, Google Business Profile, and Apify scrapers. Ten minutes later, you have a complete audit and five client-ready PDFs.',
  pipeline: [
    { step: 'INTAKE', description: 'Drop a domain. The system queues four parallel agents and sets up the report templates.' },
    { step: 'SEO AGENT', description: 'Pulls keyword rankings, backlink profile, on-page Lighthouse scores, and competitor gap analysis.' },
    { step: 'COMPANY AGENT', description: 'Scrapes hiring signals, tech stack, funding, recent press, and team intel.' },
    { step: 'LOCAL AGENT', description: 'Audits Google Business Profile, reviews, Maps visibility, and local citations.' },
    { step: 'SOCIAL AGENT', description: 'Checks LinkedIn, Instagram, X, YouTube, engagement, recency, post quality.' },
    { step: 'REPORT', description: 'AI synthesizes findings into 5 branded PDFs + an internal pitch strategy doc.' },
  ],
  features: [
    { title: '4 parallel research agents', description: "Each agent owns its lane (SEO, company, local, social) so the audit takes ~10 min, not half a day." },
    { title: '20+ data sources stitched together', description: 'DataForSEO, Lighthouse, Google Business Profile, Apify, BuiltWith, and more, pulled in parallel, normalized into one report.' },
    { title: '5 client-ready PDFs per scan', description: 'SEO snapshot, competitor brief, local audit, social presence, and an executive summary, all branded and shareable.' },
    { title: 'Internal pitch playbook included', description: 'Every scan also produces a private doc with talking points, gap insights, and the highest-leverage opportunities for the sales call.' },
  ],
  beforeAfter: [
    { label: 'Time to audit a prospect', before: '4–6 hours of manual research', after: '~10 minutes, fully automated' },
    { label: 'Cost per audit', before: 'Senior strategist time + tools', after: '~$1.50 in API calls' },
    { label: 'Deliverable to client', before: 'Loom + Google Doc', after: '5 branded PDFs + pitch playbook' },
    { label: 'Junior staff capability', before: 'Misses key data points', after: 'Same depth as a senior strategist' },
    { label: 'Throughput per week', before: '2–3 audits at most', after: '15+ audits with the same headcount' },
  ],
  resultsHeadline: 'Built for a marketing agency. Runs in 10 minutes.',
  resultsStats: [
    { number: '10 min', label: 'Per audit', context: 'vs. 4–6 hours manual' },
    { number: '50+', label: 'Data points checked', context: 'Across 20+ sources' },
    { number: '$1.50', label: 'Cost per audit', context: 'API calls only, no labor' },
  ],
  ctaHeadline: 'Want one of these for your agency?',
  ctaDescription: 'Same engine, custom-branded for your firm. We tune the agents to your niche, white-label the reports, and deploy on your accounts. 30-day guarantee.',
  productUrl,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "SEO Audit Engine", "item": `${SITE_URL}/projects/client-scan` },
  ],
};
---

<Layout
  title="SEO Audit Engine | Automated Digital Presence Audits | Brothers Automate"
  description="Automated SEO audits in 10 minutes. Keyword rankings, competitor gaps, Google Maps visibility, Lighthouse scores, social presence, and company intel, delivered as shareable client-ready reports."
>
  <Header />
  <main>
    <CaseStudyPage study={study} />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
