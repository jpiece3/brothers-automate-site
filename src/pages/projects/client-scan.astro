  /* ===== QUOTE ===== */
  .sa-quote-block { margin-top: 28px; border-left: 4px solid var(--sa-accent); padding: 24px 28px; background: var(--sa-surface); border-radius: 0 16px 16px 0; }
  .sa-quote-text { font-size: clamp(14px, 2vw, 19px); font-weight: 700; line-height: 1.55; color: var(--sa-navy); margin-bottom: 10px; }
  .sa-quote-attr { font-size: 10px; color: var(--sa-muted); letter-spacing: 0.12em; text-transform: uppercase; font-family: var(--sa-mono); }

  /* ===== SIGNAL/REPORT CARDS ===== */
  .sa-signal-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 48px; }
  .sa-signal-card { background: var(--sa-surface); border: 1.5px solid var(--sa-border); border-radius: 14px; padding: 20px; cursor: pointer; transition: all 0.2s; }
  .sa-signal-card:hover { border-color: var(--sa-accent); box-shadow: 0 4px 16px rgba(224,123,57,0.1); }
  .sa-signal-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
  .sa-signal-name { font-weight: 700; font-size: 13px; color: var(--sa-navy); }
  .sa-signal-weight { font-family: var(--sa-mono); font-size: 10px; color: var(--sa-accent); background: rgba(224,123,57,0.1); padding: 3px 8px; border-radius: 6px; font-weight: 500; }
  .sa-signal-desc { font-size: 11px; color: var(--sa-blue-gray); line-height: 1.6; margin-bottom: 12px; }
  .sa-signal-bar-wrap { height: 4px; background: var(--sa-surface2); border-radius: 999px; overflow: hidden; }
  .sa-signal-bar { height: 100%; border-radius: 999px; background: var(--sa-accent); transition: width 0.6s ease; }
  .sa-bar-green { background: var(--sa-green); }
  .sa-signal-meta { display: flex; justify-content: space-between; margin-top: 6px; font-size: 10px; color: var(--sa-muted); font-family: var(--sa-mono); }

  /* ===== PIPELINE ===== */
  .sa-pipeline { display: flex; gap: 0; margin-top: 48px; overflow-x: auto; padding-bottom: 4px; }
  .sa-pipe-stage {
    flex: 1; min-width: 110px; background: var(--sa-surface); border-top: 3px solid var(--sa-border);
    border-right: 1px solid var(--sa-border); border-bottom: 1.5px solid var(--sa-border);
    padding: 20px 16px; text-align: center; cursor: pointer; transition: all 0.2s;
  }
  .sa-pipe-stage:first-child { border-left: 1.5px solid var(--sa-border); border-radius: 16px 0 0 16px; }
  .sa-pipe-stage:last-child { border-right: 1.5px solid var(--sa-border); border-radius: 0 16px 16px 0; }
  .sa-pipe-stage:hover, .sa-pipe-stage.active { border-top-color: var(--sa-accent); background: #fff; }
  .sa-pipe-stage.sa-won { border-top-color: var(--sa-green); }
  .sa-pipe-icon { font-size: 20px; margin-bottom: 8px; }
  .sa-pipe-name { font-weight: 700; font-size: 11px; color: var(--sa-navy); }
  .sa-pipe-count { font-size: 10px; color: var(--sa-muted); margin-top: 4px; font-family: var(--sa-mono); }

  /* ===== CTA ===== */
  .sa-cta-section {
    max-width: 980px; margin: 0 auto; padding: 80px 32px 120px; border-top: 1px solid var(--sa-border);
    text-align: center; opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .sa-cta-section.visible { opacity: 1; transform: none; }
  .sa-cta-title { font-size: clamp(36px, 6vw, 72px); font-weight: 900; line-height: 1.02; margin-bottom: 18px; color: var(--sa-navy); letter-spacing: -0.03em; }
  .sa-cta-sub { font-size: 16px; color: var(--sa-blue-gray); max-width: 400px; margin: 0 auto 40px; line-height: 1.7; }
  .sa-cta-btn-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .sa-btn-p { display: inline-block; background: var(--sa-accent); color: #fff; border: none; padding: 16px 34px; font-family: var(--sa-sans); font-weight: 700; font-size: 14px; cursor: pointer; border-radius: 999px; transition: background 0.15s; box-shadow: 0 4px 16px rgba(224,123,57,0.3); text-decoration: none; }
  .sa-btn-p:hover { background: var(--sa-accent2); }
  .sa-btn-s { display: inline-block; background: transparent; color: var(--sa-navy); border: 2px solid var(--sa-navy); padding: 16px 34px; font-family: var(--sa-sans); font-weight: 700; font-size: 14px; cursor: pointer; border-radius: 999px; transition: all 0.15s; text-decoration: none; }
  .sa-btn-s:hover { background: var(--sa-navy); color: #fff; }

  /* ===== ANIMATIONS ===== */
  @keyframes saFadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

