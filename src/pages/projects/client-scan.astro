</style>

<!-- DM Mono font -->
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap" />

<script>
  const scanLines = [
    ['sa-log-working', '\u27F6 Initializing scan for handymanbocaratonfl.com \u00B7 Boca Raton, FL'],
    ['sa-log-ok', '\u2713 Input parsed \u00B7 auto-discovering competitors'],
    ['sa-log-working', '\u27F6 Spawning 4 research agents in parallel...'],
    ['sa-log-ok', '\u2713 Agent 1: SEO & Technical \u00B7 domain rank, keywords, lighthouse, crawl'],
    ['sa-log-ok', '\u2713 Agent 2: Company Intel \u00B7 leadership, revenue, hiring signals'],
    ['sa-log-ok', '\u2713 Agent 3: Local & Maps \u00B7 maps rankings, GBP, organic SERP'],
    ['sa-log-ok', '\u2713 Agent 4: Social & Reviews \u00B7 Instagram, Facebook, Yelp, BBB'],
    ['sa-log-working', '\u27F6 All 4 agents complete \u00B7 validating research data...'],
    ['sa-log-ok', '\u2713 4/4 JSON files verified \u00B7 total API cost: $1.47'],
    ['sa-log-working', '\u27F6 Generating 5 client-facing reports...'],
    ['sa-log-ok', '\u2713 SEO analysis, website audit, action plan, methodology \u00B7 done'],
    ['sa-log-working', '\u27F6 Generating internal strategy docs...'],
    ['sa-log-ok', '\u2713 Company intel, pitch plan, full keyword tables \u00B7 done'],
    ['sa-log-qual', '\u2192 Persisting to dashboard \u00B7 24 keywords tracked'],
    ['sa-log-ok', '\u26A1 Scan complete \u00B7 8 deliverables \u00B7 $1.47 total \u00B7 10 minutes'],
  ];

  function runScan() {
    const log = document.getElementById('scanLog');
    if (!log) return;
    log.innerHTML = '';
    log.classList.add('visible');
    let i = 0;
    const iv = setInterval(() => {
      if (i >= scanLines.length) { clearInterval(iv); return; }
      const [cls, msg] = scanLines[i];
      const div = document.createElement('div');
      div.className = cls;
      div.textContent = msg;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      i++;
    }, 350);
  }

  const scanInput = document.getElementById('scanInput');
  if (scanInput) {
    scanInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') runScan();
    });
  }

  function toggleLoop(el) {
    document.querySelectorAll('.sa-loop-card').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
  }

  function highlightTier(el) {
    document.querySelectorAll('.sa-tier-row').forEach(r => r.classList.remove('highlight'));
    el.classList.add('highlight');
  }

  function togglePipe(el) {
    document.querySelectorAll('.sa-pipe-stage').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
  }

  const saObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) e.target.classList.add('visible');
    });
  }, { threshold: 0.2 });
  document.querySelectorAll('.sa-section, .sa-cta-section').forEach(el => saObs.observe(el));

  const signalObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.sa-signal-bar').forEach(b => {
          const w = b.style.width;
          b.style.width = '0';
          requestAnimationFrame(() => { b.style.width = w; });
        });
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.sa-signal-grid').forEach(g => signalObs.observe(g));

  window.runScan = runScan;
  window.toggleLoop = toggleLoop;
  window.highlightTier = highlightTier;
  window.togglePipe = togglePipe;
</script>

<style is:global>
  .sa-log-ok { color: #3a9e6e; }
  .sa-log-working { color: #e07b39; }
  .sa-log-qual { color: #1e3557; font-weight: 500; }
</style>
