---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CaseStudyPage from '../../components/CaseStudyPage.astro';
import { projectToCaseStudy } from '../../lib/projectToCaseStudy';

const SITE_URL = 'https://brothersautomate.com';
const slug = 'equipment-identifier';

const study = projectToCaseStudy(slug, {
  badge: 'AI Equipment Cataloging',
  headline: 'AI Equipment Cataloger.',
  headlineHighlight: 'Photos in. Lot titles out.',
  meta: {
    client: 'Heavy Equipment Auction Co.',
    industry: 'Auction / Heavy Equipment',
    timeline: '3 weeks to production',
    techStack: ['OpenAI Vision', 'Supabase', 'Apify', 'Google Sheets'],
  },
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Projects", "item": `${SITE_URL}/projects` },
    { "@type": "ListItem", "position": 3, "name": "Equipment Identifier", "item": `${SITE_URL}/projects/${slug}` },
  ],
};
---

<Layout title="Equipment Identifier | AI Equipment Cataloging | Brothers Automate" description="Upload photos of heavy equipment, get back auction-ready lot titles in seconds. AI vision identifies manufacturer, model, year, and category from a single photo.">
  <Header />
  <main><CaseStudyPage study={study} /></main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
