<style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: #fdfcfa; color: #1a365d; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    a { color: #3182ce; }

    /* Nav */
    .top-nav {
      padding: 1rem 0;
      border-bottom: 1px solid #e8e6e1;
      background: #ffffff;
    }
    .top-nav .container { display: flex; justify-content: space-between; align-items: center; }
    .top-nav a { color: #64748b; text-decoration: none; font-size: 0.875rem; font-weight: 500; }
    .top-nav a:hover { color: #1a365d; }
    .nav-brand { font-weight: 700; color: #1a365d !important; }

    /* Hero */
    .hero {
      padding: 100px 0 60px;
      text-align: center;
      background: linear-gradient(135deg, #7f1d1d 0%, #dc2626 50%, #991b1b 100%);
      color: white;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.15);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 9999px;
      padding: 0.4rem 1rem;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .hero h1 {
      font-size: clamp(1.75rem, 4.5vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .hero h1 .highlight {
      background: rgba(255,255,255,0.15);
      padding: 0.1em 0.3em;
      border-radius: 8px;
    }
    .hero p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.85);
      max-width: 650px;
      margin: 0 auto;
    }

    /* Gap Comparison */
    .gap-section { padding: 60px 0; }
    .section-label {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #ed8936;
      margin-bottom: 0.5rem;
    }
    .section-title {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .section-subtitle {
      color: #64748b;
      margin-bottom: 2rem;
      max-width: 600px;
    }

    .comparison-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -1px rgba(0,0,0,0.04);
      border: 1px solid #e8e6e1;
    }
    .comparison-table thead th {
      background: #1a365d;
      color: white;
      padding: 1rem 1.25rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.875rem;
    }
    .comparison-table thead th:first-child { width: 35%; }
    .comparison-table tbody td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid #f0eeea;
      font-size: 0.95rem;
    }
    .comparison-table tbody tr:last-child td { border-bottom: none; }
    .comparison-table tbody tr:nth-child(even) { background: #f8f7f4; }
    .comparison-table .you { color: #dc2626; font-weight: 700; }
    .comparison-table .them { color: #16a34a; font-weight: 700; }
    .metric-label { font-weight: 600; color: #1a365d; }
    .gap-tag {
      display: inline-block;
      background: #fef2f2;
      color: #dc2626;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2em 0.6em;
      border-radius: 9999px;
      margin-left: 0.5rem;
    }

    /* Missing section */
