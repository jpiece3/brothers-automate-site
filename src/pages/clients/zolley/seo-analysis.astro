            <th>Difficulty</th>
            <th>CPC Value</th>
            <th>Your Current Position</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>handyman boca raton</strong></td>
            <td>480</td>
            <td><span class="kd-badge kd-easy">KD 0</span></td>
            <td>$9.39</td>
            <td>Not on page 1 (organic #12)</td>
          </tr>
          <tr>
            <td><strong>handyman in boca raton florida</strong></td>
            <td>480</td>
            <td><span class="kd-badge kd-easy">KD 0</span></td>
            <td>$9.39</td>
            <td>#16</td>
          </tr>
          <tr>
            <td><strong>handyman service boca raton</strong></td>
            <td>480</td>
            <td><span class="kd-badge kd-easy">KD 0</span></td>
            <td>$9.39</td>
            <td>#17</td>
          </tr>
          <tr>
            <td><strong>home repair services boca raton</strong></td>
            <td>170+</td>
            <td><span class="kd-badge kd-easy">KD 0</span></td>
            <td>$8+</td>
            <td>#7 (organic, not Maps)</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="opp-tier">
      <div class="tier-header">
        <span class="tier-badge growth">Growth Plays</span>
        <h3>New service pages + review generation (Month 1-3)</h3>
      </div>
      <table class="keyword-table">
        <thead>
          <tr>
            <th>Keyword</th>
            <th>Monthly Searches</th>
            <th>Difficulty</th>
            <th>Page Needed</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>plumber boca raton</strong></td>
            <td>1,000+</td>
            <td><span class="kd-badge kd-easy">Low</span></td>
            <td>Plumbing Repair Services page</td>
          </tr>
          <tr>
            <td><strong>electrician boca raton</strong></td>
            <td>1,000+</td>
            <td><span class="kd-badge kd-med">Medium</span></td>
            <td>Electrical Services page</td>
          </tr>
          <tr>
            <td><strong>bathroom remodel boca raton</strong></td>
            <td>300+</td>
            <td><span class="kd-badge kd-easy">Low</span></td>
            <td>Bathroom Remodeling page</td>
          </tr>
          <tr>
            <td><strong>kitchen repair boca raton</strong></td>
            <td>200+</td>
            <td><span class="kd-badge kd-easy">Low</span></td>
            <td>Kitchen Repair Services page</td>
          </tr>
          <tr>
            <td><strong>drywall repair boca raton</strong></td>
            <td>150+</td>
            <td><span class="kd-badge kd-easy">KD 0</span></td>
            <td>Optimize existing page</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="opp-tier">
      <div class="tier-header">
        <span class="tier-badge long">Long-Term Authority</span>
        <h3>Blog content + location pages (Month 3-6+)</h3>
      </div>
      <table class="keyword-table">
        <thead>
          <tr>
            <th>Keyword Category</th>
            <th>Example Keywords</th>
            <th>Strategy</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Location variants</strong></td>
            <td>handyman Delray Beach, handyman Boynton Beach, handyman Deerfield Beach</td>
