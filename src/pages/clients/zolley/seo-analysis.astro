      padding: 60px 0;
      background: #f8f7f4;
    }
    .missing-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .missing-card {
      background: #ffffff;
      border: 1px solid #e8e6e1;
      border-radius: 12px;
      padding: 1.5rem;
    }
    .missing-card .status-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      margin-right: 0.5rem;
    }
    .missing-card .status-dot.red { background: #dc2626; }
    .missing-card .status-dot.amber { background: #f59e0b; }
    .missing-card h3 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
    }
    .missing-card p { color: #64748b; font-size: 0.9rem; }

    /* Opportunities */
    .opps-section { padding: 60px 0; }
    .opp-tier {
      margin-bottom: 2rem;
    }
    .tier-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .tier-badge {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.85rem;
      border-radius: 9999px;
      font-size: 0.8rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .tier-badge.quick { background: #dcfce7; color: #15803d; }
    .tier-badge.growth { background: #dbeafe; color: #1d4ed8; }
    .tier-badge.long { background: #f3e8ff; color: #7e22ce; }
    .tier-header h3 { font-size: 1.15rem; font-weight: 700; }

    .keyword-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      border-radius: 12px;
      overflow: hidden;
      border: 1px solid #e8e6e1;
      font-size: 0.9rem;
    }
    .keyword-table thead th {
      background: #f8f7f4;
      padding: 0.75rem 1rem;
      text-align: left;
      font-weight: 600;
      font-size: 0.8rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-bottom: 1px solid #e8e6e1;
    }
    .keyword-table tbody td {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid #f0eeea;
    }
    .keyword-table tbody tr:last-child td { border-bottom: none; }
    .kd-badge {
      display: inline-block;
      padding: 0.15em 0.5em;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 700;
    }
    .kd-easy { background: #dcfce7; color: #15803d; }
    .kd-med { background: #fef9c3; color: #a16207; }

    /* Demand */
    .demand-section {
      padding: 60px 0;
      background: #f8f7f4;
    }
    .demand-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
    .demand-card {
      background: #ffffff;
      border: 1px solid #e8e6e1;
      border-radius: 12px;
      padding: 1.5rem;
      text-align: center;
    }
    .demand-card .big-number {
      font-size: 2.5rem;
      font-weight: 800;
      color: #1a365d;
      line-height: 1.1;
    }
    .demand-card .label {
      color: #64748b;
      font-size: 0.9rem;
      margin-top: 0.25rem;
    }

    /* Takeaway */
    .takeaway-section { padding: 60px 0; }
    .takeaway-box {
      background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
      border: 1px solid #fde68a;
      border-radius: 16px;
      padding: 2rem;
    }
    .takeaway-box h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
      color: #92400e;
    }
    .takeaway-box ul {
      list-style: none;
      padding: 0;
    }
    .takeaway-box li {
      padding: 0.5rem 0;
      padding-left: 1.5rem;
      position: relative;
      color: #78350f;
      font-size: 0.95rem;
    }
    .takeaway-box li::before {
      content: '';
