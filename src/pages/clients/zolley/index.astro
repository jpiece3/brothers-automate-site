---
import ClientReportLayout from '../../../layouts/ClientReportLayout.astro';
---

<ClientReportLayout title="Digital Marketing Analysis" clientName="1st Home Maintenance">
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Prepared for 1st Home Maintenance</div>
      <h1>Your Digital Marketing<br><span>Analysis is Ready</span></h1>
      <p>We analyzed your online presence across SEO, local search, social media, and reviews. Here's what we found.</p>
      <div class="hero-date">Prepared by Brothers Automate &middot; April 3, 2026</div>
    </div>
  </section>

  <div class="container">
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-number red">24</div>
        <div class="stat-label">Ranked Keywords</div>
      </div>
      <div class="stat-item">
        <div class="stat-number red">0</div>
        <div class="stat-label">Google Reviews</div>
      </div>
      <div class="stat-item">
        <div class="stat-number red">0</div>
        <div class="stat-label">Social Profiles</div>
      </div>
      <div class="stat-item">
        <div class="stat-number amber">6</div>
        <div class="stat-label">Total Pages</div>
      </div>
    </div>
  </div>

  <section class="cards-section">
    <div class="container">
      <h2>Your Reports</h2>
      <p class="subtitle">Click any report to see the full analysis.</p>
      <div class="cards-grid">
        <a href="/clients/zolley/seo-analysis" class="report-card seo">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </div>
          <h3>SEO & Competitor Analysis</h3>
          <p>See how you stack up against competitors, which keywords you're missing, and the biggest opportunities to get found online.</p>
          <span class="card-link">View full report <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
        <a href="/clients/zolley/website-audit" class="report-card audit">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <h3>Website Audit & Scorecard</h3>
          <p>Performance, content, local visibility, and social presence scores with specific findings and recommendations.</p>
          <span class="card-link">View full report <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
        <a href="/clients/zolley/action-plan" class="report-card action">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          </div>
          <h3>Action Plan & Roadmap</h3>
          <p>A prioritized, step-by-step plan organized into quick wins, growth plays, and long-term strategies to dominate local search.</p>
          <span class="card-link">View full report <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
        <a href="/clients/zolley/research-process" class="report-card process">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#3182ce" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3>Research Process</h3>
          <p>How we conducted this analysis and what data sources informed our findings and recommendations.</p>
          <span class="card-link">View full report <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Talk About What's Possible?</h2>
      <p>Let's walk through these findings together and build a plan to get your phone ringing more.</p>
      <a href="https://cal.com/james-pinder-simpleflo/free-quiz-audit-automation-brothers" class="btn-cta">
        Book a Free Strategy Call
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      Prepared by Brothers Automate &middot; AI-powered research across 35+ data sources &middot; April 2026
    </div>
  </footer>
</ClientReportLayout>

<style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #fdfcfa;
      color: #1a365d;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* Hero */
    .hero {
      padding: 120px 0 60px;
      text-align: center;
      background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
      color: white;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 9999px;
      padding: 0.5rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 500;
      margin-bottom: 1.5rem;
      backdrop-filter: blur(10px);
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
    }
    .hero h1 span { color: #ed8936; }
    .hero p {
      font-size: 1.125rem;
      color: rgba(255,255,255,0.8);
      max-width: 600px;
      margin: 0 auto 2rem;
    }
    .hero-date {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.5);
    }

    /* Stats Bar */
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: #e8e6e1;
      border-radius: 16px;
      overflow: hidden;
      margin: -40px auto 0;
      max-width: 900px;
      position: relative;
      z-index: 2;
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.08), 0 10px 10px -5px rgba(0,0,0,0.03);
    }
    .stat-item {
      background: #ffffff;
      padding: 1.5rem 1rem;
      text-align: center;
    }
    .stat-number {
      font-size: 2rem;
      font-weight: 800;
      color: #1a365d;
      line-height: 1.1;
    }
    .stat-number.red { color: #dc2626; }
    .stat-number.amber { color: #f59e0b; }
    .stat-number.green { color: #16a34a; }
    .stat-label {
      font-size: 0.8rem;
      color: #64748b;
      font-weight: 500;
      margin-top: 0.25rem;
    }

    /* Cards Section */
    .cards-section {
      padding: 80px 0;
    }
    .cards-section h2 {
      text-align: center;
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .cards-section .subtitle {
      text-align: center;
      color: #64748b;
      margin-bottom: 3rem;
      font-size: 1.05rem;
    }
    .cards-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
    .report-card {
      background: #ffffff;
      border: 1px solid #e8e6e1;
      border-radius: 16px;
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      transition: all 300ms ease;
      position: relative;
      overflow: hidden;
    }
    .report-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 25px -5px rgba(0,0,0,0.08), 0 10px 10px -5px rgba(0,0,0,0.03);
      border-color: #ed8936;
    }
    .report-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
    }
    .report-card.seo::before { background: #dc2626; }
    .report-card.audit::before { background: #f59e0b; }
    .report-card.action::before { background: #16a34a; }
    .report-card.process::before { background: #3182ce; }
    .card-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }
    .seo .card-icon { background: #fef2f2; }
    .audit .card-icon { background: #fffbeb; }
    .action .card-icon { background: #f0fdf4; }
    .process .card-icon { background: #eff6ff; }
    .report-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }
    .report-card p {
      color: #64748b;
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }
    .card-link {
      font-size: 0.875rem;
      font-weight: 600;
      color: #ed8936;
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
    }
    .card-link svg { transition: transform 200ms ease; }
    .report-card:hover .card-link svg { transform: translateX(4px); }

    /* CTA */
    .cta-section {
      background: #1a365d;
      padding: 60px 0;
      text-align: center;
      color: white;
    }
    .cta-section h2 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
    }
    .cta-section p {
      color: rgba(255,255,255,0.7);
      margin-bottom: 1.5rem;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }
    .btn-cta {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #ed8936;
      color: white;
      padding: 0.875rem 2rem;
      border-radius: 9999px;
      font-size: 1rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 200ms ease;
      border: none;
      cursor: pointer;
    }
    .btn-cta:hover { background: #dd6b20; transform: translateY(-2px); }

    /* Footer */
    .footer {
      padding: 2rem 0;
      text-align: center;
      font-size: 0.8rem;
      color: #94a3b8;
      border-top: 1px solid #e8e6e1;
    }

    @media (max-width: 767px) {
      .stats-bar { grid-template-columns: repeat(2, 1fr); }
      .cards-grid { grid-template-columns: 1fr; }
      .hero { padding: 100px 0 60px; }
    }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var elements = document.querySelectorAll('.fade-up');
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15 });
      elements.forEach(function (el) { observer.observe(el); });
    } else {
      elements.forEach(function (el) { el.classList.add('visible'); });
    }
  });
</script>
