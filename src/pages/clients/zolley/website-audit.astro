---
import ClientReportLayout from '../../../layouts/ClientReportLayout.astro';
---

<ClientReportLayout title="Website Audit & Scorecard" clientName="1st Home Maintenance">
<!-- Back link -->
<div class="back-bar">
  <div class="container">
    <a href="/clients/zolley/" class="back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Back to Overview
    </a>
  </div>
</div>

<!-- Hero -->
<header class="hero">
  <div class="container">
    <span class="badge">Website Audit & Scorecard</span>
    <h1>Website Audit Report</h1>
    <div class="url">handymanbocaratonfl.com</div>
    <div class="date">April 3, 2026 &middot; Prepared by Brothers Automate</div>

    <!-- Score Ring -->
    <div class="score-ring-wrap">
      <div class="score-ring">
        <svg width="200" height="200" viewBox="0 0 200 200">
          <circle class="bg" cx="100" cy="100" r="88" />
          <circle class="fg" cx="100" cy="100" r="88"
            stroke-dasharray="553"
            stroke-dashoffset="553" />
        </svg>
        <div class="score-text">
          <div class="score-number">38</div>
          <div class="score-label">out of 100</div>
        </div>
      </div>
    </div>

    <!-- Category Scores -->
    <div class="stats-bar">
      <div class="stat-card">
        <span class="stat-number score-high">9/10</span>
        <span class="stat-label">Performance</span>
      </div>
      <div class="stat-card">
        <span class="stat-number score-high">7/10</span>
        <span class="stat-label">Technical Health</span>
      </div>
      <div class="stat-card">
        <span class="stat-number score-low">2/10</span>
        <span class="stat-label">Content Freshness</span>
      </div>
      <div class="stat-card">
        <span class="stat-number score-low">1/10</span>
        <span class="stat-label">Local Visibility</span>
      </div>
      <div class="stat-card">
        <span class="stat-number score-low">0/10</span>
        <span class="stat-label">Social Presence</span>
      </div>
    </div>
  </div>
</header>

<!-- NAV -->
<nav class="phase-nav">
  <div class="container">
    <div class="phase-nav-inner">
      <button class="phase-btn active" onclick="scrollToSection('overview')">Overview</button>
      <button class="phase-btn" onclick="scrollToSection('scores')">Score Breakdown</button>
      <button class="phase-btn" onclick="scrollToSection('findings')">Detailed Findings</button>
      <button class="phase-btn" onclick="scrollToSection('tech')">Tech Stack</button>
      <button class="phase-btn" onclick="scrollToSection('actions')">Priority Actions</button>
    </div>
  </div>
</nav>

<!-- OVERVIEW -->
<section id="overview" class="section">
  <div class="container">
    <div class="exec-card animate-in">
      <h3>Executive Summary</h3>
      <p>
        Your website is <strong>technically excellent</strong> -- scoring 97/100 on performance, running WordPress with Yoast SEO and WP Rocket. That puts you ahead of most competitor websites on speed alone. But that's where the good news ends. You have <strong>no Google Business Profile</strong>, <strong>zero reviews</strong> on any platform, <strong>no social media presence</strong>, and only <strong>6 pages</strong> total. Your site is a race car with no gas: the engine works, but you're not going anywhere. The overall marketing readiness score of <strong>38/100</strong> reflects a site that's fast and clean but invisible to customers who are actively searching for your services.
      </p>
    </div>

    <!-- Top Findings -->
    <div class="top-findings animate-in">
      <h3>Top Findings at a Glance</h3>
      <div class="findings-summary">
        <div class="top-finding-row">
          <div class="top-finding-text">
            <strong>No Google Business Profile -- invisible on Maps</strong>
            <span>40%+ of local clicks go to the map pack. You're not in it. Competitors have 49-286 reviews.</span>
          </div>
          <div class="priority-badge priority-critical">Critical</div>
        </div>
        <div class="top-finding-row">
          <div class="top-finding-text">
            <strong>Zero reviews on any platform</strong>
            <span>Checked Google, Yelp, BBB, Angi, Glassdoor. Nothing. This is the #1 trust signal you're missing.</span>
          </div>
          <div class="priority-badge priority-critical">Critical</div>
        </div>
        <div class="top-finding-row">
          <div class="top-finding-text">
            <strong>No social media presence at all</strong>
            <span>No Facebook, Instagram, Yelp listing, or BBB. Competitors are active on multiple platforms.</span>
          </div>
          <div class="priority-badge priority-critical">Critical</div>
        </div>
        <div class="top-finding-row">
          <div class="top-finding-text">
            <strong>Only 6 pages on the entire site</strong>
            <span>Home, about, contact, drywall-repair, handyman-services, home-repairs. That's it.</span>
          </div>
          <div class="priority-badge priority-high">High</div>
        </div>
        <div class="top-finding-row">
          <div class="top-finding-text">
            <strong>97/100 performance score -- excellent foundation</strong>
            <span>WP Rocket, Yoast SEO, fast hosting. The technical stack is solid.</span>
          </div>
          <div class="priority-badge priority-good">Strength</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SCORE BREAKDOWN -->
<section id="scores" class="section alt-bg">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">Score Breakdown</div>
      <h2>Where you're strong and where you're falling short</h2>
    </div>

    <div class="score-details">
      <div class="score-row">
        <div class="score-info">
          <h4>Performance</h4>
          <p>Page speed, loading time, Core Web Vitals, mobile responsiveness</p>
        </div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill green" style="width: 90%;"></div></div>
          <span class="score-val green-text">9/10</span>
        </div>
      </div>

      <div class="score-row">
        <div class="score-info">
          <h4>Technical Health</h4>
          <p>Meta tags, headings, schema markup, sitemap, robots.txt</p>
        </div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill green" style="width: 70%;"></div></div>
          <span class="score-val green-text">7/10</span>
        </div>
      </div>

      <div class="score-row">
        <div class="score-info">
          <h4>Content Freshness</h4>
          <p>Number of pages, blog activity, content depth, keyword targeting</p>
        </div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill red" style="width: 20%;"></div></div>
          <span class="score-val red-text">2/10</span>
        </div>
      </div>

      <div class="score-row">
        <div class="score-info">
          <h4>Local Visibility</h4>
          <p>Google Business Profile, Google Maps, local pack rankings, citations</p>
        </div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill red" style="width: 10%;"></div></div>
          <span class="score-val red-text">1/10</span>
        </div>
      </div>

      <div class="score-row">
        <div class="score-info">
          <h4>Social Presence</h4>
          <p>Social media profiles, review platforms, business directories</p>
        </div>
        <div class="score-bar-wrap">
          <div class="score-bar"><div class="score-bar-fill red" style="width: 2%;"></div></div>
          <span class="score-val red-text">0/10</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DETAILED FINDINGS -->
<section id="findings" class="section">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">Detailed Findings</div>
      <h2>What we found -- the full picture</h2>
      <p>Click any finding to expand the details.</p>
    </div>

    <div class="finding-card open">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot red"></span>
        <span class="finding-title">No Google Business Profile -- invisible on Maps</span>
        <span class="finding-category">Local</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>A Google Business Profile is the single most impactful thing a local service business can do for online visibility. Without one, you don't appear in the map pack that shows up at the top of search results for "handyman boca raton" and similar queries.</p>
        <div class="finding-comparison">
          <div class="comp-item them"><strong>Mr. Handyman:</strong> 286 reviews, 4.9 stars</div>
          <div class="comp-item them"><strong>Tom & Son:</strong> 71 reviews, 4.8 stars</div>
          <div class="comp-item them"><strong>Best Boca:</strong> 67 reviews, 4.7 stars</div>
          <div class="comp-item you"><strong>You:</strong> Not listed</div>
        </div>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot red"></span>
        <span class="finding-title">Zero reviews on any platform</span>
        <span class="finding-category">Reputation</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>We checked Google, Yelp, BBB, Angi, and Glassdoor. You have zero reviews on every platform. For local service businesses, reviews are the #1 factor potential customers use to decide who to call. Even 10 reviews would dramatically increase trust and conversion rates.</p>
        <div class="finding-impact">
          <strong>Impact:</strong> Customers searching for handyman services see competitors with dozens of reviews and skip listings with none. You're losing leads before they even visit your site.
        </div>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot red"></span>
        <span class="finding-title">No social media presence at all</span>
        <span class="finding-category">Social</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>No Facebook page, no Instagram account, no Yelp listing, no BBB listing. Your competitors are active on multiple platforms. A Facebook Business Page alone would give you another place to collect reviews, share project photos, and appear in searches.</p>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot red"></span>
        <span class="finding-title">Only 6 pages on the entire website</span>
        <span class="finding-category">Content</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>Your site has: home, about, contact, drywall-repair, handyman-services, and home-repairs. That's it. Each page is a chance to rank for a different set of keywords. You're leaving thousands of potential search visitors on the table.</p>
        <div class="pages-needed">
          <span class="page-chip">Plumbing Repairs</span>
          <span class="page-chip">Electrical Work</span>
          <span class="page-chip">Bathroom Remodeling</span>
          <span class="page-chip">Kitchen Repairs</span>
          <span class="page-chip">Ceiling Fan Installation</span>
          <span class="page-chip">Exterior Repairs</span>
          <span class="page-chip">Painting Services</span>
        </div>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot red"></span>
        <span class="finding-title">Using Gmail instead of professional domain email</span>
        <span class="finding-category">Brand</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>Your contact email is 1sthomemaint@gmail.com. A professional email like info@handymanbocaratonfl.com signals credibility and helps with deliverability. This is a quick win that takes 30 minutes to set up.</p>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot amber"></span>
        <span class="finding-title">Missing meta descriptions on About and Contact pages</span>
        <span class="finding-category">Technical</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>Your About and Contact pages don't have meta descriptions. Google will auto-generate these, but they won't be optimized for clicks. Writing custom meta descriptions takes 5 minutes per page and can increase click-through rates 20-30%.</p>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot amber"></span>
        <span class="finding-title">Duplicate H1 tag on Contact page</span>
        <span class="finding-category">Technical</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>Your Contact page has a duplicate H1 heading tag. Each page should have exactly one H1 that clearly describes the page content. This is a simple fix in WordPress.</p>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot green"></span>
        <span class="finding-title">Excellent site speed and performance (97/100)</span>
        <span class="finding-category">Performance</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>Your site scores 97/100 on performance on both desktop and mobile. This is outstanding and better than most competitor websites. WP Rocket is doing its job well. You also score 97/100 on accessibility and 100/100 on SEO technical setup via Yoast.</p>
        <div class="perf-scores">
          <div class="perf-item"><span class="perf-num green-text">97</span> Performance</div>
          <div class="perf-item"><span class="perf-num green-text">97</span> Accessibility</div>
          <div class="perf-item"><span class="perf-num green-text">100</span> SEO (Yoast)</div>
        </div>
      </div>
    </div>

    <div class="finding-card">
      <div class="finding-header" onclick="this.parentElement.classList.toggle('open')">
        <span class="finding-dot green"></span>
        <span class="finding-title">Good tech stack: WordPress + Yoast SEO + WP Rocket</span>
        <span class="finding-category">Technical</span>
        <svg class="finding-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </div>
      <div class="finding-body">
        <p>WordPress with Yoast SEO is an excellent foundation for growing your online presence. The SEO plugin makes it easy to optimize meta titles, descriptions, and schema markup. WP Rocket handles caching and performance. Google Analytics is installed for tracking. The tech foundation is solid -- it just needs more content to work with.</p>
      </div>
    </div>
  </div>
</section>

<!-- TECH STACK -->
<section id="tech" class="section alt-bg">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">Technology</div>
      <h2>Your tech stack</h2>
      <p>What's powering your website behind the scenes.</p>
    </div>

    <div class="tech-grid">
      <div class="tech-card">
        <div class="tech-icon green-bg">WP</div>
        <div>
          <h4>WordPress</h4>
          <p>Content management system. The world's most popular CMS, powering 40%+ of all websites. Easy to add new pages and content.</p>
        </div>
      </div>
      <div class="tech-card">
        <div class="tech-icon green-bg">SEO</div>
        <div>
          <h4>Yoast SEO</h4>
          <p>SEO plugin for meta titles, descriptions, and schema markup. Properly configured and scoring 100/100 on technical SEO.</p>
        </div>
      </div>
      <div class="tech-card">
        <div class="tech-icon green-bg">WPR</div>
        <div>
          <h4>WP Rocket</h4>
          <p>Performance and caching plugin. Responsible for your excellent 97/100 speed score. Handles minification, lazy loading, and caching.</p>
        </div>
      </div>
      <div class="tech-card">
        <div class="tech-icon blue-bg">GA</div>
        <div>
          <h4>Google Analytics</h4>
          <p>Traffic tracking and analytics. Already installed and collecting data on visitor behavior.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRIORITY ACTIONS -->
<section id="actions" class="section">
  <div class="container">
    <div class="section-header">
      <div class="eyebrow">Priority Actions</div>
      <h2>Top 8 fixes, ranked by impact</h2>
      <p>What to do first to move the needle fastest.</p>
    </div>

    <div class="action-list">
      <div class="action-item">
        <div class="action-num critical">1</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>Invisible on Google Maps -- no GBP listing at all</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Claim and fully optimize a Google Business Profile with service categories, hours, area, photos</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>Appear in Google Maps within 1-2 weeks. Start receiving calls directly from Maps.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num critical">2</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>Zero reviews on any platform</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Text/email every past customer asking for a Google review. Set up automated review request system.</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>15-25 Google reviews in 90 days. Enough to compete in the map pack.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num high">3</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>Only 6 pages targeting a handful of keywords</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Build 5+ service-specific landing pages: plumbing, electrical, bathroom, kitchen, ceiling fans</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>5-10x increase in keyword coverage. Each page ranks for new service terms.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num high">4</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>No social media or business directory presence</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Create Facebook Business Page and Yelp listing. Add business info, photos, services.</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>Additional review platforms, local citations, referral traffic.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num medium">5</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>Missing meta descriptions and duplicate H1</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Write meta descriptions in Yoast SEO. Fix duplicate H1 on Contact page. 15 minutes total.</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>20-30% improvement in click-through rates from search results.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num medium">6</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>Gmail address instead of professional domain email</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Set up info@handymanbocaratonfl.com via Google Workspace or Zoho Mail (~$6/mo)</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>Professional credibility + better email deliverability.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num medium">7</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>No testimonials or portfolio on the website</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Add 5-10 testimonials with names and project types. Include before/after photos.</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>Increased conversion rate from website visitors to phone calls.</span>
          </div>
        </div>
      </div>

      <div class="action-item">
        <div class="action-num low">8</div>
        <div class="action-content">
          <div class="action-row">
            <span class="action-label problem">Problem</span>
            <span>No location-specific content for surrounding cities</span>
          </div>
          <div class="action-row">
            <span class="action-label solution">Fix</span>
            <span>Create location pages for Delray Beach, Boynton Beach, Deerfield Beach, Pompano Beach</span>
          </div>
          <div class="action-row">
            <span class="action-label outcome">Result</span>
            <span>Capture search traffic from every city you serve. Most have zero keyword difficulty.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Want Help Fixing These Issues?</h2>
    <p>We can walk you through the highest-impact changes and build a plan to get your score above 80.</p>
    <a href="https://cal.com/james-pinder/simple-automation-discovery" class="btn-cta">
      Book a Free Strategy Call
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<footer class="footer">
  <div class="container">Prepared by Brothers Automate &middot; April 2026</div>
</footer>
</ClientReportLayout>

<style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: #fdfcfa; color: #1a365d; line-height: 1.6; -webkit-font-smoothing: antialiased; }
    .container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

    /* Back bar */
    .back-bar { padding: 1rem 0; border-bottom: 1px solid rgba(26,54,93,0.08); background: #fdfcfa; }
    .back-link {
      display: inline-flex; align-items: center; gap: 0.35rem;
      color: #64748b; text-decoration: none; font-size: 0.875rem; font-weight: 500;
    }
    .back-link:hover { color: #1a365d; }
    .back-link svg { width: 18px; height: 18px; }

    /* Hero */
    .hero {
      padding: 3.5rem 0 3rem; text-align: center;
