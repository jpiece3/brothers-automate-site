---
import ClientReportLayout from '../../../layouts/ClientReportLayout.astro';
---

<ClientReportLayout title="Action Plan" clientName="Nexvel Solutions">
<!-- Hero -->
  <section class="hero">
    <div class="container" style="text-align:left;">
      <a href="/clients/nexvel/" class="back-link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
        Back to Overview
      </a>
    </div>
    <div class="container" style="text-align:center;">
      <div class="hero-label">Prepared by Brothers Automate - April 3, 2026</div>
      <h1>Nexvel Solutions - Action Plan</h1>
      <p class="hero-subtitle">A prioritized roadmap based on our analysis</p>
      <div class="summary-bar">
        <div class="summary-item green">
          <span class="count">5</span>
          Quick Wins
        </div>
        <div class="summary-item blue">
          <span class="count">5</span>
          Growth Plays
        </div>
        <div class="summary-item navy">
          <span class="count">3</span>
          Long-Term Investments
        </div>
      </div>
    </div>
  </section>

  <!-- Tier 1: Quick Wins -->
  <section class="tier">
    <div class="container">
      <div class="tier-header">
        <span class="tier-badge green">Tier 1</span>
        <h2 class="tier-title">Quick Wins</h2>
      </div>
      <p class="tier-timeline">This Month -- Low effort, high impact</p>

      <div class="card green-accent">
        <div class="card-number green">1</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Homepage has no H1 tag -- the most important on-page SEO element is missing.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Add a keyword-rich H1 heading to the homepage.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Improved search engine understanding of your primary services.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Results visible within 2 weeks.</span>
        </div>
      </div>

      <div class="card green-accent">
        <div class="card-number green">2</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Google Business Profile has only 7 reviews vs competitors with 100+.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Launch a systematic review generation campaign with existing clients.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">25+ reviews within 90 days, improved local map visibility.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Appear in Google Maps local pack, 15-25% more clicks from local searches.</span>
        </div>
      </div>

      <div class="card green-accent">
        <div class="card-number green">3</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Homepage statistics are outdated (claims "3 billion Google searches/day" -- actual: 8.5+ billion).</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Audit and update all statistics and claims across the site.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Improved credibility with prospects who notice outdated data.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Immediate trust improvement.</span>
        </div>
      </div>

      <div class="card green-accent">
        <div class="card-number green">4</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">A test page ("test-yoast-gif") is publicly accessible and indexed.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Remove or noindex test/development pages.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Cleaner site for search engines to crawl.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Immediate.</span>
        </div>
      </div>

      <div class="card green-accent">
        <div class="card-number green">5</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">14 pages return 301 redirects from old URL structure.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Update internal links to point to final URLs, eliminate redirect chains.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Faster page loads, better crawl efficiency.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Results within 2-4 weeks.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tier 2: Growth Plays -->
  <section class="tier">
    <div class="container">
      <div class="tier-header">
        <span class="tier-badge blue">Tier 2</span>
        <h2 class="tier-title">Growth Plays</h2>
      </div>
      <p class="tier-timeline">Next 90 Days -- Strategic moves that build momentum</p>

      <div class="card blue-accent">
        <div class="card-number blue">1</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">No dedicated service landing pages -- 6,360 searches/month with zero visibility.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Build 5 service pages (Web Design, SEO, PPC, Managed IT, Social Media) each targeting "[service] Philadelphia."</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Rank for 5+ new commercial keywords.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Capture portion of 6,360 monthly searches within 90 days.</span>
        </div>
      </div>

      <div class="card blue-accent">
        <div class="card-number blue">2</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Blog inactive since April 2020 -- competitors publish weekly.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Publish 2-4 posts/month targeting low-competition keywords in your verticals.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">10-20 new keyword rankings, establishing topical authority.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Compounding organic traffic growth starting within 3-6 months.</span>
        </div>
      </div>

      <div class="card blue-accent">
        <div class="card-number blue">3</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">No location-specific pages despite two offices and a local market.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Create location pages for Elkins Park, Philadelphia, and Montgomery County.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Rank for "[service] [location]" combinations.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Capture hyper-local searches with high conversion intent within 60-90 days.</span>
        </div>
      </div>

      <div class="card blue-accent">
        <div class="card-number blue">4</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Case studies show strong results (118% traffic growth, 9,600 leads) but aren't optimized for search.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Reformat case studies as keyword-targeted content (e.g., "How We Grew a Philadelphia HVAC Company's Traffic 118%").</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Rank for industry marketing keywords (HVAC marketing 880/mo, dental marketing 2,400/mo).</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Leverage existing proof to attract new clients in same verticals within 90 days.</span>
        </div>
      </div>

      <div class="card blue-accent">
        <div class="card-number blue">5</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Not listed on major agency directories (Clutch, DesignRush, GoodFirms).</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Submit profiles to 10 agency directories with complete information and case studies.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Backlinks from high-authority domains, direct referral leads.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Listings live within 2-4 weeks, referral traffic ongoing.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Tier 3: Long-Term Investments -->
  <section class="tier">
    <div class="container">
      <div class="tier-header">
        <span class="tier-badge navy">Tier 3</span>
        <h2 class="tier-title">Long-Term Investments</h2>
      </div>
      <p class="tier-timeline">6-12 Months -- Compounding advantages that separate you from competitors</p>

      <div class="card navy-accent">
        <div class="card-number navy">1</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">Competitor (<a href="https://seolocale.com" target="_blank" rel="noopener" style="color:inherit;text-decoration:underline;">SEO Locale</a>) has 311x more organic traffic built from content authority.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Build pillar content strategy with "Local SEO" and "Small Business IT" hub pages plus 5-7 supporting articles each.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Topical authority in core service categories, compete for higher-difficulty keywords.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Dominate local service keywords within 12 months.</span>
        </div>
      </div>

      <div class="card navy-accent">
        <div class="card-number navy">2</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">69 Instagram followers and 102 Facebook likes after 12 years -- minimal social proof.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Launch consistent social media content strategy showcasing client results, behind-the-scenes, and industry tips.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Build social proof, drive referral traffic, support brand searches.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Gradual compounding -- social becomes a lead source within 6-12 months.</span>
        </div>
      </div>

      <div class="card navy-accent">
        <div class="card-number navy">3</div>
        <div class="card-row">
          <span class="card-label problem">Problem</span>
          <span class="card-value">No AI or automation positioning despite industry trend toward AI-powered services.</span>
        </div>
        <div class="card-row">
          <span class="card-label solution">Solution</span>
          <span class="card-value">Add AI/automation messaging to service offerings, create content around AI-powered marketing.</span>
        </div>
        <div class="card-row">
          <span class="card-label outcome">Outcome</span>
          <span class="card-value">Differentiate from competitors, attract forward-thinking clients.</span>
        </div>
        <div class="card-row">
          <span class="card-label roi">ROI</span>
          <span class="card-value">Position for the next wave of client demand over 6-12 months.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="footer-cta">
    <div class="container">
      <h2>Want help executing this plan?</h2>
      <a href="https://cal.com/james-pinder-simpleflo/free-quiz-audit-automation-brothers" class="cta-button">Book a Call</a>
    </div>
  </section>

  <div class="prepared-by">
    Prepared by Brothers Automate for Nexvel Solutions -- April 3, 2026
  </div>
</ClientReportLayout>

<style is:global>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #fdfcfa;
      color: #1a365d;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 12px 0;
      font-size: 0.875rem;
      font-weight: 600;
      color: #3182ce;
      text-decoration: none;
      transition: color 0.2s;
    }
    .back-link:hover { color: #1a365d; }
    .back-link svg { width: 16px; height: 16px; }
    .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

    /* Hero */
    .hero {
      background: linear-gradient(135deg, #1a365d 0%, #2d4a7a 100%);
      color: #fff;
      padding: 48px 0 56px;
    }
    .hero .container { text-align: center; }
    .hero .back-link { color: rgba(255,255,255,0.7); }
    .hero .back-link:hover { color: #fff; }
    .hero-label {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #ed8936;
      margin-bottom: 12px;
    }
    .hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 8px;
    }
    .hero-subtitle {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.8);
      margin-bottom: 32px;
      font-weight: 400;
    }
    .summary-bar {
      display: flex;
      justify-content: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .summary-item {
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px;
      padding: 12px 20px;
      font-size: 0.9rem;
      font-weight: 600;
      backdrop-filter: blur(4px);
    }
    .summary-item .count {
      font-size: 1.25rem;
      font-weight: 800;
      display: block;
      margin-bottom: 2px;
    }
    .summary-item.green .count { color: #4ade80; }
    .summary-item.blue .count { color: #60a5fa; }
    .summary-item.navy .count { color: #ed8936; }

    /* Tier sections */
    .tier { padding: 48px 0; }
    .tier + .tier { padding-top: 0; }
    .tier-header {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 8px;
    }
    .tier-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #fff;
      padding: 4px 12px;
      border-radius: 4px;
      white-space: nowrap;
    }
    .tier-badge.green { background: #16a34a; }
    .tier-badge.blue { background: #3182ce; }
    .tier-badge.navy { background: #1a365d; }
    .tier-title {
      font-size: clamp(1.25rem, 3vw, 1.5rem);
      font-weight: 800;
    }
    .tier-timeline {
      font-size: 0.9rem;
      color: #64748b;
      font-weight: 500;
      margin-bottom: 28px;
      padding-left: 2px;
    }

    /* Cards */
    .card {
      background: #fff;
      border-radius: 12px;
      border: 1px solid #e2e8f0;
      padding: 28px;
      margin-bottom: 16px;
      transition: box-shadow 0.2s;
    }
    .card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
    .card-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      font-size: 0.8rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 14px;
    }
    .card-number.green { background: #16a34a; }
    .card-number.blue { background: #3182ce; }
    .card-number.navy { background: #1a365d; }
    .card-row {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 4px 12px;
      margin-bottom: 12px;
      align-items: baseline;
    }
    .card-row:last-child { margin-bottom: 0; }
    .card-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding-top: 2px;
    }
    .card-label.problem { color: #dc2626; }
    .card-label.solution { color: #3182ce; }
    .card-label.outcome { color: #16a34a; }
    .card-label.roi { color: #f59e0b; }
    .card-value {
      font-size: 0.925rem;
      color: #334155;
      line-height: 1.55;
    }

    /* Accent stripe on cards */
    .card.green-accent { border-left: 4px solid #16a34a; }
    .card.blue-accent { border-left: 4px solid #3182ce; }
    .card.navy-accent { border-left: 4px solid #1a365d; }

    /* Footer CTA */
    .footer-cta {
      background: linear-gradient(135deg, #1a365d 0%, #2d4a7a 100%);
      color: #fff;
      text-align: center;
      padding: 56px 24px;
      margin-top: 24px;
    }
    .footer-cta h2 {
      font-size: clamp(1.25rem, 3vw, 1.75rem);
      font-weight: 800;
      margin-bottom: 20px;
    }
    .cta-button {
      display: inline-block;
      background: #ed8936;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      padding: 14px 32px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .cta-button:hover { background: #dd6b20; transform: translateY(-1px); }

    /* Prepared by */
    .prepared-by {
      text-align: center;
      padding: 32px 24px;
      font-size: 0.8rem;
      color: #94a3b8;
    }

    @media (max-width: 600px) {
      .hero { padding: 32px 0 40px; }
      .summary-bar { flex-direction: column; align-items: center; }
      .summary-item { width: 100%; max-width: 240px; text-align: center; }
      .card { padding: 20px; }
      .card-row {
        grid-template-columns: 1fr;
        gap: 2px;
        margin-bottom: 14px;
      }
      .card-label { margin-bottom: 0; }
      .tier-header { flex-wrap: wrap; }
    }
  
</style>

<script>

</script>
