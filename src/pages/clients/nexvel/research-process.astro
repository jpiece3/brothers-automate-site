      font-size: 0.7rem;
      font-weight: 500;
      color: var(--text-secondary);
      transition: all var(--transition);
    }
    .source-tag:hover { border-color: var(--blue); color: var(--blue); }
    .source-tag.verified { background: rgba(22,163,74,0.08); border-color: rgba(22,163,74,0.2); color: var(--green); }
    .source-tag.estimated { background: rgba(237,137,54,0.08); border-color: rgba(237,137,54,0.2); color: var(--orange); }

    /* Flow diagram */
    .flow-section { background: var(--navy); color: white; padding: 5rem 0; }
    .flow-section h2, .flow-section h3 { color: white; }
    .flow-section p { color: rgba(255,255,255,0.7); }
    .flow-section .eyebrow { color: var(--orange); }

    .flow-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 900px;
      margin: 0 auto;
    }
    @media (min-width: 768px) {
      .flow-grid { grid-template-columns: repeat(3, 1fr); }
    }

    .flow-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius-lg);
      padding: 1.5rem;
      text-align: center;
      transition: all var(--transition);
      position: relative;
    }
    .flow-card:hover {
      background: rgba(255,255,255,0.1);
