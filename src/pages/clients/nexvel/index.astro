---
import ClientReportLayout from '../../../layouts/ClientReportLayout.astro';
---

<ClientReportLayout title="Digital Presence Analysis" clientName="Nexvel Solutions">
<!-- Header -->
  <header class="header">
    <div class="header-inner">
      <span class="header-brand">Brothers Automate</span>
      <span class="header-tag">Client Report</span>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <span class="hero-label fade-up">Prepared for</span>
    <h1 class="fade-up">Nexvel Solutions</h1>
    <p class="hero-subtitle fade-up">Digital Presence Analysis</p>
    <p class="hero-date fade-up">April 3, 2026 &nbsp;|&nbsp; Prepared by Brothers Automate</p>
    <p class="hero-intro fade-up">
      We conducted a comprehensive analysis of your digital presence across 35+ data sources. Here's what we found.
    </p>
  </section>

  <div class="divider"><hr></div>

  <!-- Cards -->
  <section class="cards-section">
    <div class="cards-grid">

      <a href="/clients/nexvel/seo-analysis" class="card fade-up stagger-1">
        <span class="card-number">1</span>
        <h2>Gaps &amp; Opportunities</h2>
        <p>The searches you're missing, the competitors outranking you, and the untapped keywords waiting for you.</p>
        <span class="card-arrow">
          View analysis
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </span>
      </a>

      <a href="/clients/nexvel/website-audit" class="card fade-up stagger-2">
        <span class="card-number">2</span>
        <h2>Website Health</h2>
        <p>What's working, what's broken, and what needs attention on your website.</p>
        <span class="card-arrow">
          View audit
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </span>
      </a>

      <a href="/clients/nexvel/action-plan" class="card fade-up stagger-3">
        <span class="card-number">3</span>
        <h2>Action Plan</h2>
        <p>A prioritized roadmap: what to fix first, what to build next, and the expected results.</p>
        <span class="card-arrow">
          View plan
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </span>
      </a>

      <a href="/clients/nexvel/research-process" class="card fade-up stagger-4">
        <span class="card-number">4</span>
        <h2>How We Did It</h2>
        <p>A look at the data sources and methods behind this analysis.</p>
        <span class="card-arrow">
          View process
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </span>
      </a>

    </div>
  </section>

  <!-- Footer CTA -->
  <section class="footer-cta" style="background:#1a365d;color:#ffffff;text-align:center;padding:4rem 0;">
    <h3>Ready to discuss the findings?</h3>
    <p style="color:rgba(255,255,255,0.8);">Let's walk through the analysis together and plan next steps.</p>
    <a href="https://cal.com/james-pinder/simple-automation-discovery" class="cta-button">Book a Call</a>
  </section>

  <footer class="footer-bottom">
    Brothers Automate &middot; 2026
  </footer>

  <!-- Scroll Animations -->
</ClientReportLayout>

<style is:global>

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: #fdfcfa;
      color: #1a365d;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* ── Header ── */
    .header {
      padding: 1.25rem 2rem;
      border-bottom: 1px solid rgba(26, 54, 93, 0.08);
      background: #fdfcfa;
    }

    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .header-brand {
      font-size: 1.05rem;
      font-weight: 700;
      color: #1a365d;
      letter-spacing: -0.01em;
    }

    .header-tag {
      font-size: 0.8rem;
      font-weight: 500;
      color: #64748b;
    }

    /* ── Hero ── */
    .hero {
      max-width: 1100px;
      margin: 0 auto;
      padding: 4.5rem 2rem 3rem;
      text-align: center;
    }

    .hero-label {
      display: inline-block;
      font-size: 0.78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #ed8936;
      margin-bottom: 1.25rem;
    }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 800;
      color: #1a365d;
      letter-spacing: -0.025em;
      line-height: 1.15;
      margin-bottom: 0.5rem;
    }

    .hero-subtitle {
      font-size: clamp(1.1rem, 2.5vw, 1.4rem);
      font-weight: 500;
      color: #3182ce;
      margin-bottom: 1rem;
    }

    .hero-date {
      font-size: 0.875rem;
      color: #64748b;
      margin-bottom: 2.5rem;
    }

    .hero-intro {
      max-width: 640px;
      margin: 0 auto;
      font-size: 1.05rem;
      color: #475569;
      line-height: 1.7;
    }

    /* ── Divider ── */
    .divider {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .divider hr {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(26, 54, 93, 0.12), transparent);
    }

    /* ── Cards Grid ── */
    .cards-section {
      max-width: 1100px;
      margin: 0 auto;
      padding: 3rem 2rem 4rem;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .card {
      position: relative;
      background: #fff;
      border: 1px solid rgba(26, 54, 93, 0.08);
      border-radius: 16px;
      padding: 2.25rem 2rem 2rem;
      text-decoration: none;
      color: inherit;
      transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  box-shadow 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  border-color 0.3s ease;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: linear-gradient(90deg, #ed8936, #f6ad55);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(26, 54, 93, 0.1), 0 4px 12px rgba(26, 54, 93, 0.06);
      border-color: rgba(237, 137, 54, 0.25);
    }

    .card:hover::before {
      opacity: 1;
    }

    .card-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border-radius: 10px;
      background: rgba(26, 54, 93, 0.06);
      color: #1a365d;
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
      transition: background 0.3s ease, color 0.3s ease;
    }

    .card:hover .card-number {
      background: #ed8936;
      color: #fff;
    }

    .card h2 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #1a365d;
      margin-bottom: 0.65rem;
      letter-spacing: -0.01em;
    }

    .card p {
      font-size: 0.925rem;
      color: #64748b;
      line-height: 1.65;
      flex: 1;
    }

    .card-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.25rem;
      font-size: 0.85rem;
      font-weight: 600;
      color: #ed8936;
      transition: gap 0.25s ease;
    }

    .card:hover .card-arrow {
      gap: 0.7rem;
    }

    .card-arrow svg {
      width: 16px;
      height: 16px;
      transition: transform 0.25s ease;
    }

    .card:hover .card-arrow svg {
      transform: translateX(2px);
    }

    /* ── Footer CTA ── */
    .footer-cta {
      background: #1a365d;
      padding: 4rem 2rem;
      text-align: center;
    }

    .footer-cta h3 {
      font-size: clamp(1.4rem, 3vw, 1.75rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 0.5rem;
      letter-spacing: -0.01em;
    }

    .footer-cta p {
      font-size: 1rem;
      color: rgba(255, 255, 255, 0.65);
      margin-bottom: 2rem;
    }

    .cta-button {
      display: inline-block;
      padding: 0.9rem 2.25rem;
      background: #ed8936;
      color: #fff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      text-decoration: none;
      border-radius: 10px;
      transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    }

    .cta-button:hover {
      background: #dd6b20;
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(237, 137, 54, 0.35);
    }

    .footer-bottom {
      max-width: 1100px;
      margin: 0 auto;
      padding: 1.5rem 2rem;
      text-align: center;
      font-size: 0.8rem;
      color: #94a3b8;
    }

    /* ── Animations ── */
    .fade-up {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                  transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .stagger-1 { transition-delay: 0.05s; }
    .stagger-2 { transition-delay: 0.15s; }
    .stagger-3 { transition-delay: 0.25s; }
    .stagger-4 { transition-delay: 0.35s; }

    /* ── Responsive ── */
    @media (max-width: 767px) {
      .header {
        padding: 1rem 1.25rem;
      }

      .hero {
        padding: 3rem 1.25rem 2.25rem;
      }

      .cards-section {
        padding: 2rem 1.25rem 3rem;
      }

      .cards-grid {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .card {
        padding: 1.75rem 1.5rem 1.5rem;
      }

      .footer-cta {
        padding: 3rem 1.25rem;
      }
    }
  
</style>

<script>

    document.addEventListener('DOMContentLoaded', function () {
      var elements = document.querySelectorAll('.fade-up');
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        elements.forEach(function (el) { observer.observe(el); });
      } else {
        elements.forEach(function (el) { el.classList.add('visible'); });
      }
    });
  
</script>
