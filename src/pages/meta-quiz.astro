---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TopUtilityStrip from '../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../components/operator/EyebrowTag.astro';

const SITE_URL = 'https://brothersautomate.com';
---

<Layout
  title="Where's AI worth it for your business? | Brothers Automate"
  description="Six questions, plain English. We'll match the bottleneck eating your team's time to the system we'd build to fix it. Plus a rough read on time saved and cost."
  canonicalUrl={`${SITE_URL}/meta-quiz/`}
>
  <Header />
  <main>
    <section class="op-mq-hero op-grid-bg">
      <div class="op-mq-hero-frame">
        <div class="op-mq-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / DIAGNOSTIC · 60_SEC"
            right="● 6 QUESTIONS · NO PITCH"
            bordered
          />
        </div>
        <EyebrowTag label="60-SECOND DIAGNOSTIC" />
        <h1 class="op-mq-h1" data-animate="fade-up">
          Where's AI<br />
          <span class="op-mq-h1-orange">worth it</span> for your business?
        </h1>
        <p class="op-mq-sub" data-animate="fade-up">
          Six questions, plain English. We'll match the bottleneck eating your team's time to the system we'd build to fix it, plus a rough read on time saved and what it'd cost.
        </p>
      </div>
    </section>

    <section class="op-mq-body">
      <div class="op-mq-body-frame">
        <div class="op-mq-panel" data-animate="fade-up">
          <header class="op-mq-panel-head">
            <span class="op-pulse-dot"></span>
            <span class="op-mono op-mq-panel-id" id="mq-step-id">DIAGNOSTIC · IDLE</span>
            <span class="op-mono op-mq-panel-status" id="mq-step-status">● READY</span>
            <button type="button" class="op-mq-close" id="mq-close" aria-label="Exit quiz">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </button>
          </header>
          <div class="op-mq-progress" id="mq-progress" hidden>
            <div class="op-mq-progress-fill" id="mq-progress-fill"></div>
          </div>
          <div class="op-mq-app" id="app"></div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    // ---------------------------------------------------------------------
    // QUESTIONS — 6 items, all 3 pts max so max score = 18.
    // Q2 drives the primary recommendation (pain-driven).
    // The score is preserved for Gumloop compatibility (readiness tier).
    // ---------------------------------------------------------------------
    const QUESTIONS = [
      {
        q: "What kind of operation are you running?",
        sub: "We tune the recommendation to your actual day-to-day, not a generic SaaS playbook.",
        opts: [
          { text: "Field service (HVAC, plumbing, electrical, restoration, pest)", val: "field_service", pts: 3 },
          { text: "Trades or construction (contractors, roofing, landscaping, paving)", val: "trades", pts: 3 },
          { text: "Real estate, brokerage, or property management", val: "real_estate", pts: 3 },
          { text: "Professional services (legal, accounting, agency, consulting)", val: "pro_service", pts: 3 },
          { text: "Healthcare, dental, medspa, or clinic", val: "healthcare", pts: 3 },
          { text: "Other service business", val: "other", pts: 2 }
        ]
      },
      {
        q: "Where does the wheel spin most?",
        sub: "The thing that makes you want to throw your phone. We pick the system to fix it.",
        opts: [
          { text: "Hot inbound leads sit unanswered for hours", val: "leads", pts: 3 },
          { text: "Quotes and proposals get rebuilt from scratch every time", val: "quoting", pts: 3 },
          { text: "Schedules collide, two crews land at the same address, jobs get rerouted on the fly", val: "scheduling", pts: 3 },
          { text: "Customer info gets retyped into 4 different systems", val: "admin", pts: 3 },
          { text: "Resume stack sits for weeks while we lose good people to faster shops", val: "hiring", pts: 3 },
          { text: "Calls drop to voicemail after-hours and reviews go unanswered", val: "support", pts: 3 }
        ]
      },
      {
        q: "When a brand-new lead comes in, how fast do you (really) reply?",
        sub: "Be honest. We've heard worse. Speed-to-reply is the single biggest predictor of close rate in service businesses.",
        opts: [
          { text: "Under 5 minutes, every time", val: "fast_reply", pts: 3 },
          { text: "Same day, usually", val: "same_day", pts: 2 },
          { text: "Next day or two, depending on the week", val: "variable", pts: 1 },
          { text: "Honestly? Some never get a callback", val: "never", pts: 1 }
        ]
      },
      {
        q: "If your most reliable person took a 3-week vacation, would the place keep humming?",
        sub: "Cleanest test for whether your operation is built on systems or on tribal knowledge.",
        opts: [
          { text: "Yes, things are documented and other people can step in", val: "systems", pts: 3 },
          { text: "Mostly, but a few things would drop", val: "mostly", pts: 2 },
          { text: "Honestly, no. The place runs on tribal knowledge", val: "tribal", pts: 1 },
          { text: "We don't really do vacations around here", val: "no_vacations", pts: 1 }
        ]
      },
      {
        q: "Where does your customer data actually live?",
        sub: "Pick all that apply. We've seen every combo, no judgment, just integration math.",
        multi: true,
        opts: [
          { text: "A real CRM (HubSpot, Salesforce, Pipedrive, GoHighLevel)", val: "crm", pts: 3 },
          { text: "Industry software (ServiceTitan, Jobber, FieldEdge, JobNimbus)", val: "vertical_sw", pts: 3 },
          { text: "QuickBooks, Xero, or another accounting / ERP system", val: "erp", pts: 3 },
          { text: "Spreadsheets, email threads, and Slack", val: "basic", pts: 2 },
          { text: "Sticky notes, our phones, and people's heads, mostly", val: "ad_hoc", pts: 1 }
        ]
      },
      {
        q: "If we ship the fix in 3 weeks and it actually works, what changes most?",
        sub: "Helps us right-size the build and the conversation that follows.",
        opts: [
          { text: "10+ hours a week back to me or my team", val: "time_back", pts: 3 },
          { text: "More leads actually converting (we're losing some in the cracks)", val: "revenue", pts: 3 },
          { text: "Stuff stops slipping through the cracks. We sleep better.", val: "less_chaos", pts: 3 },
          { text: "Honestly? I just want to stop having the same problem next year.", val: "resignation", pts: 3 },
          { text: "Hard to put a number on it, but I know it's a problem.", val: "unsure", pts: 2 }
        ]
      }
    ];

    // ---------------------------------------------------------------------
    // SERVICE_MAP — Q2 answer → primary recommendation.
    // ---------------------------------------------------------------------
    const SERVICE_MAP = {
      leads: {
        title: "Lead Follow-Up Automation",
        oneLiner: "An AI agent that responds to every inbound lead in under 60 seconds, qualifies them, and books or routes the hot ones to your calendar.",
        timeBack: "8 to 12 hrs / week",
        outcome: "30 to 50% more booked calls",
        timeline: "1 to 3 weeks",
        serviceLink: "/services/lead-follow-up",
        caseLink: "/projects/inbound-ai-sdr",
        caseLabel: "INBOUND AI SDR · LIVE BUILD"
      },
      quoting: {
        title: "AI Quote Generator",
        oneLiner: "Auto-generated quotes from intake forms or emails. Inquiry to professional quote in under 10 minutes, no copy-paste, no missed line items.",
        timeBack: "10 to 15 hrs / week",
        outcome: "40% faster close cycle",
        timeline: "2 to 3 weeks",
        serviceLink: "/projects/cpq-agent",
        caseLink: "/projects/cpq-agent",
        caseLabel: "AI QUOTE GENERATOR · LIVE BUILD"
      },
      scheduling: {
        title: "Route + Dispatch Optimization",
        oneLiner: "AI plans your day's routes and assigns jobs to the right tech automatically. Cuts windshield time and double-bookings.",
        timeBack: "20 to 30% more jobs / day",
        outcome: "Less drive time, fewer reschedules",
        timeline: "2 to 3 weeks",
        serviceLink: "/services/route-optimization",
        caseLink: "/projects/route-simply",
        caseLabel: "ROUTE SIMPLY · LIVE BUILD"
      },
      admin: {
        title: "Client Onboarding + Admin Automation",
        oneLiner: "Pulls customer data into your systems automatically, fires welcome sequences, and handles invoice + paperwork generation end to end.",
        timeBack: "15 to 20 hrs / week",
        outcome: "Onboarding time cut by 70%",
        timeline: "2 to 3 weeks",
        serviceLink: "/services/client-onboarding",
        caseLink: "/projects/onboarding-workflow",
        caseLabel: "ONBOARDING WORKFLOW · LIVE BUILD"
      },
      hiring: {
        title: "AI Resume Screener",
        oneLiner: "Scores incoming resumes 1 to 10 against your fit criteria so your team only spends time on the top tier.",
        timeBack: "8 to 10 hrs / week",
        outcome: "Top-3 candidates surfaced same day",
        timeline: "1 to 2 weeks",
        serviceLink: "/services/resume-screening",
        caseLink: "/projects/screenfast",
        caseLabel: "SCREENFAST · BUILT FOR YMCA"
      },
      support: {
        title: "AI Receptionist + Review Management",
        oneLiner: "Picks up after-hours calls, answers FAQs, books appointments, and responds to reviews automatically.",
        timeBack: "5 to 7 hrs / week",
        outcome: "Never miss a call again",
        timeline: "1 to 2 weeks",
        serviceLink: "/services/review-management",
        caseLink: "/projects/after-hours-agent",
        caseLabel: "AFTER-HOURS AGENT · LIVE BUILD"
      }
    };

    // ---------------------------------------------------------------------
    // READINESS — score → tier copy + CTA shape.
    // ---------------------------------------------------------------------
    const READINESS = {
      high: {
        badge: "READY TO SHIP",
        line: "You're set up well. We can have this live in 1 to 3 weeks.",
        primary: { kind: "cal", label: "Talk to the Brothers" },
        secondary: { href: "/curious", label: "OR SEND A NOTE FIRST →" }
      },
      mid: {
        badge: "STRONG FIT",
        line: "Strong fit. Let's talk through scope. No deck, no pitch, just a 30-min call to map it out.",
        primary: { kind: "cal", label: "Book a discovery call" },
        secondary: { href: "/curious", label: "OR SEND A NOTE FIRST →" }
      },
      low: {
        badge: "EARLIER STAGE",
        line: "Earlier stage, but workable. Start with the Process Intake Framework or send us a note and we'll point you at where to begin.",
        primary: { kind: "note", href: "/curious", label: "Send us a note" },
        secondary: { href: "/resources/process-intake-framework", label: "OR READ THE FRAMEWORK →" }
      }
    };

    var quizState = {
      screen: 'landing',
      currentQ: 0,
      answers: [],
      score: 0,
      name: '',
      email: '',
      result: null,
      submitting: false,
      submitError: ''
    };

    function getResult(score) {
      var max = QUESTIONS.length * 3;
      var pct = score / max;
      if (pct >= 0.75) return 'high';
      if (pct >= 0.5) return 'mid';
      return 'low';
    }

    function getRecommendation(answers) {
      // Q2 (index 1) is the pain question and drives the primary rec.
      // Q2 is single-select, so answers[1] is an index, not an array.
      var q2idx = answers[1];
      if (q2idx === undefined) return SERVICE_MAP.leads;
      var val = QUESTIONS[1].opts[q2idx].val;
      return SERVICE_MAP[val] || SERVICE_MAP.leads;
    }

    function hasAnswer(qIdx) {
      var a = quizState.answers[qIdx];
      if (QUESTIONS[qIdx].multi) return Array.isArray(a) && a.length > 0;
      return a !== undefined && a !== null;
    }

    function pointsFor(qIdx) {
      var q = QUESTIONS[qIdx];
      var a = quizState.answers[qIdx];
      if (q.multi) {
        if (!Array.isArray(a) || !a.length) return 0;
        // For multi, take the max points among selected (don't reward
        // gaming by checking everything; reward picking the best stack).
        var max = 0;
        for (var k = 0; k < a.length; k++) {
          var p = q.opts[a[k]].pts;
          if (p > max) max = p;
        }
        return max;
      }
      return q.opts[a].pts;
    }

    function buildAnswersArray() {
      return quizState.answers.map(function(a, i) {
        var q = QUESTIONS[i];
        if (q.multi && Array.isArray(a)) {
          return {
            question: q.q,
            answer: a.map(function(j) { return q.opts[j].text; }).join(' | '),
            value: a.map(function(j) { return q.opts[j].val; }).join(',')
          };
        }
        return { question: q.q, answer: q.opts[a].text, value: q.opts[a].val };
      });
    }

    function setFullscreen(active) {
      var body = document.body;
      if (active) body.classList.add('op-mq-fullscreen');
      else body.classList.remove('op-mq-fullscreen');
    }

    function escHtml(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function(c) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
      });
    }

    function setStep(idLabel, statusLabel, progressPct) {
      var idEl = document.getElementById('mq-step-id');
      var statusEl = document.getElementById('mq-step-status');
      var progress = document.getElementById('mq-progress');
      var fill = document.getElementById('mq-progress-fill');
      if (idEl) idEl.textContent = idLabel;
      if (statusEl) statusEl.textContent = statusLabel;
      if (progress) {
        if (progressPct == null) {
          progress.hidden = true;
        } else {
          progress.hidden = false;
          if (fill) fill.style.width = progressPct + '%';
        }
      }
    }

    function renderQuiz() {
      var app = document.getElementById('app');
      if (!app) return;

      if (quizState.screen === 'landing') {
        setStep('DIAGNOSTIC · IDLE', '● READY', null);
        app.innerHTML =
          '<div class="op-mq-screen op-mq-landing">' +
            '<div class="op-mq-landing-grid">' +
              '<div class="op-mq-landing-cell"><span class="op-mono op-mq-cell-label">QUESTIONS</span><span class="op-mq-cell-value">6</span></div>' +
              '<div class="op-mq-landing-cell"><span class="op-mono op-mq-cell-label">TIME</span><span class="op-mq-cell-value">~60s</span></div>' +
              '<div class="op-mq-landing-cell"><span class="op-mono op-mq-cell-label">RESULT</span><span class="op-mq-cell-value">Real rec</span></div>' +
            '</div>' +
            '<button class="op-mq-btn op-mq-btn--primary" type="button" id="mq-start">' +
              '<span class="op-mq-btn-label">START THE DIAGNOSTIC</span>' +
              '<span class="op-mq-btn-arrow" aria-hidden="true">→</span>' +
            '</button>' +
            '<p class="op-mq-fineprint op-mono">' +
              '<span>NO EMAIL TO START</span>' +
              '<span class="op-mq-dot">·</span>' +
              '<span>NO PITCH</span>' +
              '<span class="op-mq-dot">·</span>' +
              '<span>RESULT IS A REAL RECOMMENDATION</span>' +
            '</p>' +
          '</div>';
        var startBtn = document.getElementById('mq-start');
        if (startBtn) startBtn.addEventListener('click', startQuiz);
      }

      else if (quizState.screen === 'question') {
        var q = QUESTIONS[quizState.currentQ];
        var pct = ((quizState.currentQ) / QUESTIONS.length) * 100;
        var stepNum = String(quizState.currentQ + 1).padStart(2, '0');
        var totalNum = String(QUESTIONS.length).padStart(2, '0');
        setStep('STEP_' + stepNum + ' / ' + totalNum, '● ' + (quizState.currentQ + 1) + ' of ' + QUESTIONS.length, pct);

        var selected = quizState.answers[quizState.currentQ];
        var isMulti = !!q.multi;
        var optsHtml = '';
        for (var i = 0; i < q.opts.length; i++) {
          var isSel = isMulti
            ? (Array.isArray(selected) && selected.indexOf(i) !== -1)
            : (selected === i);
          var indicatorClass = isMulti ? 'op-mq-opt-check' : 'op-mq-opt-radio';
          optsHtml += '<button type="button" class="op-mq-opt' + (isMulti ? ' op-mq-opt--multi' : '') + (isSel ? ' is-selected' : '') + '" data-opt="' + i + '">' +
            '<span class="' + indicatorClass + '" aria-hidden="true">' +
              (isMulti
                ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>'
                : '') +
            '</span>' +
            '<span class="op-mq-opt-text">' + escHtml(q.opts[i].text) + '</span>' +
          '</button>';
        }
        var isLast = quizState.currentQ === QUESTIONS.length - 1;
        var canAdvance = hasAnswer(quizState.currentQ);
        app.innerHTML =
          '<div class="op-mq-screen op-mq-question">' +
            '<p class="op-mono op-mq-q-label">QUESTION ' + stepNum + ' / ' + totalNum + (isMulti ? ' · PICK ALL THAT APPLY' : '') + '</p>' +
            '<h2 class="op-mq-q-text">' + escHtml(q.q) + '</h2>' +
            '<p class="op-mq-q-sub">' + escHtml(q.sub) + '</p>' +
            '<div class="op-mq-opts">' + optsHtml + '</div>' +
            '<div class="op-mq-nav">' +
              (quizState.currentQ > 0
                ? '<button type="button" class="op-mq-btn op-mq-btn--ghost" id="mq-prev"><span aria-hidden="true">←</span> BACK</button>'
                : '<span></span>') +
              '<button type="button" class="op-mq-btn op-mq-btn--primary" id="mq-next" ' + (canAdvance ? '' : 'disabled') + '>' +
                '<span class="op-mq-btn-label">' + (isLast ? 'SEE MY RESULTS' : 'NEXT') + '</span>' +
                '<span class="op-mq-btn-arrow" aria-hidden="true">→</span>' +
              '</button>' +
            '</div>' +
          '</div>';

        // Wire up option buttons
        var optBtns = app.querySelectorAll('.op-mq-opt');
        optBtns.forEach(function(b) {
          b.addEventListener('click', function() {
            selectOption(parseInt(b.getAttribute('data-opt'), 10));
          });
        });
        var prevBtn = document.getElementById('mq-prev');
        var nextBtn = document.getElementById('mq-next');
        if (prevBtn) prevBtn.addEventListener('click', prevQ);
        if (nextBtn) nextBtn.addEventListener('click', nextQ);
      }

      else if (quizState.screen === 'email') {
        setStep('STEP_07 / 07 · GATE', '● ALMOST THERE', 100);
        app.innerHTML =
          '<div class="op-mq-screen op-mq-email">' +
            '<p class="op-mono op-mq-q-label">RESULTS · READY</p>' +
            '<h2 class="op-mq-q-text">Your match is locked in.</h2>' +
            '<p class="op-mq-q-sub">Drop your name + email and we\'ll show you the system we\'d build, the time it gives back, and what it\'d cost. We\'ll also send a copy.</p>' +
            '<form class="op-mq-form" id="mq-form" novalidate>' +
              '<div class="op-mq-row">' +
                '<label class="op-mq-field">' +
                  '<span class="op-mono op-mq-label">NAME <span class="op-mq-req">*</span></span>' +
                  '<input type="text" name="name" id="mq-name" autocomplete="name" required maxlength="120" value="' + escHtml(quizState.name) + '" />' +
                '</label>' +
                '<label class="op-mq-field">' +
                  '<span class="op-mono op-mq-label">EMAIL <span class="op-mq-req">*</span></span>' +
                  '<input type="email" name="email" id="mq-email" autocomplete="email" required maxlength="160" inputmode="email" value="' + escHtml(quizState.email) + '" />' +
                '</label>' +
              '</div>' +
              '<div class="op-mq-honeypot" aria-hidden="true">' +
                '<label>Website</label>' +
                '<input type="text" name="website_hp" id="mq-hp" tabindex="-1" autocomplete="off" />' +
              '</div>' +
              '<div class="op-mq-nav op-mq-nav--end">' +
                '<button type="button" class="op-mq-btn op-mq-btn--ghost" id="mq-back-to-q"><span aria-hidden="true">←</span> BACK</button>' +
                '<button type="submit" class="op-mq-btn op-mq-btn--primary" id="mq-submit">' +
                  '<span class="op-mq-btn-label">SHOW MY RESULTS</span>' +
                  '<span class="op-mq-btn-arrow" aria-hidden="true">→</span>' +
                '</button>' +
              '</div>' +
              '<p class="op-mq-error" id="mq-error" role="alert" aria-live="polite">' + escHtml(quizState.submitError) + '</p>' +
              '<p class="op-mq-fineprint op-mono">' +
                '<span>NEVER SHARED</span>' +
                '<span class="op-mq-dot">·</span>' +
                '<span>NO MAILING LIST</span>' +
                '<span class="op-mq-dot">·</span>' +
                '<span>UNSUBSCRIBE ANY TIME</span>' +
              '</p>' +
            '</form>' +
          '</div>';
        var nameI = document.getElementById('mq-name');
        var emailI = document.getElementById('mq-email');
        var form = document.getElementById('mq-form');
        var backBtn = document.getElementById('mq-back-to-q');
        if (nameI) nameI.addEventListener('input', function() { quizState.name = this.value; });
        if (emailI) emailI.addEventListener('input', function() { quizState.email = this.value; });
        if (form) form.addEventListener('submit', function(e) { e.preventDefault(); submitQuiz(); });
        if (backBtn) backBtn.addEventListener('click', function() {
          quizState.screen = 'question';
          quizState.currentQ = QUESTIONS.length - 1;
          renderQuiz();
        });
      }

      else if (quizState.screen === 'results') {
        setStep('RESULT · LOCKED', '● MATCH FOUND', 100);
        var rec = getRecommendation(quizState.answers);
        var max = QUESTIONS.length * 3;
        var scorePct = Math.round((quizState.score / max) * 100);
        var tier = READINESS[quizState.result] || READINESS.low;
        var firstName = quizState.name ? quizState.name.split(' ')[0] : '';

        var primaryBtnHtml;
        if (tier.primary.kind === 'cal') {
          primaryBtnHtml = '<button type="button" class="op-mq-btn op-mq-btn--primary" data-cal-link="james-pinder/simple-automation-discovery" data-cal-namespace="simple-automation-discovery" data-cal-config=\'{"layout":"month_view"}\' data-track="cta_click" data-track-location="quiz-results" data-track-label="' + escHtml(tier.primary.label) + '">' +
            '<span class="op-mq-btn-label">' + escHtml(tier.primary.label).toUpperCase() + '</span>' +
            '<span class="op-mq-btn-arrow" aria-hidden="true">→</span>' +
          '</button>';
        } else {
          primaryBtnHtml = '<a class="op-mq-btn op-mq-btn--primary" href="' + escHtml(tier.primary.href) + '" data-track="cta_click" data-track-location="quiz-results" data-track-label="' + escHtml(tier.primary.label) + '">' +
            '<span class="op-mq-btn-label">' + escHtml(tier.primary.label).toUpperCase() + '</span>' +
            '<span class="op-mq-btn-arrow" aria-hidden="true">→</span>' +
          '</a>';
        }

        app.innerHTML =
          '<div class="op-mq-screen op-mq-results">' +
            '<div class="op-mq-result-head">' +
              '<span class="op-mono op-mq-result-tier">' + escHtml(tier.badge) + '</span>' +
              '<span class="op-mono op-mq-result-score">READINESS · ' + scorePct + '%</span>' +
            '</div>' +
            '<h2 class="op-mq-result-h">' +
              (firstName ? escHtml(firstName) + ', the system we\'d build:' : 'The system we\'d build:') + '<br />' +
              '<span class="op-mq-result-h-orange">' + escHtml(rec.title) + '.</span>' +
            '</h2>' +
            '<p class="op-mq-result-blurb">' + escHtml(rec.oneLiner) + '</p>' +
            '<div class="op-mq-result-strip">' +
              '<div class="op-mq-result-cell"><span class="op-mono op-mq-cell-label">TIME BACK</span><span class="op-mq-cell-value">' + escHtml(rec.timeBack) + '</span></div>' +
              '<div class="op-mq-result-cell"><span class="op-mono op-mq-cell-label">OUTCOME</span><span class="op-mq-cell-value">' + escHtml(rec.outcome) + '</span></div>' +
              '<div class="op-mq-result-cell"><span class="op-mono op-mq-cell-label">TIMELINE</span><span class="op-mq-cell-value">' + escHtml(rec.timeline) + '</span></div>' +
            '</div>' +
            '<p class="op-mq-result-readiness">' + escHtml(tier.line) + '</p>' +
            '<div class="op-mq-result-actions">' +
              primaryBtnHtml +
              '<a class="op-mq-result-link op-mono" href="' + escHtml(tier.secondary.href) + '">' + escHtml(tier.secondary.label) + '</a>' +
            '</div>' +
            '<div class="op-mq-result-aside">' +
              '<a class="op-mq-result-aside-link" href="' + escHtml(rec.caseLink) + '">' +
                '<span class="op-mono op-mq-aside-tag">SEE IT IN ACTION</span>' +
                '<span class="op-mq-aside-label">' + escHtml(rec.caseLabel) + '</span>' +
                '<span class="op-mq-aside-arrow" aria-hidden="true">→</span>' +
              '</a>' +
            '</div>' +
            '<button type="button" class="op-mq-retake op-mono" id="mq-retake">RETAKE QUIZ ↻</button>' +
          '</div>';

        var retakeBtn = document.getElementById('mq-retake');
        if (retakeBtn) retakeBtn.addEventListener('click', resetQuiz);

        // Tracking — preserved from original
        if (typeof fbq !== 'undefined') {
          try { fbq('track', 'Lead'); } catch (e) {}
        }
        if (typeof gtag !== 'undefined') {
          try { gtag('event', 'generate_lead', { method: 'meta_quiz' }); } catch (e) {}
        }
      }
    }

    function startQuiz() {
      quizState.screen = 'question';
      quizState.currentQ = 0;
      quizState.answers = [];
      quizState.score = 0;
      setFullscreen(true);
      renderQuiz();
    }
    function selectOption(i) {
      var qIdx = quizState.currentQ;
      var q = QUESTIONS[qIdx];
      if (q.multi) {
        var arr = Array.isArray(quizState.answers[qIdx]) ? quizState.answers[qIdx].slice() : [];
        var pos = arr.indexOf(i);
        if (pos === -1) arr.push(i);
        else arr.splice(pos, 1);
        quizState.answers[qIdx] = arr;
      } else {
        quizState.answers[qIdx] = i;
      }
      renderQuiz();
    }
    function nextQ() {
      if (!hasAnswer(quizState.currentQ)) return;
      quizState.score += pointsFor(quizState.currentQ);
      if (quizState.currentQ < QUESTIONS.length - 1) {
        quizState.currentQ++;
        renderQuiz();
      } else {
        quizState.result = getResult(quizState.score);
        quizState.screen = 'email';
        renderQuiz();
      }
    }
    function prevQ() {
      if (quizState.currentQ > 0) {
        var prevIdx = quizState.currentQ - 1;
        quizState.score -= pointsFor(prevIdx);
        quizState.currentQ--;
        renderQuiz();
      }
    }
    function resetQuiz() {
      quizState = { screen: 'landing', currentQ: 0, answers: [], score: 0, name: '', email: '', result: null, submitting: false, submitError: '' };
      setFullscreen(false);
      renderQuiz();
    }
    function exitQuiz() {
      // Close button: exit fullscreen, reset to landing.
      resetQuiz();
    }

    var SUPABASE_URL = 'https://nnxbgderdyjanzwgabxl.supabase.co';
    var SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ueGJnZGVyZHlqYW56d2dhYnhsIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NjkxODA3MzgsImV4cCI6MjA4NDc1NjczOH0.jpjZ_gH1-2GZgyhXPRzPrZzWWnJtAVgU4yui4KM6wZ8';

    function setSubmitError(msg) {
      quizState.submitError = msg || '';
      var errEl = document.getElementById('mq-error');
      if (errEl) {
        errEl.textContent = quizState.submitError;
        errEl.style.display = quizState.submitError ? 'block' : 'none';
      }
    }

    function submitQuiz() {
      var nameEl = document.getElementById('mq-name');
      var emailEl = document.getElementById('mq-email');
      var hpEl = document.getElementById('mq-hp');
      var submitBtn = document.getElementById('mq-submit');
      if (!nameEl || !emailEl || !submitBtn) return;
      if (quizState.submitting) return;

      var name = (nameEl.value || '').trim();
      var email = (emailEl.value || '').trim();
      var honeypot = hpEl ? (hpEl.value || '').trim() : '';

      // Honeypot — silently advance to results without submitting
      if (honeypot) {
        quizState.screen = 'results';
        renderQuiz();
        return;
      }

      if (!name) { setSubmitError('Please enter your name.'); return; }
      if (!email || email.indexOf('@') === -1 || email.lastIndexOf('.') < email.indexOf('@')) {
        setSubmitError('Please enter a valid email address.');
        return;
      }
      setSubmitError('');

      quizState.name = name;
      quizState.email = email;
      var rec = getRecommendation(quizState.answers);
      var max = QUESTIONS.length * 3;
      var pct = Math.round((quizState.score / max) * 100);
      var quizSegment = quizState.result === 'high' ? 'partner-ready' : 'partner-nurture';
      var answersArray = buildAnswersArray();

      quizState.submitting = true;
      submitBtn.disabled = true;
      var labelEl = submitBtn.querySelector('.op-mq-btn-label');
      if (labelEl) labelEl.textContent = 'SENDING…';

      // 1. Fire Gumloop via the same-origin proxy. The proxy forwards to
      // Gumloop server-side using the Authorization Bearer header so we
      // dodge the CORS preflight that was eating the body.
      var gumloopBody = JSON.stringify({
        name: name,
        email: email,
        quiz_score: String(pct),
        quiz_result: quizState.result,
        quiz_segment: quizSegment,
        recommended_automation: rec.title,
        answers: JSON.stringify(answersArray)
      });

      var gumloopPromise = fetch('/api/quiz-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: gumloopBody
      }).then(function(res) {
        if (!res.ok) throw new Error('Proxy returned ' + res.status);
        return res.json();
      }).catch(function(e) {
        console.log('Quiz submit error:', e);
      });

      // 2. Save lead to Supabase (preserved). Same-origin would be ideal,
      // but Supabase REST is fine cross-origin (it sends proper CORS
      // headers, unlike Gumloop).
      var supabaseHeaders = {
        'Content-Type': 'application/json',
        'apikey': SUPABASE_ANON_KEY,
        'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
        'Prefer': 'return=representation'
      };
      var supabasePromise = fetch(SUPABASE_URL + '/rest/v1/meta_quiz_leads', {
        method: 'POST',
        headers: supabaseHeaders,
        body: JSON.stringify({
          name: name,
          email: email,
          quiz_score: pct,
          quiz_result: quizState.result,
          quiz_segment: quizSegment,
          recommended_automation: rec.title
        })
      }).then(function(res) { return res.json(); })
        .then(function(data) {
          if (data && data[0] && data[0].id) {
            var leadId = data[0].id;
            var responses = answersArray.map(function(a, i) {
              return {
                lead_id: leadId,
                question_index: i,
                question_text: a.question,
                answer_text: a.answer,
                answer_value: a.value
              };
            });
            return fetch(SUPABASE_URL + '/rest/v1/meta_quiz_responses', {
              method: 'POST',
              headers: supabaseHeaders,
              body: JSON.stringify(responses)
            });
          }
        }).catch(function(e) {
          console.log('Supabase write error:', e);
        });

      // Wait for the Gumloop call (the most important one); we don't
      // block on Supabase since it's a logging-only side effect.
      Promise.all([gumloopPromise, supabasePromise]).finally(function() {
        quizState.submitting = false;
        quizState.screen = 'results';
        renderQuiz();
      });
    }

    // Close button (only visible in fullscreen) + Esc key to exit.
    var closeBtn = document.getElementById('mq-close');
    if (closeBtn) closeBtn.addEventListener('click', exitQuiz);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && document.body.classList.contains('op-mq-fullscreen')) {
        exitQuiz();
      }
    });

    renderQuiz();
  </script>
</Layout>

