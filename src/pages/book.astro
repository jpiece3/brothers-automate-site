---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Call — Brothers Automate" description="Schedule a free automation discovery call with the Brothers. We'll walk through your workflows and show you what can be automated.">
  <Header />

  <main class="book-page">
    <div class="book-container">
      <div class="book-header">
        <h1>Let's talk <span class="gradient-text">automation</span></h1>
        <p>Pick a time that works. We'll walk through your current workflows and show you exactly what we can automate. No pitch, no pressure.</p>
      </div>

      <div class="cal-wrapper">
        <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-simple-automation-discovery"></div>
      </div>
    </div>
  </main>

  <Footer />

  <script type="text/javascript" is:inline>
    Cal("init", "simple-automation-discovery", {origin:"https://app.cal.com"});

    Cal.ns["simple-automation-discovery"]("inline", {
      elementOrSelector:"#my-cal-inline-simple-automation-discovery",
      config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
      calLink: "james-pinder/simple-automation-discovery",
    });

    Cal.ns["simple-automation-discovery"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});

    // Meta Pixel - Track bookings from this page
    // Uses both Cal SDK callback AND direct postMessage listener for reliability
    Cal.ns["simple-automation-discovery"]("on", {
      action: "bookingSuccessful",
      callback: function() {
        if (!window.__leadEventFired) {
          window.__leadEventFired = true;
          if (typeof fbq !== 'undefined') {
            fbq('track', 'Schedule');
            fbq('track', 'Lead');
            console.log('[BA] Meta Lead event fired via Cal callback (book page)');
          }
          if (typeof gtag !== 'undefined') {
            gtag('event', 'booking_complete', { method: 'cal_inline_book_page' });
          }
        }
      }
    });

    // Fallback: listen for Cal.com postMessage directly
    window.addEventListener('message', function(e) {
      if (e.origin !== 'https://app.cal.com') return;
      try {
        var data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
        if (data && data.action === 'bookingSuccessful' && !window.__leadEventFired) {
          window.__leadEventFired = true;
          if (typeof fbq !== 'undefined') {
            fbq('track', 'Schedule');
            fbq('track', 'Lead');
            console.log('[BA] Meta Lead event fired via postMessage fallback (book page)');
          }
          if (typeof gtag !== 'undefined') {
            gtag('event', 'booking_complete', { method: 'cal_inline_book_page' });
          }
        }
      } catch(err) {}
    });
  </script>
</Layout>

<style>
  .book-page {
    min-height: 100vh;
    padding: 120px 24px 60px;
    background: var(--bg-primary);
    background-image:
      radial-gradient(circle at 20% 50%, rgba(237, 137, 54, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(49, 130, 206, 0.04) 0%, transparent 50%),
      radial-gradient(circle at 50% 80%, rgba(26, 54, 93, 0.02) 0%, transparent 50%);
  }

  .book-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .book-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .book-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .book-header h1 .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--text-secondary) 50%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .book-header p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .cal-wrapper {
    min-height: 600px;
    border-radius: 12px;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .book-header h1 {
      font-size: 1.75rem;
    }

    .book-header p {
      font-size: 1rem;
    }

    .book-page {
      padding: 100px 16px 40px;
    }
  }
</style>
