---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Book a Call — Brothers Automate" description="Schedule a free automation discovery call with the Brothers. We'll walk through your workflows and show you what can be automated.">
  <Header />

  <main class="book-page">
    <div class="book-container">
      <div class="book-header">
        <h1>Let's talk automation</h1>
        <p>Pick a time that works. We'll walk through your current workflows and show you exactly what we can automate. No pitch, no pressure.</p>
      </div>

      <div class="cal-wrapper">
        <div style="width:100%;height:100%;overflow:scroll" id="my-cal-inline-simple-automation-discovery"></div>
      </div>
    </div>
  </main>

  <Footer />

  <script type="text/javascript" is:inline>
    Cal("init", "simple-automation-discovery", {origin:"https://app.cal.com"});

    Cal.ns["simple-automation-discovery"]("inline", {
      elementOrSelector:"#my-cal-inline-simple-automation-discovery",
      config: {"layout":"month_view","useSlotsViewOnSmallScreen":"true"},
      calLink: "james-pinder-simpleflo/simple-automation-discovery",
    });

    Cal.ns["simple-automation-discovery"]("ui", {"hideEventTypeDetails":false,"layout":"month_view"});

    // Meta Pixel - Track bookings from this page
    Cal.ns["simple-automation-discovery"]("on", {
      action: "bookingSuccessful",
      callback: function() {
        if (typeof fbq !== 'undefined') {
          fbq('track', 'Schedule');
        }
      }
    });
  </script>
</Layout>

<style>
  .book-page {
    min-height: 100vh;
    padding: 120px 24px 60px;
    background: var(--bg-primary);
  }

  .book-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .book-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .book-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 12px;
  }

  .book-header p {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .cal-wrapper {
    min-height: 600px;
    border-radius: 12px;
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .book-header h1 {
      font-size: 1.75rem;
    }

    .book-header p {
      font-size: 1rem;
    }

    .book-page {
      padding: 100px 16px 40px;
    }
  }
</style>
