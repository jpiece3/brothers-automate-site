---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categories = [...new Set(posts.map((post) => post.data.category))];
---

<Layout
  title="Blog | AI Automation Insights for Service Businesses | Brothers Automate"
  description="Operator-style guides on lead generation, automation, and the AI systems that actually move the needle for service businesses."
>
  <Header />
  <main>
    {/* Hero */}
    <section class="op-blog-hero op-grid-bg">
      <div class="op-blog-hero-frame">
        <div class="op-blog-hero-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / RESOURCES · BLOG"
            right={`${posts.length} ARTICLES · ${categories.length} CATEGORIES`}
            bordered
          />
        </div>
        <EyebrowTag label="LOG · OPERATOR INSIGHTS" />
        <h1 class="op-blog-h1" data-animate="fade-up">Notes from the workshop floor.</h1>
        <p class="op-blog-sub" data-animate="fade-up">
          Plain-English guides on AI automation, lead gen, and the systems we ship every week. Written by operators, not consultants.
        </p>
      </div>
    </section>

    {/* Listing */}
    <section class="op-blog-listing">
      <div class="op-blog-listing-frame">
        {posts.length > 0 ? (
          <div class="op-blog-grid" data-animate-stagger>
            {posts.map((post, i) => (
              <BlogCard
                title={post.data.title}
                description={post.data.description}
                date={post.data.date}
                category={post.data.category}
                slug={post.slug}
                image={post.data.image}
                index={i}
              />
            ))}
          </div>
        ) : (
          <div class="op-blog-empty">
            <p class="op-mono">NEW ENTRIES INCOMING · CHECK BACK SOON</p>
          </div>
        )}
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>

<style>
  .op-blog-hero {
    padding: 120px var(--op-section-px) 64px;
    color: var(--op-ink);
  }
  .op-blog-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-blog-hero-util { margin-bottom: 32px; }
  .op-blog-hero :global(.op-eyebrow) { margin-bottom: 24px; }

  .op-blog-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 800px;
    text-wrap: balance;
  }
  .op-blog-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 660px;
    text-wrap: pretty;
  }

  .op-blog-listing {
    padding: 56px var(--op-section-px) 96px;
    background: var(--op-cream);
    border-top: var(--op-border);
  }
  .op-blog-listing-frame { max-width: var(--op-max-content); margin: 0 auto; }

  .op-blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 700px) { .op-blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .op-blog-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-blog-empty {
    padding: 72px 0;
    text-align: center;
  }
  .op-blog-empty p {
    font-size: 11px;
    color: var(--op-navy-soft);
  }

  @media (max-width: 700px) {
    .op-blog-hero,
    .op-blog-listing { padding-left: 22px; padding-right: 22px; }
  }
</style>
