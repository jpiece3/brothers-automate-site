---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TopUtilityStrip from '../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../components/operator/EyebrowTag.astro';
import MonoCTA from '../components/operator/MonoCTA.astro';

const SITE_URL = 'https://brothersautomate.com';
const PAGE_URL = `${SITE_URL}/free-ai-audit/`;
// Brendan's AI Wins discovery call — only used on this page. All other site CTAs stay on James's Cal.
const CAL_LINK = 'brendan-pinder-dp3d5v/30min';
const CAL_NAMESPACE = '30min';

const phases = [
  {
    num: '01',
    title: 'Instant Site Audit',
    time: '20 seconds',
    body: 'Drop in your URL. We scan speed, SEO, mobile, trust, and how well your site captures leads, and score it on the spot.',
  },
  {
    num: '02',
    title: 'AI Opportunity Analysis',
    time: 'On submit',
    body: 'Our engine turns the findings, plus the pain point you tell us, into 5-7 specific automations mapped to systems we actually build.',
  },
  {
    num: '03',
    title: 'Discovery Call',
    time: '30 minutes',
    body: "We walk through your day and where time leaks. No pitch, we're pulling problems, not pushing tools.",
  },
  {
    num: '04',
    title: 'Review & Roadmap',
    time: '30 minutes',
    body: 'You get a prioritized roadmap with quick wins, ROI, and a 4-day quick-start. Implement it yourself or have us build it.',
  },
];

const audience = [
  { label: 'Home & field service', detail: 'HVAC, plumbing, electrical, remodels, drowning in quotes and follow-up.' },
  { label: 'Engineering & construction', detail: 'Civil, structural, and design firms running complex multi-stage projects.' },
  { label: 'Managed IT & MSPs', detail: 'Help desks and IT providers buried in tickets, intake, and compliance admin.' },
  { label: 'Local high-margin operators', detail: 'Coaches, agencies, clinics, and pros doing $1-15M who want capacity without hiring.' },
];

const stats = [
  { value: '<60s', label: 'Inbound lead reply time', context: 'Inbound AI SDR' },
  { value: '2-3x', label: 'More qualified leads', context: 'Lead Qualification Quiz' },
  { value: '<2 min', label: 'Quote delivery', context: 'AI Quote Generator' },
  { value: '6+ hrs', label: 'Freed up per week', context: 'For ~$40/mo in tool costs' },
];

const faqs = [
  {
    q: 'Is the audit really free?',
    a: "Yes. The instant site score and the AI opportunity report cost nothing, and the 30-minute discovery and review calls are free too. We give away the audit because it's the fastest way to show you what we'd build. No card, no obligation.",
  },
  {
    q: 'What do I need to provide?',
    a: 'To run the instant audit, just your website URL. To get the full report, your name, email, and a sentence on what is eating your time. For the optional discovery call, 30 minutes and access to the tools you already use.',
  },
  {
    q: 'Will you just try to sell me?',
    a: "No. The call is built to pull problems, not push tools. You walk away with a roadmap either way. If you want to implement it yourself, great. If you want help, we'll scope it, that's the only upsell.",
  },
  {
    q: 'How accurate is the instant audit?',
    a: 'It pulls real signals: a live crawl of your page plus Google Lighthouse performance and SEO scores. It is a fast, honest snapshot, the human + AI analysis in the full report is where the real opportunities surface.',
  },
  {
    q: 'Who is this for?',
    a: 'Service and technical businesses doing roughly $1-15M, home service, engineering, IT/MSPs, agencies, clinics, and similar local operators who are great at the work but losing hours to manual busywork.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Free AI Audit', item: PAGE_URL },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Free AI Business Audit',
  provider: { '@type': 'Organization', name: 'Brothers Automate', url: SITE_URL },
  areaServed: 'United States',
  description:
    'A free AI audit for service and technical businesses. Get an instant website score plus a prioritized report of 5-7 AI automations that save time and capture more leads.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<Layout
  title="Free AI Audit for Service Businesses | Brothers Automate"
  description="Get a free, instant AI audit of your business. Score your website in 20 seconds, then get a prioritized report of 5-7 AI automations that save hours and capture more leads. No cost, no obligation."
  canonicalUrl={PAGE_URL}
  extraSchemas={[breadcrumbSchema, faqSchema, serviceSchema]}
>
  <Header />
  <main>
    <!-- ============================ HERO + AUDIT ENGINE ============================ -->
    <section class="op-audit-hero op-grid-bg">
      <div class="op-audit-frame">
        <div class="op-audit-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / AUDIT · FREE"
            right="● AUDIT ENGINE ONLINE · NO CARD REQUIRED"
            bordered
          />
        </div>

        <div class="op-audit-grid">
          <div class="op-audit-intro">
            <EyebrowTag label="FREE AI AUDIT · FOR SERVICE & TECHNICAL BUSINESSES" />
            <h1 class="op-audit-h1" data-animate="fade-up">
              How many hours can AI<br />
              <span class="op-audit-h1-orange">save YOU?</span>
            </h1>
            <a
              href="#"
              class="op-audit-cal-cta op-mono"
              data-cal-link={CAL_LINK}
              data-cal-namespace={CAL_NAMESPACE}
              data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
              data-track="cta_click"
              data-track-location="audit-hero"
              data-track-label="Find Your AI Wins"
              data-animate="fade-up"
            >
              FIND YOUR AI WINS <span aria-hidden="true">→</span>
            </a>
            <p class="op-audit-sub" data-animate="fade-up">
              Drop in your website and get an instant score, then a prioritized report of the
              5-7 automations that would save you the most time and capture the most leads.
              Built on the same systems we run for $1-15M service businesses.
            </p>
            <ul class="op-audit-bullets op-mono">
              <li><span class="op-pulse-dot"></span><span>INSTANT SCORE · NO SIGNUP TO SEE IT</span></li>
              <li><span class="op-pulse-dot"></span><span>5-7 AI OPPORTUNITIES MAPPED TO YOUR GAPS</span></li>
              <li><span class="op-pulse-dot"></span><span>FREE · NO OBLIGATION · NEVER SHARED</span></li>
            </ul>
          </div>

          <!-- AUDIT CONSOLE -->
          <div class="op-audit-panel" data-animate="fade-up">
            <div class="op-audit-panel-header">
              <span class="op-pulse-dot"></span>
              <span class="op-mono op-audit-panel-id">AUDIT_ENGINE · v.2026</span>
              <span class="op-mono op-audit-panel-status" id="audit-status">● READY</span>
            </div>

            <!-- STAGE: input -->
            <div class="op-audit-stage" id="stage-input">
              <form id="audit-scan-form" novalidate>
                <label class="op-audit-field">
                  <span class="op-mono op-audit-label">YOUR WEBSITE</span>
                  <input
                    type="text"
                    id="audit-url"
                    name="url"
                    inputmode="url"
                    autocomplete="url"
                    placeholder="yourcompany.com"
                    maxlength="300"
                  />
                </label>
                <button type="submit" id="audit-scan-btn" class="op-audit-submit op-mono">
                  <span class="op-audit-submit-label">RUN MY FREE WEBSITE AUDIT</span>
                  <span class="op-audit-submit-arrow" aria-hidden="true">→</span>
                </button>
                <p class="op-audit-fineprint op-mono">FREE · INSTANT SCORE · ~20 SECONDS · NO SIGNUP TO SEE IT</p>
                <p class="op-audit-error" id="scan-error" role="alert" aria-live="polite"></p>
              </form>
            </div>

            <!-- STAGE: loading -->
            <div class="op-audit-stage" id="stage-loading" hidden>
              <p class="op-mono op-audit-loading-head"><span class="op-pulse-dot"></span> SCANNING <span id="loading-domain">YOUR SITE</span></p>
              <ul class="op-audit-steps op-mono" id="loading-steps">
                <li data-step>FETCHING PAGE</li>
                <li data-step>CHECKING SEO &amp; META</li>
                <li data-step>TESTING MOBILE &amp; SPEED</li>
                <li data-step>SCORING LEAD CAPTURE</li>
                <li data-step>COMPILING FINDINGS</li>
              </ul>
            </div>

            <!-- STAGE: teaser -->
            <div class="op-audit-stage" id="stage-teaser" hidden>
              <div class="op-audit-scoreline">
                <div class="op-audit-gauge" id="score-gauge">
                  <div class="op-audit-gauge-inner">
                    <span class="op-audit-gauge-num" id="score-num">0</span>
                    <span class="op-audit-gauge-of op-mono">/100</span>
                  </div>
                </div>
                <div class="op-audit-scoremeta">
                  <span class="op-mono op-audit-scoremeta-label">OVERALL SCORE · <span id="score-domain"></span></span>
                  <span class="op-audit-grade" id="score-grade">B</span>
                  <span class="op-audit-grade-note op-mono" id="score-note"></span>
                </div>
              </div>

              <div class="op-audit-cats" id="score-cats"></div>

              <div class="op-audit-findings">
                <p class="op-mono op-audit-findings-head">TOP FINDINGS</p>
                <ul id="teaser-findings"></ul>
              </div>

              <div class="op-audit-gate">
                <div class="op-audit-gate-head">
                  <span class="op-pulse-dot"></span>
                  <span class="op-mono">UNLOCK YOUR FULL AI OPPORTUNITY REPORT</span>
                </div>
                <p class="op-audit-gate-sub">
                  Get the 5-7 specific automations we'd build to fix what we found, with impact, effort, and ROI. Sent free.
                </p>
                <form id="audit-lead-form" novalidate>
                  <div class="op-audit-row">
                    <label class="op-audit-field">
                      <span class="op-mono op-audit-label">NAME <span class="op-audit-req">*</span></span>
                      <input type="text" id="lead-name" name="name" required autocomplete="name" maxlength="120" />
                    </label>
                    <label class="op-audit-field">
                      <span class="op-mono op-audit-label">EMAIL <span class="op-audit-req">*</span></span>
                      <input type="email" id="lead-email" name="email" required autocomplete="email" inputmode="email" maxlength="160" />
                    </label>
                  </div>
                  <div class="op-audit-row">
                    <label class="op-audit-field">
                      <span class="op-mono op-audit-label">PHONE <span class="op-audit-opt">OPTIONAL</span></span>
                      <input type="tel" id="lead-phone" name="phone" autocomplete="tel" maxlength="40" />
                    </label>
                    <label class="op-audit-field">
                      <span class="op-mono op-audit-label">BUSINESS TYPE <span class="op-audit-opt">OPTIONAL</span></span>
                      <input type="text" id="lead-biztype" name="business_type" maxlength="120" placeholder="e.g. HVAC, IT MSP, agency" />
                    </label>
                  </div>
                  <label class="op-audit-field">
                    <span class="op-mono op-audit-label">BIGGEST TIME DRAIN <span class="op-audit-opt">OPTIONAL BUT HELPS</span></span>
                    <textarea id="lead-pain" name="pain_point" rows="3" maxlength="2000" placeholder="Where do you lose the most time? Slow follow-up, manual quoting, scheduling, hiring..."></textarea>
                  </label>

                  <div class="op-audit-honeypot" aria-hidden="true">
                    <label>Website</label>
                    <input type="text" id="lead-hp" name="website_hp" tabindex="-1" autocomplete="off" />
                  </div>

                  <button type="submit" id="lead-submit" class="op-audit-submit op-mono">
                    <span class="op-audit-submit-label">GET MY AI REPORT</span>
                    <span class="op-audit-submit-arrow" aria-hidden="true">→</span>
                  </button>
                  <p class="op-audit-fineprint op-mono">FREE · NO OBLIGATION · WE NEVER SHARE YOUR INFO</p>
                  <p class="op-audit-error" id="lead-error" role="alert" aria-live="polite"></p>
                </form>
              </div>
            </div>

            <!-- STAGE: report -->
            <div class="op-audit-stage" id="stage-report" hidden>
              <div class="op-audit-report-head">
                <span class="op-mono op-audit-report-eyebrow">● AI OPPORTUNITY REPORT · READY</span>
                <h2 class="op-audit-report-title" id="report-headline">Your AI opportunity report</h2>
                <p class="op-audit-report-summary" id="report-summary"></p>
              </div>
              <div class="op-audit-recs" id="report-recs"></div>
              <div class="op-audit-impact">
                <div class="op-audit-impact-num"><span id="report-hours">6</span><span class="op-audit-impact-unit">hrs/wk</span></div>
                <p class="op-audit-impact-text">Estimated time these automations could free up, for roughly <strong>$40/mo</strong> in tool costs.</p>
              </div>
              <div class="op-audit-report-cta">
                <a
                  href="#"
                  class="op-audit-book op-mono"
                  data-cal-link={CAL_LINK}
                  data-cal-namespace={CAL_NAMESPACE}
                  data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
                  data-track="cta_click"
                  data-track-location="audit-report"
                  data-track-label="Book Audit Review Call"
                >
                  BOOK YOUR FREE REVIEW CALL <span aria-hidden="true">→</span>
                </a>
                <a href="/projects" class="op-audit-report-link op-mono">SEE THE BUILDS →</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================ PROOF METRICS ============================ -->
    <section class="op-audit-proof">
      <div class="op-audit-section-frame">
        <div class="op-audit-section-head">
          <EyebrowTag label="PROOF · FROM SYSTEMS WE ACTUALLY RUN" variant="paper" />
          <h2 class="op-audit-h2">Not theory. Numbers from live builds.</h2>
        </div>
        <div class="op-audit-stats">
          {stats.map((s) => (
            <div class="op-audit-stat">
              <span class="op-audit-stat-num">{s.value}</span>
              <span class="op-audit-stat-label">{s.label}</span>
              <span class="op-mono op-audit-stat-context">{s.context}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================ WHO IT'S FOR ============================ -->
    <section class="op-audit-who op-grid-bg">
      <div class="op-audit-section-frame">
        <div class="op-audit-section-head">
          <EyebrowTag label="WHO IT'S FOR" variant="paper" />
          <h2 class="op-audit-h2">Built for operators buried in repeat work.</h2>
          <p class="op-audit-section-sub">
            If you're great at the work but losing hours to follow-up, quoting, scheduling, and admin, this audit is built for you.
          </p>
        </div>
        <div class="op-audit-who-grid">
          {audience.map((a, i) => (
            <div class="op-audit-who-card">
              <span class="op-mono op-audit-who-num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="op-audit-who-label">{a.label}</h3>
              <p class="op-audit-who-detail">{a.detail}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================ PROCESS ============================ -->
    <section class="op-audit-process">
      <div class="op-audit-section-frame">
        <div class="op-audit-section-head">
          <EyebrowTag label="THE PROCESS · 04 STEPS" variant="paper" />
          <h2 class="op-audit-h2">From URL to roadmap.</h2>
          <p class="op-audit-section-sub">
            The first two steps happen right here, in seconds. The last two are free calls, only if you want them.
          </p>
        </div>
        <div class="op-audit-steps-grid">
          {phases.map((p) => (
            <div class="op-audit-phase">
              <div class="op-audit-phase-top">
                <span class="op-mono op-audit-phase-num">{p.num}</span>
                <span class="op-mono op-audit-phase-time">{p.time}</span>
              </div>
              <h3 class="op-audit-phase-title">{p.title}</h3>
              <p class="op-audit-phase-body">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================ WHY FREE ============================ -->
    <section class="op-audit-whyfree">
      <div class="op-audit-section-frame op-audit-whyfree-inner">
        <div>
          <EyebrowTag label="WHY IT'S FREE" />
          <h2 class="op-audit-h2 op-audit-h2-light">We'd rather show you than tell you.</h2>
        </div>
        <div class="op-audit-whyfree-body">
          <p>
            Most operators know AI could help but have no idea where to start, so they do nothing.
            The audit fixes that. It shows you exactly where automation fits and what it's worth, on your real business, in plain English.
          </p>
          <p>
            If you take the roadmap and build it yourself, genuinely great. If you'd rather we handle it,
            we do project builds and an embedded partnership, but there's never any pressure. The audit stands on its own.
          </p>
          <MonoCTA
            label="Find Your AI Wins"
            variant="orange"
            size="lg"
            calLink={CAL_LINK}
            trackLocation="audit-whyfree"
            trackLabel="Find Your AI Wins"
          />
        </div>
      </div>
    </section>

    <!-- ============================ FAQ ============================ -->
    <section class="op-audit-faq op-grid-bg">
      <div class="op-audit-section-frame op-audit-faq-frame">
        <div class="op-audit-section-head">
          <EyebrowTag label="FAQ · BEFORE YOU RUN IT" variant="paper" />
          <h2 class="op-audit-h2">Questions, answered straight.</h2>
        </div>
        <div class="op-audit-faq-list">
          {faqs.map((f) => (
            <details class="op-audit-faq-item">
              <summary>
                <span>{f.q}</span>
                <span class="op-audit-faq-plus" aria-hidden="true">+</span>
              </summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    (function () {
      var SCAN_URL = '/api/audit-scan';
      var SUBMIT_URL = '/api/audit-submit';

      var scanForm = document.getElementById('audit-scan-form');
      var leadForm = document.getElementById('audit-lead-form');
      if (!scanForm || !leadForm) return;

      var stages = {
        input: document.getElementById('stage-input'),
        loading: document.getElementById('stage-loading'),
        teaser: document.getElementById('stage-teaser'),
        report: document.getElementById('stage-report'),
      };
      var statusEl = document.getElementById('audit-status');
      var scanBtn = document.getElementById('audit-scan-btn');
      var leadBtn = document.getElementById('lead-submit');
      var scanError = document.getElementById('scan-error');
      var leadError = document.getElementById('lead-error');

      var scanData = null;

      function show(stage) {
        Object.keys(stages).forEach(function (k) {
          if (stages[k]) stages[k].hidden = k !== stage;
        });
      }
      function setStatus(text) { if (statusEl) statusEl.textContent = text; }
      function setError(el, msg) {
        if (!el) return;
        el.textContent = msg || '';
        el.style.display = msg ? 'block' : 'none';
      }
      function esc(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
          return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
        });
      }
      function bandColor(score) {
        if (score >= 75) return 'var(--green)';
        if (score >= 45) return 'var(--op-orange)';
        return 'var(--red)';
      }

      // ---- loading step animation ----
      var loadingTimer = null;
      function startLoading(domain) {
        var dEl = document.getElementById('loading-domain');
        if (dEl) dEl.textContent = (domain || 'your site').toUpperCase();
        var steps = Array.prototype.slice.call(document.querySelectorAll('#loading-steps [data-step]'));
        steps.forEach(function (s) { s.classList.remove('is-done', 'is-active'); });
        var i = 0;
        if (steps[0]) steps[0].classList.add('is-active');
        loadingTimer = setInterval(function () {
          if (steps[i]) { steps[i].classList.remove('is-active'); steps[i].classList.add('is-done'); }
          i++;
          if (i < steps.length) steps[i].classList.add('is-active');
          else clearInterval(loadingTimer);
        }, 1400);
      }
      function stopLoading() { if (loadingTimer) clearInterval(loadingTimer); }

      // ---- render teaser ----
      function renderTeaser(data) {
        var num = document.getElementById('score-num');
        var grade = document.getElementById('score-grade');
        var gauge = document.getElementById('score-gauge');
        var note = document.getElementById('score-note');
        var domEl = document.getElementById('score-domain');
        if (domEl) domEl.textContent = data.domain || '';
        if (grade) grade.textContent = data.grade;
        if (gauge) gauge.style.setProperty('--gauge-color', bandColor(data.score));
        if (note) {
          note.textContent = data.score >= 80 ? 'Strong, with room to automate' : data.score >= 60 ? 'Decent, real gaps to close' : 'Big opportunities waiting';
        }
        // animate the number
        if (num) {
          var target = data.score, start = performance.now(), dur = 900;
          (function tick(now) {
            var t = Math.min(1, (now - start) / dur);
            var eased = 1 - Math.pow(1 - t, 3);
            num.textContent = Math.round(target * eased);
            if (gauge) gauge.style.setProperty('--gauge-pct', (target * eased) + '%');
            if (t < 1) requestAnimationFrame(tick);
          })(start);
        }

        var cats = document.getElementById('score-cats');
        if (cats) {
          cats.innerHTML = data.categories.map(function (c) {
            return (
              '<div class="op-audit-cat">' +
              '<div class="op-audit-cat-top">' +
              '<span class="op-audit-cat-label">' + esc(c.label) + '</span>' +
              '<span class="op-audit-cat-score" style="color:' + bandColor(c.score) + '">' + c.score + '</span>' +
              '</div>' +
              '<div class="op-audit-cat-bar"><span style="width:' + c.score + '%;background:' + bandColor(c.score) + '"></span></div>' +
              '</div>'
            );
          }).join('');
        }

        var findings = document.getElementById('teaser-findings');
        if (findings) {
          findings.innerHTML = data.teaser.map(function (f) {
            return (
              '<li class="op-audit-finding op-audit-finding--' + esc(f.severity) + '">' +
              '<p class="op-audit-finding-tag">' + esc(f.label) + '</p>' +
              '<p class="op-audit-finding-msg">' + esc(f.message) + '</p></li>'
            );
          }).join('');
        }
      }

      function formatRecTags(r) {
        var type = r.category === 'strategic' ? 'Strategic' : 'Quick Win';
        var impact = r.impact || 'Medium';
        var effort = r.effort || 'Medium';
        return type + ', Impact ' + impact + ' · Effort ' + effort;
      }

      // ---- render report ----
      function renderReport(report) {
        var h = document.getElementById('report-headline');
        var sum = document.getElementById('report-summary');
        var hours = document.getElementById('report-hours');
        if (h) h.textContent = report.headline || 'Your AI opportunity report';
        if (sum) sum.textContent = report.executiveSummary || '';
        if (hours) hours.textContent = report.estimatedHoursPerWeek || 6;

        var wrap = document.getElementById('report-recs');
        if (wrap) {
          wrap.innerHTML = (report.recommendations || []).map(function (r, i) {
            var build = r.build
              ? '<a class="op-audit-rec-build" href="/projects/' + esc(r.build.slug) + '">' + esc(r.build.name) + ' →</a>'
              : '';
            var tags = formatRecTags(r);
            return (
              '<div class="op-audit-rec">' +
              '<div class="op-audit-rec-head">' +
              '<span class="op-audit-rec-num">' + String(i + 1).padStart(2, '0') + '</span>' +
              '<span class="op-audit-rec-tags op-audit-rec-cat--' + (r.category || 'quick-win') + '">' + esc(tags) + '</span>' +
              '</div>' +
              '<h3 class="op-audit-rec-title">' + esc(r.title) + '</h3>' +
              '<p class="op-audit-rec-desc">' + esc(r.description) + '</p>' +
              (r.reasoning
                ? '<div class="op-audit-rec-why">' +
                  '<span class="op-audit-rec-why-label">Why</span>' +
                  '<p class="op-audit-rec-why-text">' + esc(r.reasoning) + '</p>' +
                  '</div>'
                : '') +
              build +
              '</div>'
            );
          }).join('');
        }
      }

      // ---- scan submit ----
      scanForm.addEventListener('submit', function (e) {
        e.preventDefault();
        setError(scanError, '');
        var url = (document.getElementById('audit-url').value || '').trim();
        if (!url || url.indexOf('.') === -1) {
          setError(scanError, 'Enter your website address, e.g. yourcompany.com');
          return;
        }
        var domainGuess = url.replace(/^https?:\/\//i, '').replace(/^www\./i, '').split('/')[0];
        scanBtn.disabled = true;
        setStatus('● SCANNING');
        show('loading');
        startLoading(domainGuess);

        fetch(SCAN_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url: url }),
        })
          .then(function (res) {
            return res.json().then(function (data) {
              if (!res.ok) throw new Error(data && data.error ? data.error : 'Scan failed.');
              return data;
            });
          })
          .then(function (data) {
            scanData = data;
            stopLoading();
            renderTeaser(data);
            setStatus('● SCORE READY');
            show('teaser');
            if (typeof gtag !== 'undefined') { try { gtag('event', 'audit_scan_complete', { score: data.score }); } catch (e) {} }
            if (typeof fbq !== 'undefined') { try { fbq('trackCustom', 'AuditScan', { score: data.score }); } catch (e) {} }
            stages.teaser.scrollIntoView({ behavior: 'smooth', block: 'start' });
          })
          .catch(function (err) {
            stopLoading();
            scanBtn.disabled = false;
            setStatus('● READY');
            show('input');
            setError(scanError, err.message || "We couldn't scan that site. Check the address and try again.");
          });
      });

      // ---- lead submit ----
      leadForm.addEventListener('submit', function (e) {
        e.preventDefault();
        setError(leadError, '');
        var honeypot = (document.getElementById('lead-hp').value || '').trim();
        if (honeypot) { show('report'); return; }

        var name = (document.getElementById('lead-name').value || '').trim();
        var email = (document.getElementById('lead-email').value || '').trim();
        if (!name) { setError(leadError, 'Please enter your name.'); return; }
        if (!email || email.indexOf('@') === -1 || email.indexOf('.') === -1) {
          setError(leadError, 'Please enter a valid email.');
          return;
        }

        leadBtn.disabled = true;
        leadBtn.classList.add('is-loading');
        var label = leadBtn.querySelector('.op-audit-submit-label');
        if (label) label.textContent = 'BUILDING REPORT…';
        setStatus('● ANALYZING');

        var payload = {
          name: name,
          email: email,
          phone: (document.getElementById('lead-phone').value || '').trim(),
          business_type: (document.getElementById('lead-biztype').value || '').trim(),
          pain_point: (document.getElementById('lead-pain').value || '').trim(),
          url: scanData ? scanData.url : '',
          domain: scanData ? scanData.domain : '',
          score: scanData ? scanData.score : null,
          signals: scanData ? scanData.signals : {},
          source: 'free-ai-audit',
        };

        fetch(SUBMIT_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then(function (res) {
            return res.json().then(function (data) {
              if (!res.ok) throw new Error(data && data.error ? data.error : 'Could not build report.');
              return data;
            });
          })
          .then(function (data) {
            if (typeof fbq !== 'undefined') { try { fbq('track', 'Lead'); } catch (e) {} }
            if (typeof gtag !== 'undefined') { try { gtag('event', 'audit_report_unlocked', { method: 'free_ai_audit' }); } catch (e) {} }
            renderReport(data.report || {});
            setStatus('● REPORT READY');
            show('report');
            stages.report.scrollIntoView({ behavior: 'smooth', block: 'start' });
          })
          .catch(function (err) {
            leadBtn.disabled = false;
            leadBtn.classList.remove('is-loading');
            if (label) label.textContent = 'GET MY AI REPORT';
            setStatus('● SCORE READY');
            setError(leadError, err.message || "That didn't go through. Email james@simpleflosolutions.com and we'll send it manually.");
          });
      });
    })();
  </script>

  <!-- Init Brendan's Cal.com namespace for popup booking on this page only -->
  <script is:inline>
    (function () {
      function initBrendanCal() {
        if (typeof Cal === 'undefined') return false;
        Cal('init', '30min', { origin: 'https://app.cal.com' });
        Cal.ns['30min']('ui', {
          hideEventTypeDetails: false,
          layout: 'month_view',
          useSlotsViewOnSmallScreen: 'true',
        });
        return true;
      }
      if (!initBrendanCal()) {
        var tries = 0;
        var timer = setInterval(function () {
          if (initBrendanCal() || ++tries > 50) clearInterval(timer);
        }, 200);
      }
      ['pointerdown', 'touchstart', 'keydown'].forEach(function (evt) {
        window.addEventListener(evt, initBrendanCal, { capture: true, passive: true, once: true });
      });
    })();
  </script>
</Layout>

