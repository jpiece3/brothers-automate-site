        else if (activeFilter !== 'all' && activeFilter !== 'new' && item.level !== activeFilter) hidden = ' hidden';

        html += '<div class="ops-card level-' + item.level + hidden + '" data-section="' + section.id + '" data-idx="' + idx + '">';
        if (item.isNew) html += '<span class="ops-card-new-tag">New</span>';
        html += '<div class="ops-card-top">';
        html += '<span class="ops-card-name">' + item.name + '</span>';
        html += '<span class="ops-card-badge badge-' + item.level + '">' + capitalize(item.level) + '</span>';
        html += '</div>';
        html += '<div class="ops-card-risk">';
        html += '<span class="ops-risk-tag risk-' + item.risk + '">' + capitalize(item.risk) + '</span>';
        html += '</div>';
        html += '<p class="ops-card-summary">' + item.short + '</p>';
        html += '<p class="ops-card-expand">View details \u2192</p>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    container.innerHTML = html;
    observeNewElements();
  }

  function renderPrinciples() {
    var html = '';
    DATA.principles.forEach(function(p) {
      html += '<div class="ops-principle-card">';
      html += '<p class="ops-principle-num">Principle ' + p.num + '</p>';
      html += '<p class="ops-principle-title">' + p.title + '</p>';
      html += '<p class="ops-principle-desc">' + p.desc + '</p>';
      html += '<ul class="ops-principle-focus-list">';
      p.focus.forEach(function(f) {
        html += '<li>' + f + '</li>';
      });
      html += '</ul></div>';
    });
    principlesGrid.innerHTML = html;
  }

  function setFilter(filter) {
    activeFilter = filter;
    // Update filter bar
    document.querySelectorAll('.ops-filter-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-filter') === filter);
    });
    // Update legend
    document.querySelectorAll('.ops-legend-item').forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-filter') === filter);
    });
    renderSections();
  }

  function openModal(sectionId, idx) {
    var section = DATA.sections.find(function(s) { return s.id === sectionId; });
    if (!section) return;
    var item = section.items[idx];
    if (!item) return;

    document.getElementById('ops-modal-section-label').textContent = section.title;
    document.getElementById('ops-modal-title').textContent = item.name;
    document.getElementById('ops-modal-short').textContent = item.short;
    document.getElementById('ops-modal-detail').textContent = item.detail;
    document.getElementById('ops-modal-risk-text').textContent = item.riskNote;

    var levelBadge = document.getElementById('ops-modal-level-badge');
    levelBadge.textContent = capitalize(item.level);
    levelBadge.className = 'ops-modal-level-badge ' + item.level;

    var riskBadge = document.getElementById('ops-modal-risk-badge');
    riskBadge.textContent = capitalize(item.risk) + ' Risk';
    riskBadge.className = 'ops-modal-risk-badge ops-modal-risk-' + item.risk;

    var newTag = document.getElementById('ops-modal-new-tag');
    if (item.isNew) {
      newTag.innerHTML = '<span class="ops-card-new-tag" style="font-size:0.625rem;">New</span>';
    } else {
      newTag.innerHTML = '';
    }

    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  function observeNewElements() {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { rootMargin: '0px 0px -80px 0px', threshold: 0.1 });

    document.querySelectorAll('[data-animate]:not(.is-visible)').forEach(function(el) {
      obs.observe(el);
    });
    document.querySelectorAll('[data-animate-stagger]:not(.is-visible)').forEach(function(el) {
      obs.observe(el);
    });
  }

  // Event delegation
  document.addEventListener('click', function(e) {
    // Filter buttons
    var filterBtn = e.target.closest('.ops-filter-btn');
    if (filterBtn) {
      setFilter(filterBtn.getAttribute('data-filter'));
      return;
    }
    // Legend items
    var legendBtn = e.target.closest('.ops-legend-item');
    if (legendBtn) {
      setFilter(legendBtn.getAttribute('data-filter'));
      return;
    }
    // Cards
    var card = e.target.closest('.ops-card');
    if (card) {
      openModal(card.getAttribute('data-section'), parseInt(card.getAttribute('data-idx')));
      return;
    }
    // Modal close button
    if (e.target.closest('#ops-modal-close')) {
      closeModal();
      return;
    }
    // Overlay backdrop
    if (e.target === overlay) {
      closeModal();
      return;
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeModal();
  });

  // Initial render
  renderSections();
  renderPrinciples();
})();
</script>
