---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AI Operations Stack — Brothers Automate" description="Every ops category scored by disruption level and consequence of failure. An interactive reference framework for service businesses planning their AI operations roadmap.">
  <Header />
  <main class="ops-stack-page">

    <!-- HERO -->
    <section class="ops-hero">
      <div class="container">
        <p class="ops-hero-eyebrow" data-animate="fade-up">Interactive Reference Framework</p>
        <h1 data-animate="fade-up">The Full <span class="text-orange">AI Operations</span> Stack</h1>
        <p class="ops-hero-sub" data-animate="fade-up">Every ops category scored by disruption level — plus a second axis: what breaks if you get it wrong.</p>
        <div class="ops-hero-note" data-animate="fade-up">
          <strong>Two axes, not one.</strong> Disruption level tells you how much AI is changing the category. Consequence of failure tells you how carefully to move.
        </div>
        <div class="ops-legend" data-animate="fade-up">
          <button class="ops-legend-item active" data-filter="all">All</button>
          <button class="ops-legend-item" data-filter="low"><span class="ops-dot dot-low"></span>Low</button>
          <button class="ops-legend-item" data-filter="medium"><span class="ops-dot dot-medium"></span>Medium</button>
          <button class="ops-legend-item" data-filter="high"><span class="ops-dot dot-high"></span>High</button>
          <button class="ops-legend-item" data-filter="transformative"><span class="ops-dot dot-transformative"></span>Transformative</button>
          <button class="ops-legend-item" data-filter="new"><span class="ops-dot dot-new"></span>New</button>
        </div>
      </div>
    </section>

    <!-- MAIN CONTENT -->
    <div class="container ops-main">

      <!-- RISK AXIS EXPLAINER -->
      <div class="ops-risk-explainer" data-animate="fade-up">
        <div class="ops-risk-col">
          <p class="ops-risk-label">Consequence of Failure</p>
          <p class="ops-risk-title">Reversible</p>
          <p class="ops-risk-desc">Errors are catchable and fixable without lasting damage. Low cost of mistakes — good place to move fast and experiment.</p>
        </div>
        <div class="ops-risk-col">
          <p class="ops-risk-label">&nbsp;</p>
          <p class="ops-risk-title">Moderate</p>
          <p class="ops-risk-desc">Errors create friction, rework, or reputational exposure. Meaningful cost, but recoverable. Needs oversight, not paralysis.</p>
        </div>
        <div class="ops-risk-col">
          <p class="ops-risk-label">&nbsp;</p>
          <p class="ops-risk-title">Critical</p>
          <p class="ops-risk-desc">Errors break compliance, payroll, contracts, or data integrity. Human sign-off is non-negotiable regardless of AI capability.</p>
        </div>
      </div>

      <!-- FILTER BAR -->
      <div class="ops-filter-bar" data-animate="fade-up">
        <span class="ops-filter-label">Filter:</span>
        <button class="ops-filter-btn active" data-filter="all">All</button>
        <button class="ops-filter-btn" data-filter="low">Low</button>
        <button class="ops-filter-btn" data-filter="medium">Medium</button>
        <button class="ops-filter-btn" data-filter="high">High</button>
        <button class="ops-filter-btn" data-filter="transformative">Transformative</button>
        <button class="ops-filter-btn" data-filter="new">New</button>
      </div>

      <!-- DYNAMIC SECTIONS -->
      <div id="ops-sections-container"></div>

      <!-- PRINCIPLES -->
      <div class="ops-principles" data-animate="fade-up">
        <div class="ops-section-header">
          <span class="ops-section-num">Cross-Cutting</span>
          <h2 class="ops-section-title">Implementation Principles</h2>
        </div>
        <div id="ops-principles-grid" class="ops-principles-grid"></div>
      </div>

      <!-- RISK MATRIX -->
      <div class="ops-matrix" data-animate="fade-up">
        <div class="ops-section-header">
          <span class="ops-section-num">Framework</span>
          <h2 class="ops-section-title">How to Prioritise Your AI Ops Roadmap</h2>
        </div>
        <div class="ops-matrix-grid" data-animate-stagger>
          <div class="ops-matrix-cell">
            <div class="ops-matrix-icon">&#128640;</div>
            <p class="ops-matrix-label">Move Fast</p>
            <p class="ops-matrix-sublabel">High disruption + Reversible risk. Automate now. Learn fast.</p>
          </div>
          <div class="ops-matrix-cell">
            <div class="ops-matrix-icon">&#127959;</div>
            <p class="ops-matrix-label">Build Carefully</p>
            <p class="ops-matrix-sublabel">High disruption + Moderate risk. Pilot with oversight before scaling.</p>
          </div>
          <div class="ops-matrix-cell">
            <div class="ops-matrix-icon">&#128737;</div>
            <p class="ops-matrix-label">Human in Loop</p>
            <p class="ops-matrix-sublabel">Any disruption + Critical risk. AI assists, humans decide. Always.</p>
          </div>
          <div class="ops-matrix-cell">
            <div class="ops-matrix-icon">&#128064;</div>
            <p class="ops-matrix-label">Watch & Wait</p>
            <p class="ops-matrix-sublabel">Low disruption + any risk. Monitor the space, don't overinvest yet.</p>
          </div>
        </div>
      </div>

    </div>

    <CTA />
  </main>
  <Footer />
</Layout>

<!-- MODAL (outside main for z-index stacking) -->
<div class="ops-modal-overlay" id="ops-modal-overlay">
  <div class="ops-modal">
    <div class="ops-modal-header">
      <button class="ops-modal-close" id="ops-modal-close" aria-label="Close modal">&times;</button>
      <p class="ops-modal-section-label" id="ops-modal-section-label"></p>
      <h3 class="ops-modal-title" id="ops-modal-title"></h3>
      <div class="ops-modal-badges">
        <span class="ops-modal-level-badge" id="ops-modal-level-badge"></span>
        <span class="ops-modal-risk-badge" id="ops-modal-risk-badge"></span>
        <span id="ops-modal-new-tag"></span>
      </div>
    </div>
    <div class="ops-modal-body">
      <p class="ops-modal-short" id="ops-modal-short"></p>
      <p class="ops-modal-detail-label">Full Breakdown</p>
      <div class="ops-modal-detail" id="ops-modal-detail"></div>
      <div class="ops-modal-risk-section">
        <p class="ops-modal-risk-title">Consequence of Failure</p>
        <p class="ops-modal-risk-text" id="ops-modal-risk-text"></p>
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ── OPS STACK PAGE ── */
  .ops-stack-page {
    background: var(--bg-primary);
  }

  /* ── HERO ── */
  .ops-hero {
    background: var(--navy);
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .ops-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 65% 35%, rgba(237, 137, 54, 0.1) 0%, transparent 60%),
                radial-gradient(ellipse at 15% 75%, rgba(237, 137, 54, 0.05) 0%, transparent 50%);
    pointer-events: none;
  }
  .ops-hero .container { position: relative; z-index: 1; }
  .ops-hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }
  .ops-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }
  .ops-hero .text-orange { color: var(--orange); }
  .ops-hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    line-height: 1.7;
  }
  .ops-hero-note {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    background: rgba(237, 137, 54, 0.1);
    border: 1.5px solid rgba(237, 137, 54, 0.3);
    border-radius: var(--radius-md);
    padding: var(--space-xs) var(--space-md);
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: var(--space-lg);
    line-height: 1.5;
  }
  .ops-hero-note strong { color: var(--orange); }

  /* ── LEGEND ── */
  .ops-legend {
    display: flex;
    gap: var(--space-xs);
    justify-content: center;
    flex-wrap: wrap;
  }
  .ops-legend-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    padding: 0.375rem 1rem;
    border-radius: var(--radius-full);
    border: 1.5px solid transparent;
    transition: all var(--transition);
    background: rgba(255,255,255,0.05);
  }
  .ops-legend-item:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); }
  .ops-legend-item.active { background: rgba(237, 137, 54, 0.15); border-color: var(--orange); color: var(--orange); }
  .ops-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .dot-low { background: #7ab8f5; }
  .dot-medium { background: #f0c040; }
  .dot-high { background: var(--orange); }
  .dot-transformative { background: #ff4d4d; }
  .dot-new { background: #7fff8a; }

  /* ── MAIN WRAP ── */
  .ops-main {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  /* ── RISK AXIS EXPLAINER ── */
  .ops-risk-explainer {
    background: var(--navy);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 768px) {
    .ops-risk-explainer { grid-template-columns: 1fr 1fr 1fr; }
  }
  .ops-risk-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .ops-risk-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: white;
    margin-bottom: 6px;
  }
  .ops-risk-desc {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.65;
  }

  /* ── FILTER BAR ── */
  .ops-filter-bar {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
    background: var(--bg-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border);
    align-items: center;
  }
  .ops-filter-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-right: 4px;
  }
  .ops-filter-btn {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.375rem 1rem;
    border-radius: var(--radius-full);
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition);
  }
  .ops-filter-btn:hover { border-color: var(--orange); color: var(--orange); }
  .ops-filter-btn.active { background: var(--navy); color: white; border-color: var(--navy); }

  /* ── SECTIONS ── */
  .ops-section { margin-bottom: var(--space-xl); }
  .ops-section-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-sm);
    border-bottom: 2px solid var(--border);
  }
  .ops-section-num {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--orange);
    text-transform: uppercase;
    flex-shrink: 0;
    background: var(--navy);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    color: var(--orange);
  }
  .ops-section-title {
    font-size: clamp(1.125rem, 2.5vw, 1.375rem);
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.01em;
  }

  /* ── CARDS GRID ── */
  .ops-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }
  @media (min-width: 640px) {
    .ops-cards-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .ops-cards-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── CARD ── */
  .ops-card {
    background: var(--bg-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all var(--transition);
    position: relative;
    overflow: hidden;
  }
  .ops-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    opacity: 0.6;
    transition: opacity var(--transition);
  }
  .ops-card.level-low::before { background: #7ab8f5; }
  .ops-card.level-medium::before { background: #f0c040; }
  .ops-card.level-high::before { background: var(--orange); }
  .ops-card.level-transformative::before { background: #ff4d4d; }
  .ops-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--orange);
  }
  .ops-card:hover::before { opacity: 1; }
  .ops-card.hidden { display: none; }

  .ops-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-xs);
    margin-bottom: var(--space-xs);
  }
  .ops-card-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1.3;
    flex: 1;
  }
  .ops-card-badge {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--radius-full);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .badge-low { background: rgba(122,184,245,0.15); color: #2563eb; }
  .badge-medium { background: rgba(240,192,64,0.15); color: #b45309; }
  .badge-high { background: rgba(237,137,54,0.15); color: #c2500a; }
  .badge-transformative { background: rgba(255,77,77,0.12); color: #b91c1c; }

  .ops-card-new-tag {
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #15803d;
    background: rgba(127,255,138,0.15);
    padding: 2px 7px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 6px;
  }
  .ops-card-risk {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: var(--space-xs);
  }
  .ops-risk-tag {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: var(--radius-full);
  }
  .risk-reversible { background: rgba(22,163,74,0.12); color: #15803d; }
  .risk-moderate { background: rgba(251,191,36,0.12); color: #92400e; }
  .risk-critical { background: rgba(239,68,68,0.12); color: #991b1b; }

  .ops-card-summary {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ops-card-expand {
    margin-top: var(--space-xs);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--orange);
  }

  /* ── MODAL ── */
  .ops-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26, 54, 93, 0.6);
    backdrop-filter: blur(6px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg);
  }
  .ops-modal-overlay.open { display: flex; }
  .ops-modal {
    background: var(--bg-surface);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 560px;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: var(--shadow-xl);
    animation: opsModalIn 0.25s ease;
  }
  @keyframes opsModalIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to { opacity: 1; transform: none; }
  }
  .ops-modal-header {
    background: var(--navy);
    padding: var(--space-lg);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    position: relative;
  }
  .ops-modal-close {
    position: absolute;
    top: var(--space-sm); right: var(--space-sm);
    background: rgba(255,255,255,0.1);
    border: none;
    color: rgba(255,255,255,0.7);
    font-size: 1.25rem;
    width: 32px; height: 32px;
    border-radius: 50%;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background var(--transition-fast);
    font-family: var(--font-sans);
  }
  .ops-modal-close:hover { background: rgba(255,255,255,0.2); color: white; }
  .ops-modal-section-label {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }
  .ops-modal-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: white;
    line-height: 1.2;
    padding-right: 36px;
    margin-bottom: var(--space-sm);
  }
  .ops-modal-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
  }
  .ops-modal-level-badge {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    border: 1.5px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.08);
  }
  .ops-modal-level-badge.transformative { border-color: rgba(255,77,77,0.5); color: #fca5a5; background: rgba(255,77,77,0.1); }
  .ops-modal-level-badge.high { border-color: rgba(237,137,54,0.5); color: var(--orange); background: rgba(237,137,54,0.1); }
  .ops-modal-level-badge.medium { border-color: rgba(240,192,64,0.5); color: #fde68a; background: rgba(240,192,64,0.08); }
  .ops-modal-level-badge.low { border-color: rgba(122,184,245,0.5); color: #bfdbfe; background: rgba(122,184,245,0.08); }
  .ops-modal-risk-badge {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: var(--radius-full);
  }
  .ops-modal-risk-reversible { background: rgba(22,163,74,0.12); color: #86efac; border: 1.5px solid rgba(22,163,74,0.3); }
  .ops-modal-risk-moderate { background: rgba(251,191,36,0.08); color: #fde68a; border: 1.5px solid rgba(251,191,36,0.3); }
  .ops-modal-risk-critical { background: rgba(239,68,68,0.1); color: #fca5a5; border: 1.5px solid rgba(239,68,68,0.3); }

  .ops-modal-body { padding: var(--space-lg); }
  .ops-modal-short {
    font-size: 1rem;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.65;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border-light);
  }
  .ops-modal-detail-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--orange);
    text-transform: uppercase;
    margin-bottom: var(--space-xs);
  }
  .ops-modal-detail {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.75;
    background: var(--bg-surface-alt);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-md);
    border-left: 3px solid var(--orange);
    margin-bottom: var(--space-md);
  }
  .ops-modal-risk-section {
    background: var(--bg-surface-alt);
    border-radius: var(--radius-md);
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--border-light);
  }
  .ops-modal-risk-title {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .ops-modal-risk-text {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── PRINCIPLES ── */
  .ops-principles {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-2xl);
  }
  .ops-principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
  }
  @media (min-width: 640px) {
    .ops-principles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .ops-principles-grid { grid-template-columns: repeat(3, 1fr); }
  }
  .ops-principle-card {
    background: var(--navy);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    position: relative;
    overflow: hidden;
    transition: transform var(--transition);
  }
  .ops-principle-card:hover { transform: translateY(-2px); }
  .ops-principle-card::after {
    content: '';
    position: absolute;
    bottom: -20px; right: -20px;
    width: 80px; height: 80px;
    border-radius: 50%;
    background: rgba(237, 137, 54, 0.1);
    pointer-events: none;
  }
  .ops-principle-num {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.15em;
