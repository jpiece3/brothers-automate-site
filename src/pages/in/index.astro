---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
import { getAllLocations } from '../../data/locations';

const allLocations = getAllLocations();
const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": `${SITE_URL}/in/` },
  ],
};
---

<Layout
  title="AI Automation for Philadelphia Area Businesses | Brothers Automate"
  description="AI automation systems for service businesses in Philadelphia, Montgomery County, Delaware County, Chester County, Bucks County, and Burlington County."
  canonicalUrl={`${SITE_URL}/in/`}
>
  <Header />
  <main>
    <section class="op-inhub-hero op-grid-bg">
      <div class="op-inhub-hero-frame">
        <div class="op-inhub-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / IN · LOCATIONS"
            right={`${allLocations.length} REGIONS · PHILADELPHIA METRO`}
            bordered
          />
        </div>
        <EyebrowTag label="LOCATIONS · PHILADELPHIA METRO" />
        <h1 class="op-inhub-h1" data-animate="fade-up">
          AI for businesses<br />
          <span class="op-inhub-h1-orange">across Greater Philadelphia.</span>
        </h1>
        <p class="op-inhub-sub" data-animate="fade-up">
          We build AI systems for service businesses across the greater Philadelphia area. Automated lead follow-up, review management, route optimization, and more — custom-built in 1–3 weeks.
        </p>
      </div>
    </section>

    <section class="op-inhub-list">
      <div class="op-inhub-list-frame">
        <div class="op-inhub-grid" data-animate-stagger>
          {allLocations.map((loc, i) => (
            <a href={`/in/${loc.slug}`} class="op-inhub-card">
              <div class="op-inhub-card-header" data-animate="fade-up">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-inhub-card-id">LOC_{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="op-inhub-card-body">
                <div class="op-inhub-card-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={loc.icon}></path>
                  </svg>
                </div>
                <h3 class="op-inhub-card-name">{loc.name}, {loc.region}</h3>
                <p class="op-inhub-card-tag">{loc.tagline}</p>
              </div>
              <div class="op-inhub-card-foot op-mono">
                IN {loc.name.toUpperCase()} <span class="op-inhub-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-inhub-hero { padding: 120px var(--op-section-px) 64px; color: var(--op-ink); }
  .op-inhub-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-inhub-util { margin-bottom: 32px; }
  .op-inhub-hero :global(.op-eyebrow) { margin-bottom: 24px; }
  .op-inhub-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 820px;
    text-wrap: balance;
  }
  .op-inhub-h1-orange { color: var(--op-orange); }
  .op-inhub-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 700px;
  }
  .op-inhub-list { padding: 56px var(--op-section-px) 96px; background: var(--op-paper); border-top: var(--op-border); }
  .op-inhub-list-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-inhub-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 700px) { .op-inhub-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-inhub-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-inhub-card {
    background: var(--op-cream);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-inhub-card:hover { transform: translate(-2px, -4px); box-shadow: var(--op-shadow-lg); color: inherit; }
  .op-inhub-card:hover .op-inhub-arrow { transform: translateX(3px); color: var(--op-orange); }
  .op-inhub-card:hover .op-inhub-card-icon { background: var(--op-orange); color: var(--op-paper); }
  .op-inhub-card-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-inhub-card-id { font-size: 9px; color: var(--op-orange); }
  .op-inhub-card-body { padding: 22px 22px 18px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .op-inhub-card-icon {
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    background: var(--op-paper);
    color: var(--op-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-inhub-card-name {
    font-family: var(--op-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-inhub-card-tag {
    font-family: var(--op-font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
  }
  .op-inhub-card-foot {
    background: var(--op-paper);
    padding: 11px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: var(--op-border);
    font-size: 9px;
    color: var(--op-ink);
  }
  .op-inhub-arrow { transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease); }
  @media (max-width: 700px) {
    .op-inhub-hero, .op-inhub-list { padding-left: 22px; padding-right: 22px; }
  }
</style>
