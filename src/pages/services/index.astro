---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
import { getAllServices } from '../../data/services';

const allServices = getAllServices();
const SITE_URL = 'https://brothersautomate.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${SITE_URL}/services/` },
  ],
};
---

<Layout
  title="AI Automation Services for Service Businesses | Brothers Automate"
  description="From lead follow-up to route optimization, we build AI systems that handle the busywork so you can focus on clients. See all our services."
  canonicalUrl={`${SITE_URL}/services/`}
>
  <Header />
  <main>
    <section class="op-svchub-hero op-grid-bg">
      <div class="op-svchub-hero-frame">
        <div class="op-svchub-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / SERVICES · CATALOG"
            right={`${allServices.length} SERVICES · ALL CUSTOM-BUILT`}
            bordered
          />
        </div>
        <EyebrowTag label="SERVICES · CATALOG" />
        <h1 class="op-svchub-h1" data-animate="fade-up">
          AI systems that<br />
          <span class="op-svchub-h1-orange">handle the busywork.</span>
        </h1>
        <p class="op-svchub-sub" data-animate="fade-up">
          Lead follow-up, client onboarding, ad creative, resume screening, review management, route optimization, and more. Each system is custom-built for your business in 1–3 weeks.
        </p>
      </div>
    </section>

    <section class="op-svchub-list">
      <div class="op-svchub-list-frame">
        <div class="op-svchub-grid" data-animate-stagger>
          {allServices.map((s, i) => (
            <a href={`/services/${s.slug}`} class="op-svchub-card">
              <div class="op-svchub-card-header" data-animate="fade-up">
                <span class="op-pulse-dot"></span>
                <span class="op-mono op-svchub-card-id">SVC_{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="op-svchub-card-body">
                <div class="op-svchub-card-icon">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d={s.icon}></path>
                  </svg>
                </div>
                <h3 class="op-svchub-card-name">{s.name}</h3>
                <p class="op-svchub-card-tag">{s.tagline}</p>
              </div>
              <div class="op-svchub-card-foot op-mono">
                READ MORE <span class="op-svchub-arrow" aria-hidden="true">→</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-svchub-hero { padding: 120px var(--op-section-px) 64px; color: var(--op-ink); }
  .op-svchub-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svchub-util { margin-bottom: 32px; }
  .op-svchub-hero :global(.op-eyebrow) { margin-bottom: 24px; }
  .op-svchub-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 820px;
    text-wrap: balance;
  }
  .op-svchub-h1-orange { color: var(--op-orange); }
  .op-svchub-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 700px;
    text-wrap: pretty;
  }

  .op-svchub-list { padding: 56px var(--op-section-px) 96px; background: var(--op-paper); border-top: var(--op-border); }
  .op-svchub-list-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svchub-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
  }
  @media (min-width: 700px) { .op-svchub-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-svchub-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-svchub-card {
    background: var(--op-cream);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-svchub-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }
  .op-svchub-card:hover .op-svchub-arrow { transform: translateX(3px); color: var(--op-orange); }
  .op-svchub-card:hover .op-svchub-card-icon { background: var(--op-orange); color: var(--op-paper); }

  .op-svchub-card-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-svchub-card-id { font-size: 9px; color: var(--op-orange); }

  .op-svchub-card-body { padding: 22px 22px 18px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .op-svchub-card-icon {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    background: var(--op-paper);
    color: var(--op-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-svchub-card-name {
    font-family: var(--op-font-display);
    font-size: 19px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-svchub-card-tag {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
  }
  .op-svchub-card-foot {
    background: var(--op-paper);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: var(--op-border);
    font-size: 10px;
    color: var(--op-ink);
  }
  .op-svchub-arrow { transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease); }

  @media (max-width: 700px) {
    .op-svchub-hero, .op-svchub-list { padding-left: 22px; padding-right: 22px; }
  }
</style>
