<script>
  // Accordion toggle
  document.querySelectorAll('.ba-acc-header').forEach(header => {
    header.addEventListener('click', () => {
      const sectionId = header.getAttribute('data-toggle');
      const section = document.getElementById(sectionId);
      if (!section) return;

      const isOpen = section.classList.contains('open');

      // Close all
      document.querySelectorAll('.ba-acc-section').forEach(s => s.classList.remove('open'));

      // Toggle clicked
      if (!isOpen) {
        section.classList.add('open');
      }
    });
  });
</script>
