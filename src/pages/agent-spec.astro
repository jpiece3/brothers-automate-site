      margin-bottom: 12px;
    }
    .sidebar-title {
      font-size: 24px;
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 0;
    }
    .sidebar-title .orange { color: var(--orange); }

    .sidebar-divider {
      height: 1px;
      background: rgba(255,255,255,0.15);
