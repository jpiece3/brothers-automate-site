    .completion-fill { height: 100%; background: var(--orange); border-radius: 99px; transition: width 300ms ease; }

    /* ---- MAIN ---- */
    .main {
      flex: 1;
      overflow-y: auto;
      padding: 48px 64px 80px;
    }

    .step-heading {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 8px;
    }
    .step-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
