    }
    .how-it-works .card-label { color: rgba(255,255,255,0.5); }
    .hiw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 12px; }
    .hiw-card {
      background: rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 20px;
    }
    .hiw-step {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--orange);
      display: block;
      margin-bottom: 8px;
    }
    .hiw-card h4 { color: var(--white); font-size: 15px; font-weight: 700; margin-bottom: 6px; }
    .hiw-card p { color: rgba(255,255,255,0.6); font-size: 13px; line-height: 1.5; }

    .braindump-hint {
      font-size: 13px;
      color: var(--text-light);
      line-height: 1.6;
      margin-bottom: 16px;
    }
    .braindump-textarea { min-height: 250px; font-size: 15px; line-height: 1.7; }

    .field-hint-inline {
      font-weight: 400;
      color: var(--text-light);
      font-size: 11px;
    }

    .autofill-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 14px 28px;
      background: var(--orange);
      color: var(--white);
      border: none;
      border-radius: 10px;
      font-family: var(--font);
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: all 150ms ease;
      margin-top: 8px;
      margin-bottom: 24px;
    }
    .autofill-btn:hover { background: var(--orange-hover); }
    .autofill-btn:disabled { opacity: 0.6; cursor: wait; }

    .autofill-progress {
      background: var(--cream-dark);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 14px;
      color: var(--text);
      margin-bottom: 24px;
    }
    .autofill-success {
      background: #ecfdf5;
      border: 1px solid #a7f3d0;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 14px;
      color: #065f46;
      font-weight: 600;
      margin-bottom: 24px;
    }
    .autofill-error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      border-radius: 8px;
      padding: 12px 16px;
      font-size: 14px;
      color: #dc2626;
      margin-bottom: 24px;
    }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .info-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      background: var(--white);
    }
    .info-list { list-style: none; padding: 0; }
    .info-list li {
      font-size: 14px;
      color: var(--text);
      padding: 6px 0;
      line-height: 1.4;
    }
    .info-list.arrow li::before { content: '\2192 '; color: var(--orange); margin-right: 8px; }
    .info-list.check li::before { content: '\2714 '; color: #059669; margin-right: 8px; }

    .dot-pulse { display: inline-block; }
    .dot-pulse::after { content: '...'; animation: dots 1.5s steps(4, end) infinite; }
    @keyframes dots { 0%,20% { content: ''; } 40% { content: '.'; } 60% { content: '..'; } 80%,100% { content: '...'; } }

    /* ---- TOOL GRID ---- */
    .tool-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 12px;
      margin-bottom: 20px;
    }
    .tool-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px;
      background: var(--white);
      cursor: pointer;
      transition: all 150ms ease;
    }
    .tool-card:hover { border-color: var(--navy); box-shadow: 0 2px 8px rgba(26,54,93,0.08); }
    .tool-card.selected {
      border-color: var(--orange);
      background: #fef8f0;
      box-shadow: 0 0 0 2px rgba(237,137,54,0.2);
    }
    .tool-card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 6px;
    }
    .tool-card-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--navy);
    }
    .tool-card-cat {
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--orange);
      background: rgba(237,137,54,0.1);
      padding: 2px 8px;
      border-radius: 99px;
      white-space: nowrap;
    }
    .tool-card-desc {
      font-size: 12px;
      color: var(--text-light);
      line-height: 1.4;
      margin-bottom: 8px;
    }
    .tool-card-meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .tool-card-auth, .tool-card-cost {
      font-size: 11px;
      font-weight: 500;
      color: var(--text-light);
      background: var(--cream-dark);
      padding: 2px 8px;
      border-radius: 4px;
    }

    /* ---- RESPONSIVE ---- */
    @media (max-width: 900px) {
      .sidebar { display: none; }
      .main { padding: 24px 20px 60px; }
      .tool-grid { grid-template-columns: 1fr; }
      .hiw-grid { grid-template-columns: 1fr; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</body>
</html>
