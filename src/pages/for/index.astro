---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTA from '../../components/CTA.astro';
import IndustriesGrid from '../../components/IndustriesGrid.astro';
import TopUtilityStrip from '../../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../../components/operator/EyebrowTag.astro';
import { getAllVerticals } from '../../data/verticals';

const SITE_URL = 'https://brothersautomate.com';
const verticals = getAllVerticals();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Industries", "item": `${SITE_URL}/for/` },
  ],
};
---

<Layout
  title="AI Automations by Industry | Brothers Automate"
  description="Industry-specific AI automation systems for service businesses. Built for coaches, financial advisors, real estate, contractors, and more."
>
  <Header />
  <main>
    <section class="op-forhub-hero op-grid-bg">
      <div class="op-forhub-hero-frame">
        <div class="op-forhub-util">
          <TopUtilityStrip
            left="BROTHERS_AUTOMATE / FOR · INDUSTRIES"
            right={`${verticals.length} VERTICALS · ALL CUSTOM-BUILT`}
            bordered
          />
        </div>
        <EyebrowTag label="INDUSTRIES · WHO WE BUILD FOR" />
        <h1 class="op-forhub-h1" data-animate="fade-up">
          AI built for<br />
          <span class="op-forhub-h1-orange">your industry.</span>
        </h1>
        <p class="op-forhub-sub" data-animate="fade-up">
          Same operator playbook, customized to your audience's pain points, terminology, and buying signals. Pick your industry to see the systems we'd build for you.
        </p>
      </div>
    </section>

    <section class="op-forhub-list">
      <div class="op-forhub-list-frame">
        <IndustriesGrid />
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  .op-forhub-hero { padding: 120px var(--op-section-px) 64px; color: var(--op-ink); }
  .op-forhub-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-forhub-util { margin-bottom: 32px; }
  .op-forhub-hero :global(.op-eyebrow) { margin-bottom: 24px; }
  .op-forhub-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 88px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 800px;
    text-wrap: balance;
  }
  .op-forhub-h1-orange { color: var(--op-orange); }
  .op-forhub-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 660px;
  }
  .op-forhub-list { padding: 56px var(--op-section-px) 96px; background: var(--op-paper); border-top: var(--op-border); }
  .op-forhub-list-frame { max-width: var(--op-max-content); margin: 0 auto; }
  @media (max-width: 700px) { .op-forhub-hero, .op-forhub-list { padding-left: 22px; padding-right: 22px; } }
</style>
