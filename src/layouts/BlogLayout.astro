---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTA from '../components/CTA.astro';
import TopUtilityStrip from '../components/operator/TopUtilityStrip.astro';
import EyebrowTag from '../components/operator/EyebrowTag.astro';
import MonoCTA from '../components/operator/MonoCTA.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  image?: string;
  category: string;
}

const SITE_URL = 'https://brothersautomate.com';

const {
  title,
  description,
  date,
  author = 'Brothers Automate',
  image,
  category,
} = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isoDate = date.toISOString();
const articleImage = image ? `${SITE_URL}${image}` : `${SITE_URL}/logo.png`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": articleImage,
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": author === 'Brothers Automate'
    ? { "@type": "Organization", "name": "Brothers Automate" }
    : { "@type": "Person", "name": author, "url": "https://brothersautomate.com/about" },
  "publisher": {
    "@type": "Organization",
    "name": "Brothers Automate",
    "logo": { "@type": "ImageObject", "url": `${SITE_URL}/logo.png` }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}${Astro.url.pathname}`
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": `${SITE_URL}/blog/` },
    { "@type": "ListItem", "position": 3, "name": title, "item": `${SITE_URL}${Astro.url.pathname}` },
  ],
};
---

<Layout
  title={`${title} | Brothers Automate`}
  description={description}
  image={articleImage}
  type="article"
>
  <Header />

  <main class="op-article">
    {/* Hero */}
    <header class="op-article-hero op-grid-bg">
      <div class="op-article-hero-frame">
        <div class="op-article-util">
          <TopUtilityStrip
            left={`BROTHERS_AUTOMATE / LOG · ${category.toUpperCase()}`}
            right="ARTICLE · OPERATOR INSIGHT"
            bordered
          />
        </div>

        <div class="op-article-meta">
          <span class="op-mono op-article-cat">{category.toUpperCase()}</span>
          <span class="op-mono op-article-dot">·</span>
          <time class="op-mono op-article-date" datetime={isoDate}>{formattedDate.toUpperCase()}</time>
        </div>

        <h1 class="op-article-h1">{title}</h1>
        <p class="op-article-desc">{description}</p>

        <div class="op-mono op-article-byline">BY {author.toUpperCase()}</div>
      </div>
    </header>

    {/* Body */}
    <article class="op-article-body">
      <div class="op-article-body-frame">
        <slot />
      </div>
    </article>

    {/* Inline CTA */}
    <section class="op-article-inline-cta op-grid-bg">
      <div class="op-article-inline-cta-frame">
        <EyebrowTag label="ENJOYED THIS? SEE WHAT WE BUILD" />
        <h2 class="op-article-h2">Ready to automate your business?</h2>
        <p class="op-article-inline-cta-sub">
          See how we build AI systems for service businesses: lead follow-up, ad creative, hiring, and more. Six flagship builds, custom-made for your stack.
        </p>
        <div class="op-article-inline-cta-actions">
          <MonoCTA label="See the builds" variant="orange" size="lg" href="/projects" trackLocation={`blog-${category}`} trackLabel="See Our Projects" />
          <MonoCTA label="Talk to the Brothers" variant="navy" size="lg" calLink="james-pinder-simpleflo/free-quiz-audit-automation-brothers" trackLocation={`blog-${category}`} trackLabel="Talk to the Brothers" />
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style>
  /* Hero */
  .op-article-hero {
    padding: 110px var(--op-section-px) 56px;
    color: var(--op-ink);
  }
  .op-article-hero-frame { max-width: 920px; margin: 0 auto; }
  .op-article-util { margin-bottom: 28px; }

  .op-article-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 22px;
    font-size: 10px;
    color: var(--op-ink);
  }
  .op-article-cat { color: var(--op-orange); }
  .op-article-dot { color: var(--op-navy-soft); opacity: 0.5; }
  .op-article-date { color: var(--op-navy-soft); }

  .op-article-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    text-wrap: balance;
  }
  .op-article-desc {
    font-family: var(--op-font-body);
    font-size: 19px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 24px;
    max-width: 720px;
    text-wrap: pretty;
  }
  .op-article-byline {
    font-size: 10px;
    color: var(--op-navy-soft);
    padding-top: 14px;
    border-top: 1px solid var(--op-rule);
  }

  /* Body */
  .op-article-body {
    padding: 56px var(--op-section-px) 80px;
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-article-body-frame {
    max-width: 720px;
    margin: 0 auto;
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.7;
    color: var(--op-ink);
  }
  .op-article-body-frame :global(h2) {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(26px, 3vw, 34px);
    line-height: 1.15;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 48px 0 16px;
    text-wrap: balance;
  }
  .op-article-body-frame :global(h3) {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: 22px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 32px 0 12px;
  }
  .op-article-body-frame :global(p) {
    margin: 0 0 18px;
    color: var(--op-ink);
  }
  .op-article-body-frame :global(a) {
    color: var(--op-orange);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-article-body-frame :global(a:hover) {
    color: var(--op-orange-deep);
  }
  .op-article-body-frame :global(ul),
  .op-article-body-frame :global(ol) {
    margin: 0 0 22px;
    padding-left: 24px;
  }
  .op-article-body-frame :global(li) {
    margin-bottom: 8px;
  }
  .op-article-body-frame :global(blockquote) {
    margin: 28px 0;
    padding: 18px 22px;
    background: var(--op-cream);
    border-left: 4px solid var(--op-orange);
    border-radius: var(--op-radius-sm);
    font-style: italic;
    color: var(--op-ink);
  }
  .op-article-body-frame :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .op-article-body-frame :global(code) {
    font-family: var(--op-font-mono);
    font-size: 14px;
    background: var(--op-cream);
    padding: 1px 6px;
    border-radius: 3px;
    color: var(--op-ink);
  }
  .op-article-body-frame :global(pre) {
    background: var(--op-navy);
    color: var(--op-cream);
    padding: 18px 22px;
    border-radius: var(--op-radius-sm);
    overflow-x: auto;
    margin: 22px 0;
    font-family: var(--op-font-mono);
    font-size: 13px;
    line-height: 1.6;
  }
  .op-article-body-frame :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }
  .op-article-body-frame :global(hr) {
    border: none;
    border-top: 1.5px solid var(--op-ink);
    margin: 36px 0;
  }
  .op-article-body-frame :global(img) {
    max-width: 100%;
    border: var(--op-border);
    border-radius: var(--op-radius-sm);
    margin: 22px 0;
  }
  .op-article-body-frame :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 22px 0;
    font-size: 14px;
  }
  .op-article-body-frame :global(th),
  .op-article-body-frame :global(td) {
    padding: 10px 14px;
    border: 1px solid var(--op-rule);
    text-align: left;
  }
  .op-article-body-frame :global(th) {
    background: var(--op-cream);
    font-weight: 700;
  }

  /* Inline CTA */
  .op-article-inline-cta {
    padding: 64px var(--op-section-px);
  }
  .op-article-inline-cta-frame {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .op-article-inline-cta-frame :global(.op-eyebrow) {
    margin-bottom: 18px;
  }
  .op-article-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 42px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .op-article-inline-cta-sub {
    font-family: var(--op-font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    margin: 0 auto 28px;
    max-width: 600px;
  }
  .op-article-inline-cta-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }

  @media (max-width: 700px) {
    .op-article-hero,
    .op-article-body,
    .op-article-inline-cta { padding-left: 22px; padding-right: 22px; }
    .op-article-body-frame { font-size: 16px; }
  }
</style>
