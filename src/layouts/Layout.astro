---
interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  articleHeadline?: string;
  extraSchemas?: object[];
}

const SITE_URL = 'https://brothersautomate.com';
const DEFAULT_IMAGE = `${SITE_URL}/logo.png`;
const DEFAULT_DESCRIPTION = "AI automations for service businesses doing $1-5M. We build the systems that handle your busywork : lead follow-up, ad creative, hiring, reviews, and more. Built by operators, for operators.";

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_IMAGE,
  canonicalUrl,
  type = 'website',
  datePublished,
  dateModified,
  articleHeadline,
  extraSchemas = [],
} = Astro.props;

const currentUrl = canonicalUrl || `${SITE_URL}${Astro.url.pathname}`;

// Organization Schema
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Brothers Automate",
  "url": SITE_URL,
  "logo": `${SITE_URL}/logo.png`,
  "description": "AI automations for service businesses doing $1-5M. We build the systems that handle your busywork : lead follow-up, ad creative, hiring, reviews, and more.",
  "sameAs": [
    "https://www.linkedin.com/in/james-pinder-52a261372/",
    "https://www.instagram.com/simpleflo_james/",
    "https://x.com/simpleflo_james",
    "https://www.youtube.com/@James_simple_flo"
  ]
};

// Article Schema (emitted when type='article' AND datePublished is provided)
const articleSchema = type === 'article' && datePublished ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": articleHeadline || title,
  "description": description,
  "image": image,
  "datePublished": datePublished,
  "dateModified": dateModified || datePublished,
  "author": {
    "@type": "Organization",
    "name": "Brothers Automate",
    "url": SITE_URL,
  },
  "publisher": {
    "@type": "Organization",
    "name": "Brothers Automate",
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/logo.png`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": currentUrl,
  },
} : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Analytics (GA4 + Meta Pixel) — deferred to idle so they don't
       compete with above-the-fold paint on mobile. Both pixels define
       their queueing functions immediately so any code can call gtag()
       or fbq() before the actual SDKs arrive; the SDKs flush the queue
       when they load. PageView events are captured ~500-2000ms after
       first paint instead of synchronously — standard tradeoff for CWV. -->
  <script is:inline>
    // GA4 — define gtag() queue immediately, load gtag.js on idle.
    window.dataLayer = window.dataLayer || [];
    window.gtag = function(){dataLayer.push(arguments);};
    gtag('js', new Date());
    gtag('config', 'G-5S4S0F38JN');

    // Meta Pixel — define fbq() queue immediately, load fbevents.js on idle.
    (function(f,b,e){if(f.fbq)return;var n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];})(window, document, 'script');
    fbq('init', '958976529966289');
    fbq('track', 'PageView');

    // Load the actual SDKs on the first real user interaction only.
    // We intentionally do NOT load on idle/timeout: a no-interaction page
    // load (e.g. a Lighthouse run, or a hard bounce) never downloads the
    // ~160 KiB of gtag.js + fbevents.js, which keeps them out of the
    // "reduce unused JavaScript" audit and off the mobile main thread.
    // Tradeoff: a visitor who lands and leaves without scrolling, tapping,
    // or typing won't fire a PageView. The 'scroll' listener catches nearly
    // all engaged sessions, so the analytics gap is limited to true bounces.
    function __loadAnalytics() {
      if (window.__analyticsLoaded) return;
      window.__analyticsLoaded = true;
      // GA4 gtag.js
      var ga = document.createElement('script');
      ga.async = true;
      ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-5S4S0F38JN';
      document.head.appendChild(ga);
      // Meta Pixel fbevents.js
      var fb = document.createElement('script');
      fb.async = true;
      fb.src = 'https://connect.facebook.net/en_US/fbevents.js';
      document.head.appendChild(fb);
    }
    ['pointerdown','touchstart','keydown','scroll'].forEach(function(evt){
      window.addEventListener(evt, __loadAnalytics, { capture: true, passive: true, once: true });
    });
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=958976529966289&ev=PageView&noscript=1"
  /></noscript>

  <meta name="description" content={description}>
  <title>{title}</title>

  <!-- Canonical URL -->
  <link rel="canonical" href={currentUrl}>

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type}>
  <meta property="og:url" content={currentUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={image}>
  <meta property="og:site_name" content="Brothers Automate">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:url" content={currentUrl}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={image}>

  <!-- Additional Meta -->
  <meta name="theme-color" content="#1a365d">
  <meta name="author" content="Brothers Automate">

  <!-- Fonts (non-blocking via media=print + onload swap) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    media="print"
    onload="this.media='all'"
  >
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap">
  </noscript>

  <!-- Resource hints for third-party services -->
  <link rel="preconnect" href="https://i.ytimg.com" crossorigin>
  <link rel="preconnect" href="https://connect.facebook.net">
  <link rel="preconnect" href="https://app.cal.com">
  <link rel="dns-prefetch" href="https://app.cal.com">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}

  {extraSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- Cal.com Embed (deferred to idle / first interaction for LCP) -->
  <script type="text/javascript" is:inline>
    // Define the Cal() queue immediately (tiny, no network).
    (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");

    // Defer the init call (which triggers embed.js download) until idle
    // OR until the user interacts with a Cal.com booking element.
    window.__calInitDone = false;
    function __initCal() {
      if (window.__calInitDone) return;
      window.__calInitDone = true;
      Cal("init", "simple-automation-discovery", {origin:"https://app.cal.com"});
      Cal.ns["simple-automation-discovery"]("ui", {"hideEventTypeDetails":false,"layout":"month_view","useSlotsViewOnSmallScreen":"true"});

      // Track Cal.com bookings as Schedule + Lead events (Meta + GA).
      Cal.ns["simple-automation-discovery"]("on", {
        action: "bookingSuccessful",
        callback: function() {
          if (!window.__leadEventFired) {
            window.__leadEventFired = true;
            if (typeof fbq !== 'undefined') { fbq('track', 'Schedule'); fbq('track', 'Lead'); }
            if (typeof gtag !== 'undefined') { gtag('event', 'booking_complete', { method: 'cal_popup' }); }
          }
        }
      });
    }

    // Idle-time init (runs after first paint).
    if ('requestIdleCallback' in window) {
      requestIdleCallback(__initCal, { timeout: 4000 });
    } else {
      setTimeout(__initCal, 2500);
    }

    // First-interaction init (in case the user clicks a Cal button before idle fires).
    ['pointerdown', 'touchstart', 'keydown'].forEach(function(evt) {
      window.addEventListener(evt, function calInteractionHandler() {
        __initCal();
        ['pointerdown','touchstart','keydown'].forEach(function(e) {
          window.removeEventListener(e, calInteractionHandler, { capture: true });
        });
      }, { capture: true, passive: true, once: false });
    });

    // postMessage fallback for booking events (works even if Cal callback is missed).
    window.addEventListener('message', function(e) {
      if (e.origin !== 'https://app.cal.com') return;
      try {
        var data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
        if (data && data.action === 'bookingSuccessful' && !window.__leadEventFired) {
          window.__leadEventFired = true;
          if (typeof fbq !== 'undefined') { fbq('track', 'Schedule'); fbq('track', 'Lead'); }
          if (typeof gtag !== 'undefined') { gtag('event', 'booking_complete', { method: 'cal_popup' }); }
        }
      } catch(err) {}
    });
  </script>

  <!-- Styles -->
  <style is:global>
    @import '../styles/global.css';
  </style>
</head>
<body>
  <slot />

  <script>
    // Pre-process text-reveal elements: wrap each word in a span so CSS can stagger
    document.querySelectorAll('[data-animate="text-reveal"]').forEach((el) => {
      const text = el.textContent || '';
      el.innerHTML = text
        .split(/\s+/)
        .filter(Boolean)
        .map(w => `<span class="word">${w}</span>`)
        .join(' ');
    });

    // Counter animation helper: animate from 0 to a target number when in view
    function animateCounter(el: HTMLElement) {
      const targetAttr = el.getAttribute('data-value');
      if (!targetAttr) return;
      const target = parseFloat(targetAttr);
      if (isNaN(target)) return;
      const prefix = el.getAttribute('data-prefix') || '';
      const suffix = el.getAttribute('data-suffix') || '';
      const decimals = parseInt(el.getAttribute('data-decimals') || '0', 10);
      const duration = parseInt(el.getAttribute('data-duration') || '1200', 10);
      const start = performance.now();
      function tick(now: number) {
        const t = Math.min(1, (now - start) / duration);
        // ease-out-expo
        const eased = t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
        const value = target * eased;
        el.textContent = prefix + value.toFixed(decimals) + suffix;
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = prefix + target.toFixed(decimals) + suffix;
      }
      requestAnimationFrame(tick);
    }

    // Scroll animation observer
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -80px 0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          // Counter elements get their numeric animation when revealed
          if (entry.target.matches('[data-animate="counter"]')) {
            animateCounter(entry.target as HTMLElement);
          }
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe all animated elements
    document.querySelectorAll('[data-animate], [data-animate-stagger]').forEach(el => {
      observer.observe(el);
    });

    // Hero entrance, fire on load (no scroll required) for above-the-fold elements
    requestAnimationFrame(() => {
      document.querySelectorAll('[data-animate-onload]').forEach(el => {
        el.classList.add('is-visible');
        if (el.matches('[data-animate="counter"]')) {
          animateCounter(el as HTMLElement);
        }
      });
    });
  </script>

  <!-- Conversion Event Tracking -->
  <script is:inline>
    (function() {
      // Helper functions
      function trackGA4(eventName, params) {
        if (typeof gtag !== 'undefined') gtag('event', eventName, params);
      }
      function trackMeta(eventName, params) {
        if (typeof fbq !== 'undefined') fbq('track', eventName, params || {});
      }

      // Click delegation for all tracked elements
      document.addEventListener('click', function(e) {
        var target = e.target.closest('[data-track]');
        if (!target) return;

        var action = target.getAttribute('data-track');
        var label = target.getAttribute('data-track-label') || '';
        var location = target.getAttribute('data-track-location') || '';

        if (action === 'cta_click') {
          trackGA4('cta_click', { cta_location: location, cta_text: label });
        } else if (action === 'project_card_click') {
          trackGA4('select_content', { content_type: 'project', item_id: label });
          trackMeta('ViewContent', { content_name: label, content_type: 'project' });
        } else if (action === 'problem_card_click') {
          trackGA4('select_content', { content_type: 'pain_point', item_id: label });
        } else if (action === 'nav_click') {
          trackGA4('navigation_click', { link_text: label });
        } else if (action === 'social_click') {
          trackGA4('social_click', { platform: label, link_url: target.href || '' });
        }
      });

      // ViewContent on project and blog pages
      var path = window.location.pathname;
      var projectMatch = path.match(/^\/projects\/([^\/]+)\/?$/);
      if (projectMatch && projectMatch[1] !== '') {
        var slug = projectMatch[1];
        var projectName = (document.querySelector('h1') || {}).textContent || slug;
        trackGA4('view_item', { content_type: 'project', item_id: slug, item_name: projectName });
        trackMeta('ViewContent', { content_name: projectName, content_type: 'project', content_ids: [slug] });
      }
      if (path.indexOf('/blog/') === 0 && path !== '/blog/' && path !== '/blog') {
        var articleTitle = (document.querySelector('h1') || {}).textContent || '';
        trackGA4('view_item', { content_type: 'blog_article', item_name: articleTitle });
        trackMeta('ViewContent', { content_name: articleTitle, content_type: 'blog_article' });
      }

      // Scroll depth tracking (GA4 only)
      var milestones = [25, 50, 75, 100];
      var fired = {};
      var scrollTimer;
      window.addEventListener('scroll', function() {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(function() {
          var h = document.documentElement;
          var st = h.scrollTop || document.body.scrollTop;
          var sh = (h.scrollHeight || document.body.scrollHeight) - h.clientHeight;
          var pct = sh > 0 ? Math.round((st / sh) * 100) : 0;
          for (var i = 0; i < milestones.length; i++) {
            if (pct >= milestones[i] && !fired[milestones[i]]) {
              fired[milestones[i]] = true;
              trackGA4('scroll_depth', { percent_scrolled: milestones[i], page_path: path });
            }
          }
        }, 150);
      }, { passive: true });
    })();
  </script>
</body>
</html>
