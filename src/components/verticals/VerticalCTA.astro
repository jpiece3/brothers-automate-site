---
import EyebrowTag from '../operator/EyebrowTag.astro';
import MonoCTA from '../operator/MonoCTA.astro';

interface Props {
  headline: string;
  headlineHighlight: string;
  subheadline: string;
}

const { headline, headlineHighlight, subheadline } = Astro.props;
---

<section class="op-vertcta op-grid-bg" id="cta">
  <div class="op-vertcta-frame">
    <div class="op-vertcta-panel" data-animate="scale-up">
      <div class="op-vertcta-panel-header">
        <span class="op-pulse-dot op-pulse-dot--lg"></span>
        <span class="op-mono op-vertcta-id">SCHEDULE_INTAKE · 30_MIN</span>
        <span class="op-mono op-vertcta-status">● ACCEPTING NEW BUILDS</span>
      </div>
      <div class="op-vertcta-panel-body">
        <div class="op-vertcta-eyebrow"><EyebrowTag label="GET ON OUR CALENDAR" /></div>
        <h2 class="op-vertcta-h2">{headline} <span class="op-vertcta-h2-orange">{headlineHighlight}</span></h2>
        <p class="op-vertcta-sub">{subheadline}</p>
        <div class="op-vertcta-actions">
          <MonoCTA label="Talk to the Brothers" variant="orange" size="lg" calLink="james-pinder-simpleflo/free-quiz-audit-automation-brothers" trackLocation="vertical-cta" trackLabel="Talk to the Brothers" />
        </div>
        <p class="op-mono op-vertcta-fineprint">FREE CONSULTATION · NO OBLIGATION</p>
      </div>
    </div>
  </div>
</section>

<style>
  .op-vertcta { padding: 72px var(--op-section-px) 96px; }
  .op-vertcta-frame { max-width: 1000px; margin: 0 auto; }
  .op-vertcta-panel {
    background: var(--op-navy);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow-lg);
    color: var(--op-cream);
  }
  .op-vertcta-panel-header {
    background: var(--op-navy-deep);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.08);
  }
  .op-vertcta-id { font-size: 9px; color: var(--op-orange); }
  .op-vertcta-status { margin-left: auto; font-size: 8.5px; color: var(--op-cream); opacity: 0.55; }
  .op-vertcta-panel-body { padding: 36px 32px 32px; text-align: center; }
  .op-vertcta-eyebrow { margin-bottom: 18px; display: flex; justify-content: center; }
  .op-vertcta-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-paper);
    margin: 0 auto 16px;
    max-width: 700px;
  }
  .op-vertcta-h2-orange { color: var(--op-orange); }
  .op-vertcta-sub {
    font-family: var(--op-font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--op-cream);
    opacity: 0.78;
    margin: 0 auto 24px;
    max-width: 600px;
  }
  .op-vertcta-actions { display: flex; justify-content: center; margin-bottom: 18px; }
  .op-vertcta-fineprint { font-size: 9px; color: var(--op-cream); opacity: 0.5; margin: 0; }
  @media (max-width: 700px) { .op-vertcta { padding: 56px 22px 72px; } .op-vertcta-panel-body { padding: 28px 22px 26px; } }
</style>
