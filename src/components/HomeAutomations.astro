</style>

<script>
  // Hover state + step cycling for each operator card.
  // Also fires count-up animations on metric numbers.
  (() => {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function easeOutCubic(t: number): number { return 1 - Math.pow(1 - t, 3); }

    function fmtMetric(target: number, value: number, fmt: string, fallback: string): string {
      switch (fmt) {
        case 'multiplier': return `${value.toFixed(1)}x`;
        case 'lt-min':     return `<${Math.max(1, Math.round(value))} min`;
        case 'lt-s':       return `<${Math.max(1, Math.round(value))}s`;
        case 'twentyfour': return `${Math.round(value)}/7`;
        case 'min':        return `${Math.round(value)} min`;
        case 'plus':       return `${Math.round(value)}+`;
        case 'percent':    return `${Math.round(value)}%`;
        case 'int':        return `${Math.round(value)}`;
        default:           return fallback;
      }
    }

    function animateCountUp(el: HTMLElement, target: number, fmt: string, fallback: string, duration = 900) {
      const start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / duration);
        const eased = easeOutCubic(t);
        el.textContent = fmtMetric(target, target * eased, fmt, fallback);
        if (t < 1) requestAnimationFrame(tick);
        else el.textContent = fmtMetric(target, target, fmt, fallback);
      };
      requestAnimationFrame(tick);
    }

    document.querySelectorAll<HTMLElement>('.op-card').forEach((card) => {
      if ((card as any).__opCardInited) return;
      (card as any).__opCardInited = true;

      let timer: number | null = null;
      let step = 0;

      const m1 = card.querySelector<HTMLElement>('.op-card-metric-value[data-metric-idx="0"]');
      const m2 = card.querySelector<HTMLElement>('.op-card-metric-value[data-metric-idx="1"]');
      const m1Target = parseFloat(card.dataset.m1Target || '0');
      const m2Target = parseFloat(card.dataset.m2Target || '0');
      const m1Fmt = card.dataset.m1Fmt || 'static';
      const m2Fmt = card.dataset.m2Fmt || 'static';
      const m1Fallback = card.dataset.m1Value || '';
      const m2Fallback = card.dataset.m2Value || '';

      const reset = () => {
        card.setAttribute('data-active', 'false');
        card.setAttribute('data-step', '0');
        step = 0;
        if (timer != null) { clearInterval(timer); timer = null; }
        if (m1) m1.textContent = m1Fallback;
        if (m2) m2.textContent = m2Fallback;
      };

      const activate = () => {
        if (reduce) {
          card.setAttribute('data-active', 'true');
          card.setAttribute('data-step', '3');
          return;
        }
        card.setAttribute('data-active', 'true');
        step = 0;
        card.setAttribute('data-step', '0');
        // start step cycling
        timer = window.setInterval(() => {
          step = (step + 1) % 5;
          if (step === 4) step = 0; // 4 steps: 0..3
          card.setAttribute('data-step', String(step));
        }, 700);
        // fire count-ups (only fmt types that need motion)
        if (m1 && ['multiplier','lt-min','lt-s','twentyfour','min','plus','percent','int'].includes(m1Fmt)) {
          animateCountUp(m1, m1Target, m1Fmt, m1Fallback, 900);
        }
        if (m2 && ['multiplier','lt-min','lt-s','twentyfour','min','plus','percent','int'].includes(m2Fmt)) {
          animateCountUp(m2, m2Target, m2Fmt, m2Fallback, 1100);
        }
      };

      card.addEventListener('mouseenter', activate);
      card.addEventListener('mouseleave', reset);
      card.addEventListener('focusin', activate);
      card.addEventListener('focusout', reset);
    });
  })();
</script>
