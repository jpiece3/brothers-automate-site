---
/**
 * YourLifeAfter, the pleasure-state section that paints what the owner's
 * week looks like after the systems are running. Slots between
 * AboutOperators and HowWeWork in the homepage section order.
 *
 * Uses operator primitives (TopUtilityStrip, EyebrowTag, SpecStrip) so
 * the visual matches the rest of the site. The contrast — dashboard
 * visuals + human content — is the point.
 */
import TopUtilityStrip from './operator/TopUtilityStrip.astro';
import EyebrowTag from './operator/EyebrowTag.astro';
import SpecStrip from './operator/SpecStrip.astro';

const beats = [
  {
    n: '01',
    title: 'You take Friday off and nothing breaks.',
    body: 'Quotes still go out. Leads still get followed up with. Onboarding still happens. The business runs whether you\'re at the lake or at your desk.',
  },
  {
    n: '02',
    title: 'You stop being the bottleneck.',
    body: 'Inquiries don\'t wait on you. New hires don\'t wait on you. Reviews don\'t wait on you. The system moves at the speed of the work, not the speed of your inbox.',
  },
  {
    n: '03',
    title: 'You hire slower, not faster.',
    body: 'That $70K admin role you were about to post? You don\'t need it. You add capacity through systems, not headcount.',
  },
  {
    n: '04',
    title: 'Sunday night doesn\'t feel like Sunday night anymore.',
    body: 'No quote backlog. No "I\'ll get to it tomorrow" pile. The week starts clean because the last week closed itself.',
  },
  {
    n: '05',
    title: 'You go back to doing the part you actually love.',
    body: 'The reason you started this thing. Not the inbox part.',
  },
];
---

<section class="op-life op-grid-bg" id="your-life-after">
  <div class="op-life-frame">
    <div class="op-life-util">
      <TopUtilityStrip
        left="BROTHERS_AUTOMATE / SECTION 05 · OPERATOR_OUTPUT"
        right="THE DREAM STATE · 05 OUTCOMES"
        bordered
      />
    </div>

    <div class="op-life-header" data-animate="fade-up">
      <EyebrowTag label="WHAT YOU GET BACK · NOT WHAT WE BUILD" />
      <h2 class="op-life-h2">
        Built so you can <span class="op-life-h2-orange">actually step away.</span>
      </h2>
      <p class="op-life-sub">
        The system you didn't know you were paying for. Here's what a week looks like once it's running.
      </p>
    </div>

    <div class="op-life-grid" data-animate-stagger>
      {beats.map((beat) => (
        <article class="op-life-card">
          <div class="op-life-card-header">
            <span class="op-pulse-dot op-pulse-dot--lg"></span>
            <span class="op-mono op-life-card-id">OUTCOME_{beat.n}</span>
            <span class="op-mono op-life-card-tag">REAL · NOT MARKETING</span>
          </div>
          <div class="op-life-card-body">
            <div class="op-life-card-num">{beat.n}</div>
            <h3 class="op-life-card-title">{beat.title}</h3>
            <p class="op-life-card-text">{beat.body}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="op-life-stats" data-animate="fade-up">
      <SpecStrip cells={[
        { value: '14/wk', label: 'Hours back to you' },
        { value: '+32%', label: 'Deals closed (avg)' },
        { value: '52/yr', label: 'Sundays off' },
        { value: '0', label: 'Net new admin hires' },
      ]} />
    </div>
  </div>
</section>

<style>
  .op-life {
    padding: 72px var(--op-section-px) 88px;
  }
  .op-life-frame {
    max-width: 1200px;
    margin: 0 auto;
  }
  .op-life-util { margin-bottom: 48px; }

  .op-life-header {
    max-width: 820px;
    margin-bottom: 48px;
  }
  .op-life-header > :global(.op-eyebrow) {
    margin-bottom: 24px;
    align-self: flex-start;
  }
  .op-life-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(40px, 4.5vw, 60px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 18px;
    text-wrap: balance;
  }
  .op-life-h2-orange { color: var(--op-orange); }
  .op-life-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 680px;
    text-wrap: pretty;
  }

  /* Grid: 2 cols on desktop, 1 on mobile. First card spans both cols. */
  .op-life-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .op-life-grid > :nth-child(1) {
    grid-column: 1 / -1;
  }
  @media (max-width: 900px) {
    .op-life-grid { grid-template-columns: 1fr; }
    .op-life-grid > :nth-child(1) { grid-column: auto; }
  }

  .op-life-card {
    position: relative;
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 3px 4px 0 var(--op-ink);
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-life-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--op-shadow-lg);
  }

  .op-life-card-header {
    background: var(--op-navy-deep);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: var(--op-border);
  }
  .op-life-card-id {
    font-size: 9px;
    color: var(--op-orange);
    letter-spacing: 0.18em;
  }
  .op-life-card-tag {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.5;
    letter-spacing: 0.18em;
  }

  .op-life-card-body {
    padding: 22px 24px 26px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .op-life-card-num {
    font-family: var(--op-font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--op-orange);
    letter-spacing: 0.22em;
    line-height: 1;
  }
  .op-life-card-title {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: 24px;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }
  .op-life-card-text {
    font-family: var(--op-font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    font-weight: 500;
    margin: 0;
    text-wrap: pretty;
  }

  /* Featured first card gets a slightly bigger title */
  .op-life-grid > :nth-child(1) .op-life-card-title {
    font-size: 30px;
  }
  .op-life-grid > :nth-child(1) .op-life-card-text {
    font-size: 16px;
    max-width: 720px;
  }

  .op-life-stats {
    margin-top: 56px;
  }

  @media (max-width: 700px) {
    .op-life { padding: 56px 22px 64px; }
    .op-life-util { margin-bottom: 32px; }
    .op-life-header { margin-bottom: 32px; }
    .op-life-card-body { padding: 18px 20px 22px; }
    .op-life-card-title { font-size: 21px; }
    .op-life-grid > :nth-child(1) .op-life-card-title { font-size: 24px; }
    .op-life-stats { margin-top: 36px; }
  }
</style>
