---
/**
 * VideoFacade — lightweight YouTube facade (no panel chrome).
 *
 * Shows the YouTube thumbnail with a play overlay; the real iframe only
 * loads on click (youtube-nocookie, autoplay), so a page with several of
 * these costs nothing on load. Safe to render many times on one page —
 * the bundled script binds every .op-vf instance once.
 *
 * Props:
 *   videoId: string  required, the YouTube video ID (e.g. "oxRFshb7-Dw")
 *   title:   string  used for aria-label + iframe title
 */
interface Props {
  videoId: string;
  title?: string;
}

const { videoId, title = 'Watch the build' } = Astro.props;

const thumbJpg = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const thumbFallback = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const webpSrcset = `https://i.ytimg.com/vi_webp/${videoId}/mqdefault.webp 320w, https://i.ytimg.com/vi_webp/${videoId}/sddefault.webp 640w, https://i.ytimg.com/vi_webp/${videoId}/maxresdefault.webp 1280w`;
const jpgSrcset = `https://i.ytimg.com/vi/${videoId}/mqdefault.jpg 320w, https://i.ytimg.com/vi/${videoId}/sddefault.jpg 640w, https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg 1280w`;
const thumbSizes = '(max-width: 700px) 92vw, (max-width: 1024px) 46vw, 380px';
---

<div class="op-vf" data-video-id={videoId} data-title={title}>
  <button class="op-vf-trigger" type="button" aria-label={`Play video: ${title}`}>
    <picture>
      <source type="image/webp" srcset={webpSrcset} sizes={thumbSizes} />
      <img
        src={thumbJpg}
        srcset={jpgSrcset}
        sizes={thumbSizes}
        loading="lazy"
        decoding="async"
        alt={`${title} video thumbnail`}
        onerror={`this.onerror=null;this.srcset='';this.src='${thumbFallback}';`}
        width="1280"
        height="720"
      />
    </picture>
    <span class="op-vf-play" aria-hidden="true">
      <svg viewBox="0 0 68 48" width="58" height="41">
        <path class="op-vf-play-bg" d="M 66.52,7.74 C 65.69,4.65 63.27,2.22 60.18,1.39 54.6,0 33.95,0 33.95,0 33.95,0 13.3,0 7.72,1.39 4.63,2.22 2.21,4.65 1.38,7.74 0,13.29 0,24 0,24 c 0,0 0,10.71 1.38,16.26 0.83,3.09 3.25,5.52 6.34,6.35 C 13.3,48 33.95,48 33.95,48 33.95,48 54.6,48 60.18,46.61 63.27,45.78 65.69,43.35 66.52,40.26 67.9,34.71 67.9,24 67.9,24 67.9,13.29 66.52,7.74 Z" />
        <path d="M 45,24 27,14 v 20 z" fill="#fff" />
      </svg>
    </span>
  </button>
</div>

<script>
  document.querySelectorAll('.op-vf').forEach(function (panel) {
    var trigger = panel.querySelector('.op-vf-trigger');
    if (!trigger) return;
    trigger.addEventListener('click', function () {
      var videoId = panel.getAttribute('data-video-id');
      var title = panel.getAttribute('data-title') || 'Video';
      if (!videoId) return;
      var iframe = document.createElement('iframe');
      iframe.src = 'https://www.youtube-nocookie.com/embed/' + videoId + '?autoplay=1&rel=0&modestbranding=1';
      iframe.title = title;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.setAttribute('allowfullscreen', '');
      iframe.loading = 'lazy';
      iframe.className = 'op-vf-iframe';
      trigger.replaceWith(iframe);
    });
  });
</script>

<style>
  .op-vf {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--op-navy-deep);
    border-bottom: var(--op-border);
  }
  .op-vf-trigger {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    background: var(--op-navy-deep);
    display: block;
    overflow: hidden;
  }
  .op-vf-trigger img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--op-dur-hover) var(--op-ease), filter var(--op-dur-hover) var(--op-ease);
  }
  .op-vf-trigger:hover img {
    transform: scale(1.03);
    filter: brightness(1.05);
  }
  .op-vf-trigger:focus-visible {
    outline: 2px solid var(--op-orange);
    outline-offset: -2px;
  }
  .op-vf-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.45));
    transition: transform var(--op-dur-hover) var(--op-ease);
  }
  .op-vf-play-bg {
    fill: #cc0000;
    fill-opacity: 0.9;
    transition: fill var(--op-dur-hover) var(--op-ease), fill-opacity var(--op-dur-hover) var(--op-ease);
  }
  .op-vf-trigger:hover .op-vf-play {
    transform: translate(-50%, -50%) scale(1.08);
  }
  .op-vf-trigger:hover .op-vf-play-bg {
    fill: var(--op-orange);
    fill-opacity: 1;
  }
  .op-vf :global(.op-vf-iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
</style>
