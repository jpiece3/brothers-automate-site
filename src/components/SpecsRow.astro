---
---

<section class="specs">
  <div class="container">
    <div class="specs-grid" data-animate="fade-up">
      <div class="spec">
        <span class="spec-label">Shipped</span>
        <span class="spec-number">
          <span data-animate="counter" data-value="50" data-suffix="+" data-animate-onload>50+</span>
        </span>
        <span class="spec-context">AI systems</span>
      </div>

      <div class="spec">
        <span class="spec-label">Build time</span>
        <span class="spec-number">1–3 wks</span>
        <span class="spec-context">per build</span>
      </div>

      <div class="spec">
        <span class="spec-label">Pricing</span>
        <span class="spec-number">$3,500/mo</span>
        <span class="spec-context">or scoped</span>
      </div>

      <div class="spec">
        <span class="spec-label">Risk</span>
        <span class="spec-number">30-day</span>
        <span class="spec-context">guarantee</span>
      </div>
    </div>
  </div>
</section>

<style>
  .specs {
    padding: var(--section-py-tight) 0;
    background: var(--bg-surface-alt);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .specs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .spec {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: var(--space-md);
    border-left: 2px solid var(--border);
  }

  .spec-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-muted);
  }

  .spec-number {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: var(--navy);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    font-variant-numeric: tabular-nums;
  }

  .spec-context {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .specs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
    .spec-number {
      font-size: 1.5rem;
    }
  }
</style>
