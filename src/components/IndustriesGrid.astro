---
import { getAllVerticals } from '../data/verticals';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const verticals = getAllVerticals();
---

<div class={`op-ind-grid${compact ? ' op-ind-grid--compact' : ''}`} data-animate-stagger>
  {verticals.map((v, i) => (
    <a href={`/for/${v.slug}`} class="op-ind-card">
      <div class="op-ind-card-header">
        <span class="op-pulse-dot"></span>
        <span class="op-mono op-ind-card-id">IND_{String(i + 1).padStart(2, '0')}</span>
      </div>
      <div class="op-ind-card-body">
        <div class="op-ind-card-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d={v.icon}></path>
          </svg>
        </div>
        <h3 class="op-ind-card-name">{v.label}</h3>
        <p class="op-ind-card-tag">{v.tagline}</p>
      </div>
      <div class="op-ind-card-foot op-mono">
        FOR {v.label.toUpperCase()} <span class="op-ind-arrow" aria-hidden="true">→</span>
      </div>
    </a>
  ))}
</div>

<style>
  .op-ind-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 700px) { .op-ind-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-ind-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-ind-card {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-ind-card:hover { transform: translate(-2px, -4px); box-shadow: var(--op-shadow-lg); color: inherit; }
  .op-ind-card:hover .op-ind-arrow { transform: translateX(3px); color: var(--op-orange); }
  .op-ind-card:hover .op-ind-card-icon { background: var(--op-orange); color: var(--op-paper); }

  .op-ind-card-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-ind-card-id { font-size: 9px; color: var(--op-orange); }

  .op-ind-card-body { padding: 22px 22px 18px; flex: 1; display: flex; flex-direction: column; gap: 10px; }
  .op-ind-card-icon {
    width: 40px;
    height: 40px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    background: var(--op-cream);
    color: var(--op-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-ind-card-name {
    font-family: var(--op-font-display);
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-ind-card-tag {
    font-family: var(--op-font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
  }
  .op-ind-card-foot {
    background: var(--op-paper);
    padding: 11px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: var(--op-border);
    font-size: 9px;
    color: var(--op-ink);
  }
  .op-ind-arrow { transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease); }

  .op-ind-grid--compact .op-ind-card-body { padding: 16px 18px 14px; }
  .op-ind-grid--compact .op-ind-card-name { font-size: 15px; }
  .op-ind-grid--compact .op-ind-card-tag { font-size: 12px; }
</style>
