---
/**
 * DirectAnswer, the 50-80 word TL;DR block that AI engines (ChatGPT,
 * Perplexity, Claude, Google AIO) tend to lift verbatim into citations.
 *
 * Placement: directly under H1, before the first H2.
 * Semantic markup: role="doc-abstract" signals "abstract" to AI parsers.
 *
 * Props:
 *   children: slotted text. Keep to 50-80 words, declarative, with at
 *             least one specific number/range/year. Skip marketing language.
 */
---

<div class="geo-direct-answer" role="doc-abstract">
  <span class="geo-direct-answer-label op-mono">DIRECT ANSWER</span>
  <p class="geo-direct-answer-text"><slot /></p>
</div>

<style>
  .geo-direct-answer {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    box-shadow: var(--op-shadow);
    padding: 22px 26px;
    margin: 28px 0 36px;
    max-width: 820px;
  }

  .geo-direct-answer-label {
    display: inline-block;
    font-size: 10px;
    color: var(--op-orange);
    margin-bottom: 10px;
    letter-spacing: var(--op-tracking-mono);
  }

  .geo-direct-answer-text {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy);
    margin: 0;
    text-wrap: pretty;
  }

  @media (max-width: 700px) {
    .geo-direct-answer {
      padding: 18px 20px;
      margin: 22px 0 28px;
    }
    .geo-direct-answer-text { font-size: 15px; }
  }
</style>
