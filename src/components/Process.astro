---
const phases = [
  {
    number: '01',
    title: 'Discover',
    days: 'Day 1',
    tasks: [
      '30-minute kickoff call to map your bottleneck',
      'Document your current workflow and tools',
      'Identify the highest-ROI automation opportunity'
    ]
  },
  {
    number: '02',
    title: 'Design',
    days: 'Days 2–3',
    tasks: [
      'Architecture the solution around your existing stack',
      'Map data flow between your tools',
      'Define triggers, logic, and output formats'
    ]
  },
  {
    number: '03',
    title: 'Build',
    days: 'Days 4–7',
    tasks: [
      'Custom development. No templates, no plugins.',
      'Wire up integrations (CRM, email, scheduling, inventory)',
      'Internal testing and edge-case handling'
    ]
  },
  {
    number: '04',
    title: 'Deploy',
    days: 'Days 7–10',
    tasks: [
      'Launch on your domain with full documentation',
      'Docs you can actually understand',
      'Walkthrough call + 30-day support window'
    ]
  }
];
---

<section class="process" id="process">
  <div class="container">
    <div class="process-header">
      <span class="tracker-label" data-animate="fade-up">
        <span class="num">02</span> HOW WE WORK
      </span>
      <h2 data-animate="fade-up">How we work.</h2>
      <p data-animate="fade-up">
        Four phases. No scope creep, no discovery marathons. Same playbook whether it's a one-off build or ongoing AI ops on retainer.
      </p>
    </div>

    <div class="phases" data-animate="fade-up">
      <div class="phases-connector" aria-hidden="true"></div>
      <div class="phases-grid" data-animate-stagger>
        {phases.map((phase) => (
          <div class="phase">
            <div class="phase-num">{phase.number}</div>
            <h3 class="phase-title">{phase.title}</h3>
            <ul class="phase-list">
              {phase.tasks.map((task) => (
                <li>{task}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="process-cta" data-animate="fade-up">
      <a
        href="#"
        class="btn btn-primary"
        data-cal-link="james-pinder/simple-automation-discovery"
        data-cal-namespace="simple-automation-discovery"
        data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        data-track="cta_click" data-track-location="process" data-track-label="Let's Get Started"
      >Map your bottleneck</a>
      <span class="process-cta-note">30-min discovery call · no pitch deck · just operators</span>
    </div>
  </div>
</section>

<style>
  .process {
    padding: var(--section-py) 0;
    background: var(--bg-primary);
  }

  .process-header {
    max-width: var(--max-narrow);
    margin: 0 auto var(--space-3xl);
  }

  .process-header h2 {
    font-size: var(--text-h2);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-md) 0;
  }

  .process-header p {
    font-size: var(--text-lead);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin: 0;
  }

  /* === Phases grid === */
  .phases {
    position: relative;
    max-width: var(--max-content);
    margin: 0 auto;
  }

  /* Hairline connector that draws across the top on scroll-in */
  .phases-connector {
    position: absolute;
    top: 14px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0,
      var(--orange) 8%,
      var(--orange) 92%,
      transparent 100%
    );
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left center;
    transition:
      transform var(--dur-marquee) var(--ease-out-expo),
      opacity var(--dur-base) var(--ease-out-expo);
  }

  .phases.is-visible .phases-connector {
    opacity: 1;
    transform: scaleX(1);
  }

  .phases-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .phases-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl) var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .phases-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-lg);
    }
  }

  .phase {
    position: relative;
    padding-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* The dot that "marks" the phase on the connector line */
  .phase::before {
    content: '';
    position: absolute;
    top: 11px;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--orange);
    box-shadow: 0 0 0 4px var(--bg-primary);
  }

  .phase-num {
    font-family: var(--font-mono);
    font-size: 2.25rem;
    font-weight: 600;
    color: var(--navy);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    margin-bottom: var(--space-xs);
  }

  .phase-title {
    font-size: 1.5rem;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--navy);
    font-weight: 700;
    margin: 0;
  }

  .phase-list {
    list-style: none;
    margin: var(--space-sm) 0 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-top: 1px solid var(--border-light);
    padding-top: var(--space-md);
  }

  .phase-list li {
    position: relative;
    padding-left: var(--space-md);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .phase-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 8px;
    height: 1px;
    background: var(--orange);
  }

  /* CTA */
  .process-cta {
    text-align: center;
    margin-top: var(--space-3xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .process-cta-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Mobile — drop the connector entirely */
  @media (max-width: 1023px) {
    .phases-connector {
      display: none;
    }
    .phase::before {
      display: none;
    }
    .phase {
      padding-top: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phases-connector {
      transition: none;
    }
    .phases.is-visible .phases-connector {
      transform: scaleX(1);
    }
  }
</style>
