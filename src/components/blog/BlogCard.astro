---
interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  index?: number;
}

const { title, description, date, category, slug, image, index = 0 } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});

const logCode = `LOG_${String(index + 1).padStart(2, '0')}`;
---

<a href={`/blog/${slug}`} class="op-blogcard">
  <div class="op-blogcard-header">
    <span class="op-pulse-dot"></span>
    <span class="op-mono op-blogcard-code">{logCode}</span>
    <span class="op-mono op-blogcard-date">{formattedDate.toUpperCase()}</span>
  </div>

  {image && (
    <div class="op-blogcard-image">
      <img src={image} alt={title} loading="lazy" />
    </div>
  )}

  <div class="op-blogcard-body">
    <span class="op-mono op-blogcard-cat">{category.toUpperCase()}</span>
    <h3 class="op-blogcard-title">{title}</h3>
    <p class="op-blogcard-desc">{description}</p>
  </div>

  <div class="op-blogcard-foot op-mono">
    READ ARTICLE <span class="op-blogcard-arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .op-blogcard {
    display: flex;
    flex-direction: column;
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--op-shadow);
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-blogcard:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }
  .op-blogcard:hover .op-blogcard-arrow {
    transform: translateX(3px);
    color: var(--op-orange);
  }

  .op-blogcard-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-blogcard-code {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-blogcard-date {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.55;
  }

  .op-blogcard-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--op-cream);
    border-bottom: var(--op-border);
  }
  .op-blogcard-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--op-ease);
  }
  .op-blogcard:hover .op-blogcard-image img { transform: scale(1.04); }

  .op-blogcard-body {
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .op-blogcard-cat {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-blogcard-title {
    font-family: var(--op-font-display);
    font-size: 19px;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
    font-weight: 800;
    text-wrap: balance;
  }
  .op-blogcard-desc {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
    flex: 1;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .op-blogcard-foot {
    padding: 12px 16px;
    border-top: var(--op-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 10px;
    color: var(--op-ink);
    background: var(--op-paper);
  }
  .op-blogcard-arrow {
    font-size: 14px;
    transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease);
  }
</style>
