---
import { projects } from '../data/projects';
import { getAllServices } from '../data/services';
import { getAllVerticals } from '../data/verticals';
import { getAllLocations } from '../data/locations';

const year = new Date().getFullYear();
const services = getAllServices();
const verticals = getAllVerticals();
const locations = getAllLocations();
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-logo">
        <img src="/logo.png" alt="Brothers Automate" width="160" height="50" loading="lazy" decoding="async" />
        <p class="footer-mission">Our mission: to design and install AI systems that quietly run in the background so service businesses get more qualified leads and waste far less time on manual work.</p>
      </div>

      <div class="footer-links">
        <div class="footer-col">
          <h4>Projects</h4>
          <ul>
            {projects.map(p => (
              <li><a href={`/projects/${p.slug}`}>{p.name}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            {services.map(s => (
              <li><a href={`/services/${s.slug}`}>{s.name}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-col">
          <h4>Industries</h4>
          <ul>
            {verticals.map(v => (
              <li><a href={`/for/${v.slug}`}>{v.shortLabel}</a></li>
            ))}
            <li><a href="/for/" class="view-all">View All &rarr;</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Locations</h4>
          <ul>
            {locations.map(l => (
              <li><a href={`/in/${l.slug}`}>{l.name}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/blog">Blog</a></li>
            <li>
              <a
                href="#"
                data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
                data-cal-namespace="free-quiz-audit-automation-brothers"
                data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
                data-track="cta_click" data-track-location="footer" data-track-label="Book a Call"
              >Book a Call</a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-socials">
      <a href="https://www.linkedin.com/in/james-pinder-52a261372/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" data-track="social_click" data-track-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href="https://www.instagram.com/simpleflo_james/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" data-track="social_click" data-track-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://x.com/simpleflo_james" target="_blank" rel="noopener noreferrer" aria-label="X" data-track="social_click" data-track-label="X">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://www.youtube.com/@James_simple_flo" target="_blank" rel="noopener noreferrer" aria-label="YouTube" data-track="social_click" data-track-label="YouTube">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">
        &copy; {year} Brothers Automate. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-surface);
    border-top: 1px solid var(--border);
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer-logo {
    flex-shrink: 0;
  }

  .footer-logo img {
    height: 50px;
    width: auto;
  }

  .footer-mission {
    font-size: 0.8125rem;
    color: var(--orange);
    line-height: 1.6;
    max-width: 240px;
    margin: var(--space-sm) 0 0;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .footer-links {
      grid-template-columns: repeat(5, auto);
      gap: var(--space-2xl);
    }
  }

  .footer-col h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--navy);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-col li {
    margin-bottom: var(--space-xs);
  }

  .footer-col a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--orange);
  }

  .view-all {
    font-weight: 600;
    color: var(--orange) !important;
    font-size: 0.8125rem !important;
    margin-top: var(--space-xs);
    display: inline-block;
  }

  .footer-bottom {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0;
  }

  .footer-socials {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--border);
  }

  .footer-socials a {
    color: var(--text-secondary);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .footer-socials a:hover {
    color: var(--orange);
  }

  @media (max-width: 767px) {
    .footer-top {
      text-align: center;
    }

    .footer-logo {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .footer-mission {
      max-width: 300px;
      text-align: center;
    }

    .footer-bottom {
      text-align: center;
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
