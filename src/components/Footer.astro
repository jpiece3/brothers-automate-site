---
import { getAllServices } from '../data/services';
import { getAllVerticals } from '../data/verticals';
import { getAllLocations } from '../data/locations';
import { projects } from '../data/projects';
import TopUtilityStrip from './operator/TopUtilityStrip.astro';
import MonoCTA from './operator/MonoCTA.astro';

const year = new Date().getFullYear();
const services = getAllServices();
const verticals = getAllVerticals();
const locations = getAllLocations();
---

<footer class="op-footer">
  <div class="op-footer-frame">
    <div class="op-footer-util">
      <TopUtilityStrip
        left="BROTHERS_AUTOMATE / FOOTER · V.2026"
        right="● ALL SYSTEMS RUNNING"
        bordered
      />
    </div>

    {/* Top: logo + mission + nav columns */}
    <div class="op-footer-top">
      <div class="op-footer-brand">
        <a href="/" class="op-footer-logo" aria-label="Brothers Automate home">
          <img src="/logo.png" alt="Brothers Automate" width="160" height="50" loading="lazy" decoding="async" />
        </a>
        <p class="op-footer-mission">
          We design and install AI systems that quietly run in the background — so service businesses get more qualified leads and waste far less time on manual work.
        </p>
        <MonoCTA
          label="Talk to the Brothers"
          variant="orange"
          size="sm"
          calLink="james-pinder/simple-automation-discovery"
          trackLocation="footer"
          trackLabel="Talk to the Brothers"
          class="op-footer-cta"
        />
      </div>

      <div class="op-footer-cols">
        <div class="op-footer-col">
          <div class="op-mono op-footer-col-label">
            <span class="op-footer-col-num">01</span> THE BUILDS
          </div>
          <ul>
            <li><a href="/projects/inbound-ai-sdr">Inbound AI SDR</a></li>
            <li><a href="/projects/quiz-funnels">Lead Qualification Quiz</a></li>
            <li><a href="/projects/cpq-agent">AI Quote Generator</a></li>
            <li><a href="/projects/client-scan">SEO Audit Engine</a></li>
            <li><a href="/projects/onboarding-workflow">Client Onboarding</a></li>
            <li><a href="/projects/screenfast">AI Resume Screener</a></li>
            <li><a href="/projects">All projects →</a></li>
          </ul>
        </div>

        <div class="op-footer-col">
          <div class="op-mono op-footer-col-label">
            <span class="op-footer-col-num">02</span> COMPANY
          </div>
          <ul>
            <li><a href="/about">About</a></li>
            <li><a href="/pricing">Pricing</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/resources">Resources</a></li>
            <li>
              <a
                href="#"
                data-cal-link="james-pinder/simple-automation-discovery"
                data-cal-namespace="simple-automation-discovery"
                data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
                data-track="cta_click" data-track-location="footer" data-track-label="Book a Call"
              >Book a call</a>
            </li>
          </ul>
        </div>

        <div class="op-footer-col">
          <div class="op-mono op-footer-col-label">
            <span class="op-footer-col-num">03</span> CONNECT
          </div>
          <ul>
            <li><a href="https://www.linkedin.com/in/james-pinder-52a261372/" target="_blank" rel="noopener noreferrer" data-track="social_click" data-track-label="LinkedIn">LinkedIn</a></li>
            <li><a href="https://www.instagram.com/simpleflo_james/" target="_blank" rel="noopener noreferrer" data-track="social_click" data-track-label="Instagram">Instagram</a></li>
            <li><a href="https://x.com/simpleflo_james" target="_blank" rel="noopener noreferrer" data-track="social_click" data-track-label="X">X / Twitter</a></li>
            <li><a href="https://www.youtube.com/@James_simple_flo" target="_blank" rel="noopener noreferrer" data-track="social_click" data-track-label="YouTube">YouTube</a></li>
          </ul>
        </div>
      </div>
    </div>

    {/* Sitemap details (preserved for SEO) */}
    <details class="op-footer-sitemap">
      <summary class="op-mono">
        <span class="op-footer-sitemap-num">04</span> EXPLORE ALL PAGES
        <span class="op-footer-sitemap-arrow" aria-hidden="true">+</span>
      </summary>
      <div class="op-footer-sitemap-body">
        <div class="op-footer-sitemap-group">
          <div class="op-mono op-footer-sitemap-label">SERVICES</div>
          <div class="op-footer-sitemap-links">
            {services.map((s) => (
              <a href={`/services/${s.slug}`}>{s.name}</a>
            ))}
          </div>
        </div>
        <div class="op-footer-sitemap-group">
          <div class="op-mono op-footer-sitemap-label">INDUSTRIES</div>
          <div class="op-footer-sitemap-links">
            {verticals.map((v) => (
              <a href={`/for/${v.slug}`}>{v.shortLabel}</a>
            ))}
          </div>
        </div>
        <div class="op-footer-sitemap-group">
          <div class="op-mono op-footer-sitemap-label">LOCATIONS</div>
          <div class="op-footer-sitemap-links">
            {locations.map((l) => (
              <a href={`/in/${l.slug}`}>{l.name}</a>
            ))}
          </div>
        </div>
        <div class="op-footer-sitemap-group">
          <div class="op-mono op-footer-sitemap-label">ALL PROJECTS</div>
          <div class="op-footer-sitemap-links">
            {projects.map((p) => (
              <a href={`/projects/${p.slug}`}>{p.name}</a>
            ))}
          </div>
        </div>
      </div>
    </details>

    {/* Bottom strip */}
    <div class="op-footer-bottom">
      <span class="op-mono">© {year} BROTHERS AUTOMATE · ALL RIGHTS RESERVED</span>
      <span class="op-mono op-footer-built">BUILT IN-HOUSE · NO TEMPLATES</span>
    </div>
  </div>
</footer>

<style>
  .op-footer {
    border-top: var(--op-border);
    padding: 56px var(--op-section-px) 32px;
    background: var(--op-navy);
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    color: var(--op-cream);
  }

  .op-footer-frame {
    max-width: var(--op-max-content);
    margin: 0 auto;
  }

  .op-footer-util {
    margin-bottom: 36px;
  }

  /* Top section */
  .op-footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  @media (min-width: 900px) {
    .op-footer-top {
      grid-template-columns: 1.1fr 2fr;
      gap: 64px;
    }
  }

  .op-footer-brand {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .op-footer-logo {
    display: inline-flex;
    align-items: center;
    background: var(--op-paper);
    border: 1.5px solid var(--op-paper);
    border-radius: var(--op-radius);
    padding: 10px 16px;
    box-shadow: var(--op-shadow);
  }
  .op-footer-logo img {
    height: 38px;
    width: auto;
    display: block;
  }

  .op-footer-mission {
    font-family: var(--op-font-body);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    color: rgba(244, 238, 226, 0.7);
    max-width: 320px;
    margin: 0;
    text-wrap: pretty;
  }

  .op-footer-cta { align-self: flex-start; }

  /* Nav columns */
  .op-footer-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  @media (max-width: 700px) {
    .op-footer-cols { grid-template-columns: 1fr 1fr; gap: 28px; }
  }
  @media (max-width: 480px) {
    .op-footer-cols { grid-template-columns: 1fr; }
  }

  .op-footer-col-label {
    font-size: 10px;
    color: var(--op-cream);
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1.5px solid rgba(244, 238, 226, 0.2);
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .op-footer-col-num {
    color: var(--op-orange);
    font-size: 9px;
  }

  .op-footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .op-footer-col a {
    font-family: var(--op-font-body);
    font-size: 14px;
    font-weight: 500;
    color: rgba(244, 238, 226, 0.75);
    text-decoration: none;
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-footer-col a:hover {
    color: var(--op-orange);
  }

  /* Sitemap (collapsible) */
  .op-footer-sitemap {
    background: var(--op-navy-deep);
    border: 1.5px solid rgba(244, 238, 226, 0.15);
    border-radius: var(--op-radius);
    margin-bottom: 32px;
  }
  .op-footer-sitemap summary {
    list-style: none;
    cursor: pointer;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 11px;
    color: var(--op-cream);
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-footer-sitemap summary::-webkit-details-marker { display: none; }
  .op-footer-sitemap-num {
    color: var(--op-orange);
    font-size: 9px;
  }
  .op-footer-sitemap-arrow {
    margin-left: auto;
    width: 22px;
    height: 22px;
    border: 1.5px solid rgba(244, 238, 226, 0.4);
    border-radius: var(--op-radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--op-font-display);
    font-size: 16px;
    font-weight: 800;
    color: var(--op-cream);
    line-height: 1;
    transition: transform var(--op-dur-hover) var(--op-ease), background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-footer-sitemap[open] .op-footer-sitemap-arrow {
    transform: rotate(45deg);
    background: var(--op-orange);
    color: var(--op-paper);
    border-color: var(--op-orange);
  }
  .op-footer-sitemap summary:hover { color: var(--op-orange); }

  .op-footer-sitemap-body {
    border-top: 1.5px solid rgba(244, 238, 226, 0.15);
    padding: 20px 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .op-footer-sitemap-label {
    font-size: 9px;
    color: var(--op-orange);
    margin-bottom: 8px;
    letter-spacing: 0.22em;
  }
  .op-footer-sitemap-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    line-height: 1.7;
  }
  .op-footer-sitemap-links a {
    font-family: var(--op-font-body);
    font-size: 12.5px;
    font-weight: 500;
    color: rgba(244, 238, 226, 0.65);
    text-decoration: none;
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-footer-sitemap-links a:hover { color: var(--op-orange); }

  /* Bottom strip */
  .op-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid rgba(244, 238, 226, 0.15);
    font-size: 9px;
    color: rgba(244, 238, 226, 0.55);
    flex-wrap: wrap;
    gap: 10px;
  }
  .op-footer-built {
    color: rgba(244, 238, 226, 0.45);
  }

  @media (max-width: 600px) {
    .op-footer { padding: 40px 22px 24px; }
    .op-footer-bottom { font-size: 8.5px; }
  }
</style>
