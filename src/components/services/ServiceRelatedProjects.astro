---
import MonoCTA from '../operator/MonoCTA.astro';

interface Props {
  projects: { slug: string; name: string; description: string }[];
}

const { projects } = Astro.props;
---

<section class="op-svcrp">
  <div class="op-svcrp-frame">
    <div class="op-svcrp-header" data-animate="fade-up">
      <span class="op-mono op-svcrp-label"><span class="op-svcrp-num">05</span> SEE IT IN ACTION</span>
      <h2 class="op-svcrp-h2">Related projects.</h2>
    </div>

    <div class="op-svcrp-grid" data-animate-stagger>
      {projects.map((p, i) => (
        <a href={`/projects/${p.slug}`} class="op-svcrp-card">
          <div class="op-svcrp-card-header">
            <span class="op-pulse-dot"></span>
            <span class="op-mono op-svcrp-card-id">PROJECT_{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div class="op-svcrp-card-body">
            <h3>{p.name}</h3>
            <p>{p.description}</p>
          </div>
          <div class="op-svcrp-card-foot op-mono">
            VIEW PROJECT <span class="op-svcrp-arrow" aria-hidden="true">→</span>
          </div>
        </a>
      ))}
    </div>

    <div class="op-svcrp-cta-row" data-animate="fade-up">
      <MonoCTA label="See all projects" variant="navy" size="md" href="/projects" trackLocation="service-related-projects" trackLabel="See All Projects" />
    </div>
  </div>
</section>

<style>
  .op-svcrp { padding: 72px var(--op-section-px); background: var(--op-paper); border-top: var(--op-border); border-bottom: var(--op-border); }
  .op-svcrp-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svcrp-header { max-width: 720px; margin-bottom: 36px; }
  .op-svcrp-label {
    display: inline-flex;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-svcrp-num { color: var(--op-orange); font-size: 9px; }
  .op-svcrp-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
  }

  .op-svcrp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 24px;
  }
  @media (min-width: 700px) { .op-svcrp-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-svcrp-grid { grid-template-columns: repeat(3, 1fr); } }

  .op-svcrp-card {
    background: var(--op-cream);
    border: var(--op-border);
    border-radius: var(--op-radius);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    transition: transform var(--op-dur-hover) var(--op-ease), box-shadow var(--op-dur-hover) var(--op-ease);
  }
  .op-svcrp-card:hover {
    transform: translate(-2px, -4px);
    box-shadow: var(--op-shadow-lg);
    color: inherit;
  }
  .op-svcrp-card-header {
    background: var(--op-navy-deep);
    color: var(--op-cream);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: var(--op-border);
  }
  .op-svcrp-card-id { font-size: 9px; color: var(--op-orange); }
  .op-svcrp-card-body { padding: 22px 22px 18px; flex: 1; }
  .op-svcrp-card-body h3 {
    font-family: var(--op-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0 0 8px;
  }
  .op-svcrp-card-body p {
    font-family: var(--op-font-body);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    margin: 0;
  }
  .op-svcrp-card-foot {
    background: var(--op-paper);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: var(--op-border);
    font-size: 10px;
    color: var(--op-ink);
  }
  .op-svcrp-arrow { transition: transform var(--op-dur-fast) var(--op-ease), color var(--op-dur-fast) var(--op-ease); }
  .op-svcrp-card:hover .op-svcrp-arrow { transform: translateX(3px); color: var(--op-orange); }
  .op-svcrp-cta-row { display: flex; justify-content: flex-start; }
  @media (max-width: 700px) { .op-svcrp { padding: 56px 22px; } }
</style>
