---
import CalloutBox from '../operator/CalloutBox.astro';
import MonoCTA from '../operator/MonoCTA.astro';

interface Props {
  headline: string;
  headlineHighlight: string;
  description: string;
  features: { title: string; description: string; icon: string }[];
  conclusion: string;
  callout: string;
}

const { headline, headlineHighlight, description, features, conclusion, callout } = Astro.props;
---

<section class="op-svcs op-grid-bg" id="solution">
  <div class="op-svcs-frame">
    <div class="op-svcs-header" data-animate="fade-up">
      <span class="op-mono op-svcs-label"><span class="op-svcs-num">02</span> THE SOLUTION</span>
      <h2 class="op-svcs-h2">
        {headline}<br />
        <span class="op-svcs-h2-orange">{headlineHighlight}</span>
      </h2>
      <p class="op-svcs-desc">{description}</p>
    </div>

    <div class="op-svcs-features" data-animate-stagger>
      {features.map((f, i) => (
        <div class="op-svcs-feature">
          <div class="op-svcs-feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d={f.icon}></path>
            </svg>
          </div>
          <span class="op-mono op-svcs-feature-num">F.{String(i + 1).padStart(2, '0')}</span>
          <h3 class="op-svcs-feature-title">{f.title}</h3>
          <p class="op-svcs-feature-body">{f.description}</p>
        </div>
      ))}
    </div>

    <p class="op-svcs-conclusion" data-animate="fade-up">{conclusion}</p>

    <div class="op-svcs-callout" data-animate="fade-up">
      <CalloutBox header="THE BOTTOM LINE">
        <p>{callout}</p>
      </CalloutBox>
    </div>

    <div class="op-svcs-cta-row" data-animate="fade-up">
      <MonoCTA label="See all services" variant="navy" size="md" href="/services" trackLocation="service-solution" trackLabel="See All Services" />
    </div>
  </div>
</section>

<style>
  .op-svcs { padding: 72px var(--op-section-px); }
  .op-svcs-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svcs-header { max-width: 760px; margin-bottom: 40px; }
  .op-svcs-label {
    display: inline-flex;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-svcs-num { color: var(--op-orange); font-size: 9px; }
  .op-svcs-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 18px;
    text-wrap: balance;
  }
  .op-svcs-h2-orange { color: var(--op-orange); }
  .op-svcs-desc {
    font-family: var(--op-font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 720px;
  }

  .op-svcs-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 32px;
  }
  @media (min-width: 700px) { .op-svcs-features { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .op-svcs-features { grid-template-columns: repeat(3, 1fr); } }

  .op-svcs-feature {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    padding: 22px 24px;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .op-svcs-feature-icon {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    background: var(--op-cream);
    color: var(--op-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 4px;
  }
  .op-svcs-feature-num { font-size: 9px; color: var(--op-orange); }
  .op-svcs-feature-title {
    font-family: var(--op-font-display);
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-svcs-feature-body {
    font-family: var(--op-font-body);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
  }

  .op-svcs-conclusion {
    font-family: var(--op-font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--op-ink);
    margin: 0 auto 28px;
    max-width: 720px;
    text-wrap: pretty;
  }
  .op-svcs-callout { max-width: 720px; margin: 0 auto 28px; }
  .op-svcs-cta-row {
    display: flex;
    justify-content: flex-start;
    margin-top: 8px;
  }

  @media (max-width: 700px) { .op-svcs { padding: 56px 22px; } }
</style>
