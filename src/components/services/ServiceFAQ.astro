---
interface Props {
  faq: { question: string; answer: string }[];
}

const { faq } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer },
  })),
};
---

<section class="op-svcfaq" id="faq">
  <div class="op-svcfaq-frame">
    <div class="op-svcfaq-header" data-animate="fade-up">
      <span class="op-mono op-svcfaq-label"><span class="op-svcfaq-num">04</span> FAQ</span>
      <h2 class="op-svcfaq-h2">Questions before you book.</h2>
    </div>
    <div class="op-svcfaq-list" data-animate-stagger>
      {faq.map((item, i) => (
        <details class="op-svcfaq-item">
          <summary class="op-svcfaq-q">
            <span class="op-mono op-svcfaq-q-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="op-svcfaq-q-text">{item.question}</span>
            <span class="op-svcfaq-q-icon" aria-hidden="true">+</span>
          </summary>
          <div class="op-svcfaq-a">{item.answer}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .op-svcfaq {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-svcfaq-frame { max-width: 1000px; margin: 0 auto; }
  .op-svcfaq-header { margin-bottom: 36px; max-width: 720px; }
  .op-svcfaq-label {
    display: inline-flex;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-svcfaq-num { color: var(--op-orange); font-size: 9px; }
  .op-svcfaq-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }

  .op-svcfaq-list { display: flex; flex-direction: column; }
  .op-svcfaq-item { border-bottom: 1px solid var(--op-rule); }
  .op-svcfaq-item[open] { background: var(--op-cream); }
  .op-svcfaq-q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 4px;
    font-family: var(--op-font-body);
    font-size: 16px;
    font-weight: 600;
    color: var(--op-ink);
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-svcfaq-q::-webkit-details-marker { display: none; }
  .op-svcfaq-q-num { width: 28px; flex-shrink: 0; font-size: 9px; color: var(--op-navy-soft); }
  .op-svcfaq-q-text { flex: 1; text-wrap: balance; }
  .op-svcfaq-q-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border: 1.5px solid var(--op-ink);
    border-radius: var(--op-radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--op-font-display);
    font-size: 16px;
    font-weight: 800;
    color: var(--op-ink);
    line-height: 1;
    transition: transform var(--op-dur-hover) var(--op-ease), background var(--op-dur-hover) var(--op-ease), color var(--op-dur-hover) var(--op-ease);
  }
  .op-svcfaq-item[open] .op-svcfaq-q-icon {
    transform: rotate(45deg);
    background: var(--op-orange);
    color: var(--op-paper);
  }
  .op-svcfaq-q:hover { color: var(--op-orange); }
  .op-svcfaq-a {
    padding: 4px 4px 22px 50px;
    font-family: var(--op-font-body);
    font-size: 15px;
    line-height: 1.6;
    font-weight: 500;
    color: var(--op-navy-soft);
    max-width: 800px;
  }
  @media (max-width: 700px) { .op-svcfaq { padding: 56px 22px; } }
</style>
