---
import CalloutBox from '../operator/CalloutBox.astro';

interface Props {
  headline: string;
  painPoints: string[];
  costOfInaction: string;
}

const { headline, painPoints, costOfInaction } = Astro.props;
---

<section class="op-svcp" id="problem">
  <div class="op-svcp-frame">
    <div class="op-svcp-header" data-animate="fade-up">
      <span class="op-mono op-svcp-label"><span class="op-svcp-num">01</span> THE PROBLEM</span>
      <h2 class="op-svcp-h2">{headline}</h2>
    </div>

    <div class="op-svcp-grid" data-animate-stagger>
      {painPoints.map((point) => (
        <div class="op-svcp-pain">
          <span class="op-svcp-x" aria-hidden="true">✗</span>
          <p>{point}</p>
        </div>
      ))}
    </div>

    <div class="op-svcp-callout" data-animate="fade-up">
      <CalloutBox header="THE COST OF DOING NOTHING">
        <p>{costOfInaction}</p>
      </CalloutBox>
    </div>
  </div>
</section>

<style>
  .op-svcp {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-svcp-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svcp-header { max-width: 720px; margin-bottom: 36px; }
  .op-svcp-label {
    display: inline-flex;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-svcp-num { color: var(--op-orange); font-size: 9px; }
  .op-svcp-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }

  .op-svcp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-bottom: 32px;
  }
  @media (min-width: 700px) { .op-svcp-grid { grid-template-columns: 1fr 1fr; } }

  .op-svcp-pain {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    background: var(--op-cream);
    border: 1px solid var(--op-rule);
    border-left: 3px solid var(--op-orange);
    border-radius: var(--op-radius-sm);
  }
  .op-svcp-x {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    background: var(--op-orange);
    color: var(--op-paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    border-radius: 2px;
  }
  .op-svcp-pain p {
    margin: 0;
    font-family: var(--op-font-body);
    font-size: 14.5px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--op-ink);
  }

  .op-svcp-callout { max-width: 800px; }

  @media (max-width: 700px) { .op-svcp { padding: 56px 22px; } }
</style>
