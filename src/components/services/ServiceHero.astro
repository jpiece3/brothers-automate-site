---
import EyebrowTag from '../operator/EyebrowTag.astro';
import SpecStrip from '../operator/SpecStrip.astro';
import MonoCTA from '../operator/MonoCTA.astro';
import TopUtilityStrip from '../operator/TopUtilityStrip.astro';

interface Props {
  badge: string;
  headline: string;
  headlineGradient: string;
  subheadline: string;
  stats: { number: string; label: string }[];
  trustSignal: string;
}

const { badge, headline, headlineGradient, subheadline, stats, trustSignal } = Astro.props;
---

<section class="op-svc-hero op-grid-bg" id="hero">
  <div class="op-svc-hero-frame">
    <div class="op-svc-hero-util">
      <TopUtilityStrip
        left={`BROTHERS_AUTOMATE / SERVICE · ${badge.toUpperCase()}`}
        right="● ACCEPTING NEW BUILDS"
        bordered
      />
    </div>

    <EyebrowTag label={`SERVICE · ${badge.toUpperCase()}`} />

    <h1 class="op-svc-h1" data-animate="fade-up">
      {headline}<br />
      <span class="op-svc-h1-orange">{headlineGradient}</span>
    </h1>

    <p class="op-svc-sub" data-animate="fade-up">{subheadline}</p>

    <div class="op-svc-ctas" data-animate="fade-up">
      <MonoCTA
        label="Talk to the Brothers"
        variant="orange"
        size="lg"
        calLink="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
        trackLocation={`service-hero-${badge}`}
        trackLabel="Talk to the Brothers"
      />
      <a href="/projects" class="op-svc-link op-mono">SEE OUR PROJECTS →</a>
    </div>

    {stats && stats.length > 0 && (
      <div class="op-svc-specs" data-animate="fade-up">
        <SpecStrip cells={stats.map((s) => ({ value: s.number, label: s.label }))} />
      </div>
    )}

    <p class="op-svc-trust op-mono">● {trustSignal.toUpperCase()}</p>
  </div>
</section>

<style>
  .op-svc-hero {
    padding: 120px var(--op-section-px) 64px;
    color: var(--op-ink);
  }
  .op-svc-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svc-hero-util { margin-bottom: 32px; }
  .op-svc-hero :global(.op-eyebrow) { margin-bottom: 24px; }

  .op-svc-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 84px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 24px;
    max-width: 900px;
    text-wrap: balance;
  }
  .op-svc-h1-orange { color: var(--op-orange); }

  .op-svc-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 32px;
    max-width: 700px;
    text-wrap: pretty;
  }

  .op-svc-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .op-svc-link {
    font-size: 11px;
    color: var(--op-ink);
    text-decoration: none;
    border-bottom: 2px solid var(--op-ink);
    padding-bottom: 4px;
    transition: color var(--op-dur-hover) var(--op-ease), border-color var(--op-dur-hover) var(--op-ease);
  }
  .op-svc-link:hover { color: var(--op-orange); border-color: var(--op-orange); }

  .op-svc-specs { margin-bottom: 24px; }

  .op-svc-trust {
    font-size: 10px;
    color: var(--op-navy-soft);
    margin: 0;
  }

  @media (max-width: 700px) {
    .op-svc-hero { padding: 100px 22px 56px; }
    .op-svc-ctas { flex-direction: column; align-items: stretch; }
  }
</style>
