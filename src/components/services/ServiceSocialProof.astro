---
interface Props {
  headline: string;
  stats: { number: string; label: string; context: string }[];
}

const { headline, stats } = Astro.props;
---

<section class="op-svcsp">
  <div class="op-svcsp-frame">
    <div class="op-svcsp-header" data-animate="fade-up">
      <span class="op-mono op-svcsp-label"><span class="op-svcsp-num">03</span> THE NUMBERS</span>
      <h2 class="op-svcsp-h2">{headline}</h2>
    </div>
    <div class="op-svcsp-grid" data-animate-stagger>
      {stats.map((s) => (
        <div class="op-svcsp-card">
          <div class="op-svcsp-num-big">{s.number}</div>
          <div class="op-svcsp-label-big">{s.label}</div>
          <div class="op-mono op-svcsp-context">{s.context}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .op-svcsp { padding: 72px var(--op-section-px); background: var(--op-cream); }
  .op-svcsp-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-svcsp-header { max-width: 720px; margin-bottom: 36px; }
  .op-svcsp-label {
    display: inline-flex;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-svcsp-num { color: var(--op-orange); font-size: 9px; }
  .op-svcsp-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0;
    text-wrap: balance;
  }
  .op-svcsp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 700px) { .op-svcsp-grid { grid-template-columns: repeat(3, 1fr); } }
  .op-svcsp-card {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    padding: 26px 28px;
    box-shadow: var(--op-shadow);
    border-left-width: 4px;
    border-left-color: var(--op-orange);
  }
  .op-svcsp-num-big {
    font-family: var(--op-font-display);
    font-size: clamp(36px, 4.5vw, 52px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--op-ink);
    line-height: 1;
    margin-bottom: 8px;
  }
  .op-svcsp-label-big {
    font-family: var(--op-font-body);
    font-size: 15px;
    font-weight: 600;
    color: var(--op-orange);
    margin-bottom: 4px;
  }
  .op-svcsp-context {
    font-size: 9px;
    color: var(--op-navy-soft);
    line-height: 1.4;
  }
  @media (max-width: 700px) { .op-svcsp { padding: 56px 22px; } }
</style>
