---
import EyebrowTag from '../operator/EyebrowTag.astro';
import MonoCTA from '../operator/MonoCTA.astro';

interface Props {
  headline: string;
  headlineHighlight: string;
  subheadline: string;
}

const { headline, headlineHighlight, subheadline } = Astro.props;
---

<section class="op-svccta op-grid-bg" id="cta">
  <div class="op-svccta-frame">
    <div class="op-svccta-panel" data-animate="scale-up">
      <div class="op-svccta-panel-header">
        <span class="op-pulse-dot op-pulse-dot--lg"></span>
        <span class="op-mono op-svccta-id">SCHEDULE_INTAKE · 30_MIN</span>
        <span class="op-mono op-svccta-status">● ACCEPTING NEW BUILDS</span>
      </div>
      <div class="op-svccta-panel-body">
        <div class="op-svccta-eyebrow"><EyebrowTag label="GET ON OUR CALENDAR" /></div>
        <h2 class="op-svccta-h2">
          {headline} <span class="op-svccta-h2-orange">{headlineHighlight}</span>
        </h2>
        <p class="op-svccta-sub">{subheadline}</p>
        <div class="op-svccta-actions">
          <MonoCTA
            label="Talk to the Brothers"
            variant="orange"
            size="lg"
            calLink="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
            trackLocation="service-cta"
            trackLabel="Talk to the Brothers"
          />
        </div>
        <p class="op-mono op-svccta-fineprint">FREE CONSULTATION · NO OBLIGATION</p>
      </div>
    </div>
  </div>
</section>

<style>
  .op-svccta { padding: 72px var(--op-section-px) 96px; }
  .op-svccta-frame { max-width: 1000px; margin: 0 auto; }
  .op-svccta-panel {
    background: var(--op-navy);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow-lg);
    color: var(--op-cream);
  }
  .op-svccta-panel-header {
    background: var(--op-navy-deep);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.08);
  }
  .op-svccta-id { font-size: 9px; color: var(--op-orange); }
  .op-svccta-status { margin-left: auto; font-size: 8.5px; color: var(--op-cream); opacity: 0.55; }
  .op-svccta-panel-body { padding: 36px 32px 32px; text-align: center; }
  .op-svccta-eyebrow { margin-bottom: 18px; display: flex; justify-content: center; }
  .op-svccta-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-paper);
    margin: 0 auto 16px;
    max-width: 700px;
    text-wrap: balance;
  }
  .op-svccta-h2-orange { color: var(--op-orange); }
  .op-svccta-sub {
    font-family: var(--op-font-body);
    font-size: 15px;
    line-height: 1.55;
    color: var(--op-cream);
    opacity: 0.78;
    margin: 0 auto 24px;
    max-width: 600px;
  }
  .op-svccta-actions {
    display: flex;
    justify-content: center;
    margin-bottom: 18px;
  }
  .op-svccta-fineprint {
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.5;
    margin: 0;
  }
  @media (max-width: 700px) { .op-svccta { padding: 56px 22px 72px; } .op-svccta-panel-body { padding: 28px 22px 26px; } }
</style>
