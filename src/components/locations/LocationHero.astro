---
import EyebrowTag from '../operator/EyebrowTag.astro';
import SpecStrip from '../operator/SpecStrip.astro';
import MonoCTA from '../operator/MonoCTA.astro';
import TopUtilityStrip from '../operator/TopUtilityStrip.astro';

interface Props {
  badge: string;
  headline: string;
  headlineGradient: string;
  subheadline: string;
  stats: { number: string; label: string }[];
}

const { badge, headline, headlineGradient, subheadline, stats } = Astro.props;
---

<section class="op-loc-hero op-grid-bg" id="hero">
  <div class="op-loc-hero-frame">
    <div class="op-loc-hero-util">
      <TopUtilityStrip
        left={`BROTHERS_AUTOMATE / IN · ${badge.toUpperCase()}`}
        right="● ACCEPTING NEW BUILDS"
        bordered
      />
    </div>

    <EyebrowTag label={`LOCATION · ${badge.toUpperCase()}`} />

    <h1 class="op-loc-h1" data-animate="fade-up">
      {headline}<br />
      <span class="op-loc-h1-orange">{headlineGradient}</span>
    </h1>

    <p class="op-loc-sub" data-animate="fade-up">{subheadline}</p>

    <div class="op-loc-ctas" data-animate="fade-up">
      <MonoCTA label="Talk to the Brothers" variant="orange" size="lg" calLink="james-pinder/simple-automation-discovery" trackLocation={`location-hero-${badge}`} trackLabel="Talk to the Brothers" />
      <a href="/projects" class="op-loc-link op-mono">SEE OUR PROJECTS →</a>
    </div>

    {stats && stats.length > 0 && (
      <div class="op-loc-specs" data-animate="fade-up">
        <SpecStrip cells={stats.map((s) => ({ value: s.number, label: s.label }))} />
      </div>
    )}

    <p class="op-loc-trust op-mono">● TWO BROTHERS · 5 YRS BUILDING · BUILT FOR OPERATORS</p>
  </div>
</section>

<style>
  .op-loc-hero { padding: 120px var(--op-section-px) 64px; color: var(--op-ink); }
  .op-loc-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-loc-hero-util { margin-bottom: 32px; }
  .op-loc-hero :global(.op-eyebrow) { margin-bottom: 24px; }
  .op-loc-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 84px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 24px;
    max-width: 900px;
    text-wrap: balance;
  }
  .op-loc-h1-orange { color: var(--op-orange); }
  .op-loc-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 32px;
    max-width: 700px;
  }
  .op-loc-ctas { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; margin-bottom: 40px; }
  .op-loc-link {
    font-size: 11px;
    color: var(--op-ink);
    text-decoration: none;
    border-bottom: 2px solid var(--op-ink);
    padding-bottom: 4px;
    transition: color var(--op-dur-hover) var(--op-ease), border-color var(--op-dur-hover) var(--op-ease);
  }
  .op-loc-link:hover { color: var(--op-orange); border-color: var(--op-orange); }
  .op-loc-specs { margin-bottom: 24px; }
  .op-loc-trust { font-size: 10px; color: var(--op-navy-soft); margin: 0; }
  @media (max-width: 700px) {
    .op-loc-hero { padding: 100px 22px 56px; }
    .op-loc-ctas { flex-direction: column; align-items: stretch; }
  }
</style>
