---

<div class="quiz-popup" id="quizPopup">
  <button class="quiz-popup-close" id="quizPopupClose" aria-label="Dismiss">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
  <p class="quiz-popup-text">Looking to offer automation to your clients?</p>
  <a href="/meta-quiz" class="quiz-popup-cta">Take the 2-min quiz &rarr;</a>
</div>

<script is:inline>
  (function() {
    var path = window.location.pathname;
    if (path.indexOf('/meta-quiz') !== -1 || path.indexOf('/book') !== -1) return;
    if (localStorage.getItem('ba_quiz_dismissed')) return;

    setTimeout(function() {
      var popup = document.getElementById('quizPopup');
      if (popup) popup.classList.add('visible');
    }, 5000);

    document.addEventListener('click', function(e) {
      if (e.target.closest('#quizPopupClose')) {
        var popup = document.getElementById('quizPopup');
        if (popup) popup.classList.remove('visible');
        localStorage.setItem('ba_quiz_dismissed', 'true');
      }
    });
  })();
</script>

<style is:global>
  .quiz-popup {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--navy);
    border: none;
    border-radius: var(--radius-lg);
    padding: 20px 24px;
    box-shadow: var(--shadow-xl);
    z-index: 999;
    max-width: 380px;
    opacity: 0;
    transform: translateY(20px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .quiz-popup.visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .quiz-popup-close {
    position: absolute;
    top: 10px;
    right: 10px;
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.5);
    padding: 4px;
    border-radius: 50%;
    transition: color 0.2s;
  }

  .quiz-popup-close:hover {
    color: white;
  }

  .quiz-popup-text {
    font-size: 15px;
    font-weight: 600;
    color: white;
    margin-bottom: 12px;
    padding-right: 20px;
    line-height: 1.4;
  }

  .quiz-popup-cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--orange);
    color: white;
    font-size: 14px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all 0.2s;
  }

  .quiz-popup-cta:hover {
    background: var(--orange-hover);
    color: white;
    transform: translateY(-1px);
    box-shadow: var(--shadow);
  }

  @media (max-width: 640px) {
    .quiz-popup {
      left: 12px;
      right: 12px;
      bottom: 12px;
      max-width: none;
      transform: translateX(0) translateY(20px);
    }

    .quiz-popup.visible {
      transform: translateX(0) translateY(0);
    }
  }
</style>
