---
import EyebrowTag from './operator/EyebrowTag.astro';
import SpecStrip from './operator/SpecStrip.astro';
import MonoCTA from './operator/MonoCTA.astro';
import CyclingWord from './operator/CyclingWord.astro';
import OpBuildPanel from './operator/OpBuildPanel.astro';
import TopUtilityStrip from './operator/TopUtilityStrip.astro';
---

<section class="op-hero op-grid-bg" id="hero">
  <div class="op-hero-frame">
    <!-- Top utility strip — sits above the fold under the fixed header -->
    <div class="op-hero-util">
      <TopUtilityStrip
        left="BROTHERS_AUTOMATE / V.2026"
        right="LIVE BUILDS · INBOUND AI SDR RUNNING"
      />
    </div>

    <!-- Two-column hero grid -->
    <div class="op-hero-grid">
      <!-- Left -->
      <div class="op-hero-left">
        <EyebrowTag label="AI OPERATIONS · BUILT FOR $1M–$15M REVENUE" />

        <h1 class="op-hero-headline">
          <span class="op-hero-line">Add AI.</span>
          <span class="op-hero-line">Skip the</span>
          <span class="op-hero-line op-hero-line-cycling">
            <CyclingWord words={['hire.', 'hours.', 'handoff.', 'headache.']} />
          </span>
        </h1>

        <p class="op-hero-sub">
          We build the AI systems you'd otherwise hire someone to do — <strong>lead gen, quotes, onboarding, hiring, support</strong>. Custom-built around how your business actually runs.
        </p>

        <div class="op-hero-ctas">
          <MonoCTA
            label="Talk to the Brothers"
            variant="orange"
            size="lg"
            calLink="james-pinder/simple-automation-discovery"
            trackLocation="hero"
            trackLabel="Talk to the Brothers"
          />
          <a class="op-hero-link" href="/projects" data-track="cta_click" data-track-location="hero" data-track-label="See our work">
            See our work →
          </a>
          <a class="op-hero-link op-hero-link--quiet" href="/curious" data-track="cta_click" data-track-location="hero" data-track-label="Send a note">
            Or send us a note →
          </a>
        </div>

        <SpecStrip cells={[
          { value: '$1M–$15M', label: 'Revenue range we serve' },
          { value: '1–3 wks', label: 'From kickoff to live' },
          { value: '30-day', label: 'Money-back guarantee' },
        ]} />
      </div>

      <!-- Right -->
      <div class="op-hero-right">
        <OpBuildPanel />
        <div class="op-hero-meta">
          <span class="op-mono">↗ ONE OF SIX BUILDS · LIVE PREVIEW</span>
          <a class="op-mono op-hero-meta-link" href="/projects/inbound-ai-sdr">SEE IT IN ACTION →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .op-hero {
    position: relative;
    padding: 88px var(--op-section-px) 64px;
    color: var(--op-ink);
  }

  .op-hero-frame {
    max-width: var(--op-max-content);
    margin: 0 auto;
  }

  .op-hero-util {
    margin-bottom: 24px;
  }

  .op-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: center;
  }

  .op-hero-left {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  /* Headline */
  .op-hero-headline {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(48px, 6.4vw, 84px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 4px 0 0;
    text-wrap: balance;
  }
  .op-hero-line {
    display: block;
  }
  .op-hero-line-cycling {
    color: var(--op-orange);
    min-height: 1em;
  }

  /* Sub */
  .op-hero-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--op-navy-soft);
    max-width: 520px;
    margin: 0;
    text-wrap: pretty;
  }
  .op-hero-sub strong {
    color: var(--op-navy);
    font-weight: 700;
  }

  /* CTAs row */
  .op-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 22px;
    margin-bottom: 4px;
  }
  .op-hero-link {
    color: var(--op-ink);
    font-family: var(--op-font-body);
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    border-bottom: 2px solid var(--op-ink);
    padding-bottom: 2px;
    letter-spacing: -0.01em;
    transition: color var(--op-dur-hover) var(--op-ease), border-color var(--op-dur-hover) var(--op-ease);
  }
  .op-hero-link:hover {
    color: var(--op-orange);
    border-color: var(--op-orange);
  }
  .op-hero-link--quiet {
    color: var(--op-navy-soft);
    border-bottom-color: transparent;
    font-weight: 500;
    font-size: 14px;
  }
  .op-hero-link--quiet:hover {
    color: var(--op-orange);
    border-bottom-color: var(--op-orange);
  }

  /* Right side */
  .op-hero-right {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .op-hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--op-navy-soft);
  }
  .op-hero-meta-link {
    color: var(--op-ink);
    text-decoration: none;
    transition: color var(--op-dur-hover) var(--op-ease);
  }
  .op-hero-meta-link:hover {
    color: var(--op-orange);
  }

  /* Tablet */
  @media (max-width: 1100px) {
    .op-hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .op-hero-headline {
      font-size: clamp(56px, 9vw, 80px);
    }
  }

  /* Mobile */
  @media (max-width: 700px) {
    .op-hero {
      padding: 92px 22px 64px;
    }
    .op-hero-util {
      margin-bottom: 24px;
    }
    .op-hero-grid {
      gap: 36px;
    }
    .op-hero-left {
      gap: 22px;
    }
    .op-hero-headline {
      font-size: clamp(44px, 11vw, 64px);
    }
    .op-hero-sub {
      font-size: 16px;
    }
    .op-hero-ctas {
      flex-direction: column;
      align-items: stretch;
      gap: 16px;
    }
    .op-hero-meta {
      font-size: 9px;
      letter-spacing: 0.18em;
      gap: 10px;
    }
  }
</style>
