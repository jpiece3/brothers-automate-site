---
import EyebrowTag from './operator/EyebrowTag.astro';
import MonoCTA from './operator/MonoCTA.astro';
import TopUtilityStrip from './operator/TopUtilityStrip.astro';
---

<section class="op-cta-block op-grid-bg" id="cta">
  <div class="op-cta-frame">
    <div class="op-cta-util">
      <TopUtilityStrip
        left="BROTHERS_AUTOMATE / SECTION 06 · TALK TO THE BROTHERS"
        right="30-MIN DISCOVERY CALL · NO PITCH"
        bordered
      />
    </div>

    <div class="op-cta-panel" data-animate="scale-up">
      <div class="op-cta-panel-header">
        <span class="op-pulse-dot op-pulse-dot--lg"></span>
        <span class="op-mono op-cta-panel-id">SCHEDULE_INTAKE · 30_MIN</span>
        <span class="op-mono op-cta-panel-status">● ACCEPTING NEW BUILDS</span>
      </div>

      <div class="op-cta-panel-body">
        <div class="op-cta-eyebrow">
          <EyebrowTag label="GET ON OUR CALENDAR" />
        </div>

        <h2 class="op-cta-h2">
          Tell us what's eating your time.<br />
          <span class="op-cta-h2-orange">We'll show you what we'd build to fix it.</span>
        </h2>

        <p class="op-cta-sub">
          30 minutes. We listen, we map your bottleneck, we tell you straight whether we can help and what it'd cost. No deck. No pressure. Either you walk away with a plan or you walk away with clarity.
        </p>

        <div class="op-cta-actions">
          <MonoCTA
            label="Talk to the Brothers"
            variant="orange"
            size="lg"
            calLink="james-pinder/simple-automation-discovery"
            trackLocation="cta-section"
            trackLabel="Talk to the Brothers"
          />
          <a href="/projects" class="op-cta-link op-mono" data-track="cta_click" data-track-location="cta-section" data-track-label="See the builds">
            OR SEE THE BUILDS →
          </a>
        </div>

        <div class="op-cta-fineprint">
          <span class="op-mono">FREE CONSULTATION</span>
          <span class="op-cta-dot">·</span>
          <span class="op-mono">NO OBLIGATION</span>
          <span class="op-cta-dot">·</span>
          <span class="op-mono">CUSTOM-BUILT FOR YOUR BUSINESS</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .op-cta-block {
    padding: 72px var(--op-section-px) 96px;
  }
  .op-cta-frame {
    max-width: 1200px;
    margin: 0 auto;
  }
  .op-cta-util {
    margin-bottom: 32px;
  }

  /* Panel */
  .op-cta-panel {
    background: var(--op-navy);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow-lg);
    color: var(--op-cream);
    max-width: 760px;
    margin: 0 auto;
  }
  .op-cta-panel-header {
    background: var(--op-navy-deep);
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.08);
  }
  .op-cta-panel-id {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-cta-panel-status {
    margin-left: auto;
    font-size: 8.5px;
    color: var(--op-cream);
    opacity: 0.55;
  }

  .op-cta-panel-body {
    padding: 36px 32px 32px;
    text-align: center;
  }
  .op-cta-eyebrow {
    margin-bottom: 18px;
    display: flex;
    justify-content: center;
  }

  .op-cta-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.05;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-paper);
    margin: 0 auto 16px;
    max-width: 600px;
    text-wrap: balance;
  }
  .op-cta-h2-orange { color: var(--op-orange); }

  .op-cta-sub {
    font-family: var(--op-font-body);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-cream);
    opacity: 0.78;
    margin: 0 auto 22px;
    max-width: 560px;
    text-wrap: pretty;
  }

  .op-cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .op-cta-link {
    color: var(--op-cream);
    font-size: 11px;
    text-decoration: none;
    border-bottom: 1.5px solid var(--op-cream);
    padding-bottom: 4px;
    transition: color var(--op-dur-hover) var(--op-ease), border-color var(--op-dur-hover) var(--op-ease);
  }
  .op-cta-link:hover {
    color: var(--op-orange);
    border-color: var(--op-orange);
  }

  .op-cta-fineprint {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.5;
  }
  .op-cta-dot { opacity: 0.5; }

  @media (max-width: 700px) {
    .op-cta-block { padding: 56px 22px 72px; }
    .op-cta-panel-body { padding: 36px 24px 32px; }
    .op-cta-actions { flex-direction: column; align-items: stretch; gap: 16px; }
    .op-cta-fineprint { gap: 6px; }
    .op-cta-dot { display: none; }
  }
</style>
