---
export interface CaseStudyMeta {
  client: string;
  industry: string;
  timeline: string;
  techStack: string[];
}

export interface MetricCard {
  number: string;
  label: string;
}

export interface BeforeAfter {
  label: string;
  before: string;
  after: string;
}

export interface PipelineStep {
  step: string;
  description: string;
}

export interface CaseStudyFeature {
  title: string;
  description: string;
}

export interface CaseStudyProps {
  badge: string;
  headline: string;
  headlineHighlight: string;
  subtitle: string;
  meta: CaseStudyMeta;
  metrics: MetricCard[];
  problemHeadline: string;
  problemDescription: string;
  painPoints: string[];
  solutionHeadline: string;
  solutionDescription: string;
  pipeline: PipelineStep[];
  features: CaseStudyFeature[];
  beforeAfter: BeforeAfter[];
  resultsHeadline: string;
  resultsStats: { number: string; label: string; context?: string }[];
  testimonial?: { quote: string; author: string; role: string };
  ctaHeadline: string;
  ctaDescription: string;
  productUrl?: string;
  videoUrl?: string;
}

interface Props {
  study: CaseStudyProps;
}

const { study } = Astro.props;
---

<!-- Case Study Hero -->
<section class="cs-hero">
  <div class="hero-bg-grid"></div>
  <div class="container">
    <div class="cs-hero-content" data-animate="fade-up">
      <span class="cs-eyebrow">Case Study</span>
      <h1>{study.headline}<br /><span class="gradient-text">{study.headlineHighlight}</span></h1>
      <p class="cs-hero-sub">{study.subtitle}</p>

      <!-- Client Metadata Bar -->
      <div class="cs-meta-bar">
        <div class="cs-meta-item">
          <span class="cs-meta-label">Client</span>
          <span class="cs-meta-value">{study.meta.client}</span>
        </div>
        <div class="cs-meta-divider"></div>
        <div class="cs-meta-item">
          <span class="cs-meta-label">Industry</span>
          <span class="cs-meta-value">{study.meta.industry}</span>
        </div>
        <div class="cs-meta-divider"></div>
        <div class="cs-meta-item">
          <span class="cs-meta-label">Timeline</span>
          <span class="cs-meta-value">{study.meta.timeline}</span>
        </div>
        <div class="cs-meta-divider"></div>
        <div class="cs-meta-item">
          <span class="cs-meta-label">Tech Stack</span>
          <span class="cs-meta-value">{study.meta.techStack.join(' + ')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Metrics Dashboard -->
<section class="cs-metrics">
  <div class="container">
    <div class="cs-metrics-grid" data-animate-stagger>
      {study.metrics.map((metric) => (
        <div class="cs-metric-card">
          <span class="cs-metric-number">{metric.number}</span>
          <span class="cs-metric-label">{metric.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Problem -->
<section class="cs-problem bg-surface-alt">
  <div class="container">
    <div class="cs-problem-content">
      <div class="cs-problem-text" data-animate="fade-up">
        <span class="cs-section-label">The Problem</span>
        <h2>{study.problemHeadline}</h2>
        <p>{study.problemDescription}</p>
      </div>
      <div class="cs-pain-points" data-animate-stagger>
        {study.painPoints.map((point) => (
          <div class="cs-pain-point">
            <span class="cs-pain-marker">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </span>
            <span>{point}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Solution + Pipeline -->
<section class="cs-solution bg-surface">
  <div class="container">
    <div data-animate="fade-up">
      <span class="cs-section-label">The AI Solution</span>
      <h2>{study.solutionHeadline}</h2>
      <p class="cs-solution-desc">{study.solutionDescription}</p>
    </div>

    <!-- Pipeline Flow -->
    <div class="cs-pipeline" data-animate="fade-up">
      <div class="cs-pipeline-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"></polyline></svg>
        <span>Automation Pipeline</span>
      </div>
      <div class="cs-pipeline-steps">
        {study.pipeline.map((step, i) => (
          <div class="cs-pipeline-step">
            <div class="cs-pipeline-number">{i + 1}</div>
            <div class="cs-pipeline-info">
              <strong>{step.step}</strong>
              <span>{step.description}</span>
            </div>
            {i < study.pipeline.length - 1 && (
              <div class="cs-pipeline-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Features -->
    <div class="cs-features-grid" data-animate-stagger>
      {study.features.map((feature) => (
        <div class="cs-feature-card">
          <h3>{feature.title}</h3>
          <p>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Before / After -->
<section class="cs-before-after bg-navy">
  <div class="container">
    <div data-animate="fade-up">
      <span class="cs-section-label cs-section-label-light">Before & After</span>
      <h2>The Transformation</h2>
    </div>
    <div class="cs-ba-grid" data-animate-stagger>
      {study.beforeAfter.map((item) => (
        <div class="cs-ba-row">
          <span class="cs-ba-label">{item.label}</span>
          <div class="cs-ba-values">
            <div class="cs-ba-before">
              <span class="cs-ba-tag">Before</span>
              <span>{item.before}</span>
            </div>
            <div class="cs-ba-arrow">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </div>
            <div class="cs-ba-after">
              <span class="cs-ba-tag">After</span>
              <span>{item.after}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Results -->
<section class="cs-results bg-surface-alt">
  <div class="container">
    <div data-animate="fade-up">
      <span class="cs-section-label">The Results</span>
      <h2>{study.resultsHeadline}</h2>
    </div>
    <div class="cs-results-stats" data-animate-stagger>
      {study.resultsStats.map((stat) => (
        <div class="cs-result-stat">
          <span class="cs-result-number">{stat.number}</span>
          <span class="cs-result-label">{stat.label}</span>
          {stat.context && <span class="cs-result-context">{stat.context}</span>}
        </div>
      ))}
    </div>

    {study.testimonial && (
      <blockquote class="cs-testimonial" data-animate="fade-up">
        <p>"{study.testimonial.quote}"</p>
        <cite>
          <strong>{study.testimonial.author}</strong>
          <span>{study.testimonial.role}</span>
        </cite>
      </blockquote>
    )}

    {study.videoUrl && (
      <div class="cs-video-embed" data-animate="scale-up">
        <iframe
          src={study.videoUrl}
          title="Case Study Demo"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    )}
  </div>
</section>

<!-- CTA -->
<section class="cs-cta-section">
  <div class="container">
    <div class="cs-cta-content" data-animate="fade-up">
      <h2>{study.ctaHeadline}</h2>
      <p>{study.ctaDescription}</p>
      <div class="cs-cta-buttons">
        <a
          href="#"
          class="btn btn-primary btn-lg"
          data-cal-link="james-pinder-simpleflo/free-quiz-audit-automation-brothers"
          data-cal-namespace="free-quiz-audit-automation-brothers"
          data-cal-config='{"layout":"month_view","useSlotsViewOnSmallScreen":"true"}'
        >Talk to the Brothers</a>
        {study.productUrl && (
          <a href={study.productUrl} class="btn btn-secondary btn-lg" target="_blank" rel="noopener">Try It Live</a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* ===== HERO ===== */
  .cs-hero {
    position: relative;
    padding-top: 160px;
    padding-bottom: var(--space-2xl);
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-surface-alt) 100%);
    text-align: center;
    overflow: hidden;
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 54, 93, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
  }

  .cs-hero-content {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .cs-eyebrow {
    display: inline-block;
    padding: var(--space-xs) var(--space-md);
    background: rgba(237, 137, 54, 0.1);
    border: 1px solid rgba(237, 137, 54, 0.3);
    color: var(--orange);
    border-radius: 100px;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-md);
  }

  .cs-hero h1 {
    margin-bottom: var(--space-md);
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.15;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--orange) 0%, var(--blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cs-hero-sub {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 650px;
    margin: 0 auto var(--space-xl);
  }

  /* ===== META BAR ===== */
  .cs-meta-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    padding: var(--space-md) var(--space-xl);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    flex-wrap: wrap;
  }

  .cs-meta-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .cs-meta-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .cs-meta-value {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--navy);
  }

  .cs-meta-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* ===== METRICS DASHBOARD ===== */
  .cs-metrics {
    padding: 0 0 var(--space-xl);
    margin-top: calc(-1 * var(--space-md));
  }

  .cs-metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-md);
    max-width: 900px;
    margin: 0 auto;
  }

  .cs-metric-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    text-align: center;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }

  .cs-metric-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--orange) 0%, var(--blue) 100%);
  }

  .cs-metric-number {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 4px;
  }

  .cs-metric-label {
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* ===== SECTION LABELS ===== */
  .cs-section-label {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--orange);
    margin-bottom: var(--space-sm);
  }

  .cs-section-label-light {
    color: rgba(237, 137, 54, 0.8);
  }

  /* ===== PROBLEM ===== */
  .cs-problem {
    padding: var(--space-4xl) 0;
  }

  .cs-problem-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .cs-problem-text {
    margin-bottom: var(--space-xl);
  }

  .cs-problem-text h2 {
    margin-bottom: var(--space-md);
  }

  .cs-problem-text p {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .cs-pain-points {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cs-pain-point {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-md);
    background: var(--bg-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .cs-pain-marker {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cs-pain-point span:last-child {
    color: var(--text-secondary);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  /* ===== SOLUTION ===== */
  .cs-solution {
    padding: var(--space-4xl) 0;
  }

  .cs-solution h2 {
    margin-bottom: var(--space-md);
  }

  .cs-solution-desc {
    color: var(--text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
    max-width: 700px;
    margin-bottom: var(--space-xl);
  }

  /* ===== PIPELINE ===== */
  .cs-pipeline {
    background: var(--bg-surface-alt);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    margin-bottom: var(--space-xl);
    max-width: 900px;
  }

  .cs-pipeline-header {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .cs-pipeline-steps {
    display: flex;
    align-items: stretch;
    gap: var(--space-sm);
    overflow-x: auto;
    padding-bottom: var(--space-xs);
  }

  .cs-pipeline-step {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex: 1;
    min-width: 0;
  }

  .cs-pipeline-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .cs-pipeline-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .cs-pipeline-info strong {
    font-size: 0.875rem;
    color: var(--navy);
    white-space: nowrap;
  }

  .cs-pipeline-info span {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .cs-pipeline-arrow {
    color: var(--orange);
    flex-shrink: 0;
    margin-left: auto;
  }

  /* ===== FEATURES ===== */
  .cs-features-grid {
    display: grid;
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .cs-features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cs-feature-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow);
    transition: all var(--transition);
  }

  .cs-feature-card:hover {
    box-shadow: var(--shadow-md);
  }

  .cs-feature-card h3 {
    font-size: 1.0625rem;
    color: var(--navy);
    margin: 0 0 var(--space-xs);
  }

  .cs-feature-card p {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ===== BEFORE / AFTER ===== */
  .cs-before-after {
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cs-before-after h2 {
    margin-bottom: var(--space-xl);
  }

  .cs-ba-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 800px;
    margin: 0 auto;
  }

  .cs-ba-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    text-align: left;
  }

  .cs-ba-label {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
  }

  .cs-ba-values {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .cs-ba-before,
  .cs-ba-after {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .cs-ba-tag {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .cs-ba-before .cs-ba-tag {
    color: #f87171;
  }

  .cs-ba-after .cs-ba-tag {
    color: #4ade80;
  }

  .cs-ba-before span:last-child {
    font-size: 1rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
  }

  .cs-ba-after span:last-child {
    font-size: 1rem;
    font-weight: 700;
    color: white;
  }

  .cs-ba-arrow {
    color: var(--orange);
    flex-shrink: 0;
  }

  /* ===== RESULTS ===== */
  .cs-results {
    padding: var(--space-4xl) 0;
    text-align: center;
  }

  .cs-results h2 {
    margin-bottom: var(--space-xl);
  }

  .cs-results-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-2xl);
    flex-wrap: wrap;
    margin-bottom: var(--space-xl);
  }

  .cs-result-stat {
    text-align: center;
  }

  .cs-result-number {
    display: block;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--orange);
    line-height: 1;
    margin-bottom: var(--space-xs);
  }

  .cs-result-label {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 2px;
  }

  .cs-result-context {
    display: block;
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .cs-testimonial {
    max-width: 600px;
    margin: var(--space-xl) auto 0;
    padding: var(--space-lg);
    border-left: 3px solid var(--orange);
    text-align: left;
    background: var(--bg-surface);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    box-shadow: var(--shadow);
  }

  .cs-testimonial p {
    font-size: 1.125rem;
    color: var(--navy);
    font-style: italic;
    line-height: 1.7;
    margin: 0 0 var(--space-md);
  }

  .cs-testimonial cite {
    font-style: normal;
  }

  .cs-testimonial strong {
    display: block;
    color: var(--navy);
    font-size: 0.9375rem;
  }

  .cs-testimonial cite span {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }

  .cs-video-embed {
    max-width: 700px;
    margin: var(--space-xl) auto 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16/9;
    box-shadow: var(--shadow-lg);
  }

  .cs-video-embed iframe {
    width: 100%;
    height: 100%;
  }

  /* ===== CTA ===== */
  .cs-cta-section {
    padding: var(--space-3xl) 0;
    text-align: center;
    background: var(--bg-surface);
  }

  .cs-cta-content {
    max-width: 600px;
    margin: 0 auto;
  }

  .cs-cta-content h2 {
    margin-bottom: var(--space-sm);
  }

  .cs-cta-content p {
    color: var(--text-secondary);
    margin-bottom: var(--space-lg);
    font-size: 1.0625rem;
  }

  .cs-cta-buttons {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    align-items: center;
  }

  @media (min-width: 480px) {
    .cs-cta-buttons {
      flex-direction: row;
      justify-content: center;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 767px) {
    .cs-hero {
      padding-top: 120px;
      padding-bottom: var(--space-xl);
    }

    .cs-meta-bar {
      flex-direction: column;
      gap: var(--space-sm);
      padding: var(--space-md);
    }

    .cs-meta-divider {
      width: 60px;
      height: 1px;
    }

    .cs-pipeline-steps {
      flex-direction: column;
    }

    .cs-pipeline-arrow {
      transform: rotate(90deg);
