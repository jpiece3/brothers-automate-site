---
import EyebrowTag from './operator/EyebrowTag.astro';
import SpecStrip from './operator/SpecStrip.astro';
import MonoCTA from './operator/MonoCTA.astro';
import CalloutBox from './operator/CalloutBox.astro';
import TopUtilityStrip from './operator/TopUtilityStrip.astro';

export interface CaseStudyMeta {
  client: string;
  industry: string;
  timeline: string;
  techStack: string[];
}

export interface MetricCard {
  number: string;
  label: string;
}

export interface BeforeAfter {
  label: string;
  before: string;
  after: string;
}

export interface PipelineStep {
  step: string;
  description: string;
}

export interface CaseStudyFeature {
  title: string;
  description: string;
}

export interface CaseStudyProps {
  badge: string;
  headline: string;
  headlineHighlight: string;
  subtitle: string;
  meta: CaseStudyMeta;
  metrics: MetricCard[];
  problemHeadline: string;
  problemDescription: string;
  painPoints: string[];
  solutionHeadline: string;
  solutionDescription: string;
  pipeline?: PipelineStep[];
  features: CaseStudyFeature[];
  beforeAfter?: BeforeAfter[];
  resultsHeadline: string;
  resultsStats: { number: string; label: string; context?: string }[];
  testimonial?: { quote: string; author: string; role: string };
  ctaHeadline: string;
  ctaDescription: string;
  productUrl?: string;
  videoUrl?: string;
}

interface Props {
  study: CaseStudyProps;
}

const { study } = Astro.props;
const slugCode = study.headline.toUpperCase().replace(/[^A-Z0-9]+/g, '_').slice(0, 32);
---

{/* === Hero === */}
<section class="op-cs-hero op-grid-bg">
  <div class="op-cs-hero-frame">
    <div class="op-cs-util">
      <TopUtilityStrip
        left={`BROTHERS_AUTOMATE / CASE_STUDY · ${study.meta.client.toUpperCase()}`}
        right="● LIVE BUILD · DEPLOYED"
        bordered
      />
    </div>

    <EyebrowTag label={`CASE STUDY · ${study.badge.toUpperCase()}`} />

    <h1 class="op-cs-h1">
      {study.headline}<br />
      <span class="op-cs-h1-orange">{study.headlineHighlight}</span>
    </h1>

    <p class="op-cs-sub" data-animate="fade-up">{study.subtitle}</p>

    {/* Client meta strip */}
    <div class="op-cs-meta-bar" data-animate="fade-up">
      <div class="op-cs-meta-cell">
        <div class="op-mono op-cs-meta-label">CLIENT</div>
        <div class="op-cs-meta-value">{study.meta.client}</div>
      </div>
      <div class="op-cs-meta-cell">
        <div class="op-mono op-cs-meta-label">INDUSTRY</div>
        <div class="op-cs-meta-value">{study.meta.industry}</div>
      </div>
      <div class="op-cs-meta-cell">
        <div class="op-mono op-cs-meta-label">TIMELINE</div>
        <div class="op-cs-meta-value">{study.meta.timeline}</div>
      </div>
      <div class="op-cs-meta-cell">
        <div class="op-mono op-cs-meta-label">TECH STACK</div>
        <div class="op-cs-meta-value">{study.meta.techStack.join(' · ')}</div>
      </div>
    </div>
  </div>
</section>

{/* === Metrics dashboard === */}
<section class="op-cs-metrics">
  <div class="op-cs-metrics-frame" data-animate="fade-up">
    <SpecStrip
      cells={study.metrics.map((m) => ({ value: m.number, label: m.label }))}
    />
  </div>
</section>

{/* === Problem === */}
<section class="op-cs-problem">
  <div class="op-cs-problem-frame">
    <div class="op-cs-problem-grid">
      <div class="op-cs-problem-text" data-animate="slide-left">
        <span class="op-mono op-cs-section-label"><span class="op-cs-section-num">01</span> THE PROBLEM</span>
        <h2 class="op-cs-h2">{study.problemHeadline}</h2>
        <p class="op-cs-h2-sub">{study.problemDescription}</p>
      </div>
      <div class="op-cs-painlist" data-animate-stagger>
        {study.painPoints.map((point) => (
          <div class="op-cs-pain">
            <span class="op-cs-pain-x" aria-hidden="true">✗</span>
            <span class="op-cs-pain-text">{point}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

{/* === Solution + Pipeline === */}
<section class="op-cs-solution op-grid-bg">
  <div class="op-cs-solution-frame">
    <div class="op-cs-solution-header" data-animate="fade-up">
      <span class="op-mono op-cs-section-label"><span class="op-cs-section-num">02</span> THE AI SOLUTION</span>
      <h2 class="op-cs-h2">{study.solutionHeadline}</h2>
      <p class="op-cs-h2-sub">{study.solutionDescription}</p>
    </div>

    {/* Pipeline as an OperatorPanel */}
    {study.pipeline && study.pipeline.length > 0 && (
    <div class="op-cs-pipeline" data-animate="fade-up">
      <div class="op-cs-pipeline-header">
        <span class="op-pulse-dot op-pulse-dot--lg"></span>
        <span class="op-mono op-cs-pipeline-id">PIPELINE · {study.pipeline.length} STEPS · {slugCode}</span>
        <span class="op-mono op-cs-pipeline-status">● LIVE</span>
      </div>
      <div class="op-cs-pipeline-grid">
        {study.pipeline.map((step, i) => (
          <div class="op-cs-pipeline-step">
            <div class="op-cs-pipeline-num op-mono">{String(i + 1).padStart(2, '0')}</div>
            <div class="op-cs-pipeline-name">{step.step}</div>
            <div class="op-cs-pipeline-desc">{step.description}</div>
          </div>
        ))}
      </div>
    </div>
    )}

    {/* Features */}
    <div class="op-cs-features" data-animate-stagger>
      {study.features.map((feature, i) => (
        <div class="op-cs-feature">
          <span class="op-mono op-cs-feature-num">F.{String(i + 1).padStart(2, '0')}</span>
          <h3 class="op-cs-feature-title">{feature.title}</h3>
          <p class="op-cs-feature-body">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{/* === Before / After === */}
{study.beforeAfter && study.beforeAfter.length > 0 && (
<section class="op-cs-ba">
  <div class="op-cs-ba-frame">
    <div class="op-cs-ba-header" data-animate="fade-up">
      <span class="op-mono op-cs-section-label"><span class="op-cs-section-num">03</span> THE TRANSFORMATION</span>
      <h2 class="op-cs-h2">Before vs after.</h2>
    </div>
    <div class="op-cs-ba-table" data-animate="fade-up">
      <div class="op-cs-ba-table-head op-mono">
        <div>METRIC</div>
        <div>BEFORE</div>
        <div class="op-cs-ba-arrow-cell" aria-hidden="true">→</div>
        <div>AFTER</div>
      </div>
      {study.beforeAfter.map((item) => (
        <div class="op-cs-ba-row">
          <div class="op-cs-ba-label">{item.label}</div>
          <div class="op-cs-ba-before">{item.before}</div>
          <div class="op-cs-ba-arrow-cell" aria-hidden="true">→</div>
          <div class="op-cs-ba-after">{item.after}</div>
        </div>
      ))}
    </div>
  </div>
</section>
)}

{/* === Results === */}
<section class="op-cs-results">
  <div class="op-cs-results-frame">
    <div class="op-cs-results-panel" data-animate="scale-up">
      <div class="op-cs-results-panel-header">
        <span class="op-pulse-dot op-pulse-dot--lg"></span>
        <span class="op-mono op-cs-results-id">RESULTS · {slugCode}</span>
        <span class="op-mono op-cs-results-status">● VERIFIED</span>
      </div>
      <div class="op-cs-results-body">
        <span class="op-mono op-cs-section-label op-cs-section-label--light">
          <span class="op-cs-section-num">04</span> THE RESULTS
        </span>
        <h2 class="op-cs-h2 op-cs-h2--light">{study.resultsHeadline}</h2>

        <div class="op-cs-results-stats">
          {study.resultsStats.map((s) => (
            <div class="op-cs-results-stat">
              <div class="op-cs-results-stat-num">{s.number}</div>
              <div class="op-cs-results-stat-label">{s.label}</div>
              {s.context && <div class="op-mono op-cs-results-stat-context">{s.context}</div>}
            </div>
          ))}
        </div>

        {study.testimonial && (
          <div class="op-cs-results-testimonial">
            <CalloutBox header="WHAT THE CLIENT SAID">
              <p>"{study.testimonial.quote}"</p>
            </CalloutBox>
            <div class="op-mono op-cs-results-testimonial-cite">
              — {study.testimonial.author} · {study.testimonial.role}
            </div>
          </div>
        )}

        {study.videoUrl && (
          <div class="op-cs-results-video">
            <div class="op-cs-results-video-frame">
              <iframe
                src={study.videoUrl}
                title="Case Study Demo"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

{/* === CTA === */}
<section class="op-cs-cta op-grid-bg">
  <div class="op-cs-cta-frame">
    <div class="op-cs-cta-block" data-animate="fade-up">
      <span class="op-mono op-cs-section-label"><span class="op-cs-section-num">05</span> NEXT STEP</span>
      <h2 class="op-cs-h2 op-cs-cta-h2">{study.ctaHeadline}</h2>
      <p class="op-cs-h2-sub op-cs-cta-sub">{study.ctaDescription}</p>
      <div class="op-cs-cta-actions">
        <MonoCTA
          label="Talk to the Brothers"
          variant="orange"
          size="lg"
          calLink="james-pinder/simple-automation-discovery"
          trackLocation="case-study"
          trackLabel="Talk to the Brothers"
        />
        {study.productUrl && (
          <MonoCTA
            label="Try it live"
            variant="navy"
            size="lg"
            href={study.productUrl}
            external
            trackLocation="case-study"
            trackLabel="Try It Live"
          />
        )}
      </div>
    </div>
  </div>
</section>

<style>
  /* === Hero === */
  .op-cs-hero {
    padding: 120px var(--op-section-px) 56px;
    color: var(--op-ink);
  }
  .op-cs-hero-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cs-util { margin-bottom: 32px; }
  .op-cs-hero :global(.op-eyebrow) { margin-bottom: 22px; }

  .op-cs-h1 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(40px, 5.6vw, 76px);
    line-height: 0.98;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 22px;
    max-width: 900px;
    text-wrap: balance;
  }
  .op-cs-h1-orange { color: var(--op-orange); }

  .op-cs-sub {
    font-family: var(--op-font-body);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0 0 36px;
    max-width: 720px;
    text-wrap: pretty;
  }

  /* Meta bar */
  .op-cs-meta-bar {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: var(--op-border);
    border-radius: var(--op-radius);
    background: var(--op-paper);
    overflow: hidden;
    box-shadow: var(--op-shadow);
    max-width: 1100px;
  }
  .op-cs-meta-cell {
    padding: 14px 18px;
    border-right: var(--op-border);
  }
  .op-cs-meta-cell:last-child { border-right: none; }
  .op-cs-meta-label {
    font-size: 8.5px;
    color: var(--op-orange);
    margin-bottom: 6px;
  }
  .op-cs-meta-value {
    font-family: var(--op-font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--op-ink);
    line-height: 1.3;
  }
  @media (max-width: 800px) {
    .op-cs-meta-bar { grid-template-columns: 1fr 1fr; }
    .op-cs-meta-cell:nth-child(2n) { border-right: none; }
    .op-cs-meta-cell:nth-child(n+3) { border-top: var(--op-border); }
  }

  /* Section labels */
  .op-cs-section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    color: var(--op-ink);
    margin-bottom: 16px;
  }
  .op-cs-section-label--light { color: var(--op-cream); }
  .op-cs-section-num { color: var(--op-orange); font-size: 9px; }

  .op-cs-h2 {
    font-family: var(--op-font-display);
    font-weight: 800;
    font-size: clamp(32px, 4vw, 50px);
    line-height: 1.02;
    letter-spacing: var(--op-tracking-display);
    color: var(--op-ink);
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .op-cs-h2--light { color: var(--op-paper); }
  .op-cs-h2-sub {
    font-family: var(--op-font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--op-navy-soft);
    margin: 0;
    max-width: 720px;
    text-wrap: pretty;
  }

  /* === Metrics === */
  .op-cs-metrics {
    padding: 32px var(--op-section-px) 56px;
  }
  .op-cs-metrics-frame { max-width: var(--op-max-content); margin: 0 auto; }

  /* === Problem === */
  .op-cs-problem {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-cs-problem-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cs-problem-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 36px;
  }
  @media (min-width: 900px) {
    .op-cs-problem-grid { grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  }

  .op-cs-painlist {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .op-cs-pain {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 14px 16px;
    background: var(--op-cream);
    border: 1px solid var(--op-rule);
    border-left: 3px solid var(--op-orange);
    border-radius: var(--op-radius-sm);
  }
  .op-cs-pain-x {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    background: var(--op-orange);
    color: var(--op-paper);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 800;
    border-radius: 2px;
  }
  .op-cs-pain-text {
    font-family: var(--op-font-body);
    font-size: 14.5px;
    line-height: 1.5;
    font-weight: 500;
    color: var(--op-ink);
  }

  /* === Solution + Pipeline === */
  .op-cs-solution {
    padding: 72px var(--op-section-px);
  }
  .op-cs-solution-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cs-solution-header { max-width: 760px; margin-bottom: 40px; }

  .op-cs-pipeline {
    background: var(--op-navy);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow-md);
    margin-bottom: 36px;
    color: var(--op-cream);
  }
  .op-cs-pipeline-header {
    background: var(--op-navy-deep);
    padding: 12px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.08);
  }
  .op-cs-pipeline-id { font-size: 10px; color: var(--op-orange); }
  .op-cs-pipeline-status {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.55;
  }
  .op-cs-pipeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    padding: 8px;
    gap: 8px;
  }
  .op-cs-pipeline-step {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 14px;
    border-radius: var(--op-radius-sm);
    display: flex;
    flex-direction: column;
    gap: 6px;
    position: relative;
  }
  .op-cs-pipeline-num {
    font-size: 9px;
    color: var(--op-orange);
  }
  .op-cs-pipeline-name {
    font-family: var(--op-font-display);
    font-size: 14px;
    font-weight: 800;
    color: var(--op-paper);
    letter-spacing: -0.02em;
  }
  .op-cs-pipeline-desc {
    font-family: var(--op-font-body);
    font-size: 12.5px;
    line-height: 1.45;
    color: var(--op-cream);
    opacity: 0.78;
  }

  /* Features */
  .op-cs-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }
  @media (min-width: 700px) { .op-cs-features { grid-template-columns: 1fr 1fr; } }

  .op-cs-feature {
    background: var(--op-paper);
    border: var(--op-border);
    border-radius: var(--op-radius);
    padding: 22px 24px;
    box-shadow: var(--op-shadow);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .op-cs-feature-num { font-size: 9px; color: var(--op-orange); }
  .op-cs-feature-title {
    font-family: var(--op-font-display);
    font-size: 19px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--op-ink);
    margin: 0;
  }
  .op-cs-feature-body {
    font-family: var(--op-font-body);
    font-size: 14px;
    line-height: 1.55;
    font-weight: 500;
    color: var(--op-navy-soft);
    margin: 0;
  }

  /* === Before / After === */
  .op-cs-ba {
    padding: 72px var(--op-section-px);
    background: var(--op-paper);
    border-top: var(--op-border);
    border-bottom: var(--op-border);
  }
  .op-cs-ba-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cs-ba-header { max-width: 720px; margin-bottom: 36px; }

  .op-cs-ba-table {
    border: var(--op-border);
    border-radius: var(--op-radius);
    background: var(--op-cream);
    overflow: hidden;
    box-shadow: var(--op-shadow);
  }
  .op-cs-ba-table-head {
    display: grid;
    grid-template-columns: 1.2fr 1fr 40px 1fr;
    background: var(--op-navy);
    color: var(--op-cream);
    border-bottom: var(--op-border);
  }
  .op-cs-ba-table-head > div {
    padding: 12px 18px;
    font-size: 10px;
    border-right: 1px solid rgba(255, 255, 255, 0.1);
  }
  .op-cs-ba-table-head > div:last-child { border-right: none; }
  .op-cs-ba-arrow-cell {
    text-align: center;
    color: var(--op-orange);
    font-weight: 800;
    font-size: 16px;
  }
  .op-cs-ba-row {
    display: grid;
    grid-template-columns: 1.2fr 1fr 40px 1fr;
    border-bottom: 1px solid var(--op-rule);
  }
  .op-cs-ba-row:last-child { border-bottom: none; }
  .op-cs-ba-row > div {
    padding: 14px 18px;
    border-right: 1px solid var(--op-rule);
    font-family: var(--op-font-body);
    font-size: 14px;
    color: var(--op-ink);
    line-height: 1.4;
  }
  .op-cs-ba-row > div:last-child { border-right: none; }
  .op-cs-ba-label {
    background: var(--op-paper);
    font-weight: 700 !important;
  }
  .op-cs-ba-before { color: var(--op-navy-soft) !important; }
  .op-cs-ba-after {
    color: var(--op-ink) !important;
    font-weight: 600;
    background: rgba(224, 112, 60, 0.06);
  }
  .op-cs-ba-row .op-cs-ba-arrow-cell {
    background: var(--op-paper);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 700px) {
    .op-cs-ba-table-head,
    .op-cs-ba-row {
      grid-template-columns: 1fr;
    }
    .op-cs-ba-table-head > div,
    .op-cs-ba-row > div {
      border-right: none;
      border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    }
    .op-cs-ba-table-head > div:last-child,
    .op-cs-ba-row > div:last-child { border-bottom: none; }
    .op-cs-ba-arrow-cell { display: none; }
    .op-cs-ba-table-head { display: none; }
  }

  /* === Results === */
  .op-cs-results {
    padding: 72px var(--op-section-px);
    background: var(--op-cream);
  }
  .op-cs-results-frame { max-width: var(--op-max-content); margin: 0 auto; }
  .op-cs-results-panel {
    background: var(--op-navy);
    border: var(--op-border);
    border-radius: var(--op-radius-md);
    overflow: hidden;
    box-shadow: var(--op-shadow-lg);
    color: var(--op-cream);
  }
  .op-cs-results-panel-header {
    background: var(--op-navy-deep);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1.5px solid rgba(255, 255, 255, 0.08);
  }
  .op-cs-results-id { font-size: 10px; color: var(--op-orange); }
  .op-cs-results-status {
    margin-left: auto;
    font-size: 9px;
    color: var(--op-cream);
    opacity: 0.55;
  }
  .op-cs-results-body { padding: 48px 56px 52px; }
  @media (max-width: 700px) { .op-cs-results-body { padding: 32px 24px 36px; } }

  .op-cs-results-stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-top: 28px;
  }
  @media (min-width: 700px) { .op-cs-results-stats { grid-template-columns: repeat(3, 1fr); } }

  .op-cs-results-stat {
    border-left: 2px solid var(--op-orange);
    padding-left: 18px;
  }
