{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "redirects": [
    { "source": "/how-we-work", "destination": "/#process", "statusCode": 301 },
    { "source": "/compare", "destination": "/pricing", "statusCode": 301 },
    { "source": "/what-you-get", "destination": "/projects", "statusCode": 301 },
    { "source": "/solutions", "destination": "/projects", "statusCode": 301 },
    { "source": "/solutions/:path*", "destination": "/projects", "statusCode": 301 },
    { "source": "/ai-ops-stack", "destination": "/resources/ai-ops-stack", "statusCode": 301 },
    { "source": "/agent-principles", "destination": "/resources/agent-principles", "statusCode": 301 },
    { "source": "/resources/blog-autopilot", "destination": "/services/blog-autopilot", "statusCode": 301 }
  ]
}
